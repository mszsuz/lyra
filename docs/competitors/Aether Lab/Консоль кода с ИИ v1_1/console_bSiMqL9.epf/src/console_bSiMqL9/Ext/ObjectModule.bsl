// Загружает файл в API
// Параметры:
//  ПутьКФайлу - Строка - путь к файлу на сервере
//  ИмяФайла - Строка - имя файла (например, "meta.xml")
// Возвращаемое значение:
//  Структура - результат запроса: ИдентификаторФайла (Число), Успех (Булево), Ошибка (Строка)
Функция ЗагрузитьФайл(ПутьКФайлу, ИмяФайла) Экспорт
	
	// Проверка входных параметров
	Если Не ЗначениеЗаполнено(ПутьКФайлу) Или Не ЗначениеЗаполнено(ИмяФайла) Тогда
		Возврат Новый Структура("Успех, Ошибка", Ложь, "Не указан путь к файлу или имя файла");
	КонецЕсли;
	
	// Кодирование файла в Base64 
	ДвоичныеДанные = ПолучитьИзВременногоХранилища(ПутьКФайлу);
	//ДвоичныеДанные = Новый ДвоичныеДанные(ПутьКФайлу);
	СтрокаBase64 = Base64Строка(ДвоичныеДанные);
	
	// Формирование JSON-данных
	Данные = Новый Структура;
	Данные.Вставить("file", СтрокаBase64);
	Данные.Вставить("filename", ИмяФайла);
	Данные.Вставить("name", ИмяФайла);
	
	// Отправка POST-запроса
	Результат = ВыполнитьHTTPЗапрос("/api/file-manager/files/", "POST", Данные);
	
	// Обработка ответа
	Если Результат.Успех Тогда
		ОтветJSON = ПрочитатьJSONИзСтроки(Результат.Ответ);
		Возврат Новый Структура("Успех, ИдентификаторФайла, Ошибка", Истина, ОтветJSON.id, "");
	Иначе
		Возврат Новый Структура("Успех, Ошибка", Ложь, Результат.Ошибка);
	КонецЕсли;
	
КонецФункции

