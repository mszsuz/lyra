#Область ОбработкаЧата
Функция СформироватьHTMLЧата(История, ПоказыватьВремя = Истина) Экспорт

    HTML = "<!DOCTYPE html><html><head>" +
        "<meta charset='utf-8'>" +
        // Подключение библиотек для markdown и подсветки синтаксиса
        "<link rel='stylesheet' href='https://cdn.jsdelivr.net/npm/highlight.js@11.9.0/styles/github-dark.min.css'>" +
        "<style>" +
        " body { font-family: Segoe UI, sans-serif; margin: 0; background: #f5f5f5; height: 100vh; display: flex; flex-direction: column; }" +
        " .container {" +
        "   flex: 1;" +
        "   overflow-y: auto;" +
        "   padding: 16px;" +
        "   display: flex;" +
        "   flex-direction: column;" +
        " }" +
        " .message { margin: 8px 0; padding: 10px 12px; border-radius: 12px; max-width: 80%; word-wrap: break-word; font-size: 13px; line-height: 1.35; }" +
        " .user { background: #0078D4; color: white; align-self: flex-end; margin-left: auto; }" +
        " .bot { background: #E5E5EA; color: black; align-self: flex-start; }" +
        " .time { font-size: 0.8em; opacity: 0.7; margin-top: 4px; }" +

        // статус ИИ
        " .status { font-size: 0.75em; opacity: 0.8; margin-top: 4px; display: inline-flex; align-items: center; gap: 6px; color: #6b7280; }" +
        " .status-dot { " +
        "   width: 6px;" +
        "   height: 6px;" +
        "   border-radius: 999px;" +
        "   background: #10B981;" +
        "   flex-shrink: 0;" +
        "   margin-right: 2px;" + // небольшой отступ после точки
        "   animation: statusPulse 1.2s ease-in-out infinite;" + // анимация
        " }" +

        // простая «моргающая» анимация
        " @keyframes statusPulse {" +
        "   0% { opacity: 0.3; transform: scale(1); }" +
        "   50% { opacity: 1; transform: scale(1.2); }" +
        "   100% { opacity: 0.3; transform: scale(1); }" +
        " }" +

        "</style>" +
        "</head>" +
        "<body>" +
        "<div class='container' id='messages'>";

    // === История сообщений ===
    Для Каждого Сообщение Из История Цикл
        
        Роль = НРег(Сообщение.is_user);

        // Основной текст
        // Для сообщений от бота используем markdown, для пользователя - простой текст
        Если Роль Тогда
            // Сообщения пользователя - простой текст с экранированием
            Текст = ЭкранироватьHTML(Сообщение.text);
            Текст = СтрЗаменить(Текст, Символы.ПС, "<br>");
            ТекстHTML = Текст;
        Иначе
            // Сообщения от бота - markdown (будет обработан через JavaScript)
            // Экранируем текст для безопасного использования в data-атрибуте
            ТекстДляАтрибута = ЭкранироватьHTML(Сообщение.text);
            // Рендерим безопасный текст сразу, чтобы не было мигания до выполнения JS
            ТекстДляПоказа = ЭкранироватьHTML(Сообщение.text);
            ТекстДляПоказа = СтрЗаменить(ТекстДляПоказа, Символы.ПС, "<br>");
            ТекстHTML = "<div class='markdown-content' data-markdown=""" + ТекстДляАтрибута + """>" + ТекстДляПоказа + "</div>";
        КонецЕсли;

        // Время
        ВремяТекст = "";
        Если ПоказыватьВремя
            И Сообщение.Свойство("created_at")
            И ЗначениеЗаполнено(Сообщение.created_at) Тогда

            Попытка
                ДатаВремя = ПрочитатьДатуJSON(Сообщение.created_at, ФорматДатыJSON.ISO);
                ВремяТекст = "<div class='time'>" + Формат(ДатаВремя, "ДФ='HH:mm'") + "</div>";
            Исключение
            КонецПопытки;

        КонецЕсли;

        // Статус ИИ — только если status.id = "in_progress"
        СтатусHTML = "";
        Если НЕ Роль
            И Сообщение.Свойство("status")
            И ЗначениеЗаполнено(Сообщение.status)
            И Сообщение.status.Свойство("id")
            И Сообщение.status.id = "in_progress"
            И Сообщение.Свойство("status_message")
            И ЗначениеЗаполнено(Сообщение.status_message) Тогда

            СтатусТекст = ЭкранироватьHTML(Сообщение.status_message);
            СтатусHTML = "<div class='status'><span class='status-dot'></span>" + СтатусТекст + "</div>";
        КонецЕсли;

        // Сборка сообщения
        Если Роль Тогда
            HTML = HTML + "<div class='message user'>" + ТекстHTML + ВремяТекст + "</div>";
        Иначе
            HTML = HTML + "<div class='message bot'>" + ТекстHTML + СтатусHTML + ВремяТекст + "</div>";
        КонецЕсли;

    КонецЦикла;

    // === ПРОКРУТКА ВНИЗ И ОБРАБОТКА MARKDOWN ===
    HTML = HTML +
        "</div>" +
        // Подключаем библиотеки в конце body для гарантированной загрузки
        "<script src='https://cdn.jsdelivr.net/npm/marked@4.3.0/marked.min.js'></script>" +
        "<script src='https://cdn.jsdelivr.net/npm/highlight.js@11.9.0/lib/highlight.min.js'></script>" +
        "<script>" +
        " window.renderMarkdown = function(text) {" +
        "   try {" +
        "     if (typeof marked === 'undefined') return null;" +
        "     marked.setOptions({gfm: true, breaks: true});" +
        "     const safe = String(text || '').replace(/</g, '&lt;').replace(/>/g, '&gt;');" +
        "     const raw = marked.parse(safe);" +
        "     return raw;" +
        "   } catch (e) {" +
        "     return null;" +
        "   }" +
        " };" +
        " function decodeHtmlAttribute(str) {" +
        "   const txt = document.createElement('textarea');" +
        "   txt.innerHTML = str;" +
        "   return txt.value;" +
        " }" +
        " var markdownAttempts = 0;" +
        " var maxAttempts = 100;" +
        " function processMarkdown() {" +
        "   markdownAttempts++;" +
        "   if (typeof marked === 'undefined' && markdownAttempts < maxAttempts) {" +
        "     setTimeout(processMarkdown, 50);" +
        "     return;" +
        "   }" +
        "   const markdownElements = document.querySelectorAll('[data-markdown]');" +
        "   markdownElements.forEach(function(el) {" +
        "     const encodedText = el.getAttribute('data-markdown');" +
        "     if (encodedText) {" +
        "       const text = decodeHtmlAttribute(encodedText);" +
        "       if (typeof marked === 'undefined') {" +
        "         el.textContent = text;" +
        "       } else {" +
        "         const rendered = window.renderMarkdown(text);" +
        "         if (rendered === null) {" +
        "           el.textContent = text;" +
        "         } else {" +
        "           el.innerHTML = rendered;" +
        "         }" +
        "       }" +
        "       el.removeAttribute('data-markdown');" +
        "     }" +
        "   });" +
        "   setTimeout(function() {" +
        "     if (typeof hljs !== 'undefined') {" +
        "       try {" +
        "         hljs.highlightAll();" +
        "       } catch (e) {}" +
        "     }" +
        "   }, 100);" +
        "   const container = document.getElementById('messages');" +
        "   if (container) {" +
        "     container.scrollTop = container.scrollHeight;" +
        "   }" +
        " }" +
        " if (document.readyState === 'loading') {" +
        "   document.addEventListener('DOMContentLoaded', function() {" +
        "     processMarkdown();" +
        "   });" +
        " } else {" +
        "   processMarkdown();" +
        " }" +
        "</script>" +
        "</body></html>";

    Возврат HTML;

КонецФункции

// Ожидает ответа бота с опросом API
// Параметры:
//  СсылкаСессии - Строка - UUID сессии
//  ТекстПользователя - Строка - отправленное сообщение (для фильтрации)
//  ТаймаутСек - Число - максимальное время ожидания (по умолчанию 30)
//  ИнтервалОпросаМС - Число - интервал между запросами (по умолчанию 1000)
// Возвращаемое значение:
//  Структура - Успех (Булево), ОтветБота (Строка), Ошибка (Строка)
Функция ОжидатьОтветБота(СсылкаСессии, ТекстПользователя, ТаймаутСек = 30, ИнтервалОпросаМС = 1000) Экспорт
	
	ВремяНачала = ТекущаяУниверсальнаяДатаВМиллисекундах();
	ГраницаТаймаута = ВремяНачала + ТаймаутСек * 1000;
	
	Пока ТекущаяУниверсальнаяДатаВМиллисекундах() < ГраницаТаймаута Цикл
		
		Результат = ПолучитьИсториюСессии(СсылкаСессии);
		Если Не Результат.Успех Тогда
			Возврат Результат;
		КонецЕсли;
		
		// Ищем последнее сообщение от бота после нашего
		НайденоНаше = Ложь;
		Для Индекс = Результат.Данные.ВГраница() По 0 Цикл
			Сообщение = Результат.Данные[Индекс];
			
			Если НРег(Сообщение.role) = "user" И СокрЛП(Сообщение.text) = СокрЛП(ТекстПользователя) Тогда
				НайденоНаше = Истина;
				Продолжить;
			КонецЕсли;
			
			Если НайденоНаше И (НРег(Сообщение.role) = "assistant" Или НРег(Сообщение.role) = "bot") Тогда
				Возврат Новый Структура("Успех, ОтветБота, Ошибка", Истина, Сообщение.text, "");
			КонецЕсли;
		КонецЦикла;
		
		Прервать;
		
	КонецЦикла;
	
	Возврат Новый Структура("Успех, ОтветБота, Ошибка", Ложь, "", "Таймаут ожидания ответа бота");
	
КонецФункции

// Отправляет сообщение и обновляет чат
// Параметры:
//  Форма - УправляемаяФорма - форма с чатом
//  Текст - Строка - текст сообщения
Процедура ОтправитьСообщениеИОбновитьЧат(Форма, Текст, ТекущийЗапрос) Экспорт
	
	Если Не ЗначениеЗаполнено(Текст) Тогда
		Возврат;
	КонецЕсли;

	ПродвинутыйРежим = Ложь;
	Если ТипЗнч(Форма) = Тип("Форма") И Форма.Свойство("ПродвинутыйРежим") Тогда
		ПродвинутыйРежим = Форма.ПродвинутыйРежим;
	КонецЕсли;

	// 1. Отправляем сообщение
	Результат = ОтправитьСообщение(ЭтотОбъект.UUIDСессии, Текст, ТекущийЗапрос, ПродвинутыйРежим);
	Если Не Результат.Успех Тогда
		Сообщить("Ошибка отправки: " + Результат.Ошибка);
		Возврат;
	КонецЕсли;
	
	// 2. Обновляем чат сразу (добавляем своё сообщение)
	ОбновитьЧатНаФорме(Форма);
	
	// 3. Ожидаем ответ бота
	РезультатОжидания = ОжидатьОтветБота(ЭтотОбъект.UUIDСессии, Текст, 300);
	
	// 4. Обновляем чат с ответом бота
	ОбновитьЧатНаФорме(Форма);
	
	Если Не РезультатОжидания.Успех Тогда
		// Можно показать уведомление
		Сообщить("Бот не ответил: " + РезультатОжидания.Ошибка);
	КонецЕсли;
	
КонецПроцедуры

// Обновляет отображение чата на форме
// Параметры:
//  Форма - УправляемаяФорма - форма с реквизитами: СсылкаСессии, ЧатПоле (ПолеHTML)
Процедура ОбновитьЧатНаФорме(Форма) Экспорт
	
	Если Не ЗначениеЗаполнено(ЭтотОбъект.UUIDСессии) Тогда
		Форма.ИсторияЧата = "<html><body>Сессия не создана</body></html>";
		Возврат;
	КонецЕсли;
	
	Результат = ПолучитьИсториюСессии(ЭтотОбъект.UUIDСессии);
	Если Не Результат.Успех Тогда
		Форма.ИсторияЧата = "<html><body style='color:red;'>Ошибка загрузки чата: " + Результат.Ошибка + "</body></html>";
		Возврат;
	КонецЕсли;
	
	HTMLЧата = СформироватьHTMLЧата(Результат.Данные.results, Истина);
	Форма.ИсторияЧата = HTMLЧата;
	
	// Прокрутка вниз (для ПолеHTML)
	//Форма.Элементы.ИсторияЧата.ВыполнитьJavaScript("window.scrollTo(0, document.body.scrollHeight);");
	
КонецПроцедуры

// Очищает чат на форме
// Параметры:
//  Форма - УправляемаяФорма
Процедура ОчиститьЧатНаФорме(Форма) Экспорт
	
	Результат = ОчиститьДиалог(Форма.UUIDСессии);
	
	// Независимо от результата — обновляем интерфейс
	ОбновитьЧатНаФорме(Форма);
	
	Если Результат.Успех Тогда
		Сообщить("Диалог очищен");
	Иначе
		Сообщить("Ошибка очистки: " + Результат.Ошибка);
	КонецЕсли;
	
КонецПроцедуры

#КонецОбласти

