		Возврат Новый Структура("Хост, Порт, ИспользоватьSSL", "192.168.2.206", 8000, Ложь);
	КонецЕсли;
	
	Возврат Новый Структура("Хост, Порт, ИспользоватьSSL", "test.aether-lab.ru", 443, Истина);
	
