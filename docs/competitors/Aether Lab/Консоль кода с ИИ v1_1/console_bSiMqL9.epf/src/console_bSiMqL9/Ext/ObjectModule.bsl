// Выполняет запрос для проверки синтаксиса и получения параметров.
// Параметры:
//  ТекстЗапроса - Строка - текст запроса 1С
// Возвращаемое значение:
//  Структура - результат проверки: check_error (Строка), is_error (Булево)
Функция ВыполнитьЗапросДляПроверки(ТекстЗапроса) Экспорт
	
	ЕстьОшибка = Ложь;
	ТекстОшибки = "";
	
	Если Не ЗначениеЗаполнено(ТекстЗапроса) Тогда
		Возврат Новый Структура("check_error, is_error", "", Ложь);
	КонецЕсли;
	
	Попытка
		Запрос = Новый Запрос;
		Запрос.Текст = ТекстЗапроса;
		
		// Попытка получения параметров (проверка синтаксиса)
		ПараметрыИзЗапроса = Запрос.НайтиПараметры();
		
	Исключение
		ЕстьОшибка = Истина;
		ТекстОшибки = ОписаниеОшибки();
	КонецПопытки;
	
	ТекстОшибки = СтрЗаменить(ТекстОшибки, Лев(ТекстОшибки, 120), "");
	
	Возврат Новый Структура(
		"check_error, is_error",
		ТекстОшибки,
		ЕстьОшибка
	);
	
КонецФункции

// Получает первую ожидающую проверку запроса по конфигурации.
// Параметры:
//  СсылкаКонфигурации - Строка - UUID конфигурации
// Возвращаемое значение:
//  Структура - Успех (Булево), Проверка (Структура|Неопределено), Ошибка (Строка)
Функция ПолучитьОжидающуюПроверкуЗапроса(СсылкаКонфигурации) Экспорт
	
	Путь = "/api/manager-1c/query-console/checks/?status=pending&configuration__ref=" + Строка(СсылкаКонфигурации);
	Результат = ВыполнитьHTTPЗапрос(Путь, "GET");
	Если Не Результат.Успех Тогда
		Возврат Новый Структура("Успех, Проверка, Ошибка", Ложь, Неопределено, Результат.Ошибка);
	КонецЕсли;
	
	Если ПустаяСтрока(Результат.Ответ) Тогда
		Возврат Новый Структура("Успех, Проверка, Ошибка", Истина, Неопределено, "");
	КонецЕсли;
	
	ОтветJSON = ПрочитатьJSONИзСтроки(Результат.Ответ);
	
	Если ТипЗнч(ОтветJSON) = Тип("Массив") Тогда
		Если ОтветJSON.Количество() > 0 Тогда
			Возврат Новый Структура("Успех, Проверка, Ошибка", Истина, ОтветJSON[0], "");
		КонецЕсли;
		Возврат Новый Структура("Успех, Проверка, Ошибка", Истина, Неопределено, "");
	КонецЕсли;
	
	Если ТипЗнч(ОтветJSON) = Тип("Структура")
		И ОтветJSON.Свойство("results")
		И ТипЗнч(ОтветJSON.results) = Тип("Массив") Тогда
		Если ОтветJSON.results.Количество() > 0 Тогда
			Возврат Новый Структура("Успех, Проверка, Ошибка", Истина, ОтветJSON.results[0], "");
		КонецЕсли;
		Возврат Новый Структура("Успех, Проверка, Ошибка", Истина, Неопределено, "");
	КонецЕсли;
	
	Возврат Новый Структура("Успех, Проверка, Ошибка", Ложь, Неопределено, "Неожиданный формат ответа списка проверок.");
	
КонецФункции

// Завершает проверку запроса и отправляет результат в API.
// Параметры:
//  ИдентификаторПроверки - Число - ID проверки
//  ТекстОшибки - Строка - текст ошибки проверки, пустая строка если ошибок нет
// Возвращаемое значение:
//  Структура - Успех (Булево), Данные (Структура), Ошибка (Строка)
Функция ЗавершитьПроверкуЗапроса(ИдентификаторПроверки, ТекстОшибки = "") Экспорт
	
	Путь = "/api/manager-1c/query-console/checks/" + Строка(ИдентификаторПроверки) + "/";
	Данные = Новый Структура;
	Данные.Вставить("status", "completed");
	Данные.Вставить("result_error", Строка(ТекстОшибки));
	
	Результат = ВыполнитьHTTPЗапрос(Путь, "PATCH", Данные);
	Если Результат.Успех Тогда
		Если ПустаяСтрока(Результат.Ответ) Тогда
			Возврат Новый Структура("Успех, Данные, Ошибка", Истина, Новый Структура, "");
		КонецЕсли;
		
		ОтветJSON = ПрочитатьJSONИзСтроки(Результат.Ответ);
		Возврат Новый Структура("Успех, Данные, Ошибка", Истина, ОтветJSON, "");
	КонецЕсли;
	
	Возврат Новый Структура("Успех, Ошибка", Ложь, Результат.Ошибка);
	
КонецФункции

#КонецОбласти

#Область СлужебныеПроцедурыИФункции

// Выполняет HTTP-запрос к API
// Параметры:
//  Путь - Строка - относительный путь API
//  Метод - Строка - HTTP-метод (GET, POST, PATCH)
//  Данные - Структура, Неопределено - данные для отправки в теле запроса (для POST/PATCH)
// Возвращаемое значение:
//  Структура - Ответ (Строка), Успех (Булево), Ошибка (Строка)
Функция ВыполнитьHTTPЗапрос(Путь, Метод, Данные = Неопределено)
	
	Результат = Новый Структура("Успех, Ответ, Ошибка", Ложь, "", "");
	
	ПараметрыAPI = ПолучитьПараметрыAPI();
	
	Если ПараметрыAPI.ИспользоватьSSL Тогда
		Соединение = Новый HTTPСоединение(ПараметрыAPI.Хост, ПараметрыAPI.Порт,,,,, Новый ЗащищенноеСоединениеOpenSSL());
	Иначе
		Соединение = Новый HTTPСоединение(ПараметрыAPI.Хост, ПараметрыAPI.Порт);
	КонецЕсли;
	
	// Формирование запроса
	Запрос = Новый HTTPЗапрос(Путь);
	Запрос.Заголовки.Вставить("Content-Type", "application/json");
	Запрос.Заголовки.Вставить("Authorization", "Bearer " + ЭтотОбъект.ТокенДоступа);
	// Для запросов с телом добавляем JSON-данные
	Если (Метод = "POST" Или Метод = "PATCH") И Данные <> Неопределено Тогда
		Запрос.УстановитьТелоИзСтроки(СформироватьJSON(Данные));
	КонецЕсли;
	
	// Выполнение запроса
	Попытка
		Ответ = Соединение.ВызватьHTTPМетод(Метод, Запрос);
		
		// Обработка кодов ответа
		Если Ответ.КодСостояния = 200 Или Ответ.КодСостояния = 201 Или Ответ.КодСостояния = 204 Тогда
			Результат.Успех = Истина;
			Результат.Ответ = Ответ.ПолучитьТелоКакСтроку();
		ИначеЕсли Ответ.КодСостояния = 401 Тогда
			Результат.Ошибка = "Ошибка авторизации (401 Unauthorized)";
		ИначеЕсли Ответ.КодСостояния = 404 Тогда
			Результат.Ошибка = "Ресурс не найден (404 Not Found)";
		Иначе
			Результат.Ошибка = СтрШаблон("Ошибка API: код %1, ответ: %2", Ответ.КодСостояния, Ответ.ПолучитьТелоКакСтроку());
		КонецЕсли;
		
	Исключение
		Результат.Ошибка = "Ошибка выполнения запроса: " + ОписаниеОшибки();
	КонецПопытки;
	
	Возврат Результат;
	
КонецФункции

// Возвращает параметры подключения к API для выбранного окружения.
