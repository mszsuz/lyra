	Объект.UUIDСессии = ПолучитьНастройку("AL_UUIDСессии");
	
	// Инициализация флагов пулинга
	ОжидаемОтветИИ = Ложь;
	ПулингЧатаАктивен = Ложь;
	ИнтервалПулингаЧатаСек = 2;
	ПулингКонфигаАктивен = Ложь;
	ИнтервалПулингаКонфигаСек = 3;
	ОтложенныйКодДляРедактора = "";
	ДиалогОшибкиСессииПоказан = Ложь;
	ДиалогОшибкиКонфигурацииПоказан = Ложь;
	ПроверкаЗапросаВПроцессе = Ложь;
	СтатусКонфигурации = "";
	ОбновитьЗаголовокФормы();
	
	Если Не ЗначениеЗаполнено(Объект.UUIDКонфигурации) Тогда		
