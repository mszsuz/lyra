Функция ПроверитьКонфигурциюНаСервере() 
	ОбъектДляСервера = РеквизитФормыВЗначение("Объект");
	Результат = ОбъектДляСервера.ПроверитьКонфигурацию(Объект.UUIDКонфигурации);
	
	StatusId = "";
	ИмяКонфигурации = "";
	
	Данные = Неопределено;
	Ошибка = "";
	Если Результат.Свойство("Ошибка") Тогда
		Ошибка = Результат.Ошибка;
	КонецЕсли;
	
	Если Результат.Успех Тогда
		
		Если Результат.Свойство("Данные") Тогда
			Данные = Результат.Данные;
		КонецЕсли;

		Если Данные <> Неопределено Тогда
			Если Данные.Свойство("name") И ЗначениеЗаполнено(Данные.name) Тогда
				ИмяКонфигурации = Строка(Данные.name);
			ИначеЕсли Данные.Свойство("title") И ЗначениеЗаполнено(Данные.title) Тогда
				ИмяКонфигурации = Строка(Данные.title);
			ИначеЕсли Данные.Свойство("configuration_name") И ЗначениеЗаполнено(Данные.configuration_name) Тогда
				ИмяКонфигурации = Строка(Данные.configuration_name);
			КонецЕсли;
		КонецЕсли;
		
		Если Данные <> Неопределено И Данные.Свойство("updated_at") Тогда
			ДатаОбновленияМетаданных = XMLЗначение(Тип("Дата"), Данные.updated_at);
		КонецЕсли;
		
		Если Данные <> Неопределено
			И Данные.Свойство("status") И ЗначениеЗаполнено(Данные.status)
			И Данные.status.Свойство("id") Тогда
			StatusId = Данные.status.id;
		КонецЕсли;
		
	КонецЕсли;
	
	// Обновляем человекочитаемый статус конфигурации на форме
	СтатусКонфигурации = "";
	Если Не Результат.Успех Тогда
		Если НЕ ПустаяСтрока(Ошибка) Тогда
			СтатусКонфигурации = "Ошибка: " + Ошибка;
		Иначе
			СтатусКонфигурации = "Ошибка при запросе состояния конфигурации";
		КонецЕсли;
	Иначе
		Если StatusId = "active" Тогда
			СтатусКонфигурации = "Готова к работе";
		ИначеЕсли StatusId = "indexing" Тогда
			СтатусКонфигурации = "Индексация";
		ИначеЕсли StatusId = "required_reindex" Тогда
			СтатусКонфигурации = "Требуется переиндексация";
		ИначеЕсли StatusId = "updating" Тогда
			СтатусКонфигурации = "Обновление конфигурации";
		ИначеЕсли StatusId = "creating" Тогда
			СтатусКонфигурации = "Создание конфигурации";
		ИначеЕсли НЕ ПустаяСтрока(StatusId) Тогда
			СтатусКонфигурации = "Статус: " + StatusId;
		Иначе
			СтатусКонфигурации = "Статус не определён";
		КонецЕсли;
	КонецЕсли;
	
	Если ПустаяСтрока(ИмяКонфигурации) Тогда
		ИмяКонфигурации = "Конфигурация";
	КонецЕсли;
	
	Возврат Новый Структура("Успех, Данные, Ошибка, StatusId, ИмяКонфигурации, СтатусКонфигурации", Результат.Успех, Данные, Ошибка, StatusId, ИмяКонфигурации, СтатусКонфигурации);
	
КонецФункции

&НаКлиенте
Процедура ОбновитьЗаголовокФормы(ИмяКонфигурации = "", СтатусКонфигурации = "") Экспорт
	Если ПустаяСтрока(СтатусКонфигурации) Тогда
		СтатусКонфигурации = "Инициализация";
	КонецЕсли;
	
	ЭтаФорма.Заголовок = "(" + СтатусКонфигурации + ")";
КонецПроцедуры

Функция ПроверитьСостояниеСессии()
	ОбъектДляСервера = РеквизитФормыВЗначение("Объект");
	
	Если ЗначениеЗаполнено(Объект.UUIDСессии) Тогда
		ПроверкаСессии = ОбъектДляСервера.ПроверитьСессию(Объект.UUIDСессии);
		Если ПроверкаСессии.Успех Тогда
			Возврат Новый Структура("Успех, UUIDСессии, Ошибка", Истина, Объект.UUIDСессии, "");
		КонецЕсли;
	КонецЕсли;
	
	РезультатСоздания = ОбъектДляСервера.СоздатьСессию(Объект.UUIDКонфигурации);
	Если РезультатСоздания.Успех Тогда
		НоваяСессия = Новый УникальныйИдентификатор(РезультатСоздания.СсылкаСессии);
		Объект.UUIDСессии = НоваяСессия;
		Возврат Новый Структура("Успех, UUIDСессии, Ошибка", Истина, НоваяСессия, "");
	КонецЕсли;
	
	ТекстОшибки = "Ошибка инициализации сессии";
	Если РезультатСоздания.Свойство("Ошибка") И ЗначениеЗаполнено(РезультатСоздания.Ошибка) Тогда
		ТекстОшибки = Строка(РезультатСоздания.Ошибка);
	КонецЕсли;
	Возврат Новый Структура("Успех, UUIDСессии, Ошибка", Ложь, Неопределено, ТекстОшибки);
КонецФункции

