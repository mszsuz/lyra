КонецФункции

Функция НормализоватьКлючПрофиля(Домен) Экспорт
	
	Если Не ЗначениеЗаполнено(Домен) Тогда
		Возврат "default";
	КонецЕсли;
	
	НормализованныйДомен = НРег(Строка(Домен));
	НормализованныйДомен = СтрЗаменить(НормализованныйДомен, "https://", "");
	НормализованныйДомен = СтрЗаменить(НормализованныйДомен, "http://", "");
	
	ПозицияСлеша = Найти(НормализованныйДомен, "/");
	Если ПозицияСлеша > 0 Тогда
		НормализованныйДомен = Лев(НормализованныйДомен, ПозицияСлеша - 1);
	КонецЕсли;
	
	Если Не ЗначениеЗаполнено(НормализованныйДомен) Тогда
		Возврат "default";
	КонецЕсли;
	
	Возврат НормализованныйДомен;
	
КонецФункции

Функция ПолучитьКлючПрофиляНастроек() Экспорт
	Возврат НормализоватьКлючПрофиля(ПолучитьХостAPIДляПрофиля());
КонецФункции

Функция КлючОбъектаНастроекV2() Экспорт
	Возврат "AetherAIConsoleV2";
КонецФункции

Функция КлючЗаписиНастроекV2() Экспорт
	Возврат "Profiles";
КонецФункции


// Ленивая инициализация ключей
Процедура ИнициализироватьКлючи() Экспорт

    Если ПустаяСтрока(КлючОбъектаНастроек) Тогда
        // Можно назвать как угодно, но лучше что-то уникальное
        КлючОбъектаНастроек = "AetherAIConsole";
    КонецЕсли;

    Если ПустаяСтрока(КлючЗаписиНастроек) Тогда
        КлючЗаписиНастроек = "UserSettings";
    КонецЕсли;

КонецПроцедуры

Процедура ИнициализироватьНастройкиV2() Экспорт
	
	Если ТипЗнч(СтруктураНастроекV2) = Тип("Структура") Тогда
		Возврат;
	КонецЕсли;
	
	СтруктураНастроекV2 = Новый Структура("Профили", Новый Соответствие);
	
	Попытка
		Значение = ХранилищеОбщихНастроек.Загрузить(
			КлючОбъектаНастроекV2(),
			КлючЗаписиНастроекV2(),
			,
			
		);
	Исключение
		Возврат;
	КонецПопытки;
	
	Если ТипЗнч(Значение) = Тип("Структура") Тогда
		СтруктураНастроекV2 = Значение;
	КонецЕсли;
	
	Профили = Неопределено;
	Если НЕ СтруктураНастроекV2.Свойство("Профили", Профили) Или ТипЗнч(Профили) <> Тип("Соответствие") Тогда
		СтруктураНастроекV2.Вставить("Профили", Новый Соответствие);
	КонецЕсли;
	
КонецПроцедуры

Процедура СохранитьНастройкиV2() Экспорт
	
	ИнициализироватьНастройкиV2();
	
	Попытка
		ХранилищеОбщихНастроек.Сохранить(
			КлючОбъектаНастроекV2(),
			КлючЗаписиНастроекV2(),
			СтруктураНастроекV2,
			,
			
		);
	Исключение
	КонецПопытки;
	
КонецПроцедуры

Функция ПолучитьПрофильV2(СоздаватьЕслиНет = Ложь) Экспорт
	
	ИнициализироватьНастройкиV2();
	
	Профили = СтруктураНастроекV2.Профили;
	КлючПрофиля = ПолучитьКлючПрофиляНастроек();
	
	Профиль = Профили.Получить(КлючПрофиля);
	Если ТипЗнч(Профиль) = Тип("Структура") Тогда
		Возврат Профиль;
	КонецЕсли;
	
	Если Не СоздаватьЕслиНет Тогда
		Возврат Неопределено;
	КонецЕсли;
	
	Профиль = Новый Структура;
	Профили.Вставить(КлючПрофиля, Профиль);
	СтруктураНастроекV2.Вставить("Профили", Профили);
	Возврат Профиль;
	
КонецФункции

Функция ПолучитьНастройкуИзПрофиляV2(ИмяНастройки, ЗначениеПоУмолчанию = Неопределено) Экспорт
	
	Профиль = ПолучитьПрофильV2(Ложь);
	Если Профиль = Неопределено Тогда
		Возврат ЗначениеПоУмолчанию;
	КонецЕсли;
	
	Если Профиль.Свойство(ИмяНастройки) Тогда
		Возврат Профиль[ИмяНастройки];
	КонецЕсли;
	
	Возврат ЗначениеПоУмолчанию;
	
КонецФункции

Процедура УстановитьНастройкуВПрофильV2(ИмяНастройки, Значение) Экспорт
	
	Профиль = ПолучитьПрофильV2(Истина);
	Профиль.Вставить(ИмяНастройки, Значение);
	
	Профили = СтруктураНастроекV2.Профили;
	Профили.Вставить(ПолучитьКлючПрофиляНастроек(), Профиль);
	СтруктураНастроекV2.Вставить("Профили", Профили);
	СохранитьНастройкиV2();
	
КонецПроцедуры

Процедура УдалитьНастройкуИзПрофиляV2(ИмяНастройки) Экспорт
	
	Профиль = ПолучитьПрофильV2(Ложь);
	Если Профиль = Неопределено Тогда
		Возврат;
	КонецЕсли;
	
	Если Профиль.Свойство(ИмяНастройки) Тогда
		Профиль.Удалить(ИмяНастройки);
		Профили = СтруктураНастроекV2.Профили;
		Профили.Вставить(ПолучитьКлючПрофиляНастроек(), Профиль);
		СтруктураНастроекV2.Вставить("Профили", Профили);
		СохранитьНастройкиV2();
	КонецЕсли;
	
КонецПроцедуры

Функция ПолучитьНастройкуИзLegacy(ИмяНастройки, ЗначениеПоУмолчанию = Неопределено) Экспорт
	
	ИнициализироватьНастройки();
	
	Если СтруктураНастроек.Свойство(ИмяНастройки) Тогда
		Возврат СтруктураНастроек[ИмяНастройки];
	КонецЕсли;
	
	Возврат ЗначениеПоУмолчанию;
	
КонецФункции

Процедура УдалитьНастройкуИзLegacy(ИмяНастройки) Экспорт
	
	ИнициализироватьНастройки();
	Если СтруктураНастроек.Свойство(ИмяНастройки) Тогда
		СтруктураНастроек.Удалить(ИмяНастройки);
		СохранитьНастройки();
	КонецЕсли;
	
КонецПроцедуры


// Загрузка структуры настроек из ХранилищеОбщихНастроек
Процедура ИнициализироватьНастройки() Экспорт

    // Уже загружали в этом сеансе
    Если ТипЗнч(СтруктураНастроек) = Тип("Структура") Тогда
        Возврат;
    КонецЕсли;

    ИнициализироватьКлючи();

    СтруктураНастроек = Новый Структура;

    КлючОбъекта      = КлючОбъектаНастроек;
    КлючНастроек     = КлючЗаписиНастроек;
    ВладелецНастроек = ИмяПользователя(); // настройки текущего пользователя

    Попытка
        Значение = ХранилищеОбщихНастроек.Загрузить(
            КлючОбъекта,
            КлючНастроек,
            ,                 // 4-й параметр не используем
            
        );
    Исключение
        // нет прав на чтение / администрирование данных — оставляем пустую структуру
        Возврат;
    КонецПопытки;

    Если Значение = Неопределено Тогда
        // настроек ещё нет
        Возврат;
    КонецЕсли;

    // На всякий случай — поддержка и Структуры, и Соответствия
    Если ТипЗнч(Значение) = Тип("Структура") Тогда
        СтруктураНастроек = Значение;
    ИначеЕсли ТипЗнч(Значение) = Тип("Соответствие") Тогда
        Для Каждого Парам Из Значение Цикл
            СтруктураНастроек.Вставить(Парам.Ключ, Парам.Значение);
        КонецЦикла;
    КонецЕсли;

КонецПроцедуры


// Сохранение структуры настроек в ХранилищеОбщихНастроек
Процедура СохранитьНастройки() Экспорт

    ИнициализироватьКлючи();

    Если ТипЗнч(СтруктураНастроек) <> Тип("Структура") Тогда
        СтруктураНастроек = Новый Структура;
    КонецЕсли;

    КлючОбъекта      = КлючОбъектаНастроек;
    КлючНастроек     = КлючЗаписиНастроек;
    ИмяПользователяХ = ИмяПользователя(); // владелец

    Попытка
        ХранилищеОбщихНастроек.Сохранить(
            КлючОбъекта,
            КлючНастроек,
            СтруктураНастроек,
            ,                   // пустой 4-й параметр
            
        );
    Исключение
        // нет прав на запись — можно залогировать или промолчать
    КонецПопытки;

КонецПроцедуры


// Получить значение настройки по имени
Функция ПолучитьНастройку(ИмяНастройки, ЗначениеПоУмолчанию = Неопределено) Экспорт

	ЗначениеИзПрофиля = ПолучитьНастройкуИзПрофиляV2(ИмяНастройки, Неопределено);
	Если ЗначениеИзПрофиля <> Неопределено Тогда
		Возврат ЗначениеИзПрофиля;
	КонецЕсли;
	
	ЗначениеИзLegacy = ПолучитьНастройкуИзLegacy(ИмяНастройки, Неопределено);
	Если ЗначениеИзLegacy <> Неопределено Тогда
		УстановитьНастройкуВПрофильV2(ИмяНастройки, ЗначениеИзLegacy);
		Возврат ЗначениеИзLegacy;
	КонецЕсли;
	
	Возврат ЗначениеПоУмолчанию;

КонецФункции


// Установить/изменить настройку
Процедура УстановитьНастройку(ИмяНастройки, Значение) Экспорт

	УстановитьНастройкуВПрофильV2(ИмяНастройки, Значение);

КонецПроцедуры


// Удалить настройку по имени
Процедура УдалитьНастройку(ИмяНастройки) Экспорт

	УдалитьНастройкуИзПрофиляV2(ИмяНастройки);

КонецПроцедуры


// Полный сброс всех настроек нашей обработки для текущего пользователя
Процедура СброситьВсеНастройки() Экспорт

	ИнициализироватьНастройкиV2();
	КлючПрофиля = ПолучитьКлючПрофиляНастроек();
	Профиль = СтруктураНастроекV2.Профили.Получить(КлючПрофиля);
	
	Если Профиль <> Неопределено Тогда
		СтруктураНастроекV2.Профили.Удалить(КлючПрофиля);
