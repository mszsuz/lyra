&НаКлиенте
Процедура ЗапуститьПулингКонфига()
	
	Если ИнтервалПулингаКонфигаСек <= 0 Тогда
		ИнтервалПулингаКонфигаСек = 3;
	КонецЕсли;
	
	Попытка
		ОтключитьОбработчикОжидания("ПроверитьКонфигНаКлиенте");
	Исключение
	КонецПопытки;
	
	ПодключитьОбработчикОжидания("ПроверитьКонфигНаКлиенте", ИнтервалПулингаКонфигаСек);
	ПулингКонфигаАктивен = Истина;
	
КонецПроцедуры

&НаКлиенте
Процедура ОстановитьПулингКонфига()
	
	Попытка
		ОтключитьОбработчикОжидания("ПроверитьКонфигНаКлиенте");
	Исключение
	КонецПопытки;
	
	ПулингКонфигаАктивен = Ложь;
	
КонецПроцедуры

&НаКлиенте
Процедура ПроверитьКонфигНаКлиенте()
	
	Результат = ПроверитьКонфигурциюНаСервере();
	Если Результат = Неопределено Или Не Результат.Успех Тогда
		Если Результат <> Неопределено И ЭтоОшибкаАвторизации(Результат) Тогда
			ОстановитьПулингКонфига();
			ЗапроситьНовыйТокен("Токен недействителен или истёк. Введите новый токен доступа.");
		КонецЕсли;
		Возврат;
	КонецЕсли;

	Если Результат.Свойство("СтатусКонфигурации") Тогда
		ОбновитьЗаголовокФормы(Результат.ИмяКонфигурации, Результат.СтатусКонфигурации);
	КонецЕсли;
	
	Если Результат.Свойство("StatusId") И ЗначениеЗаполнено(Результат.StatusId) Тогда
		Если Результат.StatusId = "active" Тогда
			// Конфигурация полностью готова — останавливаем пулинг и работаем с сессией
			ОстановитьПулингКонфига();
			ПроверитьСессиюНаКлиенте();
		ИначеЕсли Результат.StatusId = "indexing" Тогда
			// Идёт индексация: можно уже создавать сессию и отправлять запросы,
			// но пулинг конфигурации продолжаем до перехода в active
			ПроверитьСессиюНаКлиенте();
		Иначе
			// Прочие статусы (creating/updating/required_reindex) — просто ждём, пулинг оставляем включённым
		КонецЕсли;
	КонецЕсли;
	
КонецПроцедуры

