		УстановитьНастройку("AL_UUIDКонфигурации", Объект.UUIDКонфигурации); 
	КонецЕсли;	
	Если Не ЗначениеЗаполнено(Объект.ТокенДоступа) Тогда
		ОписаниеОповещения = Новый ОписаниеОповещения("ВводТокенаЗавершение", ЭтотОбъект);
		ПоказатьВводЗначения(ОписаниеОповещения, ЭтотОбъект.ТокенДоступа, НСтр("ru = 'Введите токен доступа'"));
