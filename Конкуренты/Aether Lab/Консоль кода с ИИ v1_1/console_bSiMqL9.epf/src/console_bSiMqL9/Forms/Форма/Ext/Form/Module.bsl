КонецПроцедуры

&НаКлиенте
Процедура ОбновитьМетаданные(Команда = Неопределено)
	Если Команда <> Неопределено Тогда
		Текст = НСтр("ru = 'Обновить метаданные конфигурации на сервере? Это может занять несколько минут.'");
		ОписаниеОповещения = Новый ОписаниеОповещения("ОбновитьМетаданныеЗавершение", ЭтотОбъект);
		ПоказатьВопрос(ОписаниеОповещения, Текст, РежимДиалогаВопрос.ОКОтмена);
		Возврат;
	КонецЕсли;
	
    ОбновитьСостояние("Инициализация", "Подготовка к работе", 0);   
	АдресФайла = ВыгрузитьМД();
	ОбновитьСостояние("Инициализация", "Обновление структуры метаданных", 30);
	Id_файла = ОтправитьФайл(АдресФайла);
	Если Не ЗначениеЗаполнено(Id_файла) Тогда
		Возврат;	
	КонецЕсли;
	ОбновитьСостояние("Инициализация", "Завершение подготовки", 70);
	ОбновитьКонфигурацию(Id_файла);                      
	
	// Сразу после успешного обновления — запрашиваем состояние конфигурации и дальше действуем по правилам пулинга
	ЗапуститьПулингКонфига();
	ПроверитьКонфигНаКлиенте();
	
	ОбновитьСостояние("Инициализация", "Завершено", 100);
КонецПроцедуры

&НаКлиенте
Процедура ОбновитьМетаданныеЗавершение(Результат, ДополнительныеПараметры) Экспорт
	Если Результат = КодВозвратаДиалога.ОК Тогда
		ОбновитьМетаданные();
	КонецЕсли;
КонецПроцедуры

&НаКлиенте
Процедура ПроверитьСессиюНаКлиенте()
	РезультатСессии = ПроверитьСостояниеСессии();
	Если РезультатСессии = Неопределено Или Не РезультатСессии.Успех Тогда
		Объект.UUIDСессии = Неопределено;
		УдалитьНастройку("AL_UUIDСессии");
		УдалитьНастройкуИзLegacy("AL_UUIDСессии");
		
		Если РезультатСессии <> Неопределено И ЭтоОшибкаАвторизации(РезультатСессии) Тогда
			ЗапроситьНовыйТокен("Токен недействителен или истёк. Введите новый токен доступа.");
			Возврат;
		КонецЕсли;
		
		ТекстОшибки = "";
		Если РезультатСессии <> Неопределено И РезультатСессии.Свойство("Ошибка") Тогда
			ТекстОшибки = РезультатСессии.Ошибка;
		КонецЕсли;
		
		ПоказатьДиалогОшибкиСессии(ТекстОшибки);
		Возврат;
	КонецЕсли;
	
	Объект.UUIDСессии = РезультатСессии.UUIDСессии;
	ДиалогОшибкиСессииПоказан = Ложь;
	УстановитьНастройку("AL_UUIDСессии", Объект.UUIDСессии);
	
	// При инициализации экрана грузим историю один раз. Пулинг чата включаем только если уже идёт ответ ИИ.
	СостояниеЧата = ИсторияСессииНаСервере();
	Если СостояниеЧата <> Неопределено И СостояниеЧата.Успех Тогда
		// Код для редактора: из последнего сообщения (current_code) или при первом открытии — из current_version сессии
		КодДляРедактора = "";
		Если СостояниеЧата.Свойство("КодТекст") Тогда
			КодДляРедактора = СостояниеЧата.КодТекст;
		КонецЕсли;
		Если Не ЗначениеЗаполнено(КодДляРедактора) Тогда
			РезультатВерсии = ПолучитьКодИзТекущейВерсииСессии();
			Если РезультатВерсии.Успех И ЗначениеЗаполнено(РезультатВерсии.КодИзВерсии) Тогда
				КодДляРедактора = РезультатВерсии.КодИзВерсии;
			КонецЕсли;
		КонецЕсли;
		Если ЗначениеЗаполнено(КодДляРедактора) Тогда
			// Сначала очищаем редактор, чтобы новый код заменял содержимое, а не добавлялся к существующему
			ОчиститьТекст();
			ОтложенныйКодДляРедактора = КодДляРедактора;
			УстановитьТекст(КодДляРедактора, Неопределено, Ложь);
		КонецЕсли;
		
		Если СостояниеЧата.Свойство("ЕстьInProgressИИ") И СостояниеЧата.ЕстьInProgressИИ Тогда
			ОжидаемОтветИИ = Истина;
			ЗапуститьПулингЧата(2);
		Иначе
			ОжидаемОтветИИ = Ложь;
			ОстановитьПулингЧата();
		КонецЕсли;
		УправлениеБлокировкойПокаРаботаетАгент();
		ЗагрузитьИсториюИзмененийНаКлиенте(Истина);
	КонецЕсли;
КонецПроцедуры


&НаСервере
Функция ВыгрузитьМД() 
	ВременныйФайл = ПолучитьИмяВременногоФайла(".xml");
	Файл = Новый Файл(ВременныйФайл);
	Объект.ИмяФайлаВыгрузки = ВременныйФайл;
	ОбъектДляСервера = РеквизитФормыВЗначение("Объект");
	ОбъектДляСервера.НеВыгружатьРегистрыБухгалтерии = Истина;    
	ОбъектДляСервера.НеВыгружатьРегистрыРасчета = Истина;   
	ОбъектДляСервера.НеВыгружатьДвиженияДокументов = Истина;
	ОбъектДляСервера.СостояниеИндикатораПрогресса = Новый Структура("Заголовок");
	ОбъектДляСервера.Индикатор = Новый Структура("Значение, МаксимальноеЗначение");
	ВыгрузкаЗавершена = ОбъектДляСервера.ВыполнитьВыгрузку(); 
	
	АдресФайла = ПоместитьВоВременноеХранилище(Новый ДвоичныеДанные(Объект.ИмяФайлаВыгрузки), ЭтаФорма.УникальныйИдентификатор);
    Возврат АдресФайла;
КонецФункции

&НаСервере
Функция ОтправитьФайл(АдресФайла)
	ОбъектДляСервера = РеквизитФормыВЗначение("Объект");
	ЗагруженныйФайл = ОбъектДляСервера.ЗагрузитьФайл(АдресФайла, "Конфигурация"); 
	Если Не ЗагруженныйФайл.Успех Тогда
		Сообщить(ЗагруженныйФайл.Ошибка, СтатусСообщения.Внимание);
		Возврат Неопределено;
	КонецЕсли;
	Возврат ЗагруженныйФайл.ИдентификаторФайла;
КонецФункции

&НаСервере
Процедура ОбновитьКонфигурацию(Id_файла)	
	ОбъектДляСервера = РеквизитФормыВЗначение("Объект");
	Результат = ОбъектДляСервера.СоздатьКонфигурацию(Id_файла);
	Если Не Результат.Успех Тогда
		Сообщить(Результат.Ошибка);
		// Тут надо бы закрывать форму
		Возврат;
	КонецЕсли;
		
	ДатаОбновленияМетаданных = XMLЗначение(Тип("Дата"), Результат.Обновлено);
	УстановитьНастройку("AL_UUIDКонфигурации", Новый УникальныйИдентификатор(Результат.СсылкаКонфигурации));
	
КонецПроцедуры

&НаКлиенте
Процедура Отправить(Команда)
	РезультатОтправки = ОтправитьНаСервере(ПолучитьТекст());
	Если РезультатОтправки = Неопределено Тогда
		Возврат;
	КонецЕсли;
	
	Если РезультатОтправки.Успех Тогда
		// Сразу обновляем историю (до первого тика пулинга) и включаем ускоренный пулинг
		ОжидаемОтветИИ = Истина;
		УправлениеБлокировкойПокаРаботаетАгент();
		ИсторияСессииНаКлиенте();
		ЗапуститьПулингЧата(2);
	Иначе
		Сообщить(РезультатОтправки.Ошибка);
	КонецЕсли;
КонецПроцедуры


&НаКлиенте
Процедура ИсторияСессииНаКлиенте() Экспорт                      
	
	СостояниеЧата = ИсторияСессииНаСервере();
	Если СостояниеЧата = Неопределено Тогда
		Возврат;
	КонецЕсли;
	
	Если Не СостояниеЧата.Успех Тогда
		// При временных ошибках пулинг не останавливаем.
		Если ЭтоОшибкаДоступа(СостояниеЧата) Тогда
			Если ПулингЧатаАктивен Тогда
				ОстановитьПулингЧата();
			КонецЕсли;
			Если НЕ ДиалогОшибкиСессииПоказан Тогда
				ДиалогОшибкиСессииПоказан = Истина;
				ПоказатьПредупреждение(, НСтр("ru = 'Потерян доступ к чату. Проверьте токен и права доступа.'"));
			КонецЕсли;
		КонецЕсли;
		Возврат;
	КонецЕсли;
	
	ДиалогОшибкиСессииПоказан = Ложь;
	
	КодТекст = "";
	Если СостояниеЧата.Свойство("КодТекст") Тогда
		КодТекст = СостояниеЧата.КодТекст;
	КонецЕсли;
	// Правило: базовый фоновый пулинг чата не применяем, опрашиваем только в ожидании ответа ассистента.
	Если ОжидаемОтветИИ Тогда
		
		////////////////////////////////////////////////////////////////////////////////
		// AL: Проверка запросов (новые проверки)
		ОбработатьПроверкуЗапросаНаКлиенте(Объект.UUIDСессии);
		
		ЕстьInProgressИИ = СостояниеЧата.Свойство("ЕстьInProgressИИ") И СостояниеЧата.ЕстьInProgressИИ;
		ЕстьЛюбыеСообщенияИИ = СостояниеЧата.Свойство("ЕстьСообщениеИИ") И СостояниеЧата.ЕстьСообщениеИИ;
		
		Если ЕстьInProgressИИ Тогда
			// продолжаем ждать
		ИначеЕсли ЕстьЛюбыеСообщенияИИ Тогда
			// ответ завершён (нет in_progress и есть хотя бы одно AI-сообщение)
			ОжидаемОтветИИ = Ложь;
			ОстановитьПулингЧата();
			ЗагрузитьИсториюИзмененийНаКлиенте(Истина);
		Иначе
			// ассистент ещё не успел создать сообщение — продолжаем пулинг
		КонецЕсли;
		
	Иначе
		Если ПулингЧатаАктивен Тогда
			ОстановитьПулингЧата();
		КонецЕсли;
	КонецЕсли;
	
	УправлениеБлокировкойПокаРаботаетАгент();
			
	Если ЗначениеЗаполнено(КодТекст) Тогда
		// Сначала очищаем редактор, чтобы новый код заменял содержимое, а не добавлялся к существующему
		ОчиститьТекст();
		ОтложенныйКодДляРедактора = "";
		УстановитьТекст(КодТекст, Неопределено, Истина);
	КонецЕсли;
		
КонецПроцедуры


&НаСервере
Функция ОтправитьНаСервере(ТекущийКод)
	ОбработкаОбъект = РеквизитФормыВЗначение("Объект");
	СтруктураОтвета = ОбработкаОбъект.ОтправитьСообщение(Объект.UUIDСессии, Промпт, ТекущийКод, ПродвинутыйРежим);
	Если СтруктураОтвета.Успех Тогда   
		ЭтотОбъект.Промпт = "";
		ИсторияСессииНаСервере();    
		Возврат Новый Структура("Успех, Ошибка", Истина, "");
	Иначе
		Возврат Новый Структура("Успех, Ошибка", Ложь, СтруктураОтвета.Ошибка);
	КонецЕсли; 

КонецФункции

// Возвращает код из текущей версии сессии (current_version_state) для загрузки в редактор при первом открытии
&НаСервере
Функция ПолучитьКодИзТекущейВерсииСессии() Экспорт
	ОбработкаОбъект = РеквизитФормыВЗначение("Объект");
	Если Не ЗначениеЗаполнено(Объект.UUIDСессии) Тогда
		Возврат Новый Структура("Успех, КодИзВерсии", Ложь, "");
	КонецЕсли;
	Результат = ОбработкаОбъект.ПроверитьСессию(Объект.UUIDСессии);
	Если Не Результат.Успех Или Не Результат.Свойство("Данные") Тогда
		Возврат Новый Структура("Успех, КодИзВерсии", Ложь, "");
	КонецЕсли;
	КодИзВерсии = "";
	Если Результат.Данные.Свойство("current_version_state") И ЗначениеЗаполнено(Результат.Данные.current_version_state) Тогда
		КодИзВерсии = Результат.Данные.current_version_state;
	КонецЕсли;
	Возврат Новый Структура("Успех, КодИзВерсии", Истина, КодИзВерсии);
КонецФункции

&НаСервере
Функция ИсторияСессииНаСервере() Экспорт                      
	
	ОбработкаОбъект = РеквизитФормыВЗначение("Объект");
	СтруктураОтвета = ОбработкаОбъект.ПолучитьИсториюСессии(ОбработкаОбъект.UUIDСессии);  
	
	Если НЕ СтруктураОтвета.Успех Тогда 
		Возврат Новый Структура("Успех, Ошибка", Ложь, СтруктураОтвета.Ошибка);
	КонецЕсли;
	
	ИсторияЧата = ОбработкаОбъект.СформироватьHTMLЧата(СтруктураОтвета.Данные.results);	       
	
	// Вычисляем состояния для управления пулингом чата
	ЕстьInProgressИИ = Ложь;
	ЕстьСообщениеИИ = Ложь;
	Для Каждого Сообщение Из СтруктураОтвета.Данные.results Цикл
		ЭтоИИ = Ложь;
		Если Сообщение.Свойство("is_user") Тогда
			ЭтоИИ = НЕ Сообщение.is_user;
		ИначеЕсли Сообщение.Свойство("role") Тогда
			Роль = НРег(Сообщение.role);
			ЭтоИИ = (Роль = "assistant" Или Роль = "bot");
		КонецЕсли;
		
		Если ЭтоИИ Тогда
			ЕстьСообщениеИИ = Истина;
			Если Сообщение.Свойство("status") И ЗначениеЗаполнено(Сообщение.status)
				И Сообщение.status.Свойство("id") И Сообщение.status.id = "in_progress" Тогда
				ЕстьInProgressИИ = Истина;
				Прервать;
			КонецЕсли;
		КонецЕсли;
	КонецЦикла;
	
	КодТекст = "";
	Если СтруктураОтвета.Данные.count > 0 И (ПоследнееСообщение <> СтруктураОтвета.Данные.results[СтруктураОтвета.Данные.count - 1].ID Или Не ЗначениеЗаполнено(ПоследнееСообщение)) Тогда
		ПослСообщение = СтруктураОтвета.Данные.results[СтруктураОтвета.Данные.count - 1];
		СтатусId = "";
		Если ПослСообщение.Свойство("status") И ЗначениеЗаполнено(ПослСообщение.status)
			И ПослСообщение.status.Свойство("id") Тогда
			СтатусId = ПослСообщение.status.id;
		КонецЕсли;
		
		Если СтатусId <> "in_progress" Тогда 
			ПоследнееСообщение = ПослСообщение.ID;
			Если ЗначениеЗаполнено(ПослСообщение.current_code) Тогда
				КодТекст = ПослСообщение.current_code;
			КонецЕсли;   
		КонецЕсли;
	КонецЕсли;
	
	Возврат Новый Структура(
		"Успех, Ошибка, КодТекст, ЕстьInProgressИИ, ЕстьСообщениеИИ",
		Истина,
		"",
		КодТекст,
		ЕстьInProgressИИ,
		ЕстьСообщениеИИ);
КонецФункции

////////////////////////////////////////////////////////////////////////////////
// AL: Проверка запросов (новые проверки)

&НаКлиенте
Процедура ОбработатьПроверкуЗапросаНаКлиенте(UUIDСессии) Экспорт
	Если ПроверкаЗапросаВПроцессе Тогда
		Возврат;
	КонецЕсли;
	
	Если Не ЗначениеЗаполнено(UUIDСессии) Тогда
		Возврат;
	КонецЕсли;
	
	ПроверкаЗапросаВПроцессе = Истина;
	Попытка
		РезультатПроверки = ОбработатьПроверкуЗапросаНаСервере(UUIDСессии);
		Если РезультатПроверки <> Неопределено И Не РезультатПроверки.Успех И РезультатПроверки.Свойство("Ошибка")
			И ЗначениеЗаполнено(РезультатПроверки.Ошибка) Тогда
			Сообщить("Ошибка проверки запроса: " + РезультатПроверки.Ошибка, СтатусСообщения.Важное);
		КонецЕсли;
	Исключение
		Сообщить("Ошибка запуска проверки запроса: " + ОписаниеОшибки(), СтатусСообщения.Важное);
	КонецПопытки;
	ПроверкаЗапросаВПроцессе = Ложь;
КонецПроцедуры

&НаСервере
Функция ОбработатьПроверкуЗапросаНаСервере(UUIDСессии) Экспорт
	ОбработкаОбъект = РеквизитФормыВЗначение("Объект");
	
	ОтветСессии = ОбработкаОбъект.ПроверитьСессию(UUIDСессии);
	Если Не ОтветСессии.Успех Или Не ОтветСессии.Свойство("Данные") Или ТипЗнч(ОтветСессии.Данные) <> Тип("Структура") Тогда
		Возврат Новый Структура("Успех, ВыполненаПроверка, Ошибка", Ложь, Ложь, ОтветСессии.Ошибка);
	КонецЕсли;
	
	Если Не ОтветСессии.Данные.Свойство("need_check")
		Или Не ОтветСессии.Данные.need_check Тогда
		Возврат Новый Структура("Успех, ВыполненаПроверка, Ошибка", Истина, Ложь, "");
	КонецЕсли;
	
	СсылкаКонфигурации = "";
	Если ОтветСессии.Данные.Свойство("configuration_ref")
		И ЗначениеЗаполнено(ОтветСессии.Данные.configuration_ref) Тогда
		СсылкаКонфигурации = Строка(ОтветСессии.Данные.configuration_ref);
	КонецЕсли;
	
	Если Не ЗначениеЗаполнено(СсылкаКонфигурации) Тогда
		Возврат Новый Структура("Успех, ВыполненаПроверка, Ошибка", Ложь, Ложь, "Не найдена ссылка конфигурации для проверки запроса.");
	КонецЕсли;
	
	ОтветПроверки = ОбработкаОбъект.ПолучитьОжидающуюПроверкуЗапроса(СсылкаКонфигурации);
	Если Не ОтветПроверки.Успех Тогда
		Возврат Новый Структура("Успех, ВыполненаПроверка, Ошибка", Ложь, Ложь, ОтветПроверки.Ошибка);
	КонецЕсли;
	
	Если Не ОтветПроверки.Свойство("Проверка")
		Или ОтветПроверки.Проверка = Неопределено Тогда
		Возврат Новый Структура("Успех, ВыполненаПроверка, Ошибка", Истина, Ложь, "");
	КонецЕсли;
	
	Проверка = ОтветПроверки.Проверка;
	Если Не Проверка.Свойство("id")
		Или Не ЗначениеЗаполнено(Проверка.id) Тогда
		Возврат Новый Структура("Успех, ВыполненаПроверка, Ошибка", Ложь, Ложь, "Не найден идентификатор проверки запроса.");
	КонецЕсли;
	
	ТекстЗапросаДляПроверки = "";
	Если Проверка.Свойство("query_text")
		И ЗначениеЗаполнено(Проверка.query_text) Тогда
		ТекстЗапросаДляПроверки = Строка(Проверка.query_text);
	КонецЕсли;
	
	Если Не ЗначениеЗаполнено(ТекстЗапросаДляПроверки) Тогда
		Возврат Новый Структура("Успех, ВыполненаПроверка, Ошибка", Ложь, Ложь, "Получена пустая проверка запроса.");
	КонецЕсли;
	
	РезультатВыполнения = ОбработкаОбъект.ВыполнитьЗапросДляПроверки(ТекстЗапросаДляПроверки);
	
	ТекстОшибкиЗаписи = "";
	Если ТипЗнч(РезультатВыполнения) = Тип("Структура")
		И РезультатВыполнения.Свойство("is_error")
		И РезультатВыполнения.is_error
		И РезультатВыполнения.Свойство("check_error")
		И ЗначениеЗаполнено(РезультатВыполнения.check_error) Тогда
		ТекстОшибкиЗаписи = Строка(РезультатВыполнения.check_error);
	КонецЕсли;
	
	ОтветФиксации = ОбработкаОбъект.ЗавершитьПроверкуЗапроса(Проверка.id, ТекстОшибкиЗаписи);
	Если Не ОтветФиксации.Успех Тогда
		Возврат Новый Структура("Успех, ВыполненаПроверка, Ошибка", Ложь, Ложь, ОтветФиксации.Ошибка);
	КонецЕсли;
	
	Возврат Новый Структура("Успех, ВыполненаПроверка, Ошибка", Истина, Истина, "");
КонецФункции

////////////////////////////////////////////////////////////////////////////////
// AL: История изменений кода (CodeConsoleVersion)

&НаКлиенте
Процедура ЗагрузитьИсториюИзмененийНаКлиенте(ПоказатьПервуюСтроку = Истина) Экспорт
	
	РезультатИстории = ПолучитьИсториюИзмененийНаСервере();
	Если РезультатИстории = Неопределено Тогда
		Возврат;
	КонецЕсли;
	
	ИсторияИзменений.Очистить();

	Если Не РезультатИстории.Успех Тогда
		ТекущийDiff = СформироватьHTMLДляDiff("", "Ошибка загрузки истории изменений: " + РезультатИстории.Ошибка);
		Возврат;
	КонецЕсли;
	
	Версии = РезультатИстории.Данные;
	Для Каждого Версия Из Версии Цикл
		СтрокаИстории = ИсторияИзменений.Добавить();
		
		ДатаИзменения = ТекущаяДата();
		Если Версия.Свойство("changed_at") И ЗначениеЗаполнено(Версия.changed_at) Тогда
			Попытка
				ДатаИзменения = ПрочитатьДатуJSON(Версия.changed_at, ФорматДатыJSON.ISO);
			Исключение
			КонецПопытки;
		КонецЕсли;
		СтрокаИстории.Дата = ДатаИзменения;
		
		КтоИзменил = "";
		Если Версия.Свойство("author_display") И ЗначениеЗаполнено(Версия.author_display) Тогда
			КтоИзменил = Версия.author_display;
		ИначеЕсли Версия.Свойство("author") И ЗначениеЗаполнено(Версия.author) Тогда
			Если НРег(Версия.author) = "agent" Тогда
				КтоИзменил = "Агент";
			Иначе
				КтоИзменил = "Пользователь";
			КонецЕсли;
		КонецЕсли;
		СтрокаИстории.КтоИзменил = КтоИзменил;
		
		Описание = "";
		Если Версия.Свойство("description") И ЗначениеЗаполнено(Версия.description) Тогда
			Описание = Версия.description;
		Иначе
			Описание = "Без описания";
		КонецЕсли;
		СтрокаИстории.Описание = Описание;
		
		Если Версия.Свойство("uuid") Тогда
			СтрокаИстории.UUIDВерсии = Строка(Версия.uuid);
		Иначе
			СтрокаИстории.UUIDВерсии = "";
		КонецЕсли;
	КонецЦикла;
	
	Если ИсторияИзменений.Количество() = 0 Тогда
		ТекущийDiff = СформироватьHTMLДляDiff("", "История изменений пока пуста.");
		Возврат;
	КонецЕсли;
	
	Если ПоказатьПервуюСтроку Тогда
		ПоказатьDiffПоUUIDНаКлиенте(ИсторияИзменений[0].UUIDВерсии);
	КонецЕсли;
	
КонецПроцедуры

&НаКлиенте
Процедура ИсторияИзмененийПриАктивизацииСтроки(Элемент)
	
	Если Элемент = Неопределено Или Элемент.ТекущиеДанные = Неопределено Тогда
		Возврат;
	КонецЕсли;
	
	UUIDВерсии = "";
	ТекущаяСтрока = Элемент.ТекущиеДанные;
	Если ТекущаяСтрока.Свойство("UUIDВерсии") Тогда
		UUIDВерсии = ТекущаяСтрока.UUIDВерсии;
	КонецЕсли;
	
	ПоказатьDiffПоUUIDНаКлиенте(UUIDВерсии);
	
КонецПроцедуры

&НаКлиенте
Процедура ПоказатьDiffПоUUIDНаКлиенте(UUIDВерсии)
	
	Если Не ЗначениеЗаполнено(UUIDВерсии) Тогда
		ТекущийDiff = СформироватьHTMLДляDiff("", "Для выбранной строки не найден UUID версии.");
		Возврат;
	КонецЕсли;
	
	РезультатВерсии = ПолучитьВерсиюИзмененияНаСервере(UUIDВерсии);
	Если РезультатВерсии = Неопределено Или Не РезультатВерсии.Успех Тогда
		Ошибка = "";
		Если РезультатВерсии <> Неопределено И РезультатВерсии.Свойство("Ошибка") Тогда
			Ошибка = РезультатВерсии.Ошибка;
		КонецЕсли;
		ТекущийDiff = СформироватьHTMLДляDiff("", "Ошибка загрузки diff: " + Ошибка);
		Возврат;
	КонецЕсли;
	
	ТекстDiff = "";
	Если РезультатВерсии.Данные <> Неопределено
		И РезультатВерсии.Данные.Свойство("diff")
		И ЗначениеЗаполнено(РезультатВерсии.Данные.diff) Тогда
		ТекстDiff = РезультатВерсии.Данные.diff;
	КонецЕсли;
	
	ТекущийDiff = СформироватьHTMLДляDiff(ТекстDiff);
	
КонецПроцедуры

&НаСервере
Функция ПолучитьИсториюИзмененийНаСервере() Экспорт
	
	ОбработкаОбъект = РеквизитФормыВЗначение("Объект");
	Если Не ЗначениеЗаполнено(ОбработкаОбъект.UUIDСессии) Тогда
		Возврат Новый Структура("Успех, Ошибка, Данные", Ложь, "Сессия не создана", Новый Массив);
	КонецЕсли;
	
	СтруктураОтвета = ОбработкаОбъект.ПолучитьИсториюВерсийСессии(Строка(ОбработкаОбъект.UUIDСессии));
	Если Не СтруктураОтвета.Успех Тогда
		Возврат Новый Структура("Успех, Ошибка, Данные", Ложь, СтруктураОтвета.Ошибка, Новый Массив);
	КонецЕсли;
	
	Версии = Новый Массив;
	Если СтруктураОтвета.Свойство("Данные") И СтруктураОтвета.Данные <> Неопределено Тогда
		Если ТипЗнч(СтруктураОтвета.Данные) = Тип("Структура")
			И СтруктураОтвета.Данные.Свойство("results")
			И ТипЗнч(СтруктураОтвета.Данные.results) = Тип("Массив") Тогда
			Версии = СтруктураОтвета.Данные.results;
		ИначеЕсли ТипЗнч(СтруктураОтвета.Данные) = Тип("Массив") Тогда
			Версии = СтруктураОтвета.Данные;
		КонецЕсли;
	КонецЕсли;
	
	Возврат Новый Структура("Успех, Ошибка, Данные", Истина, "", Версии);
	
КонецФункции

&НаСервере
Функция ПолучитьВерсиюИзмененияНаСервере(UUIDВерсии) Экспорт
	
	ОбработкаОбъект = РеквизитФормыВЗначение("Объект");
	Если Не ЗначениеЗаполнено(ОбработкаОбъект.UUIDСессии) Тогда
		Возврат Новый Структура("Успех, Ошибка, Данные", Ложь, "Сессия не создана", Неопределено);
	КонецЕсли;
	
	СтруктураОтвета = ОбработкаОбъект.ПолучитьВерсиюСессии(Строка(ОбработкаОбъект.UUIDСессии), Строка(UUIDВерсии));
	Если Не СтруктураОтвета.Успех Тогда
		Возврат Новый Структура("Успех, Ошибка, Данные", Ложь, СтруктураОтвета.Ошибка, Неопределено);
	КонецЕсли;
	
	Возврат Новый Структура("Успех, Ошибка, Данные", Истина, "", СтруктураОтвета.Данные);
	
КонецФункции

&НаКлиенте
Функция НормализоватьUnifiedDiff(ТекстDiff)
	
	Если Не ЗначениеЗаполнено(ТекстDiff) Тогда
		Возврат "";
	КонецЕсли;
	
	НормализованныйDiff = ТекстDiff;
	НормализованныйDiff = СтрЗаменить(НормализованныйDiff, Символы.ВК + Символы.ПС, Символы.ПС);
	НормализованныйDiff = СтрЗаменить(НормализованныйDiff, Символы.ВК, Символы.ПС);
	
	ЕстьЗаголовокFrom = СтрНайти(НормализованныйDiff, "--- ");
	ЕстьЗаголовокTo = СтрНайти(НормализованныйDiff, "+++ ");
	Если ЕстьЗаголовокFrom > 0 И ЕстьЗаголовокTo > 0 Тогда
		Возврат НормализованныйDiff;
	КонецЕсли;
	
	Возврат "--- previous" + Символы.ПС
		+ "+++ current" + Символы.ПС
		+ "@@ -1,1 +1,1 @@" + Символы.ПС
		+ НормализованныйDiff;
	
КонецФункции

&НаКлиенте
Функция ЭкранироватьСтрокуДляJS(Текст)
	
	Результат = Строка(Текст);
	Результат = СтрЗаменить(Результат, "\", "\\");
	Результат = СтрЗаменить(Результат, "'", "\'");
	Результат = СтрЗаменить(Результат, Символы.ВК + Символы.ПС, "\n");
	Результат = СтрЗаменить(Результат, Символы.ПС, "\n");
	Результат = СтрЗаменить(Результат, Символы.ВК, "\n");
	Возврат Результат;
	
КонецФункции

&НаКлиенте
Функция ЭкранироватьHTMLТекст(Текст)
	
	Результат = Строка(Текст);
	Результат = СтрЗаменить(Результат, "&", "&amp;");
	Результат = СтрЗаменить(Результат, "<", "&lt;");
	Результат = СтрЗаменить(Результат, ">", "&gt;");
	Результат = СтрЗаменить(Результат, """", "&quot;");
	Возврат Результат;
	
КонецФункции

&НаКлиенте
Функция СформироватьHTMLДляDiff(ТекстDiff, Сообщение = "") Экспорт
	
	СообщениеДляПоказа = Сообщение;
	Если Не ЗначениеЗаполнено(СообщениеДляПоказа) Тогда
		Если ЗначениеЗаполнено(ТекстDiff) Тогда
			СообщениеДляПоказа = "";
		Иначе
			СообщениеДляПоказа = "Выберите изменение слева для просмотра diff.";
		КонецЕсли;
	КонецЕсли;
	
	НормализованныйDiff = НормализоватьUnifiedDiff(ТекстDiff);
	БезопасныйDiffJS = ЭкранироватьСтрокуДляJS(НормализованныйDiff);
	БезопасныйСообщение = ЭкранироватьHTMLТекст(СообщениеДляПоказа);
	
	HTMLDiff = "<!DOCTYPE html><html><head>" 
		+ "<meta charset='utf-8'>"
		+ "<link rel='stylesheet' href='https://cdn.jsdelivr.net/npm/diff2html@3.4.47/bundles/css/diff2html.min.css'>"
		+ "<style>"
		+ " body{margin:0;padding:10px;background:#0f172a;color:#e2e8f0;font-family:Segoe UI,Arial,sans-serif;}"
		+ " #empty{color:#94a3b8;font-size:12px;padding:8px;}"
		+ " #diff{border:1px solid rgba(148,163,184,.2);border-radius:10px;overflow:auto;background:rgba(2,6,23,.55);}"
		+ " .d2h-file-header,.d2h-code-linenumber,.d2h-code-side-linenumber{background:rgba(15,23,42,.88)!important;color:#94a3b8!important;}"
		+ " .d2h-code-line,.d2h-code-line-ctn{color:#e2e8f0!important;}"
		+ " td.d2h-cntx{background:rgba(15,23,42,.78)!important;}"
		+ " td.d2h-del{background:rgba(239,68,68,.2)!important;}"
		+ " td.d2h-ins{background:rgba(34,197,94,.22)!important;}"
		+ " td.d2h-info{background:rgba(30,41,59,.95)!important;color:#cbd5e1!important;}"
		+ " td.d2h-del .d2h-code-line-prefix,td.d2h-del .d2h-code-line-ctn,td.d2h-del del{color:#fcc4c4!important;background:transparent!important;}"
		+ " td.d2h-ins .d2h-code-line-prefix,td.d2h-ins .d2h-code-line-ctn,td.d2h-ins ins{color:#bbf7d0!important;background:transparent!important;}"
		+ "</style>"
		+ "</head><body>"
		+ "<div id='empty'>" + БезопасныйСообщение + "</div>"
		+ "<div id='diff'></div>"
		+ "<script src='https://cdn.jsdelivr.net/npm/diff2html@3.4.47/bundles/js/diff2html.min.js'></script>"
		+ "<script>"
		+ " (function(){"
		+ "   var diff = '" + БезопасныйDiffJS + "';"
		+ "   var empty = document.getElementById('empty');"
		+ "   var box = document.getElementById('diff');"
		+ "   if(!diff){ box.innerHTML=''; return; }"
		+ "   try {"
		+ "     if (typeof Diff2Html !== 'undefined' && typeof Diff2Html.html === 'function') {"
		+ "       empty.style.display = 'none';"
		+ "       box.innerHTML = Diff2Html.html(diff, {drawFileList:false, matching:'lines', outputFormat:'line-by-line'});"
		+ "     } else {"
		+ "       box.innerHTML = '<pre style=""margin:0;padding:10px;white-space:pre-wrap;color:#e2e8f0;"">' + diff + '</pre>';"
		+ "     }"
		+ "   } catch(e) {"
		+ "     box.innerHTML = '<pre style=""margin:0;padding:10px;white-space:pre-wrap;color:#e2e8f0;"">' + diff + '</pre>';"
		+ "   }"
		+ " })();"
		+ "</script>"
		+ "</body></html>";
	
	Возврат HTMLDiff;
	
КонецФункции

////////////////////////////////////////////////////////////////////////////////
// AL: Управление пулингом чата (без фонового опроса)

&НаКлиенте
Процедура ЗапуститьПулингЧата(ИнтервалСек = 2)
	
	Если ИнтервалСек <= 0 Тогда
		ИнтервалСек = 2;
	КонецЕсли;
	
	ИнтервалПулингаЧатаСек = ИнтервалСек;
	
	// На всякий случай снимаем старый обработчик, чтобы не было дублей
	Попытка
		ОтключитьОбработчикОжидания("ИсторияСессииНаКлиенте");
	Исключение
	КонецПопытки;
	
	ПодключитьОбработчикОжидания("ИсторияСессииНаКлиенте", ИнтервалПулингаЧатаСек);
	ПулингЧатаАктивен = Истина;
	
КонецПроцедуры

&НаКлиенте
Процедура ОстановитьПулингЧата()
	
	Попытка
