# Конфигурация профиля your_project
# Переименуйте папку и файл под свой проект (например: Vector/Vector.env)
# Для переопределения путей на другой машине создайте your_project.env.local (см. PORTABILITY.md)

# === ОБЯЗАТЕЛЬНЫЕ ПАРАМЕТРЫ ===
# Путь к выгрузке конфигурации 1С (корень, где лежит Configuration.xml)
CONFIG_PATH=C:\path\to\your\1c\config

# === ЭМБЕДДИНГИ ===
# Вариант 1: Удалённый API (LM Studio, LocalAI, OpenAI-совместимый)
# EMBEDDING_API_BASE=http://your-host:port/v1
# EMBEDDING_MODEL=your-embedding-model-name
# EMBEDDING_DIMENSION определяется автоматически по имени модели.
# Явно задавайте, только если модель не распознана (см. KNOWN_MODELS в config.py).
# EMBEDDING_DIMENSION=768

# Вариант 2: Локальная модель (sentence-transformers)
# EMBEDDING_API_BASE=
# EMBEDDING_MODEL=your-embedding-model-name

# Qwen3 через LM Studio / GGUF:
# llama.cpp уже добавляет EOS автоматически на уровне токенизатора.
# Если true — получится двойной EOS ("Added a EOS token... 2 EOS tokens").
# Предупреждение "add_eos_token should be true" — косметическое, на качество не влияет.
# Оставьте false (или не задавайте). Подробнее: MODEL_CONFIGURATION_RECOMMENDATIONS.md, раздел 5.
# EMBEDDING_ADD_EOS_MANUAL=false

# === ОПЦИОНАЛЬНЫЕ ===
# VECTORDB_PATH по умолчанию: projects/your_project/vectordb
# GRAPHDB_PATH по умолчанию: projects/your_project/graphdb/graph.db
#
# Чанки и контекст (см. MODEL_CONFIGURATION_RECOMMENDATIONS.md):
# - nomic-embed-text-v2-moe / MiniLM (512 токенов): EMBEDDING_MAX_TOKENS=512, CHUNK_MAX_TOKENS=512
# - nomic-embed-text-v1 (8192 токенов): EMBEDDING_MAX_TOKENS=1024, CHUNK_MAX_TOKENS=1024
# Коэффициент 2.0 симв/токен для BSL. Если задан EMBEDDING_MAX_TOKENS — EMBEDDING_MAX_CHARS = tokens * 2.0
# EMBEDDING_MAX_TOKENS=512
# CHUNK_MAX_TOKENS=512
# CHUNK_OVERLAP_TOKENS=100
# Альтернатива: задать EMBEDDING_MAX_CHARS напрямую (512 токенов ≈ 1024 символов)
EMBEDDING_MAX_CHARS=1024
DEFAULT_SEARCH_LIMIT=5
MAX_SEARCH_LIMIT=20

# Поиск: метрика расстояния (cosine|l2|ip), гибрид вектор+BM25, MMR
# По умолчанию: гибрид вектор+BM25 (alpha=0.7) + MMR (lambda=0.7) — включены автоматически.
# Настройки ниже переопределяют дефолты при необходимости.
# VECTOR_DISTANCE_METRIC=cosine
# HYBRID_SEARCH_ALPHA=0.7
# SEARCH_USE_MMR=true
# MMR_LAMBDA=0.7
# SEARCH_FETCH_K=50

LOG_LEVEL=INFO
