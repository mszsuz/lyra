	Возврат ЭтотОбъект; //*-+ Возврат ЕХТ_Чат;

КонецФункции

&НаСервере
Процедура ЕХТ_Чат_Инициализация(Форма, Знач Параметры) Экспорт

	Если ТипЗнч(Форма) <> ЕХТ_Тип.УправляемаяФорма() Тогда
		ВызватьИсключение ЕХТ_Лог.ТекстИсключенияНедопустимыйПараметр(ПолноеИмя(), "Инициализация",
			"Форма", Форма);
	КонецЕсли;
	Если ТипЗнч(Параметры) <> Тип("Структура") Тогда
		ВызватьИсключение ЕХТ_Лог.ТекстИсключенияНедопустимыйПараметр(ПолноеИмя(), "Инициализация",
			"Параметры", Параметры);
	КонецЕсли;
	ЗначенияПараметров = ЕХТ_Свойства.вСтруктуру(Параметры, "Элемент, ДвоичныеДанныеПриложения");

	ДвоичныеДанныеПриложения = ЗначенияПараметров.ДвоичныеДанныеПриложения;
	ДвоичныеДанныеПриложенияТип = ТипЗнч(ДвоичныеДанныеПриложения);
	ОжидаемыеТипы = ЕХТ_Тип.ОжидаемыеТипы("Неопределено, ДвоичныеДанные");
	Если ДвоичныеДанныеПриложенияТип = ОжидаемыеТипы.ДвоичныеДанные Тогда
		// Действие не требуется.
	ИначеЕсли ДвоичныеДанныеПриложенияТип = ОжидаемыеТипы.Неопределено Тогда
		ДвоичныеДанныеПриложения = ПолучитьОбщийМакет("ЕХТ_Чат_ДвоичныеДанныеПриложения");
	Иначе
		ВызватьИсключение ЕХТ_Лог.ТекстИсключенияНедопустимыйПараметр(ПолноеИмя(), "Инициализация",
			"Параметры.ДвоичныеДанныеПриложения", ДвоичныеДанныеПриложения, ОжидаемыеТипы);
	КонецЕсли;

	Элемент = ЗначенияПараметров.Элемент;
	ОжидаемыеТипы = ЕХТ_Тип.ОжидаемыеТипы("ПолеФормы, Массив");
	ЭлементыТип = ТипЗнч(Элемент);
	Если ЭлементыТип = ОжидаемыеТипы.ПолеФормы Тогда
		МассивЭлементов = ЕХТ.Массив(Элемент);
	ИначеЕсли ЭлементыТип = ОжидаемыеТипы.Массив Тогда
		МассивЭлементов = Элемент;
	Иначе
		ВызватьИсключение ЕХТ_Лог.ТекстИсключенияНедопустимыйПараметр(ПолноеИмя(), "Инициализация",
			"Параметры.Элемент", Элемент, ОжидаемыеТипы);
	КонецЕсли;

	Для Каждого Элемент Из МассивЭлементов Цикл
		ЕХТ_Чат_УстановитьЭлемент(Форма, Элемент, ДвоичныеДанныеПриложения);
	КонецЦикла;

	Форма.УстановитьДействие("ОбработкаОповещения", "Подключаемый_ОбработкаОповещения");

КонецПроцедуры

#КонецОбласти

#Область Клиент

&НаКлиенте
Процедура ЕХТ_Чат_СобытиеПриНажатии(Знач Элемент, Знач ДанныеСобытия, СтандартнаяОбработка) Экспорт

	ВнешнийОбъект = ДанныеСобытия["Element"];
	Если ВнешнийОбъект["id"] <> "V8WebAppEventRequestForwarder" Тогда
		Возврат;
	КонецЕсли;

	СтандартнаяОбработка = Ложь;

	Форма = ЕХТ_ЭлементФормы.Форма(Элемент);

	СобытиеПриложения = ЕХТ.Структура(
		"Элемент", 		Элемент,
		"ИмяСобытия", 	ВнешнийОбъект.getAttribute("v8eventname"),
		"ИД", 			ВнешнийОбъект.getAttribute("v8uuid"),
		"Значение", 	"");

	ТипДанных = ВнешнийОбъект.getAttribute("v8type");
	Если ТипДанных = "json" Или ТипДанных = "string" Тогда

		СобытиеПриложения.Значение = ЕХТ_Значение.ИзJSON(ВнешнийОбъект["value"]);

	КонецЕсли;

	Если СобытиеПриложения.ИмяСобытия = "GetFormAttribute" Тогда

		Ответ1С = Форма[СобытиеПриложения.Значение];
		ЕХТ_Чат_ОбработатьОтвет1С(Элемент, СобытиеПриложения, Ответ1С);

	КонецЕсли;

	Если СобытиеПриложения.ИмяСобытия = "SetFormAttribute" Тогда

		Форма[СобытиеПриложения.Значение["key"]] = СобытиеПриложения.Значение["value"];
		ЕХТ_Чат_ОбработатьОтвет1С(Элемент, СобытиеПриложения);

	КонецЕсли;

	Если СобытиеПриложения.ИмяСобытия = "LoadMessages"
	 ИЛИ СобытиеПриложения.ИмяСобытия = "GetMessages" Тогда

	 	Настройки = ЕХТ_Чат_НастройкиПоУмолчанию();
	 	Ответ1С = Форма.ЕХТ_Чат_ПриОткрытии(Элемент, Настройки);
		ЕХТ_Чат_ОбработатьОтвет1С(Элемент, СобытиеПриложения, Ответ1С);

	КонецЕсли;

	Если СобытиеПриложения.ИмяСобытия = "AddMessage" Тогда

		Ответ1С = Форма.ЕХТ_Чат_ПриДобавленииСообщения(Элемент);
		ЕХТ_Чат_ОбработатьОтвет1С(Элемент, СобытиеПриложения, Ответ1С);

	КонецЕсли;

	Если СобытиеПриложения.ИмяСобытия = "OpenLink" Тогда

		АдресСсылки = СобытиеПриложения.Значение.URL;
		Ответ1С = Форма.ЕХТ_Чат_ПриНажатииСсылки(Элемент, АдресСсылки);
		ЕХТ_Чат_ОбработатьОтвет1С(Элемент, СобытиеПриложения, Ответ1С);

	КонецЕсли;

КонецПроцедуры

&НаКлиенте
Процедура ЕХТ_Чат_ОбработатьОтвет1С(Знач Элемент, Знач СобытиеПриложения, Знач Ответ1С = Неопределено) Экспорт

	СериализованныйОтвет1С = "";

	Если ЗначениеЗаполнено(Ответ1С) Тогда

		ОтветТип = ТипЗнч(Ответ1С);
		Если ЕХТ_Тип.ЭтоЛюбаяКоллекция(ОтветТип) Тогда
			СериализованныйОтвет1С = ЕХТ_Значение.вJSON(Ответ1С);

		ИначеЕсли ОтветТип = Тип("ДвоичныеДанные") Тогда
			СериализованныйОтвет1С = Base64Строка(Ответ1С);

		Иначе
			СериализованныйОтвет1С = ЕХТ_Значение.вXML(Ответ1С);
		КонецЕсли;
	КонецЕсли;

	Приложение(Элемент).V8Proxy.sendResponse(СобытиеПриложения.ИД, СериализованныйОтвет1С);

КонецПроцедуры

&НаКлиенте
Функция ЕХТ_Чат_ПолучитьНастройки(Элемент) Экспорт

	НастройкиJSON = Приложение(Элемент).getSettings();

	Возврат ЕХТ_Значение.ИзJSON(НастройкиJSON);

КонецФункции

&НаКлиенте
Процедура ЕХТ_Чат_УстановитьНастройки(Элемент, Настройки) Экспорт

	НастройкиJSON = ЕХТ_Значение.вJSON(Настройки);
	Приложение(Элемент).setSettings(НастройкиJSON);

КонецПроцедуры

&НаКлиенте
Процедура ЕХТ_Чат_УстановитьТему(Элемент, Знач НоваяТема) Экспорт

	Настройки = ЕХТ_Чат_ПолучитьНастройки(Элемент);

	Если НоваяТема.Свойство("Оформление") Тогда
		Настройки.Вставить("Оформление", НоваяТема.Оформление);
	КонецЕсли;
	Если НоваяТема.Свойство("Надписи") Тогда
		Настройки.Вставить("Надписи", НоваяТема.Надписи);
	КонецЕсли;
	Если НоваяТема.Свойство("Код") Тогда
		Настройки.Вставить("Код", НоваяТема.Код);
	КонецЕсли;

	НовыеШаблоны = ЕХТ_Структура.Получить(НоваяТема, "Сообщения.Шаблоны");
	Если НовыеШаблоны <> Неопределено Тогда

		Для Каждого Шаблон Из Настройки.Сообщения.Шаблоны Цикл

			НовыеЗначения = ЕХТ_Свойства.Значение(НовыеШаблоны, Шаблон.Ключ);
			Если НовыеЗначения = Неопределено Тогда
				Продолжить;
			КонецЕсли;

			НовыеЗначения = ЕХТ_Свойства.вСтруктуру(НовыеЗначения, "ЦветТекста, ЦветФона");
			Если НовыеЗначения.ЦветТекста <> Неопределено Тогда
				Шаблон.Значение.ЦветТекста = НовыеЗначения.ЦветТекста;
			КонецЕсли;
			Если НовыеЗначения.ЦветФона <> Неопределено Тогда
				Шаблон.Значение.ЦветФона = НовыеЗначения.ЦветФона;
			КонецЕсли;
		КонецЦикла;

	КонецЕсли;

	ЕХТ_Чат_УстановитьНастройки(Элемент, Настройки);

КонецПроцедуры

&НаКлиенте
