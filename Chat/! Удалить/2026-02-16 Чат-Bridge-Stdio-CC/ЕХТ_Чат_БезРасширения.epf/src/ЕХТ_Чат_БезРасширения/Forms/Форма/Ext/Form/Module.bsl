&НаКлиенте
Процедура WS_ПриПолученииСообщения(Соединение, Сообщение) Экспорт

	// ВАЖНО: НЕ использовать имя ТекстСообщения — это реквизит формы!
	// ДобавитьСообщениеВЧат() обнуляет ЭтотОбъект.ТекстСообщения, и если
	// локальная переменная совпадает с именем реквизита — она тоже обнулится.
	ТипСообщенияWS = ТипЗнч(Сообщение);
	ПолученныйТекст = "";
	Если ТипСообщенияWS = Тип("Строка") Тогда
		ПолученныйТекст = Сообщение;
	ИначеЕсли ТипСообщенияWS = Тип("ДвоичныеДанные") Тогда
		ПолученныйТекст = ПолучитьСтрокуИзДвоичныхДанных(Сообщение);
	Иначе
		ДобавитьСообщениеВЧат("WS: неизвестный тип: " + Строка(ТипСообщенияWS), "Предупреждение");
		Возврат;
	КонецЕсли;

	// Bridge в режиме ndjson собирает NDJSON до "type":"result" и отправляет блоком.
	ОбработатьОтветBridge(Соединение, ПолученныйТекст);

КонецПроцедуры

#КонецОбласти

#Область ОбработкаОтветовClaude

// Обработка блока NDJSON от bridge.
// Claude Code в stream-json выдаёт строки вида:
//   {"type":"system",...}                      — системная информация (пропускаем)
//   {"type":"assistant","message":{"content":[{"type":"text","text":"..."}]}}
//   {"type":"result",...}                      — финал (пропускаем)
//
// ВАЖНО: ЕХТ_Значение.ИзJSON() парсит в Структуру, а ключи с дефисами
// (claude-sonnet-4-20250514) недопустимы для имён свойств Структуры.
// Поэтому используем строковый парсинг — ищем нужные фрагменты через СтрНайти.
//
&НаКлиенте
Процедура ОбработатьОтветBridge(Соединение, БлокNDJSON)

	СобранныйТекст = "";

	// Разбираем построчно через ручной LF-сплит (Символы.ПС и Символ() ненадёжны в веб-клиенте)
	Строки = РазделитьПоLF(БлокNDJSON);

	Для Каждого ТекущаяСтрока Из Строки Цикл

		ТекущаяСтрока = СокрЛП(ТекущаяСтрока);
		Если ПустаяСтрока(ТекущаяСтрока) Тогда
			Продолжить;
		КонецЕсли;

		// Определяем тип строки через строковый поиск
		ТипСобытия = ИзвлечьЗначениеJSON(ТекущаяСтрока, "type");

		Если ТипСобытия = "assistant" Тогда
			// Сообщение ассистента — извлекаем текст
			ТекстОтвета = ИзвлечьТекстИзAssistant(ТекущаяСтрока);
			Если НЕ ПустаяСтрока(ТекстОтвета) Тогда
				СобранныйТекст = СобранныйТекст + ТекстОтвета;
			КонецЕсли;

		// system и result — пропускаем, они нам не нужны
		КонецЕсли;

	КонецЦикла;

	// Добавляем собранный текст в чат
	Если НЕ ПустаяСтрока(СобранныйТекст) Тогда
		ДобавитьСообщениеВЧат(СобранныйТекст);
	КонецЕсли;

КонецПроцедуры

// Извлекает значение строкового поля из JSON через строковый поиск.
// Пример: ИзвлечьЗначениеJSON('{"type":"assistant",...}', "type") → "assistant"
//
&НаКлиенте
Функция ИзвлечьЗначениеJSON(СтрокаJSON, ИмяПоля)

	// Ищем "имяПоля":"значение" или "имяПоля": "значение"
	Маркер = """" + ИмяПоля + """:""";
	Позиция = СтрНайти(СтрокаJSON, Маркер);
	Если Позиция = 0 Тогда
		// Попробуем с пробелом после двоеточия: "имяПоля": "значение"
		Маркер = """" + ИмяПоля + """: """;
		Позиция = СтрНайти(СтрокаJSON, Маркер);
		Если Позиция = 0 Тогда
			Возврат "";
		КонецЕсли;
	КонецЕсли;

	// Начало значения — сразу после маркера
	НачалоЗначения = Позиция + СтрДлина(Маркер);

	// Ищем закрывающую кавычку
	КонецЗначения = СтрНайти(СтрокаJSON, """", , НачалоЗначения);
	Если КонецЗначения = 0 Тогда
		Возврат "";
	КонецЕсли;

	Возврат Сред(СтрокаJSON, НачалоЗначения, КонецЗначения - НачалоЗначения);

КонецФункции

// Извлекает текст ответа Claude из строки assistant.
// JSON: {"type":"assistant","message":{"content":[{"type":"text","text":"Привет!"}]}}
// Ищем "type":"text","text":"..." и извлекаем значение text.
// Обрабатываем JSON-экранирование: \\, \", \n, \t
//
&НаКлиенте
Функция ИзвлечьТекстИзAssistant(СтрокаJSON)

	// Ищем маркер текстового блока
	МаркерТекста = """type"":""text"",""text"":""";
	Позиция = СтрНайти(СтрокаJSON, МаркерТекста);
	Если Позиция = 0 Тогда
		// Пробуем с пробелами
		МаркерТекста = """type"": ""text"", ""text"": """;
		Позиция = СтрНайти(СтрокаJSON, МаркерТекста);
		Если Позиция = 0 Тогда
			Возврат "";
		КонецЕсли;
	КонецЕсли;

	НачалоТекста = Позиция + СтрДлина(МаркерТекста);

	// Ищем конец строки — закрывающую кавычку, не экранированную бэкслэшем
	ТекущаяПозиция = НачалоТекста;
	ДлинаJSON = СтрДлина(СтрокаJSON);
	Пока ТекущаяПозиция <= ДлинаJSON Цикл
		Символ = Сред(СтрокаJSON, ТекущаяПозиция, 1);
		Если Символ = "\" Тогда
			// Экранированный символ — пропускаем следующий
			ТекущаяПозиция = ТекущаяПозиция + 2;
		ИначеЕсли Символ = """" Тогда
			// Нашли закрывающую кавычку
			Прервать;
		Иначе
			ТекущаяПозиция = ТекущаяПозиция + 1;
		КонецЕсли;
	КонецЦикла;

	Если ТекущаяПозиция > ДлинаJSON Тогда
		Возврат "";
	КонецЕсли;

	// Извлекаем сырой текст
	СыройТекст = Сред(СтрокаJSON, НачалоТекста, ТекущаяПозиция - НачалоТекста);

	// Декодируем JSON-экранирование
	// Порядок важен: сначала \\ → \, потом остальное
	СыройТекст = СтрЗаменить(СыройТекст, "\\", Символы.Таб + "SLASH");
	СыройТекст = СтрЗаменить(СыройТекст, "\n", Символы.ПС);
	СыройТекст = СтрЗаменить(СыройТекст, "\t", Символы.Таб);
	СыройТекст = СтрЗаменить(СыройТекст, "\""", """");
	СыройТекст = СтрЗаменить(СыройТекст, Символы.Таб + "SLASH", "\");

	Возврат СыройТекст;

КонецФункции

// Обработка команды (tool_use) от Claude Code.
// Claude отправляет tool_use когда хочет данные из 1С.
//
&НаКлиенте
Процедура ОбработатьКомандуClaude(Соединение, БлокКоманды)

	ИмяИнструмента = БлокКоманды.Получить("name");
	ИДИнструмента = БлокКоманды.Получить("id");
	Ввод = БлокКоманды.Получить("input");
	Если Ввод = Неопределено Тогда
		Ввод = Новый Соответствие;
	КонецЕсли;

	// Выполняем команду
	Попытка
		Если ИмяИнструмента = "execute_query" ИЛИ ИмяИнструмента = "1c_query" Тогда
			Результат = ВыполнитьЗапросНаСервере(Ввод);

		ИначеЕсли ИмяИнструмента = "get_metadata" ИЛИ ИмяИнструмента = "1c_metadata" Тогда
			Результат = ПолучитьМетаданныеНаСервере(Ввод);

		ИначеЕсли ИмяИнструмента = "eval" ИЛИ ИмяИнструмента = "1c_eval" Тогда
			Результат = ВычислитьНаСервере(Ввод);

		Иначе
			Результат = Новый Структура("error", "Неизвестный инструмент: " + ИмяИнструмента);
		КонецЕсли;
	Исключение
		Результат = Новый Структура("error", ОписаниеОшибки());
	КонецПопытки;

	// Отправляем результат обратно в Claude Code
	Ответ = Новый Соответствие;
	Ответ.Вставить("type", "tool_result");
	Ответ.Вставить("tool_use_id", ИДИнструмента);
	Ответ.Вставить("content", ЕХТ_Значение.вJSON(Результат));

	Соединение.ОтправитьСообщение(ЕХТ_Значение.вJSON(Ответ));

КонецПроцедуры

#КонецОбласти

#Область ОбработкаКоманд1С

&НаСервере
Функция ВыполнитьЗапросНаСервере(ПарамыЗапроса)

	ТекстЗапроса = ПолучитьПараметр(ПарамыЗапроса, "query");
	Если ТекстЗапроса = Неопределено Тогда
		Возврат Новый Структура("error", "Отсутствует параметр query");
	КонецЕсли;

	Попытка
		Запрос = Новый Запрос(ТекстЗапроса);
		Результат = Запрос.Выполнить();

		Если Результат.Пустой() Тогда
			Возврат Новый Структура("data,columns,count", Новый Массив, Новый Массив, 0);
		КонецЕсли;

		// Колонки
		Колонки = Новый Массив;
		Для Каждого Колонка Из Результат.Колонки Цикл
			Колонки.Добавить(Колонка.Имя);
		КонецЦикла;

		// Данные (макс 1000 строк)
		Данные = Новый Массив;
		Выборка = Результат.Выбрать();
		Счетчик = 0;

		Пока Выборка.Следующий() И Счетчик < 1000 Цикл
			СтрокаДанных = Новый Структура;
			Для Каждого ИмяКолонки Из Колонки Цикл
				Значение = Выборка[ИмяКолонки];
				СтрокаДанных.Вставить(ИмяКолонки, ЗначениеДляJSON(Значение));
			КонецЦикла;
			Данные.Добавить(СтрокаДанных);
			Счетчик = Счетчик + 1;
		КонецЦикла;

		Возврат Новый Структура("data,columns,count", Данные, Колонки, Данные.Количество());

	Исключение
		Возврат Новый Структура("error", "Ошибка запроса: " + ОписаниеОшибки());
	КонецПопытки;

КонецФункции

&НаСервере
Функция ПолучитьМетаданныеНаСервере(ПарамыЗапроса)

	ТипМета = ПолучитьПараметр(ПарамыЗапроса, "type");
	Если ТипМета = Неопределено Тогда ТипМета = ""; КонецЕсли;

	Результат = Новый Массив;

	Попытка
		Если ТипМета = "" ИЛИ ТипМета = "Catalogs" Тогда
			Для Каждого М Из Метаданные.Справочники Цикл
				Результат.Добавить(Новый Структура("type,name,synonym", "Справочник", М.Имя, Строка(М.Синоним)));
			КонецЦикла;
		КонецЕсли;

		Если ТипМета = "" ИЛИ ТипМета = "Documents" Тогда
			Для Каждого М Из Метаданные.Документы Цикл
				Результат.Добавить(Новый Структура("type,name,synonym", "Документ", М.Имя, Строка(М.Синоним)));
			КонецЦикла;
		КонецЕсли;

		Если ТипМета = "" ИЛИ ТипМета = "InformationRegisters" Тогда
			Для Каждого М Из Метаданные.РегистрыСведений Цикл
				Результат.Добавить(Новый Структура("type,name,synonym", "РегистрСведений", М.Имя, Строка(М.Синоним)));
			КонецЦикла;
		КонецЕсли;

		Возврат Результат;

	Исключение
		Возврат Новый Структура("error", "Ошибка метаданных: " + ОписаниеОшибки());
	КонецПопытки;

КонецФункции

