	КонецПопытки;

КонецПроцедуры

// Отправка текста пользователя в Claude Code через WS → bridge → stdin.
// Формат --input-format stream-json: {"type":"user","message":{"role":"user","content":"текст"}}
//
&НаКлиенте
Процедура ОтправитьВClaude(Текст)

	Соединение = WebSocketКлиентСоединения.ПолучитьСоединение("claude-bridge");
	Если Соединение = Неопределено Тогда
		ДобавитьСообщениеВЧат("Нет соединения с Claude Code. Нажмите ""Подключиться"".", "Предупреждение");
		Возврат;
	КонецЕсли;

	// Формируем JSON для stream-json input format Claude Code CLI
	// ВАЖНО: JSON должен быть ОДНОСТРОЧНЫМ! Claude Code парсит stdin построчно.
	// ЕХТ_Значение.вJSON() может генерировать pretty-print с переносами, что ломает парсинг.
	// Экранируем спецсимволы в тексте для безопасной вставки в JSON
	ТекстJSON = СтрЗаменить(Текст, "\", "\\");
	ТекстJSON = СтрЗаменить(ТекстJSON, """", "\""");
	ТекстJSON = СтрЗаменить(ТекстJSON, Символы.ПС, "\n");
	ТекстJSON = СтрЗаменить(ТекстJSON, Символы.ВК, "");
	ТекстJSON = СтрЗаменить(ТекстJSON, Символы.Таб, "\t");
	СтрокаJSON = "{""type"":""user"",""message"":{""role"":""user"",""content"":""" + ТекстJSON + """}}";
	Соединение.ОтправитьСообщение(СтрокаJSON);

КонецПроцедуры

#КонецОбласти

