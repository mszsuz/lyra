
// Тест: форма-модуль с таймером, обращением к реквизитам и callback владельца.

&НаКлиенте
Перем Владелец;

&НаКлиенте
Перем Счётчик;

&НаКлиенте
Процедура Инициализация(ФормаВладелец) Экспорт
	Владелец = ФормаВладелец;
	Счётчик = 0;
	ДобавитьЛог("МодульЧат инициализирован");
КонецПроцедуры

&НаКлиенте
Процедура ЗапуститьТаймер() Экспорт
	Счётчик = 0;
	ДобавитьЛог("Таймер запущен");
	ПодключитьОбработчикОжидания("ТикТаймера", 1, Ложь);
КонецПроцедуры

&НаКлиенте
Процедура ОстановитьТаймер() Экспорт
	ОтключитьОбработчикОжидания("ТикТаймера");
	ДобавитьЛог("Таймер остановлен, тиков: " + Счётчик);
КонецПроцедуры

&НаКлиенте
Процедура ТикТаймера() Экспорт
	Счётчик = Счётчик + 1;

	// Тест 1: изменение реквизита формы владельца
	Попытка
		Владелец.Статус = "Тик #" + Счётчик;
		Владелец.Счётчик = Счётчик;
		ДобавитьЛог("Тик #" + Счётчик + " — реквизиты OK");
	Исключение
		ДобавитьЛог("ОШИБКА реквизиты: " + ОписаниеОшибки());
	КонецПопытки;

	// Тест 2: callback владельца
	Попытка
		Владелец.ОбработатьСобытиеМодуля("Чат", "тик", Счётчик);
		ДобавитьЛог("Тик #" + Счётчик + " — callback OK");
	Исключение
		ДобавитьЛог("ОШИБКА callback: " + ОписаниеОшибки());
	КонецПопытки;

	Если Счётчик >= 5 Тогда
		ОстановитьТаймер();
	КонецЕсли;
КонецПроцедуры

&НаКлиенте
Процедура ДобавитьЛог(Текст)
	Попытка
		Владелец.Лог = Владелец.Лог + Символы.ПС + Текст;
	Исключение
	КонецПопытки;
КонецПроцедуры
