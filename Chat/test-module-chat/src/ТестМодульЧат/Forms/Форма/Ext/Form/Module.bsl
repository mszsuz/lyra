
// Главная форма. Тестирует: форма-модуль управляет реквизитами и таймером.

&НаКлиенте
Перем МодульЧат;

&НаКлиенте
Процедура ПриОткрытии(Отказ)
	МодульЧат = ПолучитьФорму("ВнешняяОбработка.ТестМодульЧат.Форма.МодульЧат",, ЭтотОбъект);
	МодульЧат.Инициализация(ЭтотОбъект);
	ЭтотОбъект.Статус = "Готово. Нажмите 'Старт таймер'";
КонецПроцедуры

&НаКлиенте
Процедура КомандаСтарт(Команда)
	МодульЧат.ЗапуститьТаймер();
КонецПроцедуры

&НаКлиенте
Процедура КомандаОстановить(Команда)
	МодульЧат.ОстановитьТаймер();
КонецПроцедуры

&НаКлиенте
Процедура ОбработатьСобытиеМодуля(ИмяМодуля, ИмяСобытия, Данные) Экспорт
	ЭтотОбъект.Лог = ЭтотОбъект.Лог + Символы.ПС
		+ "[callback] " + ИмяМодуля + "." + ИмяСобытия + " = " + Данные;
КонецПроцедуры
