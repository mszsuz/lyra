// Сбрасывает состояние стриминга.
&НаКлиенте
Процедура СброситьСостояние()
	ТекущееСообщениеИД = "";
	ТекущееСообщениеТекст = "";
	ТекущийРежимБлока = "";
	НачалоРазмышления = 0;
	ДлительностьРазмышленияМс = 0;
	НачалоПодготовкиОтвета = 0;
	СтатусыИнструментов = Новый Массив;
КонецПроцедуры

// Фиксирует длительность текущего блока размышлений.
&НаКлиенте
Процедура ЗафиксироватьРазмышление()
	Если НачалоРазмышления > 0 Тогда
		ДлительностьРазмышленияМс = ДлительностьРазмышленияМс
			+ (ТекущаяУниверсальнаяДатаВМиллисекундах() - НачалоРазмышления);
		НачалоРазмышления = 0;
	КонецЕсли;
КонецПроцедуры

// Генерирует уникальный ИД сообщения.
&НаКлиенте
Функция НовыйИДСообщения()
	Возврат "msg-" + Строка(Новый УникальныйИдентификатор);
КонецФункции

// Обновляет текст текущего сообщения через событие владельцу.
&НаКлиенте
Процедура ОбновитьСообщение(НовыйТекст)
	Если ПустаяСтрока(ТекущееСообщениеИД) Тогда
		Возврат;
	КонецЕсли;
	Данные = Новый Структура;
	Данные.Вставить("ИД", ТекущееСообщениеИД);
	Данные.Вставить("Текст", НовыйТекст);
	ОповеститьВладельца("обновить_сообщение", Данные);
КонецПроцедуры

// Отправляет событие владельцу (главной форме).
&НаКлиенте
Процедура ОповеститьВладельца(ИмяСобытия, Данные)
	Владелец.ОбработатьСобытиеМодуля("Чат", ИмяСобытия, Данные);
КонецПроцедуры

// ─── JSON-утилиты (приватные копии для hot path) ───

&НаКлиенте
Функция ЭтоОбъектJSON(Значение)
	Возврат ТипЗнч(Значение) = Тип("Структура") ИЛИ ТипЗнч(Значение) = Тип("Соответствие");
КонецФункции

&НаКлиенте
Функция ПолучитьПоле(Данные, Ключ)
	Если ТипЗнч(Данные) = Тип("Структура") Тогда
		Значение = Неопределено;
		Данные.Свойство(Ключ, Значение);
		Возврат Значение;
	ИначеЕсли ТипЗнч(Данные) = Тип("Соответствие") Тогда
		Возврат Данные.Получить(Ключ);
	Иначе
		Возврат Неопределено;
	КонецЕсли;
КонецФункции

&НаКлиенте
Функция ИзвлечьЗначение(Данные, ИмяПоля)
	Если НЕ ЭтоОбъектJSON(Данные) Тогда
		Возврат "";
	КонецЕсли;
	Значение = ПолучитьПоле(Данные, ИмяПоля);
	Если Значение = Неопределено Тогда
		Возврат "";
	КонецЕсли;
	Возврат Значение;
КонецФункции

#КонецОбласти
