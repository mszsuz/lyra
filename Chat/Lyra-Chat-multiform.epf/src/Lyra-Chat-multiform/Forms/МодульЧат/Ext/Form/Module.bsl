
// МодульЧат — жизненный цикл диалога + управление сессией.
// Служебная форма-модуль (не отображается), получается через ПолучитьФорму("МодульЧат").
//
// Владеет всей чат-логикой: стриминг, протокол (hello_ack, auth_ack, balance_update),
// отправка сообщений, QR, настройки. НЕ вызывает ЕХТ_Чат напрямую —
// отправляет UI-команды владельцу через ОповеститьВладельца().

#Область ПеременныеМодуля

// --- Ссылки на модули ---
&НаКлиенте
Перем Владелец;                  // главная форма (Форма)
&НаКлиенте
Перем Транспорт;                 // МодульТранспорт (для отправки сообщений)
&НаКлиенте
Перем Обработка;                 // МодульОбработка (для выполнения tool_call)
&НаКлиенте
Перем Напарник;                  // МодульНапарник (для запросов к 1С:Напарник)

// --- Состояние стриминга ---
&НаКлиенте
Перем ТекущееСообщениеИД;        // ИД текущего пузыря ответа
&НаКлиенте
Перем ТекущееСообщениеТекст;     // накопленный текст ответа
&НаКлиенте
Перем ТекущийРежимБлока;         // "thinking" / "text" / ""
&НаКлиенте
Перем НачалоРазмышления;         // мс, начало текущего блока thinking
&НаКлиенте
Перем ДлительностьРазмышленияМс; // суммарная длительность всех блоков thinking (мс)
&НаКлиенте
Перем НачалоПодготовкиОтвета;    // мс, начало подготовки (для таймера)
&НаКлиенте
Перем СтатусыИнструментов;       // Массив строк — цепочка статусов подготовки

// --- Состояние сессии ---
&НаКлиенте
Перем ФормИД;                    // UUID формы для переподключения (form_id)
&НаКлиенте
Перем ДанныеБазы;                // кэш данных о базе для hello (Структура)
&НаКлиенте
Перем СессияИД;                  // session_id из hello_ack
&НаКлиенте
Перем МобильныйJWT;              // mobile_jwt из hello_ack (для QR)
&НаКлиенте
Перем Баланс;                    // текущий баланс пользователя
&НаКлиенте
Перем ОтложенноеСообщение;       // текст, ожидающий отправки после подключения
&НаКлиенте
Перем БылоПодключение;           // флаг: первое подключение уже было
&НаКлиенте
Перем СессияИстекла;             // флаг: сессия завершена по TTL

#КонецОбласти

#Область ПрограммныйИнтерфейс

// Инициализация модуля.
//
// Параметры:
//  ФормаВладелец     - УправляемаяФорма - главная форма
//  МодульТранспорт   - УправляемаяФорма - модуль транспорта
//  МодульОбработка   - УправляемаяФорма - модуль обработки инструментов
//  МодульНапарник    - УправляемаяФорма - модуль интеграции с 1С:Напарник (Неопределено если недоступен)
//  ПДанныеБазы       - Структура - данные о базе для hello
//  ПФормИД           - Строка - UUID формы для переподключения
//
&НаКлиенте
Процедура Инициализация(ФормаВладелец, МодульТранспорт, МодульОбработка, МодульНапарник = Неопределено,
		ПДанныеБазы = Неопределено, ПФормИД = "") Экспорт

	Владелец = ФормаВладелец;
	Транспорт = МодульТранспорт;
	Обработка = МодульОбработка;
	Напарник = МодульНапарник;
	ДанныеБазы = ПДанныеБазы;
	ФормИД = ПФормИД;
	БылоПодключение = Ложь;
	СессияИстекла = Ложь;

	СброситьСостояние();

КонецПроцедуры

// Обрабатывает все события от транспорта (connected/closed/error/message/presence_leave).
//
// Параметры:
//  ИмяСобытия - Строка - имя события транспорта
//  Данные     - Произвольный - данные события
//
&НаКлиенте
Процедура ОбработатьСобытиеТранспорта(ИмяСобытия, Данные) Экспорт

	Если ИмяСобытия = "connected" Тогда

		// Данные — Структура с полями: client, status, subs
		Статус = Данные.status;

		Если Статус = "lobby" Тогда
			// Подключились к lobby — отправить hello
			ОтправитьHello();
		ИначеЕсли Статус = "session" Тогда
			// Переподключились с chat_jwt — канал сессии активен
			Если БылоПодключение Тогда
				ОповеститьВладельца("информация", "Соединение восстановлено!");
			Иначе
				БылоПодключение = Истина;
				ОповеститьВладельца("информация", "Лира на связи!");
			КонецЕсли;
			ОповеститьВладельца("занят", Ложь);

			// Отправить отложенное сообщение (если было)
			Если ОтложенноеСообщение <> Неопределено Тогда
				ТекстОтложенный = ОтложенноеСообщение;
				ОтложенноеСообщение = Неопределено;
				ДанныеСообщения = Новый Структура;
				ДанныеСообщения.Вставить("type", "chat");
				ДанныеСообщения.Вставить("form_id", ФормИД);
				ДанныеСообщения.Вставить("text", ТекстОтложенный);
				Транспорт.ОтправитьСообщение(ДанныеСообщения);
				ОповеститьВладельца("занят", Истина);
			КонецЕсли;
		КонецЕсли;

	ИначеЕсли ИмяСобытия = "closed" Тогда

		// Данные — Структура с полями: КодЗакрытия, ПредыдущийСтатус
		ОповеститьВладельца("занят", Ложь);
		ОповеститьВладельца("предупреждение",
			"Соединение закрыто (код " + Формат(Данные.КодЗакрытия, "ЧН=0; ЧГ=0") + "). <a href=""lyra://reconnect"" class=""chat-link"">Повторить подключение</a>");

	ИначеЕсли ИмяСобытия = "error" Тогда

		ОповеститьВладельца("предупреждение",
			Данные + ". <a href=""lyra://reconnect"" class=""chat-link"">Повторить подключение</a>");

	ИначеЕсли ИмяСобытия = "message" Тогда

		// Данные — JSON-строка (data из push.pub.data)
		ДанныеОтвета = Транспорт.РазобратьJSON(Данные);
		ОбработатьСообщениеПротокола(ДанныеОтвета);

	ИначеЕсли ИмяСобытия = "presence_leave" Тогда

		// Участник покинул канал сессии (Роутер упал / отключился)
		Если Активен() Тогда
			ОповеститьВладельца("предупреждение",
				"Сервер отключился от канала. <a href=""lyra://reconnect"" class=""chat-link"">Переподключиться</a>");
			ОповеститьВладельца("занят", Ложь);
		КонецЕсли;

	КонецЕсли;

КонецПроцедуры

// Отправляет сообщение пользователя.
// Обрабатывает прерывание стрима, очередь при отсутствии соединения, показ пузыря.
//
// Параметры:
//  ТекстСообщения - Строка - текст сообщения (уже trimmed)
//
&НаКлиенте
Процедура ОтправитьСообщениеПользователя(ТекстСообщения) Экспорт

	// Прерывание текущего стрима
	Если Активен() Тогда

		ПрерватьСтрим();

		Если ТекстСообщения = "" Тогда
			// Пустой ввод при стриме — просто abort, без сообщения в историю
			ДанныеСообщения = Новый Структура;
			ДанныеСообщения.Вставить("type", "abort");
			Транспорт.ОтправитьСообщение(ДанныеСообщения);
		Иначе
			// Новый вопрос — прерываем текущий стрим и отправляем новый
			ДанныеСообщения = Новый Структура;
			ДанныеСообщения.Вставить("type", "chat");
			ДанныеСообщения.Вставить("form_id", ФормИД);
			ДанныеСообщения.Вставить("text", ТекстСообщения);
			Транспорт.ОтправитьСообщение(ДанныеСообщения);
			ОповеститьВладельца("очистить_поле_ввода", Неопределено);
			ОповеститьВладельца("сообщение_пользователя", ТекстСообщения);

			НовыйВопрос();
		КонецЕсли;
		Возврат;
	КонецЕсли;

	Если ТекстСообщения = "" Тогда
		Возврат;
	КонецЕсли;

	// Формируем данные сообщения
	ДанныеСообщения = Новый Структура;
	ДанныеСообщения.Вставить("type", "chat");
	ДанныеСообщения.Вставить("form_id", ФормИД);
	ДанныеСообщения.Вставить("text", ТекстСообщения);

	// Отправляем через Транспорт (Centrifugo publish в канал сессии)
	Если НЕ Транспорт.ОтправитьСообщение(ДанныеСообщения) Тогда
		// Сообщение в очередь — отправится когда канал будет готов
		ОтложенноеСообщение = ТекстСообщения;
		Подключиться();
		// Показываем пузырь пользователя сразу — как будто отправлено
		ОповеститьВладельца("сообщение_пользователя", ТекстСообщения);
		ОповеститьВладельца("очистить_поле_ввода", Неопределено);
		Возврат;
	КонецЕсли;

	// Очищаем поле ввода
	ОповеститьВладельца("очистить_поле_ввода", Неопределено);
	ОповеститьВладельца("сообщение_пользователя", ТекстСообщения);

	НовыйВопрос();
	ОповеститьВладельца("занят", Истина);

КонецПроцедуры

// Подключение к Centrifugo.
//
&НаКлиенте
Процедура Подключиться() Экспорт
	АдресЦентрифуга = "ws://localhost:11000/connection/websocket";
	Транспорт.Подключиться(АдресЦентрифуга);
КонецПроцедуры

// Закрытие — disconnect + cleanup.
// Вызывается из Формы перед закрытием.
//
&НаКлиенте
Процедура ПередЗакрытием() Экспорт

	// Уведомить Роутер о закрытии формы (статус → disconnected)
	Если Транспорт <> Неопределено И ЗначениеЗаполнено(СессияИД) Тогда
		ДанныеОтключения = Новый Структура;
		ДанныеОтключения.Вставить("type", "disconnect");
		ДанныеОтключения.Вставить("form_id", ФормИД);
		Транспорт.ОтправитьСообщение(ДанныеОтключения);
	КонецЕсли;

	// Каскадное отключение WebSocket
	Если Транспорт <> Неопределено Тогда
		Транспорт.Отключиться();
	КонецЕсли;

КонецПроцедуры

// Обработка команд из ссылок чата (lyra://reconnect и пр.).
//
// Параметры:
//  Команда - Строка - имя команды (без "lyra://")
//
&НаКлиенте
Процедура ОбработатьКомандуЧата(Команда) Экспорт

	Если Команда = "reconnect" Тогда
		Если СессияИстекла = Истина Тогда
			ОповеститьВладельца("очистить_чат", Неопределено);
			СессияИстекла = Ложь;
			ОповеститьВладельца("доступность_ввода", Истина);
		КонецЕсли;
		Подключиться();
	КонецЕсли;

КонецПроцедуры

// Отправляет настройки в Роутер для сохранения.
// Вызывается из формы Настройки при нажатии "Сохранить".
//
&НаКлиенте
Процедура ОтправитьНастройки() Экспорт

	Сообщение = Новый Структура;
	Сообщение.Вставить("type", "settings_save");
	Сообщение.Вставить("naparnik_token", Владелец.Объект.Токен1СНапарник);
	Сообщение.Вставить("user_name", Владелец.Объект.ИмяПользователяЛира);
	Сообщение.Вставить("user_level", Владелец.Объект.УровеньПодготовленностиПользователя);
	Сообщение.Вставить("db_name", Владелец.Объект.НазваниеИБ);
	Транспорт.ОтправитьСообщение(Сообщение);

	// Обновить индикатор Напарника
	Если Напарник <> Неопределено Тогда
		Напарник.ПроверитьДоступность(Владелец.Объект.Токен1СНапарник);
	КонецЕсли;

КонецПроцедуры

// Обрабатывает событие протокола (text_delta, thinking_*, tool_status, assistant_end, error, tool_call).
//
// Параметры:
//  ТипСобытия - Строка - тип события протокола
//  ДанныеОтвета - Структура, Соответствие - разобранный JSON
//
&НаКлиенте
Процедура ОбработатьСобытие(ТипСобытия, ДанныеОтвета) Экспорт

	Если ТипСобытия = "text_delta" Тогда
		ОбработатьТекстДельта(ДанныеОтвета);

	ИначеЕсли ТипСобытия = "thinking_start" ИЛИ ТипСобытия = "thinking_delta" Тогда
		ОбработатьРазмышление(ТипСобытия);

	ИначеЕсли ТипСобытия = "thinking_end" Тогда
		ЗафиксироватьРазмышление();

	ИначеЕсли ТипСобытия = "tool_status" Тогда
		ОбработатьСтатусИнструмента(ДанныеОтвета);

	ИначеЕсли ТипСобытия = "assistant_end" Тогда
		ОбработатьЗавершениеОтвета(ДанныеОтвета);

	ИначеЕсли ТипСобытия = "error" Тогда
		ОбработатьОшибку(ДанныеОтвета);

	ИначеЕсли ТипСобытия = "tool_call" Тогда
		ОбработатьВызовИнструмента(ДанныеОтвета);

	КонецЕсли;

КонецПроцедуры

// Подготавливает состояние для нового вопроса.
// Вызывается при отправке сообщения.
//
&НаКлиенте
Процедура НовыйВопрос() Экспорт

	СброситьСостояние();
	НачалоПодготовкиОтвета = ТекущаяУниверсальнаяДатаВМиллисекундах();
	СтатусыИнструментов.Добавить("Готовлюсь к ответу...");

	// Создаём пузырь с индикатором подготовки
	ИДСообщения = НовыйИДСообщения();
	ТекущееСообщениеИД = ИДСообщения;

	Сообщение = Новый Структура;
	Сообщение.Вставить("ИД", ИДСообщения);
	Сообщение.Вставить("Текст", СобратьHTMLПодготовки());
	Сообщение.Вставить("Шаблон", "Ассистент");

	ОповеститьВладельца("добавить_сообщение", Сообщение);
	ОповеститьВладельца("таймер_подготовки", "подключить");

КонецПроцедуры

// Прерывает текущий стрим.
// Возвращает Истина если был активный стрим.
//
&НаКлиенте
Функция ПрерватьСтрим() Экспорт

	ОповеститьВладельца("таймер_подготовки", "отключить");

	Если НЕ ПустаяСтрока(ТекущееСообщениеИД) Тогда
		// Фиксируем размышление
		ЗафиксироватьРазмышление();

		Если НЕ ПустаяСтрока(ТекущееСообщениеТекст) Тогда
			ОбновитьСообщение(СобратьСпойлерПодготовки() + ТекущееСообщениеТекст);
		Иначе
			ИтогHTML = СобратьСпойлерПодготовки();
			Если ПустаяСтрока(ИтогHTML) Тогда
				ИтогHTML = "<span style=""color: #999; font-style: italic;"">прервано</span>";
			КонецЕсли;
			ОбновитьСообщение(ИтогHTML);
		КонецЕсли;
	КонецЕсли;

	СброситьСостояние();
	Возврат Истина;

КонецФункции

// Возвращает Истина если идёт обработка ответа.
//
&НаКлиенте
Функция Активен() Экспорт
	Возврат НЕ ПустаяСтрока(ТекущееСообщениеИД) ИЛИ НачалоПодготовкиОтвета > 0;
КонецФункции

// Обработчик таймера подготовки (вызывается из Формы через ОбработатьСобытиеМодуля).
//
&НаКлиенте
Процедура ОбновитьТаймерПодготовки() Экспорт

	Если ПустаяСтрока(ТекущееСообщениеИД) ИЛИ НачалоПодготовкиОтвета = 0 Тогда
		ОповеститьВладельца("таймер_подготовки", "отключить");
		Возврат;
	КонецЕсли;

	// Обновляем HTML подготовки
	ОбновитьСообщение(СобратьHTMLПодготовки());

КонецПроцедуры

#КонецОбласти

#Область ОбработчикиСобытийСтриминга

&НаКлиенте
Процедура ОбработатьТекстДельта(ДанныеОтвета)

	ТекстДельты = ИзвлечьЗначение(ДанныеОтвета, "text");
	Если ПустаяСтрока(ТекстДельты) Тогда
		Возврат;
	КонецЕсли;

	// Фиксируем длительность размышлений при первом тексте
	ЗафиксироватьРазмышление();
	ТекущийРежимБлока = "text";

	// Создаём пузырь при первом тексте (если ещё нет)
	Если ПустаяСтрока(ТекущееСообщениеИД) Тогда
		ИДСообщения = НовыйИДСообщения();
		ТекущееСообщениеИД = ИДСообщения;

		Сообщение = Новый Структура;
		Сообщение.Вставить("ИД", ИДСообщения);
		Сообщение.Вставить("Текст", "");
		Сообщение.Вставить("Шаблон", "Ассистент");
		ОповеститьВладельца("добавить_сообщение", Сообщение);
	КонецЕсли;

	ТекущееСообщениеТекст = ТекущееСообщениеТекст + ТекстДельты;
	ОбновитьСообщение(ТекущееСообщениеТекст);

КонецПроцедуры

&НаКлиенте
Процедура ОбработатьРазмышление(ТипСобытия)

	Если ТипСобытия = "thinking_start" Тогда
		Если НачалоРазмышления = 0 Тогда
			НачалоРазмышления = ТекущаяУниверсальнаяДатаВМиллисекундах();
		КонецЕсли;
	КонецЕсли;

	ТекущийРежимБлока = "thinking";

	// Создаём пузырь с пульсацией (если ещё нет)
	Если ПустаяСтрока(ТекущееСообщениеИД) Тогда
		НачалоПодготовкиОтвета = ТекущаяУниверсальнаяДатаВМиллисекундах();
		СтатусыИнструментов = Новый Массив;
		СтатусыИнструментов.Добавить("Готовлюсь к ответу...");

		ИДСообщения = НовыйИДСообщения();
		ТекущееСообщениеИД = ИДСообщения;

		Сообщение = Новый Структура;
		Сообщение.Вставить("ИД", ИДСообщения);
		Сообщение.Вставить("Текст", СобратьHTMLПодготовки());
		Сообщение.Вставить("Шаблон", "Ассистент");
		ОповеститьВладельца("добавить_сообщение", Сообщение);
		ОповеститьВладельца("таймер_подготовки", "подключить");
	КонецЕсли;

КонецПроцедуры

&НаКлиенте
Процедура ОбработатьСтатусИнструмента(ДанныеОтвета)

	Описание = ИзвлечьЗначение(ДанныеОтвета, "description");
	Если ПустаяСтрока(Описание) Тогда
		Возврат;
	КонецЕсли;

	СтатусыИнструментов.Добавить(Описание);
	Если НЕ ПустаяСтрока(ТекущееСообщениеИД) Тогда
		ОбновитьСообщение(СобратьHTMLПодготовки());
	КонецЕсли;

КонецПроцедуры

&НаКлиенте
Процедура ОбработатьЗавершениеОтвета(ДанныеОтвета)

	// Остановить таймер
	ОповеститьВладельца("таймер_подготовки", "отключить");

	ЗафиксироватьРазмышление();

	// Полный текст может прийти в поле text (fallback без стриминга)
	ПолныйТекст = ИзвлечьЗначение(ДанныеОтвета, "text");
	Если НЕ ЗначениеЗаполнено(ПолныйТекст) Тогда
		ПолныйТекст = ТекущееСообщениеТекст;
	КонецЕсли;

	Если ЗначениеЗаполнено(ПолныйТекст) Тогда
		ИтогHTML = СобратьСпойлерПодготовки() + ПолныйТекст;
		Если НЕ ПустаяСтрока(ТекущееСообщениеИД) Тогда
			ОбновитьСообщение(ИтогHTML);
		Иначе
			Сообщение = Новый Структура;
			Сообщение.Вставить("Текст", ИтогHTML);
			Сообщение.Вставить("Шаблон", "Ассистент");
			ОповеститьВладельца("добавить_сообщение", Сообщение);
		КонецЕсли;
	КонецЕсли;

	СброситьСостояние();
	ОповеститьВладельца("завершён", Неопределено);

КонецПроцедуры

&НаКлиенте
Процедура ОбработатьОшибку(ДанныеОтвета)

	ПричинаОшибки = ИзвлечьЗначение(ДанныеОтвета, "reason");
	ТекстОшибки = ИзвлечьЗначение(ДанныеОтвета, "message");
	Если ПустаяСтрока(ТекстОшибки) Тогда
		ТекстОшибки = "Неизвестная ошибка";
	КонецЕсли;

	Если ПричинаОшибки = "busy" Тогда
		ОповеститьВладельца("предупреждение", ТекстОшибки);
	Иначе
		ОповеститьВладельца("ошибка", ТекстОшибки);
		ОповеститьВладельца("занят", Ложь);
	КонецЕсли;

КонецПроцедуры

&НаКлиенте
Процедура ОбработатьВызовИнструмента(ДанныеОтвета)

	ИДЗапроса = ИзвлечьЗначение(ДанныеОтвета, "request_id");
	ИмяИнструмента = ИзвлечьЗначение(ДанныеОтвета, "tool");
	ПараметрыИнструмента = ПолучитьПоле(ДанныеОтвета, "params");

	// Напарник — async через HTML/JS (результат придёт через callback)
	Если ИмяИнструмента = "lyra_ask_naparnik" Тогда
		Если Напарник = Неопределено Тогда
			ОтветИнструмента = Новый Структура;
			ОтветИнструмента.Вставить("type", "tool_result");
			ОтветИнструмента.Вставить("request_id", ИДЗапроса);
			ОтветИнструмента.Вставить("error", "Модуль Напарника не инициализирован");
			Транспорт.ОтправитьСообщение(ОтветИнструмента);
			Возврат;
		КонецЕсли;

		Вопрос = ИзвлечьЗначение(ПараметрыИнструмента, "question");
		ТокенНапарника = Владелец.Объект.Токен1СНапарник;
		Навык = ИзвлечьЗначение(ПараметрыИнструмента, "skill");
		Если НЕ ЗначениеЗаполнено(Навык) Тогда Навык = "custom" КонецЕсли;
		Режим = ИзвлечьЗначение(ПараметрыИнструмента, "mode");
		Если НЕ ЗначениеЗаполнено(Режим) Тогда Режим = "standard" КонецЕсли;
		ПрямойИнструмент = ИзвлечьЗначение(ПараметрыИнструмента, "direct_tool");
		Если НЕ ЗначениеЗаполнено(ПрямойИнструмент) Тогда ПрямойИнструмент = "" КонецЕсли;
		Напарник.ЗадатьВопрос(ТокенНапарника, Вопрос, ИДЗапроса, Навык, Режим, ПрямойИнструмент);
		Возврат;
	КонецЕсли;

	// Остальные инструменты — синхронно через МодульОбработка
	Попытка
		Результат = Обработка.ВыполнитьИнструмент(ИмяИнструмента, ПараметрыИнструмента);
		ОтветИнструмента = Новый Структура;
		ОтветИнструмента.Вставить("type", "tool_result");
		ОтветИнструмента.Вставить("request_id", ИДЗапроса);
		ОтветИнструмента.Вставить("result", Результат);
		Транспорт.ОтправитьСообщение(ОтветИнструмента);
	Исключение
		ОтветИнструмента = Новый Структура;
		ОтветИнструмента.Вставить("type", "tool_result");
		ОтветИнструмента.Вставить("request_id", ИДЗапроса);
		ОтветИнструмента.Вставить("error", ОписаниеОшибки());
		Транспорт.ОтправитьСообщение(ОтветИнструмента);
	КонецПопытки;

КонецПроцедуры

#КонецОбласти

#Область ОбработчикиПротокола

// Маршрутизация сообщений протокола.
// Системные (hello_ack, auth_ack, balance_update) — обрабатываем здесь.
// Остальные — делегируем в ОбработатьСобытие.
//
&НаКлиенте
Процедура ОбработатьСообщениеПротокола(ДанныеОтвета)

	ТипСобытия = ПолучитьПоле(ДанныеОтвета, "type");
	Если ТипСобытия = Неопределено Тогда
		ТипСобытия = "";
	КонецЕсли;

	Если ТипСобытия = "hello_ack" Тогда
		ОбработатьHelloAck(ДанныеОтвета);
	ИначеЕсли ТипСобытия = "auth_ack" Тогда
		ОбработатьAuthAck(ДанныеОтвета);
	ИначеЕсли ТипСобытия = "balance_update" Тогда
		ОбработатьBalanceUpdate(ДанныеОтвета);
	ИначеЕсли ТипСобытия = "session_warning" Тогда
		ОбработатьПредупреждениеСессии(ДанныеОтвета);
	ИначеЕсли ТипСобытия = "session_expired" Тогда
		ОбработатьСессияИстекла(ДанныеОтвета);
	Иначе
		// Стриминг, ошибки, tool_call
		ОбработатьСобытие(ТипСобытия, ДанныеОтвета);
	КонецЕсли;

КонецПроцедуры

// Отправляет hello в session:lobby через Centrifugo с данными о базе.
//
&НаКлиенте
Процедура ОтправитьHello()

	// Собираем данные hello
	Привет = Новый Структура;
	Привет.Вставить("form_id", ФормИД);

	// Данные о базе (получены при открытии формы)
	Если ДанныеБазы <> Неопределено Тогда
		Привет.Вставить("config_name", ДанныеБазы.config_name);
		Привет.Вставить("config_version", ДанныеБазы.config_version);
		Привет.Вставить("config_id", ДанныеБазы.config_id);
		Привет.Вставить("computer", ДанныеБазы.computer);
		Привет.Вставить("connection_string", ДанныеБазы.connection_string);
		Привет.Вставить("base_ids", ДанныеБазы.base_ids);
	КонецЕсли;

	Транспорт.ОтправитьHello(Привет);

КонецПроцедуры

// Обрабатывает hello_ack от Роутера.
// Сохраняет session_id, chat_jwt, mobile_jwt. Переподключается на канал сессии.
//
&НаКлиенте
Процедура ОбработатьHelloAck(ДанныеОтвета)

	СессияИД = ПолучитьПоле(ДанныеОтвета, "session_id");
	ЧатJWT = ПолучитьПоле(ДанныеОтвета, "chat_jwt");
	МобильныйJWT = ПолучитьПоле(ДанныеОтвета, "mobile_jwt");
	СтатусОтвета = ПолучитьПоле(ДанныеОтвета, "status");

	Если СессияИД = Неопределено Тогда СессияИД = "" КонецЕсли;
	Если ЧатJWT = Неопределено Тогда ЧатJWT = "" КонецЕсли;
	Если МобильныйJWT = Неопределено Тогда МобильныйJWT = "" КонецЕсли;
	Если СтатусОтвета = Неопределено Тогда СтатусОтвета = "" КонецЕсли;

	Если НЕ ЗначениеЗаполнено(СессияИД) ИЛИ НЕ ЗначениеЗаполнено(ЧатJWT) Тогда
		ОповеститьВладельца("ошибка", "hello_ack без session_id или chat_jwt.");
		Возврат;
	КонецЕсли;

	// Сохранить session_id в Транспорте для publish в канал сессии
	Транспорт.УстановитьСессию(СессияИД);

	// Отобразить идентификатор сессии
	ОповеститьВладельца("ид_сессии", СессияИД);

	АвтоАвторизация = ПолучитьПоле(ДанныеОтвета, "auto_auth");
	Если АвтоАвторизация = Неопределено Тогда
		АвтоАвторизация = Ложь;
	КонецЕсли;

	Если СтатусОтвета = "reconnected" Тогда

		// Переподключение к существующей сессии — без QR
		ОповеститьВладельца("информация",
			"Переподключение к сессии " + Лев(СессияИД, 8) + "...");
		// Проверяем доступность Напарника (токен уже сохранён)
		Если Напарник <> Неопределено Тогда
			Напарник.ПроверитьДоступность(Владелец.Объект.Токен1СНапарник);
		КонецЕсли;

	ИначеЕсли АвтоАвторизация = Истина Тогда

		// Авто-авторизация (MVP) — без QR
		// Загружаем сохранённые настройки от Роутера
		ЗагрузитьНастройкиИзОтвета(ДанныеОтвета);
		// Проверяем доступность Напарника (индикатор)
		Если Напарник <> Неопределено Тогда
			Напарник.ПроверитьДоступность(Владелец.Объект.Токен1СНапарник);
		КонецЕсли;
		// Ввод разблокируется при connected(session)

	Иначе

		// Новая сессия — показать QR если есть mobile_jwt
		Если ЗначениеЗаполнено(МобильныйJWT) Тогда
			ОповеститьВладельца("информация",
				"Сессия " + Лев(СессияИД, 8) + "... создана. Ожидание авторизации...");
			ПоказатьQR(МобильныйJWT);
		Иначе
			ОповеститьВладельца("информация",
				"Сессия " + Лев(СессияИД, 8) + "... создана.");
		КонецЕсли;
		// Блокируем ввод до авторизации
		ОповеститьВладельца("занят", Истина);

	КонецЕсли;

	// Переподключиться к Centrifugo с персональным chat_jwt
	// (авто-подписка на канал сессии через channels claim в JWT)
	Транспорт.Переподключиться(ЧатJWT);

КонецПроцедуры

// Обрабатывает auth_ack от Роутера (после авторизации через мобильное приложение).
//
&НаКлиенте
Процедура ОбработатьAuthAck(ДанныеОтвета)

	СтатусАвторизации = ПолучитьПоле(ДанныеОтвета, "status");
	Если СтатусАвторизации = Неопределено Тогда
		СтатусАвторизации = "";
	КонецЕсли;
	Если СтатусАвторизации = "ok" Тогда

		// Загружаем сохранённые настройки от Роутера
		ЗагрузитьНастройкиИзОтвета(ДанныеОтвета);
		// Проверяем доступность Напарника (индикатор)
		Если Напарник <> Неопределено Тогда
			Напарник.ПроверитьДоступность(Владелец.Объект.Токен1СНапарник);
		КонецЕсли;
		ОповеститьВладельца("информация",
			"Авторизация пройдена. Можно задавать вопросы.");
		ОповеститьВладельца("занят", Ложь);

	ИначеЕсли СтатусАвторизации = "insufficient_balance" Тогда

		СообщениеБаланса = ПолучитьПоле(ДанныеОтвета, "message");
		Если СообщениеБаланса = Неопределено ИЛИ НЕ ЗначениеЗаполнено(СообщениеБаланса) Тогда
			СообщениеБаланса = "Недостаточный баланс. Пополните баланс в мобильном приложении.";
		КонецЕсли;
		ОповеститьВладельца("предупреждение", СообщениеБаланса);
		ОповеститьВладельца("занят", Истина);

	ИначеЕсли СтатусАвторизации = "auth_failed" Тогда

		ОповеститьВладельца("ошибка", "Ошибка авторизации.");
		ОповеститьВладельца("занят", Ложь);

	ИначеЕсли СтатусАвторизации = "service_unavailable" Тогда

		ОповеститьВладельца("ошибка", "Сервис временно недоступен. Попробуйте позже.");
		ОповеститьВладельца("занят", Ложь);

	Иначе
		ОповеститьВладельца("предупреждение", "auth_ack: " + СтатусАвторизации);
	КонецЕсли;

КонецПроцедуры

// Обрабатывает balance_update от Биллинга.
// При пополнении баланса (был ≤ 0, стал > 0) разблокирует ввод.
//
&НаКлиенте
Процедура ОбработатьBalanceUpdate(ДанныеОтвета)

	НовыйБаланс = ПолучитьПоле(ДанныеОтвета, "balance");
	Валюта = ПолучитьПоле(ДанныеОтвета, "currency");
	Если Валюта = Неопределено Тогда
		Валюта = "руб";
	КонецЕсли;

	Если НовыйБаланс <> Неопределено Тогда
		СтарыйБаланс = Баланс;
		Баланс = НовыйБаланс;

		// Отобразить баланс в заголовке
		ОповеститьВладельца("заголовок",
			"Лира — " + Формат(Баланс, "ЧДЦ=2; ЧГ=0") + " " + Валюта);

		// Разблокировать ввод если баланс пополнен (был ≤ 0, стал > 0)
		Если СтарыйБаланс <> Неопределено И СтарыйБаланс <= 0 И Баланс > 0 Тогда
			ОповеститьВладельца("информация",
				"Баланс пополнен. Можно задавать вопросы.");
			ОповеститьВладельца("занят", Ложь);
		КонецЕсли;

		// Предупреждение при нулевом балансе (списание во время работы)
		Если Баланс <= 0 И (СтарыйБаланс = Неопределено ИЛИ СтарыйБаланс > 0) Тогда
			ОповеститьВладельца("предупреждение",
				"Баланс исчерпан. Пополните баланс в мобильном приложении.");
			ОповеститьВладельца("занят", Истина);
		КонецЕсли;
	КонецЕсли;

КонецПроцедуры

// Предупреждение: сессия скоро завершится из-за неактивности.
&НаКлиенте
Процедура ОбработатьПредупреждениеСессии(ДанныеОтвета)

	ОставшиесяСекунды = ПолучитьПоле(ДанныеОтвета, "remaining_seconds");
	Если ОставшиесяСекунды <> Неопределено И ОставшиесяСекунды > 0 Тогда
		Минуты = Цел(ОставшиесяСекунды / 60);
		Если Минуты >= 1 Тогда
			ТекстВремени = "" + Минуты + " мин.";
		Иначе
			ТекстВремени = "" + ОставшиесяСекунды + " сек.";
		КонецЕсли;
	Иначе
		ТекстВремени = "несколько минут";
	КонецЕсли;

	ТекстПредупреждения = "Сессия будет автоматически завершена через " + ТекстВремени
		+ " из-за неактивности.<br>Отправьте сообщение для продолжения.";

	ОповеститьВладельца("предупреждение", ТекстПредупреждения);
	ОповеститьВладельца("оповещение", ТекстПредупреждения);

КонецПроцедуры

// Обрабатывает уведомление о завершении сессии из-за неактивности.
&НаКлиенте
Процедура ОбработатьСессияИстекла(ДанныеОтвета)

	СессияИстекла = Истина;
	ОповеститьВладельца("доступность_ввода", Ложь);

	ОповеститьВладельца("предупреждение",
		"Сессия завершена из-за неактивности.<br><a href=""lyra://reconnect"" class=""chat-link"">Начать новую.</a>");

КонецПроцедуры

// Загружает настройки из ответа Роутера (hello_ack / auth_ack).
//
&НаКлиенте
Процедура ЗагрузитьНастройкиИзОтвета(ДанныеОтвета)

	// Токен Напарника — на верхнем уровне
	ТокенНапарника = ПолучитьПоле(ДанныеОтвета, "naparnik_token");
	Если ЗначениеЗаполнено(ТокенНапарника) Тогда
		Владелец.Объект.Токен1СНапарник = ТокенНапарника;
	КонецЕсли;

	// Остальные настройки — в объекте settings
	Настройки = ПолучитьПоле(ДанныеОтвета, "settings");
	Если Настройки = Неопределено Тогда
		Возврат;
	КонецЕсли;

	Значение = ПолучитьПоле(Настройки, "user_name");
	Если ЗначениеЗаполнено(Значение) Тогда
		Владелец.Объект.ИмяПользователяЛира = Значение;
	КонецЕсли;

	Значение = ПолучитьПоле(Настройки, "user_level");
	Если ЗначениеЗаполнено(Значение) Тогда
		Владелец.Объект.УровеньПодготовленностиПользователя = Значение;
	КонецЕсли;

	Значение = ПолучитьПоле(Настройки, "db_name");
	Если ЗначениеЗаполнено(Значение) Тогда
		Владелец.Объект.НазваниеИБ = Значение;
	КонецЕсли;

КонецПроцедуры

// Генерирует QR-код из JWT и выводит в чат.
// QR = mobile_jwt, мобильное приложение сканирует для подключения к каналу сессии.
//
&НаКлиенте
Процедура ПоказатьQR(Знач JWT)

	Base64Картинка = СгенерироватьQRBase64(JWT);

	Если ЗначениеЗаполнено(Base64Картинка) Тогда
		// Base64Строка() в 1С добавляет переводы строк — убираем
		Base64Картинка = СтрЗаменить(Base64Картинка, Символы.ВК, "");
		Base64Картинка = СтрЗаменить(Base64Картинка, Символы.ПС, "");

		HTML = "<div style=""text-align:center;padding:16px;"">"
			+ "<img src=""data:image/png;base64," + Base64Картинка + """ style=""width:200px;height:200px;"" />"
			+ "<div style=""margin-top:8px;color:#888;font-size:0.85em;"">Отсканируйте QR-код в мобильном приложении Лира</div>"
			+ "</div>";
		ОповеститьВладельца("информация", HTML);
	Иначе
		// Fallback: JWT как текст для ручного ввода
		ОповеститьВладельца("предупреждение",
			"Не удалось сгенерировать QR-код. Код для мобильного приложения:<br/>"
			+ "<code style=""font-size:0.7em;word-break:break-all;"">" + JWT + "</code>");
	КонецЕсли;

КонецПроцедуры

&НаСервереБезКонтекста
Функция СгенерироватьQRBase64(Знач Текст)

	Попытка
		SSL = Новый ЗащищенноеСоединениеOpenSSL;
		Соединение = Новый HTTPСоединение("api.qrserver.com", 443, , , , 5, SSL);

		КодированныйТекст = КодироватьСтроку(Текст, СпособКодированияСтроки.КодировкаURL);
		Запрос = Новый HTTPЗапрос("/v1/create-qr-code/?size=256x256&data=" + КодированныйТекст);
		Ответ = Соединение.Получить(Запрос);

		Если Ответ.КодСостояния = 200 Тогда
			Возврат Base64Строка(Ответ.ПолучитьТелоКакДвоичныеДанные());
		КонецЕсли;
	Исключение
	КонецПопытки;

	Возврат "";

КонецФункции

#КонецОбласти

