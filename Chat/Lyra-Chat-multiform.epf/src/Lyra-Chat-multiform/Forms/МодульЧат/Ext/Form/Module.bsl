&НаКлиенте
Процедура ЕХТ_Чат_СобытиеПриНажатии(Знач Элемент, Знач ДанныеСобытия, СтандартнаяОбработка) Экспорт

	ВнешнийОбъект = ДанныеСобытия["Element"];
	Если ВнешнийОбъект["id"] <> "V8WebAppEventRequestForwarder" Тогда
		Возврат;
	КонецЕсли;

	СтандартнаяОбработка = Ложь;

	СобытиеПриложения = ЕХТ_Структура(
		"Элемент", 		Элемент,
		"ИмяСобытия", 	ВнешнийОбъект.getAttribute("v8eventname"),
		"ИД", 			ВнешнийОбъект.getAttribute("v8uuid"),
		"Значение", 	"");

	ТипДанных = ВнешнийОбъект.getAttribute("v8type");
	Если ТипДанных = "json" Или ТипДанных = "string" Тогда

		СобытиеПриложения.Значение = Общий.ЕХТ_Структура_ИзJSON(ВнешнийОбъект["value"]);

	КонецЕсли;

	Если СобытиеПриложения.ИмяСобытия = "GetFormAttribute" Тогда

		Ответ1С = Владелец[СобытиеПриложения.Значение];
		ЕХТ_Чат_ОтправитьОтвет1С(Элемент, СобытиеПриложения, Ответ1С);

	КонецЕсли;

	Если СобытиеПриложения.ИмяСобытия = "SetFormAttribute" Тогда

		Владелец[СобытиеПриложения.Значение["key"]] = СобытиеПриложения.Значение["value"];
		ЕХТ_Чат_ОтправитьОтвет1С(Элемент, СобытиеПриложения, Неопределено);

	КонецЕсли;

	Если СобытиеПриложения.ИмяСобытия = "Init" Тогда

		Настройки = ЕХТ_Чат_НастройкиПоУмолчанию();
		Размер = Общий.ЕХТ_Свойства_вСтруктуру(СобытиеПриложения.Значение, "Ширина, Высота");
		Ответ1С = ЕХТ_Чат_ПриОткрытии(Элемент, Настройки, Размер);
		ЕХТ_Чат_ОтправитьОтвет1С(Элемент, СобытиеПриложения, Ответ1С);

	КонецЕсли;

	Если СобытиеПриложения.ИмяСобытия = "LoadMessages" Тогда

		Ответ1С = ЕХТ_Чат_ПриЗагрузкеСообщений(Элемент);
		ЕХТ_Чат_ОтправитьОтвет1С(Элемент, СобытиеПриложения, Ответ1С);

	КонецЕсли;

	Если СобытиеПриложения.ИмяСобытия = "Resize" Тогда

		Размер = Общий.ЕХТ_Свойства_вСтруктуру(СобытиеПриложения.Значение, "Ширина, Высота");
		Ответ1С = ЕХТ_Чат_ПриИзмененииРазмера(Элемент, Размер);
		ЕХТ_Чат_ОтправитьОтвет1С(Элемент, СобытиеПриложения, Ответ1С);

	КонецЕсли;

	Если СобытиеПриложения.ИмяСобытия = "AddMessage" Тогда

		Ответ1С = ЕХТ_Чат_ПриДобавленииСообщения(Элемент);
		ЕХТ_Чат_ОтправитьОтвет1С(Элемент, СобытиеПриложения, Ответ1С);

	КонецЕсли;

	Если СобытиеПриложения.ИмяСобытия = "UpdateMessage" Тогда

		Ответ1С = ЕХТ_Чат_ПриОбновленииСообщения(Элемент);
		ЕХТ_Чат_ОтправитьОтвет1С(Элемент, СобытиеПриложения, Ответ1С);

	КонецЕсли;

	Если СобытиеПриложения.ИмяСобытия = "OpenLink" Тогда

		АдресСсылки = Общий.ЕХТ_Свойства_Значение(СобытиеПриложения.Значение, "URL");
		Ответ1С = ЕХТ_Чат_ПриНажатииСсылки(Элемент, АдресСсылки);
		ЕХТ_Чат_ОтправитьОтвет1С(Элемент, СобытиеПриложения, Ответ1С);

	ИначеЕсли СобытиеПриложения.ИмяСобытия = "ButtonClick" Тогда

		ТекстСообщения = Общий.ЕХТ_Свойства_Значение(СобытиеПриложения.Значение, "Текст");
		Ответ1С = ЕХТ_Чат_ПриНажатииКнопки(Элемент, ТекстСообщения);
		ЕХТ_Чат_ОтправитьОтвет1С(Элемент, СобытиеПриложения, Ответ1С);

	ИначеЕсли СобытиеПриложения.ИмяСобытия = "MenuClick" Тогда

		ИДПункта = Общий.ЕХТ_Свойства_Значение(СобытиеПриложения.Значение, "ИД");
		Ответ1С = ЕХТ_Чат_ПриВыбореМеню(Элемент, ИДПункта);
		ЕХТ_Чат_ОтправитьОтвет1С(Элемент, СобытиеПриложения, Ответ1С);

	КонецЕсли;

КонецПроцедуры

&НаКлиенте
Процедура ЕХТ_Чат_ОтправитьОтвет1С(Знач Элемент, Знач СобытиеПриложения, Знач Ответ1С) Экспорт

	Результат = "";

	Если ЗначениеЗаполнено(Ответ1С) Тогда

		ОтветТип = ТипЗнч(Ответ1С);
		Если Общий.ЕХТ_Тип_ЭтоЛюбаяКоллекция(ОтветТип) Тогда
			Результат = Общий.ЕХТ_Значение_вJSON(Ответ1С);

		ИначеЕсли ОтветТип = Тип("ДвоичныеДанные") Тогда
			Результат = Base64Строка(Ответ1С);

		Иначе
			Результат = Общий.ЕХТ_Значение_вXML(Ответ1С);
		КонецЕсли;
	КонецЕсли;

	ЕХТ_Чат_Объект(Элемент).V8Proxy.sendResponse(СобытиеПриложения.ИД, Результат);

КонецПроцедуры

