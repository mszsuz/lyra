#Область ОбработчикиЕХТЧат

&НаКлиенте
Функция ЕХТ_Чат_ПриНажатииКнопки(Знач Элемент, Знач Текст) Экспорт

	Ответ = Новый Структура;
	ТекстСообщения = СокрЛП(Текст);

	// Режим "Прервать" — идёт стрим
	Если Активен() Тогда
		ПрерватьСтрим();

		Если ТекстСообщения = "" Тогда
			// Только abort
			ДанныеСообщения = Новый Структура;
			ДанныеСообщения.Вставить("type", "abort");
			Транспорт.ОтправитьСообщение(ДанныеСообщения);
			ОповеститьВладельца("занят", Ложь);
			Ответ.Вставить("Настройки", ЕХТ_Структура(
				"ПолеВвода", ЕХТ_Структура(
					"КнопкаОтправки", ЕХТ_Структура("Прервать", Ложь))));
			Возврат Ответ;
		КонецЕсли;
		// abort + новый вопрос — продолжаем ниже к отправке
	КонецЕсли;

	// Пустой текст — ничего не делать
	Если ТекстСообщения = "" Тогда
		Возврат Ответ;
	КонецЕсли;

	// Отправка сообщения
	ДанныеСообщения = Новый Структура;
	ДанныеСообщения.Вставить("type", "chat");
	ДанныеСообщения.Вставить("form_id", Сессия.ПолучитьФормИД());
	ДанныеСообщения.Вставить("text", ТекстСообщения);

	Если НЕ Транспорт.ОтправитьСообщение(ДанныеСообщения) Тогда
		ОтложенноеСообщение = ТекстСообщения;
		Сессия.Подключиться();
	КонецЕсли;

	ВывестиВЧатСообщениеПользователя(ЭлементЧат, ТекстСообщения);
	НовыйВопрос();
	ОповеститьВладельца("занят", Истина);
	Ответ.Вставить("ОчиститьПоле", Истина);
	Ответ.Вставить("Настройки", ЕХТ_Структура(
		"ПолеВвода", ЕХТ_Структура(
			"КнопкаОтправки", ЕХТ_Структура("Прервать", Истина))));
	Возврат Ответ;

КонецФункции

&НаКлиенте
Функция ЕХТ_Чат_ПриВыбореМеню(Знач Элемент, Знач ИДПункта) Экспорт

	Результат = Новый Структура;

	Если ИДПункта = "theme_light" Тогда
		НоваяТема = ЕХТ_Чат_СветлаяТемаПоУмолчанию();
		ЕХТ_Чат_УстановитьТему(Элемент, НоваяТема);
		Владелец.Чат1_Настройка_ТемнаяТема = Ложь;

	ИначеЕсли ИДПункта = "theme_dark" Тогда
		НоваяТема = ЕХТ_Чат_ТемнаяТемаПоУмолчанию();
		ЕХТ_Чат_УстановитьТему(Элемент, НоваяТема);
		Владелец.Чат1_Настройка_ТемнаяТема = Истина;

	ИначеЕсли ИДПункта = "settings" Тогда
		ОткрытьФорму("ВнешняяОбработка.ЛираЧат.Форма.Настройки", , Владелец);

	ИначеЕсли ИДПункта = "about" Тогда
		Результат.Вставить("Сообщение", ЕХТ_Чат_НовоеСообщение(
			"**Лира** — ИИ-ассистент для 1С:Предприятие" + Символы.ПС
			+ Владелец.Элементы.Версия.Заголовок,
			"Информация", "О программе"));

	КонецЕсли;

	Возврат Результат;

КонецФункции

&НаКлиенте
Функция ЕХТ_Чат_ПриОткрытии(Знач Элемент, Знач Настройки, Знач Размер) Экспорт

	Результат = ЕХТ_Структура(
		"Настройки", Настройки,
		"Сообщения", Новый Массив);

	Если Элемент = Владелец.Элементы.Чат1 Тогда
		Результат.Настройки.Сообщения.Автосвертка = Владелец.Чат1_Настройка_Автосвертка;
		Результат.Настройки.Аватары.Видимость = Владелец.Чат1_Настройка_Аватары;
		Если Владелец.Чат1_Настройка_ТемнаяТема Тогда
			ГлубокийМерж(Результат.Настройки, ЕХТ_Чат_ТемнаяТемаПоУмолчанию());
		Иначе
			ГлубокийМерж(Результат.Настройки, ЕХТ_Чат_СветлаяТемаПоУмолчанию());
		КонецЕсли;
	КонецЕсли;

	Возврат Результат;

