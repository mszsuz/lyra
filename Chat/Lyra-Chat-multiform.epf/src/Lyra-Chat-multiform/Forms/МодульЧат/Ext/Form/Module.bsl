// Форматирует миллисекунды в "12 сек" или "1 мин 45 сек"
&НаКлиенте
Функция ФорматВремениПодготовки(МиллисекундПрошло)
	Секунд = Цел(МиллисекундПрошло / 1000);
	Если Секунд < 60 Тогда
		Возврат "" + Формат(Секунд, "ЧН=0; ЧГ=0") + " сек";
	Иначе
		Минут = Цел(Секунд / 60);
		ОстСекунд = Секунд - Минут * 60;
		Возврат "" + Формат(Минут, "ЧН=0; ЧГ=0") + " мин " + Формат(ОстСекунд, "ЧН=0; ЧГ=0") + " сек";
	КонецЕсли;
КонецФункции

// Группирует статусы: ["a","b","b","c"] → [" • a", " • b × 2", " • c"]
&НаКлиенте
Функция СгруппироватьСтатусы()
	Результат = Новый Массив;
	Счётчики = Новый Соответствие;
	Порядок = Новый Массив;
	Для Каждого Статус Из СтатусыИнструментов Цикл
		Кол = Счётчики.Получить(Статус);
		Если Кол = Неопределено Тогда
			Счётчики.Вставить(Статус, 1);
			Порядок.Добавить(Статус);
		Иначе
			Счётчики.Вставить(Статус, Кол + 1);
		КонецЕсли;
	КонецЦикла;
	Для Каждого Статус Из Порядок Цикл
		Кол = Счётчики.Получить(Статус);
		Если Кол > 1 Тогда
			Результат.Добавить(" • " + Статус + " × " + Формат(Кол, "ЧН=0; ЧГ=0"));
		Иначе
			Результат.Добавить(" • " + Статус);
		КонецЕсли;
	КонецЦикла;
	Возврат Результат;
КонецФункции

// Группировка статусов для спойлера — без "Готовлюсь к ответу..."
&НаКлиенте
Функция СгруппироватьСтатусыИнструментов()
	Результат = Новый Массив;
	Счётчики = Новый Соответствие;
	Порядок = Новый Массив;
	Для Каждого Статус Из СтатусыИнструментов Цикл
		Если Статус = "Готовлюсь к ответу..." Тогда
			Продолжить;
		КонецЕсли;
		Кол = Счётчики.Получить(Статус);
		Если Кол = Неопределено Тогда
			Счётчики.Вставить(Статус, 1);
			Порядок.Добавить(Статус);
		Иначе
			Счётчики.Вставить(Статус, Кол + 1);
		КонецЕсли;
	КонецЦикла;
	Для Каждого Статус Из Порядок Цикл
		Кол = Счётчики.Получить(Статус);
		Если Кол > 1 Тогда
			Результат.Добавить(" • " + Статус + " × " + Формат(Кол, "ЧН=0; ЧГ=0"));
		Иначе
			Результат.Добавить(" • " + Статус);
		КонецЕсли;
	КонецЦикла;
	Возврат Результат;
КонецФункции

// Собирает HTML пузыря подготовки: список статусов + пульсация + таймер
&НаКлиенте
Функция СобратьHTMLПодготовки()
	HTML = "<div style=""color: #888; font-size: 0.9em; line-height: 1.8;"">";
	Для Каждого Строка Из СгруппироватьСтатусы() Цикл
		HTML = HTML + "<div>" + Строка + "</div>";
	КонецЦикла;
	Прошло = ТекущаяУниверсальнаяДатаВМиллисекундах() - НачалоПодготовкиОтвета;
	HTML = HTML + "<div style=""margin-top: 4px;"">"
		+ SVGПульсация() + " " + ФорматВремениПодготовки(Прошло)
		+ "</div></div>";
	Возврат HTML;
КонецФункции

// Собирает свёрнутый спойлер подготовки для финального ответа
&НаКлиенте
Функция СобратьСпойлерПодготовки()
	КолвоИнструментов = СтатусыИнструментов.Количество() - 1;

	Если КолвоИнструментов <= 0 Тогда
		Возврат "";
	КонецЕсли;

	Если НачалоПодготовкиОтвета > 0 Тогда
		Прошло = ТекущаяУниверсальнаяДатаВМиллисекундах() - НачалоПодготовкиОтвета;
	Иначе
		Прошло = 0;
	КонецЕсли;

	ЗаголовокСпойлера = "Подготовка: " + ФорматВремениПодготовки(Прошло)
		+ ", инструментов: " + Формат(КолвоИнструментов, "ЧН=0; ЧГ=0");

	HTML = "<details style=""margin-bottom: 8px; color: #999; font-size: 0.85em;"">"
		+ "<summary>" + ЗаголовокСпойлера + "</summary>"
		+ "<div style=""padding: 4px 0 0 16px; line-height: 1.6;"">";
	Для Каждого Строка Из СгруппироватьСтатусыИнструментов() Цикл
		HTML = HTML + "<div>" + Строка + "</div>";
	КонецЦикла;
	HTML = HTML + "</div></details>";
	Возврат HTML;
КонецФункции

#КонецОбласти

