&НаКлиенте
Функция ЕХТ_Чат_ПриНажатииСсылки(Знач Элемент, Знач АдресСсылки) Экспорт

	// Ссылки-действия (lyra/send/...) — текст ссылки отправляется как сообщение
	Если СтрНачинаетсяС(АдресСсылки, "lyra/send/") Тогда
		ТекстСообщения = "«" + СтрЗаменить(Сред(АдресСсылки, СтрДлина("lyra/send/") + 1), "_", " ") + "»";
		Если ЗначениеЗаполнено(ТекстСообщения) Тогда
			ОтправитьСообщениеПользователя(ТекстСообщения);
		КонецЕсли;
		Возврат Новый Структура;
	КонецЕсли;

	// Команды Лиры (lyra://)
	Если АдресСсылки = "lyra://reconnect" Тогда
		ОбработатьКомандуЧата("reconnect");
		Возврат Новый Структура;
	КонецЕсли;

	// Навигационные ссылки 1С (e1cib/) — открываем объект/список/обработку
	Если СтрНачинаетсяС(АдресСсылки, "e1cib/") Тогда
		Попытка
			ПерейтиПоНавигационнойСсылке(АдресСсылки);
		Исключение
			ВывестиВЧатИнформацию(Элемент, "Не удалось открыть ссылку: " + ОписаниеОшибки());
		КонецПопытки;
	КонецЕсли;

	Возврат Новый Структура;

