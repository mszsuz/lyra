
// МодульТранспорт — Centrifugo-клиент + JSON-утилиты на BSL.
// Служебная форма-модуль (не отображается), получается через ПолучитьФорму("МодульТранспорт").
// Объединяет транспорт (WebSocket, publish, ping/pong, watchdog) и JSON-сериализацию.

#Область ПеременныеМодуля

&НаКлиенте
Перем Владелец;             // ссылка на главную форму (для обратной связи)
&НаКлиенте
Перем КлючСоединенияWS;    // ключ для WebSocketКлиентСоединения
&НаКлиенте
Перем ОбщийJWT;             // зашитый JWT для lobby (константа)
&НаКлиенте
Перем ТекущийJWT;           // chat_jwt после hello_ack (или общий JWT при первом connect)
&НаКлиенте
Перем СессияИД;             // session_id из hello_ack
&НаКлиенте
Перем КаналСессии;          // "session:<session_id>"
&НаКлиенте
Перем СтатусПодключения;   // "disconnected" / "lobby" / "session"
&НаКлиенте
Перем СчётчикКоманд;       // auto-increment id для команд Centrifugo
&НаКлиенте
Перем АдресСервера;         // URL WebSocket Centrifugo (для переподключения)
&НаКлиенте
Перем ClientUUID;           // UUID соединения из connect response
&НаКлиенте
Перем ВремяПоследнегоPing;  // мс, время последнего ping от Centrifugo (для watchdog)
&НаКлиенте
Перем WatchdogАктивен;      // Булево, watchdog таймер запущен

#КонецОбласти

#Область ПрограммныйИнтерфейс

// Инициализация модуля.
//
// Параметры:
//  Контекст - Структура - DI-контейнер (Контекст.ГлавнаяФорма.Форма)
//
&НаКлиенте
Процедура Инициализация(Контекст) Экспорт

	Владелец = Контекст.ГлавнаяФорма.Форма;
	КлючСоединенияWS = "LyraChatMultiform_Centrifugo";
	СчётчикКоманд = 0;
	СтатусПодключения = "disconnected";
	ВремяПоследнегоPing = 0;
	WatchdogАктивен = Ложь;
	ОбщийJWT = "eyJhbGciOiJIUzI1NiIsInR5cCI6IkpXVCJ9.eyJzdWIiOiJsb2JieS11c2VyIiwiZXhwIjoyMDg4MzYwNzUzLCJpYXQiOjE3NzMwMDA3NTN9.2as7077BWfd-zmCRCvFRkLBVp4LtyguvZTtGCpL9SMA";

КонецПроцедуры

// Подключается к Centrifugo по WebSocket.
//
&НаКлиенте
Процедура Подключиться(Знач АдресЦентрифуга) Экспорт

	// При повторном подключении — закрываем старое соединение и генерируем новый ключ
	Если ЕстьАктивноеСоединение() Тогда
		Отключиться();
	КонецЕсли;
	КлючСоединенияWS = "LyraChatMultiform_Lobby_" + Строка(Новый УникальныйИдентификатор);

	Если НЕ ЗначениеЗаполнено(АдресЦентрифуга) Тогда
		АдресЦентрифуга = "ws://localhost:11000/connection/websocket";
	КонецЕсли;

	АдресСервера = АдресЦентрифуга;
	ТекущийJWT = ОбщийJWT;
	СессияИД = Неопределено;
	КаналСессии = "";
	СтатусПодключения = "connecting";

	ОткрытьВебСокет(АдресЦентрифуга);

КонецПроцедуры

// Возвращает Истина, если WebSocket-соединение существует.
//
&НаКлиенте
Функция Подключен() Экспорт
	Возврат ЕстьАктивноеСоединение();
КонецФункции

&НаКлиенте
Функция ЕстьАктивноеСоединение()
	Попытка
		Соединение = WebSocketКлиентСоединения.ПолучитьСоединение(КлючСоединенияWS);
		Возврат Соединение <> Неопределено;
	Исключение
		Возврат Ложь;
	КонецПопытки;
КонецФункции

// Отправляет hello в session:lobby с данными о базе.
//
&НаКлиенте
Процедура ОтправитьHello(Знач ДанныеОБазе) Экспорт
	ДанныеОБазе.Вставить("type", "hello");
	Опубликовать("session:lobby", ДанныеОБазе);
КонецПроцедуры

// Отправляет сообщение (publish) в канал сессии.
//
&НаКлиенте
Функция ОтправитьСообщение(Знач Данные) Экспорт

	Если НЕ ЗначениеЗаполнено(КаналСессии) Тогда
		ОповеститьВладельца("error", "Нет канала сессии.");
		Возврат Ложь;
	КонецЕсли;

	Если ТипЗнч(Данные) = Тип("Строка") Тогда
		Попытка
			Данные = ПрочитатьJSONИзСтроки(Данные);
		Исключение
		КонецПопытки;
	КонецЕсли;

	Возврат Опубликовать(КаналСессии, Данные);

КонецФункции

// Переподключается к Centrifugo с новым JWT (chat_jwt).
//
&НаКлиенте
Процедура Переподключиться(Знач JWT) Экспорт

	ТекущийJWT = JWT;
	СтатусПодключения = "disconnected";

	Попытка
		Соединение = WebSocketКлиентСоединения.ПолучитьСоединение(КлючСоединенияWS);
		Если Соединение <> Неопределено Тогда
			Соединение.Закрыть();
		КонецЕсли;
	Исключение
	КонецПопытки;

	КлючСоединенияWS = "LyraChatMultiform_Session_" + Строка(Новый УникальныйИдентификатор);
	ОткрытьВебСокет(АдресСервера);

КонецПроцедуры

// Отключается от Centrifugo.
//
&НаКлиенте
Процедура Отключиться() Экспорт

	Попытка
		Соединение = WebSocketКлиентСоединения.ПолучитьСоединение(КлючСоединенияWS);
		Если Соединение <> Неопределено Тогда
			Соединение.Закрыть();
		КонецЕсли;
	Исключение
	КонецПопытки;

	СтатусПодключения = "disconnected";

КонецПроцедуры

// Возвращает текущий статус подключения.
//
&НаКлиенте
Функция ПолучитьСтатусПодключения() Экспорт
	Возврат СтатусПодключения;
КонецФункции

// Устанавливает данные сессии после получения hello_ack.
//
&НаКлиенте
Процедура УстановитьСессию(Знач НовыйСессияИД) Экспорт
	СессияИД = НовыйСессияИД;
	КаналСессии = "session:" + СессияИД;
КонецПроцедуры

#КонецОбласти

#Область JSON

// Разбирает строку JSON.
// Основной путь: ПрочитатьЗначениеJSON (клиент, возвращает Структура).
// Fallback: ПрочитатьJSON на сервере (возвращает Соответствие).
//
&НаКлиенте
Функция РазобратьJSON(Знач СтрокаJSON) Экспорт

	Если НЕ ЗначениеЗаполнено(СтрокаJSON) Тогда
		Возврат Новый Структура;
	КонецЕсли;

	Попытка
		Возврат ПрочитатьЗначениеJSON(СтрокаJSON);
	Исключение
		Попытка
			Возврат РазобратьJSON_Сервер(СтрокаJSON);
		Исключение
			Возврат Новый Структура;
		КонецПопытки;
	КонецПопытки;

КонецФункции

// Сериализует значение в JSON-строку.
//
&НаКлиенте
Функция СобратьJSON(Значение) Экспорт

	Попытка
		Возврат ЗаписатьЗначениеJSON(Значение);
	Исключение
		Попытка
			Возврат СобратьJSON_Сервер(Значение);
		Исключение
			Возврат "{}";
		КонецПопытки;
	КонецПопытки;

КонецФункции

// Экранирует спецсимволы в строке для безопасной вставки в JSON.
//
&НаКлиенте
Функция ЭкранироватьJSON(Текст) Экспорт

	Результат = СтрЗаменить(Текст, "\", "\\");
	Результат = СтрЗаменить(Результат, """", "\""");
	Результат = СтрЗаменить(Результат, Символы.ПС, "\n");
	Результат = СтрЗаменить(Результат, Символы.ВК, "");
	Результат = СтрЗаменить(Результат, Символы.Таб, "\t");

	Возврат Результат;

КонецФункции

// Конвертирует 1С-значение в JSON-совместимый тип.
//
&НаКлиенте
Функция ЗначениеДляJSON(ИсходноеЗначение) Экспорт

	Если ИсходноеЗначение = Неопределено ИЛИ ИсходноеЗначение = Null Тогда
		Возврат Null;
	ИначеЕсли ТипЗнч(ИсходноеЗначение) = Тип("Булево")
		ИЛИ ТипЗнч(ИсходноеЗначение) = Тип("Число")
		ИЛИ ТипЗнч(ИсходноеЗначение) = Тип("Строка") Тогда
		Возврат ИсходноеЗначение;
	ИначеЕсли ТипЗнч(ИсходноеЗначение) = Тип("Дата") Тогда
		Возврат Формат(ИсходноеЗначение, "ДФ=yyyy-MM-ddTHH:mm:ss");
	Иначе
		Возврат Строка(ИсходноеЗначение);
	КонецЕсли;

КонецФункции

// Проверяет что значение является JSON-объектом (Структура или Соответствие).
//
&НаКлиенте
Функция ЭтоОбъектJSON(Значение) Экспорт
	Возврат ТипЗнч(Значение) = Тип("Структура") ИЛИ ТипЗнч(Значение) = Тип("Соответствие");
КонецФункции

// Получает значение поля из Структуры или Соответствия.
//
&НаКлиенте
Функция ПолучитьПоле(Данные, Ключ) Экспорт

	Если ТипЗнч(Данные) = Тип("Структура") Тогда
		Значение = Неопределено;
		Данные.Свойство(Ключ, Значение);
		Возврат Значение;
	ИначеЕсли ТипЗнч(Данные) = Тип("Соответствие") Тогда
		Возврат Данные.Получить(Ключ);
	Иначе
		Возврат Неопределено;
	КонецЕсли;

КонецФункции

#КонецОбласти

#Область ОбработчикиWebSocket

&НаКлиенте
Процедура WS_ПриОткрытии(Соединение) Экспорт
	ОтправитьConnect(Соединение);
КонецПроцедуры

&НаКлиенте
Процедура WS_ПриЗакрытии(Соединение, КодЗакрытия) Экспорт

	ОстановитьWatchdog();
	ПредыдущийСтатус = СтатусПодключения;
	СтатусПодключения = "disconnected";

	Если ПредыдущийСтатус <> "disconnected" Тогда
		ОповеститьВладельца("closed",
			Новый Структура("КодЗакрытия, ПредыдущийСтатус", КодЗакрытия, ПредыдущийСтатус));
	КонецЕсли;

КонецПроцедуры

&НаКлиенте
Процедура WS_ПриОшибке(Соединение, КодОшибки, Описание) Экспорт

	ОстановитьWatchdog();

	Если СтатусПодключения = "disconnected" Тогда
		Возврат;
	КонецЕсли;

	СтатусПодключения = "disconnected";
	ТекстОшибки = СокрЛП(Описание);
	Если ПустаяСтрока(ТекстОшибки) Тогда
		ТекстОшибки = "Не удалось подключиться";
	Иначе
		ТекстОшибки = "Ошибка подключения: " + ТекстОшибки;
	КонецЕсли;
	ОповеститьВладельца("error", ТекстОшибки);

КонецПроцедуры

&НаКлиенте
Процедура WS_ПриПолученииСообщения(Соединение, Сообщение) Экспорт

	ТекстСообщения = "";
	Если ТипЗнч(Сообщение) = Тип("Строка") Тогда
		ТекстСообщения = Сообщение;
	ИначеЕсли ТипЗнч(Сообщение) = Тип("ДвоичныеДанные") Тогда
		ТекстСообщения = ПолучитьСтрокуИзДвоичныхДанных(Сообщение);
	Иначе
		Возврат;
	КонецЕсли;

	// Мульти-JSON: Centrifugo может слать несколько JSON в одном WS-фрейме через \n
	Строки = СтрРазделить(ТекстСообщения, Символы.ПС, Ложь);

	Для Каждого СтрокаJSON Из Строки Цикл

		СтрокаJSON = СокрЛП(СтрокаJSON);
		Если НЕ ЗначениеЗаполнено(СтрокаJSON) Тогда
			Продолжить;
		КонецЕсли;

		// Ping: пустой JSON → ответить pong
		Если СтрокаJSON = "{}" Тогда
			ВремяПоследнегоPing = ТекущаяУниверсальнаяДатаВМиллисекундах();
			Попытка
				Соединение.ОтправитьСообщение("{}");
			Исключение
			КонецПопытки;
			Продолжить;
		КонецЕсли;

		Попытка
			СообщениеОбъект = ПрочитатьJSONИзСтроки(СтрокаJSON);
		Исключение
			Продолжить;
		КонецПопытки;

		Если ТипЗнч(СообщениеОбъект) <> Тип("Соответствие") Тогда
			Продолжить;
		КонецЕсли;

		// Ответ на команду (есть id)
		Если СообщениеОбъект["id"] <> Неопределено Тогда
			ОбработатьОтветКоманды(СообщениеОбъект);
			Продолжить;
		КонецЕсли;

		// Push-сообщение (нет id, есть push)
		ПушДанные = СообщениеОбъект["push"];
		Если ПушДанные = Неопределено Тогда
			Продолжить;
		КонецЕсли;

		// Развернуть pub-конверт
		ПабДанные = ПушДанные["pub"];
		Если ПабДанные <> Неопределено Тогда
			Данные = ПабДанные["data"];
			Если Данные <> Неопределено Тогда
				ДанныеJSON = ЗаписатьJSONВСтроку(Данные);
				ОповеститьВладельца("message", ДанныеJSON);
			КонецЕсли;
		КонецЕсли;

		// Presence: join/leave участника канала
		ДанныеJoin = ПушДанные["join"];
		Если ДанныеJoin <> Неопределено Тогда
			ОповеститьВладельца("presence_join", ДанныеJoin);
			Продолжить;
		КонецЕсли;

		ДанныеLeave = ПушДанные["leave"];
		Если ДанныеLeave <> Неопределено Тогда
			ОповеститьВладельца("presence_leave", ДанныеLeave);
			Продолжить;
		КонецЕсли;

	КонецЦикла;

КонецПроцедуры

#КонецОбласти

#Область СлужебныеПроцедуры

&НаКлиенте
Процедура ОткрытьВебСокет(Знач URLВебСокет)

	Попытка
		СтароеСоединение = WebSocketКлиентСоединения.ПолучитьСоединение(КлючСоединенияWS);
		Если СтароеСоединение <> Неопределено Тогда
			СтароеСоединение.Закрыть();
		КонецЕсли;
	Исключение
	КонецПопытки;

	ОбработчикиСокета = Новый ОбработчикиWebSocketКлиентСоединения;
	ОбработчикиСокета.Модуль = ЭтотОбъект;
	ОбработчикиСокета.ОбработчикОткрытияСоединения = "WS_ПриОткрытии";
	ОбработчикиСокета.ОбработчикЗакрытияСоединения = "WS_ПриЗакрытии";
	ОбработчикиСокета.ОбработчикПолученияСообщения = "WS_ПриПолученииСообщения";
	ОбработчикиСокета.ОбработчикОшибки = "WS_ПриОшибке";

	ПараметрыСоединения = Новый ПараметрыWebSocketКлиентСоединения;

	Попытка
		WebSocketКлиентСоединения.ОткрытьСоединение(КлючСоединенияWS, URLВебСокет,
			ОбработчикиСокета, ПараметрыСоединения);
	Исключение
		ОповеститьВладельца("error",
			"Не удалось подключиться к Centrifugo: " + ОписаниеОшибки());
	КонецПопытки;

КонецПроцедуры

&НаКлиенте
Процедура ОтправитьConnect(Соединение)

	JWT = ТекущийJWT;
	Если НЕ ЗначениеЗаполнено(JWT) Тогда
		JWT = ОбщийJWT;
	КонецЕсли;

	ИДКоманды = СледующийИДКоманды();
	КомандаJSON = "{""id"":" + Формат(ИДКоманды, "ЧГ=0")
		+ ",""connect"":{""token"":""" + JWT + """}}";

	Попытка
		Соединение.ОтправитьСообщение(КомандаJSON);
	Исключение
		ОповеститьВладельца("error",
			"Ошибка отправки connect: " + ОписаниеОшибки());
	КонецПопытки;

КонецПроцедуры

&НаКлиенте
Процедура ОбработатьОтветКоманды(Объект)

	ОшибкаОтвета = Объект["error"];
	Если ОшибкаОтвета <> Неопределено Тогда
		КодОшибки = ОшибкаОтвета["code"];
		СообщениеОшибки = ОшибкаОтвета["message"];
		ОповеститьВладельца("error",
			"Ошибка Centrifugo: " + Формат(КодОшибки, "ЧН=0; ЧГ=0") + " — " + СообщениеОшибки);
		Возврат;
	КонецЕсли;

	КоннектДанные = Объект["connect"];
	Если КоннектДанные <> Неопределено Тогда
		ClientUUID = КоннектДанные["client"];

		Если ТекущийJWT = ОбщийJWT Тогда
			СтатусПодключения = "lobby";
		Иначе
			СтатусПодключения = "session";
		КонецЕсли;

		ВремяПоследнегоPing = ТекущаяУниверсальнаяДатаВМиллисекундах();
		ЗапуститьWatchdog();

		ОповеститьВладельца("connected",
			Новый Структура("client, status, subs",
				ClientUUID, СтатусПодключения, КоннектДанные["subs"]));
		Возврат;
	КонецЕсли;

КонецПроцедуры

&НаКлиенте
Функция Опубликовать(Знач Канал, Знач Данные)

	Соединение = WebSocketКлиентСоединения.ПолучитьСоединение(КлючСоединенияWS);
	Если Соединение = Неопределено Тогда
		ОповеститьВладельца("error", "Нет соединения с Centrifugo.");
		Возврат Ложь;
	КонецЕсли;

	ИДКоманды = СледующийИДКоманды();

	ПубликацияПараметры = Новый Соответствие;
	ПубликацияПараметры.Вставить("channel", Канал);
	ПубликацияПараметры.Вставить("data", Данные);

	Команда = Новый Соответствие;
	Команда.Вставить("id", ИДКоманды);
	Команда.Вставить("publish", ПубликацияПараметры);

	КомандаJSON = ЗаписатьJSONВСтроку(Команда);

	Попытка
		Соединение.ОтправитьСообщение(КомандаJSON);
		Возврат Истина;
	Исключение
		ОповеститьВладельца("error", "Ошибка отправки: " + ОписаниеОшибки());
		Возврат Ложь;
	КонецПопытки;

КонецФункции

&НаКлиенте
Функция СледующийИДКоманды()
	СчётчикКоманд = СчётчикКоманд + 1;
	Возврат СчётчикКоманд;
КонецФункции

// Watchdog — проверка живости WebSocket по ping от Centrifugo.

&НаКлиенте
Процедура ЗапуститьWatchdog()
	Если НЕ WatchdogАктивен Тогда
		WatchdogАктивен = Истина;
		ПодключитьОбработчикОжидания("ПроверитьWatchdog", 10, Ложь);
	КонецЕсли;
КонецПроцедуры

&НаКлиенте
Процедура ОстановитьWatchdog()
	Если WatchdogАктивен Тогда
		WatchdogАктивен = Ложь;
		ОтключитьОбработчикОжидания("ПроверитьWatchdog");
	КонецЕсли;
КонецПроцедуры

&НаКлиенте
Процедура ПроверитьWatchdog() Экспорт

	Если СтатусПодключения = "disconnected" Тогда
		ОстановитьWatchdog();
		Возврат;
	КонецЕсли;

	Если ВремяПоследнегоPing = 0 Тогда
		Возврат;
	КонецЕсли;

	ПрошлоМс = ТекущаяУниверсальнаяДатаВМиллисекундах() - ВремяПоследнегоPing;

	Если ПрошлоМс > 300000 Тогда
		ОстановитьWatchdog();
		СтатусПодключения = "disconnected";

		Попытка
			Соединение = WebSocketКлиентСоединения.ПолучитьСоединение(КлючСоединенияWS);
			Если Соединение <> Неопределено Тогда
				Соединение.Закрыть();
			КонецЕсли;
		Исключение
		КонецПопытки;

		ОповеститьВладельца("closed",
			Новый Структура("КодЗакрытия, ПредыдущийСтатус", 0, "session"));
	КонецЕсли;

КонецПроцедуры

&НаКлиенте
Процедура ОповеститьВладельца(ИмяСобытия, Данные)

	Если Владелец <> Неопределено Тогда
		Попытка
			Владелец.ОбработатьСобытиеМодуля("Транспорт", ИмяСобытия, Данные);
		Исключение
			Сообщить("ОповеститьВладельца: " + ИмяСобытия + " — " + ОписаниеОшибки());
		КонецПопытки;
	КонецЕсли;

КонецПроцедуры

