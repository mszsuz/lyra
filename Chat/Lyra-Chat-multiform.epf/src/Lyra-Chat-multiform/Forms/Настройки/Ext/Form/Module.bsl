
// Форма Настройки — редактирование пользовательских настроек Лиры.
// Открывается из главной формы или по клику на индикатор Напарника.
// При сохранении отправляет настройки в Роутер через Транспорт.

&НаКлиенте
Процедура ПриОткрытии(Отказ)
	
	// Перенос значений реквизитов из главной Формы.
	ЗаполнитьЗначенияСвойств(ЭтотОбъект.Объект, ЭтотОбъект.ВладелецФормы.Объект);
	
	ЭтотОбъект.Объект.Токен1СНапарник = ЭтотОбъект.ВладелецФормы.Объект.Токен1СНапарник;
	ЭтотОбъект.Объект.ИмяПользователяЛира = ЭтотОбъект.ВладелецФормы.Объект.ИмяПользователяЛира;
	ЭтотОбъект.Объект.УровеньПодготовленностиПользователя = ЭтотОбъект.ВладелецФормы.Объект.УровеньПодготовленностиПользователя;
	ЭтотОбъект.Объект.НазваниеИБ = ЭтотОбъект.ВладелецФормы.Объект.НазваниеИБ;

КонецПроцедуры

&НаКлиенте
Процедура КомандаСохранитьНастройки(Команда)

	ФормаВладелец = ЭтотОбъект.ВладелецФормы;
	Если ФормаВладелец = Неопределено Тогда
		Возврат;
	КонецЕсли;

	// Сохраняем в реквизиты объекта владельца
	ФормаВладелец.Объект.Токен1СНапарник = ЭтотОбъект.Объект.Токен1СНапарник;
	ФормаВладелец.Объект.ИмяПользователяЛира = ЭтотОбъект.Объект.ИмяПользователяЛира;
	ФормаВладелец.Объект.УровеньПодготовленностиПользователя = ЭтотОбъект.Объект.УровеньПодготовленностиПользователя;
	ФормаВладелец.Объект.НазваниеИБ = ЭтотОбъект.Объект.НазваниеИБ;

	// Отправить в Роутер для сохранения
	ФормаВладелец.ОтправитьНастройкиВРоутер();

	Закрыть();

КонецПроцедуры

&НаКлиенте
Процедура КомандаПроверитьТокенНапарника(Команда)

	ФормаВладелец = ЭтотОбъект.ВладелецФормы;
	Если ФормаВладелец = Неопределено Тогда
		Возврат;
	КонецЕсли;

	// Проверить доступность с текущим (ещё не сохранённым) токеном
	ФормаВладелец.МодульНапарник.ПроверитьДоступность(ЭтотОбъект.Объект.Токен1СНапарник);

КонецПроцедуры




