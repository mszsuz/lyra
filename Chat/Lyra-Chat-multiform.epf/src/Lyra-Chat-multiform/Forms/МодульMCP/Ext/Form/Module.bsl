
// МодульMCP — серверные обработчики инструментов Лиры.
// Служебная форма-модуль (не отображается), получается через ПолучитьФорму("МодульMCP").
//
// Обработка tool_call/tool_result — в главной форме (Форма).
// Этот модуль только выполняет инструменты: получает имя + параметры → возвращает результат.

#Область ПрограммныйИнтерфейс

// Выполняет инструмент по имени.
//
// Параметры:
//  ИмяИнструмента      - Строка - имя инструмента (lyra_data_query, lyra_data_eval, lyra_meta_list, lyra_data_exec, lyra_nav_resolve, lyra_diag_read_log)
//  ПараметрыИнструмента - Структура, Соответствие - параметры вызова
//
// Возвращаемое значение:
//  Строка - результат выполнения (JSON-строка или текст)
//
&НаКлиенте
Функция ВыполнитьИнструмент(Знач ИмяИнструмента, Знач ПараметрыИнструмента) Экспорт

	Если ПараметрыИнструмента = Неопределено Тогда
		ПараметрыИнструмента = Новый Структура;
	КонецЕсли;

	Результат = ВыполнитьИнструментНаСервере(ИмяИнструмента, ПараметрыИнструмента);

	// Сериализуем результат в текст для отправки
	Если ТипЗнч(Результат) = Тип("Строка") Тогда
		Возврат Результат;
	КонецЕсли;

	Попытка
		Возврат ЗаписатьЗначениеJSON(Результат);
	Исключение
		Попытка
			Возврат СериализоватьВJSON_Сервер(Результат);
		Исключение
			Возврат Строка(Результат);
		КонецПопытки;
	КонецПопытки;

КонецФункции

#КонецОбласти

#Область ОбработчикиИнструментов

// Диспетчер вызова обработчика на сервере.
//
&НаСервере
Функция ВыполнитьИнструментНаСервере(Знач ИмяИнструмента, Знач Ввод)

	Если ИмяИнструмента = "lyra_data_query" Тогда
		Возврат Обработчик_lyra_data_query(Ввод);
	ИначеЕсли ИмяИнструмента = "lyra_meta_list" Тогда
		Возврат Обработчик_lyra_meta_list(Ввод);
	ИначеЕсли ИмяИнструмента = "lyra_data_eval" Тогда
		Возврат Обработчик_lyra_data_eval(Ввод);
	ИначеЕсли ИмяИнструмента = "lyra_data_exec" Тогда
		Возврат Обработчик_lyra_data_exec(Ввод);
	ИначеЕсли ИмяИнструмента = "lyra_nav_resolve" Тогда
		Возврат Обработчик_lyra_nav_resolve(Ввод);
	ИначеЕсли ИмяИнструмента = "lyra_diag_read_log" Тогда
		Возврат Обработчик_lyra_diag_read_log(Ввод);
	ИначеЕсли ИмяИнструмента = "lyra_meta_describe" Тогда
		Возврат Обработчик_lyra_meta_describe(Ввод);
	ИначеЕсли ИмяИнструмента = "lyra_data_read" Тогда
		Возврат Обработчик_lyra_data_read(Ввод);
	Иначе
		Возврат Новый Структура("error", "Неизвестный инструмент: " + ИмяИнструмента);
	КонецЕсли;

КонецФункции

// Выполнение запроса к информационной базе на языке 1С.
//
&НаСервере
Функция Обработчик_lyra_data_query(ПарамыЗапроса)

	ТекстЗапроса = ПолучитьПараметр(ПарамыЗапроса, "query");
	Если ТекстЗапроса = Неопределено Тогда
		Возврат Новый Структура("error", "Отсутствует параметр query");
	КонецЕсли;

	// Валидация синтаксиса запроса без обращения к БД
	Попытка
		Схема = Новый СхемаЗапроса;
		Схема.УстановитьТекстЗапроса(ТекстЗапроса);
	Исключение
		Возврат Новый Структура("error", "Ошибка синтаксиса запроса: " + ОписаниеОшибки()
			+ ". Проверь имена таблиц и полей через lyra_meta_list — в базе могут быть доработки и расширения.");
	КонецПопытки;

	Попытка
		Запрос = Новый Запрос(ТекстЗапроса);

		ПараметрыВвода = ПолучитьПараметр(ПарамыЗапроса, "params");
		Если ПараметрыВвода <> Неопределено Тогда
			УстановитьПараметрыЗапроса(Запрос, ПараметрыВвода);
		КонецЕсли;

		Результат = Запрос.Выполнить();

		Если Результат.Пустой() Тогда
			Возврат Новый Структура("data,columns,count", Новый Массив, Новый Массив, 0);
		КонецЕсли;

		Колонки = Новый Массив;
		Для Каждого Колонка Из Результат.Колонки Цикл
			Колонки.Добавить(Колонка.Имя);
		КонецЦикла;

		Данные = Новый Массив;
		Выборка = Результат.Выбрать();
		Счетчик = 0;

		Пока Выборка.Следующий() И Счетчик <= 100 Цикл
			СтрокаДанных = Новый Структура;
			Для Каждого ИмяКолонки Из Колонки Цикл
				Значение = Выборка[ИмяКолонки];
				СтрокаДанных.Вставить(ИмяКолонки, ЗначениеДляJSON(Значение));
			КонецЦикла;
			Данные.Добавить(СтрокаДанных);
			Счетчик = Счетчик + 1;
		КонецЦикла;

		Если Данные.Количество() > 100 Тогда
			Возврат Новый Структура("error",
				"Запрос вернул " + Данные.Количество() + " строк — слишком много. "
				+ "Уточни запрос: добавь ПЕРВЫЕ N, сузь условия ГДЕ, добавь СГРУППИРОВАТЬ ПО или уменьши количество колонок.");
		КонецЕсли;

		Возврат Новый Структура("data,columns,count", Данные, Колонки, Данные.Количество());

	Исключение
		Возврат Новый Структура("error", "Ошибка запроса: " + ОписаниеОшибки());
	КонецПопытки;

КонецФункции

// Получение списка метаданных по типу.
//
&НаСервере
Функция Обработчик_lyra_meta_list(ПарамыЗапроса)

	ТипМета = ПолучитьПараметр(ПарамыЗапроса, "type");
	Если ТипМета = Неопределено Тогда ТипМета = ""; КонецЕсли;

	Результат = Новый Массив;

	Попытка
		Если ТипМета = "" ИЛИ ТипМета = "Catalogs" Тогда
			Для Каждого М Из Метаданные.Справочники Цикл
				Результат.Добавить(Новый Структура("type,name,synonym",
					"Справочник", М.Имя, Строка(М.Синоним)));
			КонецЦикла;
		КонецЕсли;

		Если ТипМета = "" ИЛИ ТипМета = "Documents" Тогда
			Для Каждого М Из Метаданные.Документы Цикл
				Результат.Добавить(Новый Структура("type,name,synonym",
					"Документ", М.Имя, Строка(М.Синоним)));
			КонецЦикла;
		КонецЕсли;

		Если ТипМета = "" ИЛИ ТипМета = "InformationRegisters" Тогда
			Для Каждого М Из Метаданные.РегистрыСведений Цикл
				Результат.Добавить(Новый Структура("type,name,synonym",
					"РегистрСведений", М.Имя, Строка(М.Синоним)));
			КонецЦикла;
		КонецЕсли;

		Если ТипМета = "" ИЛИ ТипМета = "AccumulationRegisters" Тогда
			Для Каждого М Из Метаданные.РегистрыНакопления Цикл
				Результат.Добавить(Новый Структура("type,name,synonym",
					"РегистрНакопления", М.Имя, Строка(М.Синоним)));
			КонецЦикла;
		КонецЕсли;

		Если ТипМета = "" ИЛИ ТипМета = "AccountingRegisters" Тогда
			Для Каждого М Из Метаданные.РегистрыБухгалтерии Цикл
				Результат.Добавить(Новый Структура("type,name,synonym",
					"РегистрБухгалтерии", М.Имя, Строка(М.Синоним)));
			КонецЦикла;
		КонецЕсли;

		Возврат Результат;

	Исключение
		Возврат Новый Структура("error", "Ошибка метаданных: " + ОписаниеОшибки());
	КонецПопытки;

КонецФункции

// Вычисление выражения 1С.
//
&НаСервере
Функция Обработчик_lyra_data_eval(ПарамыЗапроса)

	Выражение = ПолучитьПараметр(ПарамыЗапроса, "expression");
	Если Выражение = Неопределено Тогда
		Возврат Новый Структура("error", "Отсутствует параметр expression");
	КонецЕсли;

	Попытка
		Результат = Вычислить(Выражение);
		Возврат Новый Структура("result", ЗначениеДляJSON(Результат));
	Исключение
		Возврат Новый Структура("error", "Ошибка вычисления: " + ОписаниеОшибки());
	КонецПопытки;

КонецФункции

// Выполнение произвольного блока кода на языке 1С.
//
&НаСервере
Функция Обработчик_lyra_data_exec(ПарамыЗапроса)

	Код = ПолучитьПараметр(ПарамыЗапроса, "code");
	Если Код = Неопределено Тогда
		Возврат Новый Структура("error", "Отсутствует параметр code");
	КонецЕсли;

	// Переменная для возврата значения из кода
	Результат = Неопределено;

	// Транзакция-песочница: любые изменения данных будут отменены
	НачатьТранзакцию();
	Попытка
		Выполнить(Код);
		ОтменитьТранзакцию();
	Исключение
		ОтменитьТранзакцию();
		Возврат Новый Структура("error", "Ошибка выполнения: " + ОписаниеОшибки());
	КонецПопытки;

	Если Результат <> Неопределено Тогда
		Возврат Новый Структура("result", ЗначениеДляJSON(Результат));
	Иначе
		Возврат Новый Структура("result", "Выполнено");
	КонецЕсли;

КонецФункции

// Получение навигационной ссылки на объект или список.
//
&НаСервере
Функция Обработчик_lyra_nav_resolve(ПарамыЗапроса)

	ТипОбъекта = ПолучитьПараметр(ПарамыЗапроса, "type");
	ИмяОбъекта = ПолучитьПараметр(ПарамыЗапроса, "name");

	Если ТипОбъекта = Неопределено ИЛИ ИмяОбъекта = Неопределено Тогда
		Возврат Новый Структура("error", "Отсутствуют параметры type и name");
	КонецЕсли;

	СсылкаОбъекта = ПолучитьПараметр(ПарамыЗапроса, "ref");

	Попытка
		ПолноеИмя = ТипОбъекта + "." + ИмяОбъекта;

		Если СсылкаОбъекта = Неопределено ИЛИ СсылкаОбъекта = "" Тогда
			// Ссылка на список
			Возврат Новый Структура("url,description",
				"e1cib/list/" + ПолноеИмя,
				"Список: " + ПолноеИмя);
		КонецЕсли;

		// Ссылка на конкретный объект — ищем по строковому представлению
		МенеджерОбъекта = Неопределено;
		Если ТипОбъекта = "Справочник" Тогда
			МенеджерОбъекта = Справочники[ИмяОбъекта];
		ИначеЕсли ТипОбъекта = "Документ" Тогда
			МенеджерОбъекта = Документы[ИмяОбъекта];
		Иначе
			// Для других типов — формируем ссылку по шаблону
			Возврат Новый Структура("url,description",
				"e1cib/data/" + ПолноеИмя + "?ref=" + СсылкаОбъекта,
				ПолноеИмя);
		КонецЕсли;

		// Пробуем найти по UUID
		Попытка
			Ссылка = МенеджерОбъекта.ПолучитьСсылку(Новый УникальныйИдентификатор(СсылкаОбъекта));
			Если Ссылка.ПолучитьОбъект() = Неопределено Тогда
				Возврат Новый Структура("error", "Объект не найден: " + СсылкаОбъекта);
			КонецЕсли;
			НавСсылка = ПолучитьНавигационнуюСсылку(Ссылка);
		Исключение
			// Не UUID — пробуем как строковое представление
			НавСсылка = "e1cib/data/" + ПолноеИмя + "?ref=" + СсылкаОбъекта;
		КонецПопытки;

		Возврат Новый Структура("url,description", НавСсылка, Строка(Ссылка));

	Исключение
		Возврат Новый Структура("error", "Ошибка получения ссылки: " + ОписаниеОшибки());
	КонецПопытки;

КонецФункции

// Чтение журнала регистрации с фильтрами.
//
&НаСервере
Функция Обработчик_lyra_diag_read_log(ПарамыЗапроса)

	Отбор = Новый Структура;

	// Период
	НачалоПериода = ПолучитьПараметр(ПарамыЗапроса, "start_date");
	КонецПериода = ПолучитьПараметр(ПарамыЗапроса, "end_date");

	Если НачалоПериода <> Неопределено И НачалоПериода <> "" Тогда
		Попытка
			Отбор.Вставить("НачалоПериода", XMLЗначение(Тип("Дата"), НачалоПериода));
		Исключение
		КонецПопытки;
	КонецЕсли;

	Если КонецПериода <> Неопределено И КонецПериода <> "" Тогда
		Попытка
			Отбор.Вставить("КонецПериода", XMLЗначение(Тип("Дата"), КонецПериода));
		Исключение
		КонецПопытки;
	КонецЕсли;

	// Уровень (Ошибка, Предупреждение, Информация, Примечание)
	Уровень = ПолучитьПараметр(ПарамыЗапроса, "level");
	Если Уровень <> Неопределено И Уровень <> "" Тогда
		МассивУровней = Новый Массив;
		Если СтрНайти(Уровень, "Ошибка") > 0 ИЛИ СтрНайти(Уровень, "error") > 0 Тогда
			МассивУровней.Добавить(УровеньЖурналаРегистрации.Ошибка);
		КонецЕсли;
		Если СтрНайти(Уровень, "Предупреждение") > 0 ИЛИ СтрНайти(Уровень, "warning") > 0 Тогда
			МассивУровней.Добавить(УровеньЖурналаРегистрации.Предупреждение);
		КонецЕсли;
		Если СтрНайти(Уровень, "Информация") > 0 ИЛИ СтрНайти(Уровень, "info") > 0 Тогда
			МассивУровней.Добавить(УровеньЖурналаРегистрации.Информация);
		КонецЕсли;
		Если СтрНайти(Уровень, "Примечание") > 0 ИЛИ СтрНайти(Уровень, "note") > 0 Тогда
			МассивУровней.Добавить(УровеньЖурналаРегистрации.Примечание);
		КонецЕсли;
		Если МассивУровней.Количество() > 0 Тогда
			Отбор.Вставить("Уровень", МассивУровней);
		КонецЕсли;
	КонецЕсли;

	// Событие (имя события журнала)
	Событие = ПолучитьПараметр(ПарамыЗапроса, "event");
	Если Событие <> Неопределено И Событие <> "" Тогда
		Отбор.Вставить("Событие", Событие);
	КонецЕсли;

	// Пользователь
	Пользователь = ПолучитьПараметр(ПарамыЗапроса, "user");
	Если Пользователь <> Неопределено И Пользователь <> "" Тогда
		ПользовательИБ = ПользователиИнформационнойБазы.НайтиПоИмени(Пользователь);
		Если ПользовательИБ <> Неопределено Тогда
			МассивПользователей = Новый Массив;
			МассивПользователей.Добавить(Пользователь);
			Отбор.Вставить("Пользователь", МассивПользователей);
		КонецЕсли;
	КонецЕсли;

	// Комментарий (подстрока)
	Комментарий = ПолучитьПараметр(ПарамыЗапроса, "comment");
	Если Комментарий <> Неопределено И Комментарий <> "" Тогда
		Отбор.Вставить("Комментарий", Комментарий);
	КонецЕсли;

	// Лимит
	Лимит = ПолучитьПараметр(ПарамыЗапроса, "limit");
	Если Лимит = Неопределено ИЛИ Лимит = "" Тогда
		Лимит = 100;
	Иначе
		Лимит = Число(Лимит);
		Если Лимит > 500 Тогда
			Лимит = 500;
		КонецЕсли;
	КонецЕсли;

	// Выгрузка
	Попытка
		ЖурналТЗ = Новый ТаблицаЗначений;
		ВыгрузитьЖурналРегистрации(ЖурналТЗ, Отбор);
	Исключение
		Возврат Новый Структура("error", "Ошибка чтения журнала: " + ОписаниеОшибки());
	КонецПопытки;

	// Ограничение количества (берём последние записи)
	ВсегоЗаписей = ЖурналТЗ.Количество();
	НачалоСреза = 0;
	Если ВсегоЗаписей > Лимит Тогда
		НачалоСреза = ВсегоЗаписей - Лимит;
	КонецЕсли;

	// Формируем результат
	Записи = Новый Массив;
	Для Инд = НачалоСреза По ВсегоЗаписей - 1 Цикл
		Строка = ЖурналТЗ[Инд];
		Запись = Новый Структура;
		Запись.Вставить("date", Формат(Строка.Дата, "ДФ=yyyy-MM-ddTHH:mm:ss"));
		Запись.Вставить("level", Строка(Строка.Уровень));
		Запись.Вставить("event", Строка.Событие);
		Запись.Вставить("user", Строка.ИмяПользователя);
		Запись.Вставить("computer", Строка.Компьютер);
		Запись.Вставить("comment", Строка.Комментарий);
		Запись.Вставить("metadata", Строка.ПредставлениеМетаданных);
		Запись.Вставить("data", Строка(Строка.Данные));
		Записи.Добавить(Запись);
	КонецЦикла;

	Результат = Новый Структура;
	Результат.Вставить("total", ВсегоЗаписей);
	Результат.Вставить("returned", Записи.Количество());
	Результат.Вставить("entries", Записи);

	Возврат Результат;

КонецФункции

// Описание структуры объекта метаданных (реквизиты с типами, табличные части).
//
&НаСервере
Функция Обработчик_lyra_meta_describe(ПарамыЗапроса)

	Путь = ПолучитьПараметр(ПарамыЗапроса, "path");
	Если Путь = Неопределено ИЛИ Путь = "" Тогда
		Возврат Новый Структура("error", "Отсутствует параметр path (например Справочник.Контрагенты)");
	КонецЕсли;

	Точка = СтрНайти(Путь, ".");
	Если Точка = 0 Тогда
		Возврат Новый Структура("error", "Формат path: Тип.Имя (например Справочник.Контрагенты)");
	КонецЕсли;

	ТипОбъекта = Лев(Путь, Точка - 1);
	ИмяОбъекта = Сред(Путь, Точка + 1);

	Попытка
		МетаданныеОбъекта = Метаданные.НайтиПоПолномуИмени(Путь);
	Исключение
		Возврат Новый Структура("error", "Не удалось найти метаданные: " + Путь);
	КонецПопытки;

	Если МетаданныеОбъекта = Неопределено Тогда
		Возврат Новый Структура("error", "Объект метаданных не найден: " + Путь);
	КонецЕсли;

	Результат = Новый Структура;
	Результат.Вставить("path", Путь);
	Результат.Вставить("synonym", МетаданныеОбъекта.Синоним);

	// Реквизиты
	Попытка
		Реквизиты = Новый Массив;
		Для Каждого Рекв Из МетаданныеОбъекта.Реквизиты Цикл
			ОписаниеРекв = Новый Структура;
			ОписаниеРекв.Вставить("name", Рекв.Имя);
			ОписаниеРекв.Вставить("synonym", Рекв.Синоним);
			ОписаниеРекв.Вставить("type", Строка(Рекв.Тип));
			Реквизиты.Добавить(ОписаниеРекв);
		КонецЦикла;
		Результат.Вставить("attributes", Реквизиты);
	Исключение
	КонецПопытки;

	// Стандартные реквизиты
	Попытка
		СтандартныеРекв = Новый Массив;
		Для Каждого Рекв Из МетаданныеОбъекта.СтандартныеРеквизиты Цикл
			ОписаниеРекв = Новый Структура;
			ОписаниеРекв.Вставить("name", Рекв.Имя);
			ОписаниеРекв.Вставить("synonym", Рекв.Синоним);
			ОписаниеРекв.Вставить("type", Строка(Рекв.Тип));
			СтандартныеРекв.Добавить(ОписаниеРекв);
		КонецЦикла;
		Результат.Вставить("standardAttributes", СтандартныеРекв);
	Исключение
	КонецПопытки;

	// Табличные части
	Попытка
		ТЧ = Новый Массив;
		Для Каждого ТабЧасть Из МетаданныеОбъекта.ТабличныеЧасти Цикл
			ОписаниеТЧ = Новый Структура;
			ОписаниеТЧ.Вставить("name", ТабЧасть.Имя);
			ОписаниеТЧ.Вставить("synonym", ТабЧасть.Синоним);
			РеквТЧ = Новый Массив;
			Для Каждого Рекв Из ТабЧасть.Реквизиты Цикл
				ОписаниеРекв = Новый Структура;
				ОписаниеРекв.Вставить("name", Рекв.Имя);
				ОписаниеРекв.Вставить("synonym", Рекв.Синоним);
				ОписаниеРекв.Вставить("type", Строка(Рекв.Тип));
				РеквТЧ.Добавить(ОписаниеРекв);
			КонецЦикла;
			ОписаниеТЧ.Вставить("attributes", РеквТЧ);
			ТЧ.Добавить(ОписаниеТЧ);
		КонецЦикла;
		Результат.Вставить("tabularSections", ТЧ);
	Исключение
	КонецПопытки;

	// Измерения, ресурсы, реквизиты (для регистров)
	Попытка
		Измерения = Новый Массив;
		Для Каждого Изм Из МетаданныеОбъекта.Измерения Цикл
			Описание = Новый Структура;
			Описание.Вставить("name", Изм.Имя);
			Описание.Вставить("synonym", Изм.Синоним);
			Описание.Вставить("type", Строка(Изм.Тип));
			Измерения.Добавить(Описание);
		КонецЦикла;
		Результат.Вставить("dimensions", Измерения);
	Исключение
	КонецПопытки;

	Попытка
		Ресурсы = Новый Массив;
		Для Каждого Рес Из МетаданныеОбъекта.Ресурсы Цикл
			Описание = Новый Структура;
			Описание.Вставить("name", Рес.Имя);
			Описание.Вставить("synonym", Рес.Синоним);
			Описание.Вставить("type", Строка(Рес.Тип));
			Ресурсы.Добавить(Описание);
		КонецЦикла;
		Результат.Вставить("resources", Ресурсы);
	Исключение
	КонецПопытки;

	Возврат Результат;

КонецФункции

// Чтение объекта по ссылке (все реквизиты).
//
&НаСервере
Функция Обработчик_lyra_data_read(ПарамыЗапроса)

	ОписаниеСсылки = ПолучитьПараметр(ПарамыЗапроса, "ref");
	Если ОписаниеСсылки = Неопределено Тогда
		Возврат Новый Структура("error", "Отсутствует параметр ref (объект _ref из результата запроса)");
	КонецЕсли;

	// Конвертируем _ref → ссылка 1С
	Ссылка = Неопределено;
	Если ТипЗнч(ОписаниеСсылки) = Тип("Соответствие") ИЛИ ТипЗнч(ОписаниеСсылки) = Тип("Структура") Тогда
		Ссылка = СсылкаИзJSON(ОписаниеСсылки);
	КонецЕсли;

	Если Ссылка = Неопределено Тогда
		Возврат Новый Структура("error", "Не удалось получить ссылку. Передайте объект _ref: {""_ref"": ""СправочникСсылка.Имя"", ""id"": ""uuid""}");
	КонецЕсли;

	Попытка
		Объект = Ссылка.ПолучитьОбъект();
	Исключение
		Возврат Новый Структура("error", "Ошибка чтения объекта: " + ОписаниеОшибки());
	КонецПопытки;

	Если Объект = Неопределено Тогда
		Возврат Новый Структура("error", "Объект не найден");
	КонецЕсли;

	// Собираем реквизиты
	Результат = Новый Структура;
	Результат.Вставить("_ref", ЗначениеДляJSON(Ссылка));
	Результат.Вставить("title", Строка(Ссылка));

	МетаданныеОбъекта = Ссылка.Метаданные();

	// Основные реквизиты
	Реквизиты = Новый Структура;
	Попытка
		Для Каждого Рекв Из МетаданныеОбъекта.Реквизиты Цикл
			Попытка
				Реквизиты.Вставить(Рекв.Имя, ЗначениеДляJSON(Объект[Рекв.Имя]));
			Исключение
				Реквизиты.Вставить(Рекв.Имя, Строка(Объект[Рекв.Имя]));
			КонецПопытки;
		КонецЦикла;
	Исключение
	КонецПопытки;
	Результат.Вставить("attributes", Реквизиты);

	// Табличные части (до 50 строк каждая)
	Попытка
		ТабЧасти = Новый Структура;
		Для Каждого ТабЧасть Из МетаданныеОбъекта.ТабличныеЧасти Цикл
			СтрокиТЧ = Новый Массив;
			ТЧОбъекта = Объект[ТабЧасть.Имя];
			Лимит = 50;
			Если ТЧОбъекта.Количество() < Лимит Тогда
				Лимит = ТЧОбъекта.Количество();
			КонецЕсли;
			Для Инд = 0 По Лимит - 1 Цикл
				СтрокаТЧ = ТЧОбъекта[Инд];
				Запись = Новый Структура;
				Для Каждого Рекв Из ТабЧасть.Реквизиты Цикл
					Попытка
						Запись.Вставить(Рекв.Имя, ЗначениеДляJSON(СтрокаТЧ[Рекв.Имя]));
					Исключение
						Запись.Вставить(Рекв.Имя, Строка(СтрокаТЧ[Рекв.Имя]));
					КонецПопытки;
				КонецЦикла;
				СтрокиТЧ.Добавить(Запись);
			КонецЦикла;
			ТабЧасти.Вставить(ТабЧасть.Имя, СтрокиТЧ);
		КонецЦикла;
		Результат.Вставить("tabularSections", ТабЧасти);
	Исключение
	КонецПопытки;

	Возврат Результат;

КонецФункции

#КонецОбласти

#Область СлужебныеПроцедуры

&НаСервереБезКонтекста
Функция СериализоватьВJSON_Сервер(Значение)
	ЗаписьJSON = Новый ЗаписьJSON;
	ЗаписьJSON.УстановитьСтроку();
	ЗаписатьJSON(ЗаписьJSON, Значение);
	Возврат ЗаписьJSON.Закрыть();
КонецФункции

&НаКлиентеНаСервереБезКонтекста
Функция ПолучитьПараметр(ПарамыЗапроса, ИмяПараметра)

	Если ТипЗнч(ПарамыЗапроса) = Тип("Соответствие") Тогда
		Возврат ПарамыЗапроса.Получить(ИмяПараметра);

	ИначеЕсли ТипЗнч(ПарамыЗапроса) = Тип("Структура") Тогда
		Если ПарамыЗапроса.Свойство(ИмяПараметра) Тогда
			Возврат ПарамыЗапроса[ИмяПараметра];
		КонецЕсли;

	КонецЕсли;

	Возврат Неопределено;

КонецФункции

&НаСервере
Процедура УстановитьПараметрыЗапроса(Запрос, Параметры)

	Если ТипЗнч(Параметры) = Тип("Соответствие") Тогда
		Для Каждого КЗ Из Параметры Цикл
			Запрос.УстановитьПараметр(КЗ.Ключ, ЗначениеПараметраИзJSON(КЗ.Значение));
		КонецЦикла;
	ИначеЕсли ТипЗнч(Параметры) = Тип("Структура") Тогда
		Для Каждого КЗ Из Параметры Цикл
			Запрос.УстановитьПараметр(КЗ.Ключ, ЗначениеПараметраИзJSON(КЗ.Значение));
		КонецЦикла;
	КонецЕсли;

КонецПроцедуры

&НаСервере
Функция ЗначениеПараметраИзJSON(Значение)

	Если ТипЗнч(Значение) = Тип("Соответствие") ИЛИ ТипЗнч(Значение) = Тип("Структура") Тогда
		Ссылка = СсылкаИзJSON(Значение);
		Если Ссылка <> Неопределено Тогда
			Возврат Ссылка;
		КонецЕсли;
	КонецЕсли;

	Возврат Значение;

КонецФункции

&НаСервере
Функция ЗначениеДляJSON(ИсходноеЗначение)

	Если ИсходноеЗначение = Неопределено ИЛИ ИсходноеЗначение = Null Тогда
		Возврат Null;
	ИначеЕсли ТипЗнч(ИсходноеЗначение) = Тип("Булево")
		ИЛИ ТипЗнч(ИсходноеЗначение) = Тип("Число")
		ИЛИ ТипЗнч(ИсходноеЗначение) = Тип("Строка") Тогда
		Возврат ИсходноеЗначение;
	ИначеЕсли ТипЗнч(ИсходноеЗначение) = Тип("Дата") Тогда
		Возврат Формат(ИсходноеЗначение, "ДФ=yyyy-MM-ddTHH:mm:ss");
	ИначеЕсли ЭтоСсылочныйТип(ИсходноеЗначение) Тогда
		Возврат СсылкаВJSON(ИсходноеЗначение);
	Иначе
		Возврат Строка(ИсходноеЗначение);
	КонецЕсли;

КонецФункции

&НаСервере
Функция ЭтоСсылочныйТип(Значение)

	Попытка
		ТипXML = XMLТипЗнч(Значение);
	Исключение
		Возврат Ложь;
	КонецПопытки;

	Если ТипXML = Неопределено Тогда
		Возврат Ложь;
	КонецЕсли;

	Возврат СтрНайти(ТипXML.ИмяТипа, "Ref.") > 0;

КонецФункции

&НаСервере
Функция СсылкаВJSON(Ссылка)

	Результат = Новый Структура;

	// XMLТипЗнч → CatalogRef.ЕХТ_Пользователи → СправочникСсылка.ЕХТ_Пользователи
	ТипXML = XMLТипЗнч(Ссылка);
	ИмяТипа1С = ИмяТипаИзXML(ТипXML.ИмяТипа);

	Результат.Вставить("_ref", ИмяТипа1С);
	Результат.Вставить("id", Строка(Ссылка.УникальныйИдентификатор()));
	Результат.Вставить("title", Строка(Ссылка));

	Возврат Результат;

КонецФункции

&НаСервере
Функция ИмяТипаИзXML(ИмяXML)

	// CatalogRef.Имя → СправочникСсылка.Имя
	// DocumentRef.Имя → ДокументСсылка.Имя
	// и т.д.
	Соответствия = Новый Соответствие;
	Соответствия.Вставить("CatalogRef", "СправочникСсылка");
	Соответствия.Вставить("DocumentRef", "ДокументСсылка");
	Соответствия.Вставить("ChartOfCharacteristicTypesRef", "ПланВидовХарактеристикСсылка");
	Соответствия.Вставить("ChartOfAccountsRef", "ПланСчетовСсылка");
	Соответствия.Вставить("ChartOfCalculationTypesRef", "ПланВидовРасчетаСсылка");
	Соответствия.Вставить("ExchangePlanRef", "ПланОбменаСсылка");
	Соответствия.Вставить("BusinessProcessRef", "БизнесПроцессСсылка");
	Соответствия.Вставить("TaskRef", "ЗадачаСсылка");

	Точка = СтрНайти(ИмяXML, ".");
	Если Точка = 0 Тогда
		Возврат ИмяXML;
	КонецЕсли;

	Префикс = Лев(ИмяXML, Точка - 1);
	Суффикс = Сред(ИмяXML, Точка);  // .ИмяОбъекта

	Русский = Соответствия.Получить(Префикс);
	Если Русский <> Неопределено Тогда
		Возврат Русский + Суффикс;
	КонецЕсли;

	Возврат ИмяXML;

КонецФункции

&НаСервере
Функция СсылкаИзJSON(ОписаниеСсылки)

	ИмяТипа = Неопределено;
	Идентификатор = Неопределено;

	Если ТипЗнч(ОписаниеСсылки) = Тип("Соответствие") Тогда
		ИмяТипа = ОписаниеСсылки.Получить("_ref");
		Идентификатор = ОписаниеСсылки.Получить("id");
	ИначеЕсли ТипЗнч(ОписаниеСсылки) = Тип("Структура") Тогда
		Если ОписаниеСсылки.Свойство("_ref") Тогда ИмяТипа = ОписаниеСсылки._ref; КонецЕсли;
		Если ОписаниеСсылки.Свойство("id") Тогда Идентификатор = ОписаниеСсылки.id; КонецЕсли;
	Иначе
		Возврат Неопределено;
	КонецЕсли;

	Если ИмяТипа = Неопределено ИЛИ Идентификатор = Неопределено Тогда
		Возврат Неопределено;
	КонецЕсли;

	Попытка
		Тип = Тип(ИмяТипа);
	Исключение
		Возврат Неопределено;
	КонецПопытки;

	Возврат XMLЗначение(Тип, Идентификатор);

КонецФункции

#КонецОбласти
