
// МодульMCP — серверные обработчики инструментов Лиры.
// Служебная форма-модуль (не отображается), получается через ПолучитьФорму("МодульMCP").
//
// Обработка tool_call/tool_result — в главной форме (Форма).
// Этот модуль только выполняет инструменты: получает имя + параметры → возвращает результат.

#Область ПрограммныйИнтерфейс

// Выполняет инструмент по имени.
//
// Параметры:
//  ИмяИнструмента      - Строка - имя инструмента (lyra_data_query, lyra_data_eval, lyra_meta_list, lyra_data_exec, lyra_nav_resolve)
//  ПараметрыИнструмента - Структура, Соответствие - параметры вызова
//
// Возвращаемое значение:
//  Строка - результат выполнения (JSON-строка или текст)
//
&НаКлиенте
Функция ВыполнитьИнструмент(Знач ИмяИнструмента, Знач ПараметрыИнструмента) Экспорт

	Если ПараметрыИнструмента = Неопределено Тогда
		ПараметрыИнструмента = Новый Структура;
	КонецЕсли;

	Результат = ВыполнитьИнструментНаСервере(ИмяИнструмента, ПараметрыИнструмента);

	// Сериализуем результат в текст для отправки
	Если ТипЗнч(Результат) = Тип("Строка") Тогда
		Возврат Результат;
	КонецЕсли;

	Попытка
		Возврат ЗаписатьЗначениеJSON(Результат);
	Исключение
		Попытка
			Возврат СериализоватьВJSON_Сервер(Результат);
		Исключение
			Возврат Строка(Результат);
		КонецПопытки;
	КонецПопытки;

КонецФункции

#КонецОбласти

#Область ОбработчикиИнструментов

// Диспетчер вызова обработчика на сервере.
//
&НаСервере
Функция ВыполнитьИнструментНаСервере(Знач ИмяИнструмента, Знач Ввод)

	Если ИмяИнструмента = "lyra_data_query" Тогда
		Возврат Обработчик_lyra_data_query(Ввод);
	ИначеЕсли ИмяИнструмента = "lyra_meta_list" Тогда
		Возврат Обработчик_lyra_meta_list(Ввод);
	ИначеЕсли ИмяИнструмента = "lyra_data_eval" Тогда
		Возврат Обработчик_lyra_data_eval(Ввод);
	ИначеЕсли ИмяИнструмента = "lyra_data_exec" Тогда
		Возврат Обработчик_lyra_data_exec(Ввод);
	ИначеЕсли ИмяИнструмента = "lyra_nav_resolve" Тогда
		Возврат Обработчик_lyra_nav_resolve(Ввод);
	Иначе
		Возврат Новый Структура("error", "Неизвестный инструмент: " + ИмяИнструмента);
	КонецЕсли;

КонецФункции

// Выполнение запроса к информационной базе на языке 1С.
//
&НаСервере
Функция Обработчик_lyra_data_query(ПарамыЗапроса)

	ТекстЗапроса = ПолучитьПараметр(ПарамыЗапроса, "query");
	Если ТекстЗапроса = Неопределено Тогда
		Возврат Новый Структура("error", "Отсутствует параметр query");
	КонецЕсли;

	Попытка
		Запрос = Новый Запрос(ТекстЗапроса);

		ПараметрыВвода = ПолучитьПараметр(ПарамыЗапроса, "params");
		Если ПараметрыВвода <> Неопределено Тогда
			УстановитьПараметрыЗапроса(Запрос, ПараметрыВвода);
		КонецЕсли;

		Результат = Запрос.Выполнить();

		Если Результат.Пустой() Тогда
			Возврат Новый Структура("data,columns,count", Новый Массив, Новый Массив, 0);
		КонецЕсли;

		Колонки = Новый Массив;
		Для Каждого Колонка Из Результат.Колонки Цикл
			Колонки.Добавить(Колонка.Имя);
		КонецЦикла;

		Данные = Новый Массив;
		Выборка = Результат.Выбрать();
		Счетчик = 0;

		Пока Выборка.Следующий() И Счетчик < 1000 Цикл
			СтрокаДанных = Новый Структура;
			Для Каждого ИмяКолонки Из Колонки Цикл
				Значение = Выборка[ИмяКолонки];
				СтрокаДанных.Вставить(ИмяКолонки, ЗначениеДляJSON(Значение));
			КонецЦикла;
			Данные.Добавить(СтрокаДанных);
			Счетчик = Счетчик + 1;
		КонецЦикла;

		Возврат Новый Структура("data,columns,count", Данные, Колонки, Данные.Количество());

	Исключение
		Возврат Новый Структура("error", "Ошибка запроса: " + ОписаниеОшибки());
	КонецПопытки;

КонецФункции

// Получение списка метаданных по типу.
//
&НаСервере
Функция Обработчик_lyra_meta_list(ПарамыЗапроса)

	ТипМета = ПолучитьПараметр(ПарамыЗапроса, "type");
	Если ТипМета = Неопределено Тогда ТипМета = ""; КонецЕсли;

	Результат = Новый Массив;

	Попытка
		Если ТипМета = "" ИЛИ ТипМета = "Catalogs" Тогда
			Для Каждого М Из Метаданные.Справочники Цикл
				Результат.Добавить(Новый Структура("type,name,synonym",
					"Справочник", М.Имя, Строка(М.Синоним)));
			КонецЦикла;
		КонецЕсли;

		Если ТипМета = "" ИЛИ ТипМета = "Documents" Тогда
			Для Каждого М Из Метаданные.Документы Цикл
				Результат.Добавить(Новый Структура("type,name,synonym",
					"Документ", М.Имя, Строка(М.Синоним)));
			КонецЦикла;
		КонецЕсли;

		Если ТипМета = "" ИЛИ ТипМета = "InformationRegisters" Тогда
			Для Каждого М Из Метаданные.РегистрыСведений Цикл
				Результат.Добавить(Новый Структура("type,name,synonym",
					"РегистрСведений", М.Имя, Строка(М.Синоним)));
			КонецЦикла;
		КонецЕсли;

		Если ТипМета = "" ИЛИ ТипМета = "AccumulationRegisters" Тогда
			Для Каждого М Из Метаданные.РегистрыНакопления Цикл
				Результат.Добавить(Новый Структура("type,name,synonym",
					"РегистрНакопления", М.Имя, Строка(М.Синоним)));
			КонецЦикла;
		КонецЕсли;

		Если ТипМета = "" ИЛИ ТипМета = "AccountingRegisters" Тогда
			Для Каждого М Из Метаданные.РегистрыБухгалтерии Цикл
				Результат.Добавить(Новый Структура("type,name,synonym",
					"РегистрБухгалтерии", М.Имя, Строка(М.Синоним)));
			КонецЦикла;
		КонецЕсли;

		Возврат Результат;

	Исключение
		Возврат Новый Структура("error", "Ошибка метаданных: " + ОписаниеОшибки());
	КонецПопытки;

КонецФункции

// Вычисление выражения 1С.
//
&НаСервере
Функция Обработчик_lyra_data_eval(ПарамыЗапроса)

	Выражение = ПолучитьПараметр(ПарамыЗапроса, "expression");
	Если Выражение = Неопределено Тогда
		Возврат Новый Структура("error", "Отсутствует параметр expression");
	КонецЕсли;

	Попытка
		Результат = Вычислить(Выражение);
		Возврат Новый Структура("result", ЗначениеДляJSON(Результат));
	Исключение
		Возврат Новый Структура("error", "Ошибка вычисления: " + ОписаниеОшибки());
	КонецПопытки;

КонецФункции

// Выполнение произвольного блока кода на языке 1С.
//
&НаСервере
Функция Обработчик_lyra_data_exec(ПарамыЗапроса)

	Код = ПолучитьПараметр(ПарамыЗапроса, "code");
	Если Код = Неопределено Тогда
		Возврат Новый Структура("error", "Отсутствует параметр code");
	КонецЕсли;

	// Транзакция-песочница: любые изменения данных будут отменены
	НачатьТранзакцию();
	Попытка
		Выполнить(Код);
		ОтменитьТранзакцию();
		Возврат Новый Структура("result", "Выполнено");
	Исключение
		ОтменитьТранзакцию();
		Возврат Новый Структура("error", "Ошибка выполнения: " + ОписаниеОшибки());
	КонецПопытки;

КонецФункции

// Получение навигационной ссылки на объект или список.
//
&НаСервере
Функция Обработчик_lyra_nav_resolve(ПарамыЗапроса)

	ТипОбъекта = ПолучитьПараметр(ПарамыЗапроса, "type");
	ИмяОбъекта = ПолучитьПараметр(ПарамыЗапроса, "name");

	Если ТипОбъекта = Неопределено ИЛИ ИмяОбъекта = Неопределено Тогда
		Возврат Новый Структура("error", "Отсутствуют параметры type и name");
	КонецЕсли;

	СсылкаОбъекта = ПолучитьПараметр(ПарамыЗапроса, "ref");

	Попытка
		ПолноеИмя = ТипОбъекта + "." + ИмяОбъекта;

		Если СсылкаОбъекта = Неопределено ИЛИ СсылкаОбъекта = "" Тогда
			// Ссылка на список
			Возврат Новый Структура("url,description",
				"e1cib/list/" + ПолноеИмя,
				"Список: " + ПолноеИмя);
		КонецЕсли;

		// Ссылка на конкретный объект — ищем по строковому представлению
		МенеджерОбъекта = Неопределено;
		Если ТипОбъекта = "Справочник" Тогда
			МенеджерОбъекта = Справочники[ИмяОбъекта];
		ИначеЕсли ТипОбъекта = "Документ" Тогда
			МенеджерОбъекта = Документы[ИмяОбъекта];
		Иначе
			// Для других типов — формируем ссылку по шаблону
			Возврат Новый Структура("url,description",
				"e1cib/data/" + ПолноеИмя + "?ref=" + СсылкаОбъекта,
				ПолноеИмя);
		КонецЕсли;

		// Пробуем найти по UUID
		Попытка
			Ссылка = МенеджерОбъекта.ПолучитьСсылку(Новый УникальныйИдентификатор(СсылкаОбъекта));
			Если Ссылка.ПолучитьОбъект() = Неопределено Тогда
				Возврат Новый Структура("error", "Объект не найден: " + СсылкаОбъекта);
			КонецЕсли;
			НавСсылка = ПолучитьНавигационнуюСсылку(Ссылка);
		Исключение
			// Не UUID — пробуем как строковое представление
			НавСсылка = "e1cib/data/" + ПолноеИмя + "?ref=" + СсылкаОбъекта;
		КонецПопытки;

		Возврат Новый Структура("url,description", НавСсылка, Строка(Ссылка));

	Исключение
		Возврат Новый Структура("error", "Ошибка получения ссылки: " + ОписаниеОшибки());
	КонецПопытки;

КонецФункции

#КонецОбласти

#Область СлужебныеПроцедуры

&НаСервереБезКонтекста
Функция СериализоватьВJSON_Сервер(Значение)
	ЗаписьJSON = Новый ЗаписьJSON;
	ЗаписьJSON.УстановитьСтроку();
	ЗаписатьJSON(ЗаписьJSON, Значение);
	Возврат ЗаписьJSON.Закрыть();
КонецФункции

&НаКлиентеНаСервереБезКонтекста
Функция ПолучитьПараметр(ПарамыЗапроса, ИмяПараметра)

	Если ТипЗнч(ПарамыЗапроса) = Тип("Соответствие") Тогда
		Возврат ПарамыЗапроса.Получить(ИмяПараметра);

	ИначеЕсли ТипЗнч(ПарамыЗапроса) = Тип("Структура") Тогда
		Если ПарамыЗапроса.Свойство(ИмяПараметра) Тогда
			Возврат ПарамыЗапроса[ИмяПараметра];
		КонецЕсли;

	КонецЕсли;

	Возврат Неопределено;

КонецФункции

&НаСервере
Процедура УстановитьПараметрыЗапроса(Запрос, Параметры)

	Если ТипЗнч(Параметры) = Тип("Соответствие") Тогда
		Для Каждого КЗ Из Параметры Цикл
			Запрос.УстановитьПараметр(КЗ.Ключ, ЗначениеПараметраИзJSON(КЗ.Значение));
		КонецЦикла;
	ИначеЕсли ТипЗнч(Параметры) = Тип("Структура") Тогда
		Для Каждого КЗ Из Параметры Цикл
			Запрос.УстановитьПараметр(КЗ.Ключ, ЗначениеПараметраИзJSON(КЗ.Значение));
		КонецЦикла;
	КонецЕсли;

КонецПроцедуры

&НаСервере
Функция ЗначениеПараметраИзJSON(Значение)

	Если ТипЗнч(Значение) = Тип("Соответствие") ИЛИ ТипЗнч(Значение) = Тип("Структура") Тогда
		Ссылка = СсылкаИзJSON(Значение);
		Если Ссылка <> Неопределено Тогда
			Возврат Ссылка;
		КонецЕсли;
	КонецЕсли;

	Возврат Значение;

КонецФункции

&НаСервере
Функция ЗначениеДляJSON(ИсходноеЗначение)

	Если ИсходноеЗначение = Неопределено ИЛИ ИсходноеЗначение = Null Тогда
		Возврат Null;
	ИначеЕсли ТипЗнч(ИсходноеЗначение) = Тип("Булево")
		ИЛИ ТипЗнч(ИсходноеЗначение) = Тип("Число")
		ИЛИ ТипЗнч(ИсходноеЗначение) = Тип("Строка") Тогда
		Возврат ИсходноеЗначение;
	ИначеЕсли ТипЗнч(ИсходноеЗначение) = Тип("Дата") Тогда
		Возврат Формат(ИсходноеЗначение, "ДФ=yyyy-MM-ddTHH:mm:ss");
	ИначеЕсли ЭтоСсылочныйТип(ИсходноеЗначение) Тогда
		Возврат СсылкаВJSON(ИсходноеЗначение);
	Иначе
		Возврат Строка(ИсходноеЗначение);
	КонецЕсли;

КонецФункции

&НаСервере
Функция ЭтоСсылочныйТип(Значение)

	Попытка
		ТипXML = XMLТипЗнч(Значение);
	Исключение
		Возврат Ложь;
	КонецПопытки;

	Если ТипXML = Неопределено Тогда
		Возврат Ложь;
	КонецЕсли;

	Возврат СтрНайти(ТипXML.ИмяТипа, "Ref.") > 0;

КонецФункции

&НаСервере
Функция СсылкаВJSON(Ссылка)

	Результат = Новый Структура;

	// XMLТипЗнч → CatalogRef.ЕХТ_Пользователи → СправочникСсылка.ЕХТ_Пользователи
	ТипXML = XMLТипЗнч(Ссылка);
	ИмяТипа1С = ИмяТипаИзXML(ТипXML.ИмяТипа);

	Результат.Вставить("_ref", ИмяТипа1С);
	Результат.Вставить("id", Строка(Ссылка.УникальныйИдентификатор()));
	Результат.Вставить("title", Строка(Ссылка));

	Возврат Результат;

КонецФункции

&НаСервере
Функция ИмяТипаИзXML(ИмяXML)

	// CatalogRef.Имя → СправочникСсылка.Имя
	// DocumentRef.Имя → ДокументСсылка.Имя
	// и т.д.
	Соответствия = Новый Соответствие;
	Соответствия.Вставить("CatalogRef", "СправочникСсылка");
	Соответствия.Вставить("DocumentRef", "ДокументСсылка");
	Соответствия.Вставить("ChartOfCharacteristicTypesRef", "ПланВидовХарактеристикСсылка");
	Соответствия.Вставить("ChartOfAccountsRef", "ПланСчетовСсылка");
	Соответствия.Вставить("ChartOfCalculationTypesRef", "ПланВидовРасчетаСсылка");
	Соответствия.Вставить("ExchangePlanRef", "ПланОбменаСсылка");
	Соответствия.Вставить("BusinessProcessRef", "БизнесПроцессСсылка");
	Соответствия.Вставить("TaskRef", "ЗадачаСсылка");

	Точка = СтрНайти(ИмяXML, ".");
	Если Точка = 0 Тогда
		Возврат ИмяXML;
	КонецЕсли;

	Префикс = Лев(ИмяXML, Точка - 1);
	Суффикс = Сред(ИмяXML, Точка);  // .ИмяОбъекта

	Русский = Соответствия.Получить(Префикс);
	Если Русский <> Неопределено Тогда
		Возврат Русский + Суффикс;
	КонецЕсли;

	Возврат ИмяXML;

КонецФункции

&НаСервере
Функция СсылкаИзJSON(ОписаниеСсылки)

	ИмяТипа = Неопределено;
	Идентификатор = Неопределено;

	Если ТипЗнч(ОписаниеСсылки) = Тип("Соответствие") Тогда
		ИмяТипа = ОписаниеСсылки.Получить("_ref");
		Идентификатор = ОписаниеСсылки.Получить("id");
	ИначеЕсли ТипЗнч(ОписаниеСсылки) = Тип("Структура") Тогда
		Если ОписаниеСсылки.Свойство("_ref") Тогда ИмяТипа = ОписаниеСсылки._ref; КонецЕсли;
		Если ОписаниеСсылки.Свойство("id") Тогда Идентификатор = ОписаниеСсылки.id; КонецЕсли;
	Иначе
		Возврат Неопределено;
	КонецЕсли;

	Если ИмяТипа = Неопределено ИЛИ Идентификатор = Неопределено Тогда
		Возврат Неопределено;
	КонецЕсли;

	Попытка
		Тип = Тип(ИмяТипа);
	Исключение
		Возврат Неопределено;
	КонецПопытки;

	Возврат XMLЗначение(Тип, Идентификатор);

КонецФункции

#КонецОбласти
