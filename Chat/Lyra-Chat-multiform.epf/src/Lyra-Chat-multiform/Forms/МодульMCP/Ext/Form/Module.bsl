
// МодульMCP — обработка протокола MCP JSON-RPC + серверные обработчики 1С-команд.
// Служебная форма-модуль (не отображается), получается через ПолучитьФорму("МодульMCP").
// 1С сама обрабатывает JSON-RPC от Claude Code (initialize, tools/list, tools/call).
// Первичный путь: ПрочитатьЗначениеJSON/ЗаписатьЗначениеJSON (клиент, 8.3.23+, Структура).
// Fallback: ПрочитатьJSON/ЗаписатьJSON через серверный вызов (Соответствие).

#Область ПеременныеМодуля

&НаКлиенте
Перем РеестрОбработчиков; // Структура "имя_инструмента" → "имя_метода"

#КонецОбласти

#Область ПрограммныйИнтерфейс

// Инициализация модуля. Регистрирует стандартные обработчики.
//
&НаКлиенте
Процедура Инициализация() Экспорт

	РеестрОбработчиков = Новый Структура;
	ЗарегистрироватьОбработчик("v8_query",    "Обработчик_v8_query");
	ЗарегистрироватьОбработчик("v8_metadata", "Обработчик_v8_metadata");
	ЗарегистрироватьОбработчик("v8_eval",     "Обработчик_v8_eval");
	ЗарегистрироватьОбработчик("v8_exec",     "Обработчик_v8_exec");

КонецПроцедуры

// Регистрирует обработчик MCP-инструмента.
//
// Параметры:
//  ИмяИнструмента - Строка - Имя MCP-инструмента (например "v8_query")
//  ИмяМетода - Строка - Имя экспортного метода-обработчика
//
&НаКлиенте
Процедура ЗарегистрироватьОбработчик(ИмяИнструмента, ИмяМетода) Экспорт
	РеестрОбработчиков.Вставить(ИмяИнструмента, ИмяМетода);
КонецПроцедуры

// Возвращает массив имён зарегистрированных инструментов.
// Используется для отправки списка в Bridge при подключении (hello).
//
// Возвращаемое значение:
//  Массив из Строка - Имена инструментов ("v8_query", "v8_eval", ...)
//
&НаКлиенте
Функция ПолучитьИменаИнструментов() Экспорт

	Результат = Новый Массив;
	Для Каждого КлючЗначение Из РеестрОбработчиков Цикл
		Результат.Добавить(КлючЗначение.Ключ);
	КонецЦикла;
	Возврат Результат;

КонецФункции

// Обрабатывает JSON-RPC сообщение от Claude Code.
// Разбирает строку, определяет метод, вызывает обработчик.
//
// Параметры:
//  СтрокаJSONRPC - Строка - Сырая строка JSON-RPC
//
// Возвращаемое значение:
//  Строка, Неопределено - JSON-строка ответа или Неопределено для уведомлений
//
&НаКлиенте
Функция ОбработатьJSONRPC(Знач СтрокаJSONRPC) Экспорт

	// Разбираем JSON: сначала клиентский путь (8.3.23+), затем серверный fallback
	Попытка
		Данные = ПрочитатьЗначениеJSON(СтрокаJSONRPC);
	Исключение
		Попытка
			Данные = РазобратьJSONRPC_Сервер(СтрокаJSONRPC);
		Исключение
			Возврат Неопределено;
		КонецПопытки;
	КонецПопытки;

	Если ТипЗнч(Данные) <> Тип("Структура") И ТипЗнч(Данные) <> Тип("Соответствие") Тогда
		Возврат Неопределено;
	КонецЕсли;

	// Уведомления (нет id) — игнорируем
	ИДЗапроса = ПолучитьПараметр(Данные, "id");
	Если ИДЗапроса = Неопределено Тогда
		Возврат Неопределено;
	КонецЕсли;

	Метод = ПолучитьПараметр(Данные, "method");
	МетодПараметры = ПолучитьПараметр(Данные, "params");
	Если МетодПараметры = Неопределено Тогда
		МетодПараметры = Новый Структура;
	КонецЕсли;

	Если Метод = "initialize" Тогда
		Возврат ОтветInitialize(ИДЗапроса);

	ИначеЕсли Метод = "tools/list" Тогда
		Возврат ОтветToolsList(ИДЗапроса);

	ИначеЕсли Метод = "tools/call" Тогда
		Возврат ОтветToolsCall(ИДЗапроса, МетодПараметры);

	Иначе
		Возврат ОтветОшибкаПротокола(ИДЗапроса, -32601, "Method not found: " + Метод);
	КонецЕсли;

КонецФункции

#КонецОбласти

#Область ОбработчикиПротоколаMCP

// Ответ на initialize — capabilities и serverInfo.
//
&НаКлиенте
Функция ОтветInitialize(ИДЗапроса)

	Capabilities = Новый Структура;
	Capabilities.Вставить("tools", Новый Структура);

	ИнфоСервера = Новый Структура;
	ИнфоСервера.Вставить("name", "1c-bridge");
	ИнфоСервера.Вставить("version", "2.0.0");

	Результат = Новый Структура;
	Результат.Вставить("protocolVersion", "2025-11-25");
	Результат.Вставить("capabilities", Capabilities);
	Результат.Вставить("serverInfo", ИнфоСервера);

	Возврат СобратьОтветJSONRPC(ИДЗапроса, Результат);

КонецФункции

// Ответ на tools/list — список инструментов с inputSchema.
//
&НаКлиенте
Функция ОтветToolsList(ИДЗапроса)

	Инструменты = Новый Массив;

	// v8_query
	Свойства = Новый Структура;
	Свойства.Вставить("query", СвойствоСхемы("string", "Текст запроса 1С"));
	Свойства.Вставить("params", СвойствоСхемы("object", "Параметры запроса (необязательно)"));
	Инструменты.Добавить(ОписаниеИнструмента("v8_query",
		"Выполнить запрос на языке запросов 1С (ВЫБРАТЬ ... ИЗ ...). Это НЕ SQL!",
		Свойства, "query"));

	// v8_eval
	Свойства = Новый Структура;
	Свойства.Вставить("expression", СвойствоСхемы("string", "Выражение на языке 1С"));
	Инструменты.Добавить(ОписаниеИнструмента("v8_eval",
		"Вычислить выражение 1С. Только выражения, НЕ процедуры. Пример: Строка(ТекущаяДата())",
		Свойства, "expression"));

	// v8_metadata
	Свойства = Новый Структура;
	Свойства.Вставить("path", СвойствоСхемы("string", "Путь в дереве метаданных (пусто = корень)"));
	Инструменты.Добавить(ОписаниеИнструмента("v8_metadata",
		"Получить дерево/ветку метаданных конфигурации 1С",
		Свойства, ""));

	// v8_exec
	Свойства = Новый Структура;
	Свойства.Вставить("code", СвойствоСхемы("string", "Код на встроенном языке 1С"));
	Инструменты.Добавить(ОписаниеИнструмента("v8_exec",
		"Выполнить блок кода на языке 1С (процедуры, циклы, условия, присваивания)",
		Свойства, "code"));

	Результат = Новый Структура;
	Результат.Вставить("tools", Инструменты);

	Возврат СобратьОтветJSONRPC(ИДЗапроса, Результат);

КонецФункции

// Ответ на tools/call — вызов инструмента через strategy-dispatch.
//
&НаКлиенте
Функция ОтветToolsCall(ИДЗапроса, Параметры)

	ИмяИнструмента = "";
	Аргументы = Новый Структура;

	Если ТипЗнч(Параметры) = Тип("Структура") ИЛИ ТипЗнч(Параметры) = Тип("Соответствие") Тогда
		Значение = ПолучитьПараметр(Параметры, "name");
		Если Значение <> Неопределено Тогда ИмяИнструмента = Строка(Значение); КонецЕсли;
		Значение = ПолучитьПараметр(Параметры, "arguments");
		Если Значение <> Неопределено Тогда Аргументы = Значение; КонецЕсли;
	КонецЕсли;

	// Strategy-dispatch: ищем обработчик в реестре
	ИмяМетода = Неопределено;
	РеестрОбработчиков.Свойство(ИмяИнструмента, ИмяМетода);
	Если ИмяМетода = Неопределено Тогда
		Возврат СобратьОтветToolsCall(ИДЗапроса,
			"Неизвестный инструмент: " + ИмяИнструмента, Истина);
	КонецЕсли;

	// Вызываем обработчик на сервере
	Попытка
		Результат = ВыполнитьОбработчикНаСервере(ИмяМетода, Аргументы);
	Исключение
		Возврат СобратьОтветToolsCall(ИДЗапроса, ОписаниеОшибки(), Истина);
	КонецПопытки;

	// Проверяем: вернулась ошибка?
	Попытка
		Если ТипЗнч(Результат) = Тип("Структура") И Результат.Свойство("error") Тогда
			Возврат СобратьОтветToolsCall(ИДЗапроса, Результат.error, Истина);
		КонецЕсли;
	Исключение
	КонецПопытки;

	// Успешный результат — сериализуем в текст
	ТекстРезультата = "";
	Попытка
		Если ТипЗнч(Результат) = Тип("Строка") Тогда
			ТекстРезультата = Результат;
		Иначе
			Попытка
				ТекстРезультата = ЗаписатьЗначениеJSON(Результат);
			Исключение
				ТекстРезультата = СериализоватьВJSON_Сервер(Результат);
			КонецПопытки;
		КонецЕсли;
	Исключение
		ТекстРезультата = Строка(Результат);
	КонецПопытки;

	Возврат СобратьОтветToolsCall(ИДЗапроса, ТекстРезультата, Ложь);

КонецФункции

#КонецОбласти

#Область ОбработчикиИнструментов

// Диспетчер вызова обработчика на сервере.
//
&НаСервере
Функция ВыполнитьОбработчикНаСервере(ИмяМетода, Ввод)

	Если ИмяМетода = "Обработчик_v8_query" Тогда
		Возврат Обработчик_v8_query(Ввод);
	ИначеЕсли ИмяМетода = "Обработчик_v8_metadata" Тогда
		Возврат Обработчик_v8_metadata(Ввод);
	ИначеЕсли ИмяМетода = "Обработчик_v8_eval" Тогда
		Возврат Обработчик_v8_eval(Ввод);
	ИначеЕсли ИмяМетода = "Обработчик_v8_exec" Тогда
		Возврат Обработчик_v8_exec(Ввод);
	Иначе
		Возврат Новый Структура("error", "Неизвестный метод: " + ИмяМетода);
	КонецЕсли;

КонецФункции

// Выполнение SQL-запроса к информационной базе.
//
&НаСервере
Функция Обработчик_v8_query(ПарамыЗапроса) Экспорт

	ТекстЗапроса = ПолучитьПараметр(ПарамыЗапроса, "query");
	Если ТекстЗапроса = Неопределено Тогда
		Возврат Новый Структура("error", "Отсутствует параметр query");
	КонецЕсли;

	Попытка
		Запрос = Новый Запрос(ТекстЗапроса);
		Результат = Запрос.Выполнить();

		Если Результат.Пустой() Тогда
			Возврат Новый Структура("data,columns,count", Новый Массив, Новый Массив, 0);
		КонецЕсли;

		Колонки = Новый Массив;
		Для Каждого Колонка Из Результат.Колонки Цикл
			Колонки.Добавить(Колонка.Имя);
		КонецЦикла;

		Данные = Новый Массив;
		Выборка = Результат.Выбрать();
		Счетчик = 0;

		Пока Выборка.Следующий() И Счетчик < 1000 Цикл
			СтрокаДанных = Новый Структура;
			Для Каждого ИмяКолонки Из Колонки Цикл
				Значение = Выборка[ИмяКолонки];
				СтрокаДанных.Вставить(ИмяКолонки, ЗначениеДляJSON(Значение));
			КонецЦикла;
			Данные.Добавить(СтрокаДанных);
			Счетчик = Счетчик + 1;
		КонецЦикла;

		Возврат Новый Структура("data,columns,count", Данные, Колонки, Данные.Количество());

	Исключение
		Возврат Новый Структура("error", "Ошибка запроса: " + ОписаниеОшибки());
	КонецПопытки;

КонецФункции

// Получение списка метаданных по типу.
//
&НаСервере
Функция Обработчик_v8_metadata(ПарамыЗапроса) Экспорт

	ТипМета = ПолучитьПараметр(ПарамыЗапроса, "type");
	Если ТипМета = Неопределено Тогда ТипМета = ""; КонецЕсли;

	Результат = Новый Массив;

	Попытка
		Если ТипМета = "" ИЛИ ТипМета = "Catalogs" Тогда
			Для Каждого М Из Метаданные.Справочники Цикл
				Результат.Добавить(Новый Структура("type,name,synonym",
					"Справочник", М.Имя, Строка(М.Синоним)));
			КонецЦикла;
		КонецЕсли;

		Если ТипМета = "" ИЛИ ТипМета = "Documents" Тогда
			Для Каждого М Из Метаданные.Документы Цикл
				Результат.Добавить(Новый Структура("type,name,synonym",
					"Документ", М.Имя, Строка(М.Синоним)));
			КонецЦикла;
		КонецЕсли;

		Если ТипМета = "" ИЛИ ТипМета = "InformationRegisters" Тогда
			Для Каждого М Из Метаданные.РегистрыСведений Цикл
				Результат.Добавить(Новый Структура("type,name,synonym",
					"РегистрСведений", М.Имя, Строка(М.Синоним)));
			КонецЦикла;
		КонецЕсли;

		Если ТипМета = "" ИЛИ ТипМета = "AccumulationRegisters" Тогда
			Для Каждого М Из Метаданные.РегистрыНакопления Цикл
				Результат.Добавить(Новый Структура("type,name,synonym",
					"РегистрНакопления", М.Имя, Строка(М.Синоним)));
			КонецЦикла;
		КонецЕсли;

		Если ТипМета = "" ИЛИ ТипМета = "AccountingRegisters" Тогда
			Для Каждого М Из Метаданные.РегистрыБухгалтерии Цикл
				Результат.Добавить(Новый Структура("type,name,synonym",
					"РегистрБухгалтерии", М.Имя, Строка(М.Синоним)));
			КонецЦикла;
		КонецЕсли;

		Возврат Результат;

	Исключение
		Возврат Новый Структура("error", "Ошибка метаданных: " + ОписаниеОшибки());
	КонецПопытки;

КонецФункции

// Вычисление выражения 1С.
//
&НаСервере
Функция Обработчик_v8_eval(ПарамыЗапроса) Экспорт

	Выражение = ПолучитьПараметр(ПарамыЗапроса, "expression");
	Если Выражение = Неопределено Тогда
		Возврат Новый Структура("error", "Отсутствует параметр expression");
	КонецЕсли;

	Попытка
		Результат = Вычислить(Выражение);
		Возврат Новый Структура("result", ЗначениеДляJSON(Результат));
	Исключение
		Возврат Новый Структура("error", "Ошибка вычисления: " + ОписаниеОшибки());
	КонецПопытки;

КонецФункции

// Выполнение произвольного блока кода на языке 1С.
//
&НаСервере
Функция Обработчик_v8_exec(ПарамыЗапроса) Экспорт

	Код = ПолучитьПараметр(ПарамыЗапроса, "code");
	Если Код = Неопределено Тогда
		Возврат Новый Структура("error", "Отсутствует параметр code");
	КонецЕсли;

	Попытка
		Выполнить(Код);
		Возврат Новый Структура("result", "Выполнено");
	Исключение
		Возврат Новый Структура("error", "Ошибка выполнения: " + ОписаниеОшибки());
	КонецПопытки;

КонецФункции

#КонецОбласти

#Область СлужебныеПроцедуры

// ─── JSON-RPC helpers ─────────────────────────────────────

// Собирает JSON-RPC ответ с результатом.
// Первичный путь: ЗаписатьЗначениеJSON (клиент, 8.3.23+).
// Fallback: ЗаписатьJSON на сервере.
//
&НаКлиенте
Функция СобратьОтветJSONRPC(ИДЗапроса, Результат)

	Ответ = Новый Структура;
	Ответ.Вставить("jsonrpc", "2.0");
	Ответ.Вставить("id", ИДЗапроса);
	Ответ.Вставить("result", Результат);

	Попытка
		Возврат ЗаписатьЗначениеJSON(Ответ);
	Исключение
		Попытка
			Возврат СериализоватьВJSON_Сервер(Ответ);
		Исключение
			Возврат "{""jsonrpc"":""2.0"",""id"":" + Строка(ИДЗапроса)
				+ ",""error"":{""code"":-32603,""message"":""Internal serialization error""}}";
		КонецПопытки;
	КонецПопытки;

КонецФункции

// Собирает ответ tools/call в формате MCP content.
//
&НаКлиенте
Функция СобратьОтветToolsCall(ИДЗапроса, ТекстСодержимого, ЕстьОшибка)

	Содержимое = Новый Структура;
	Содержимое.Вставить("type", "text");
	Содержимое.Вставить("text", ТекстСодержимого);

	МассивСодержимого = Новый Массив;
	МассивСодержимого.Добавить(Содержимое);

	Результат = Новый Структура;
	Результат.Вставить("content", МассивСодержимого);
	Если ЕстьОшибка Тогда
		Результат.Вставить("isError", Истина);
	КонецЕсли;

	Возврат СобратьОтветJSONRPC(ИДЗапроса, Результат);

КонецФункции

// Собирает JSON-RPC ошибку протокола (неизвестный метод и т.п.).
// Первичный путь: ЗаписатьЗначениеJSON (клиент, 8.3.23+).
// Fallback: ЗаписатьJSON на сервере.
//
&НаКлиенте
Функция ОтветОшибкаПротокола(ИДЗапроса, КодОшибки, Сообщение)

	ОбъектОшибки = Новый Структура;
	ОбъектОшибки.Вставить("code", КодОшибки);
	ОбъектОшибки.Вставить("message", Сообщение);

	Ответ = Новый Структура;
	Ответ.Вставить("jsonrpc", "2.0");
	Ответ.Вставить("id", ИДЗапроса);
	Ответ.Вставить("error", ОбъектОшибки);

	Попытка
		Возврат ЗаписатьЗначениеJSON(Ответ);
	Исключение
		Попытка
			Возврат СериализоватьВJSON_Сервер(Ответ);
		Исключение
			Возврат "{""jsonrpc"":""2.0"",""id"":" + Строка(ИДЗапроса)
				+ ",""error"":{""code"":" + Строка(КодОшибки) + ",""message"":""Internal error""}}";
		КонецПопытки;
	КонецПопытки;

КонецФункции

// ─── Описание инструментов (inputSchema) ──────────────────

// Создаёт описание инструмента для tools/list.
//
&НаКлиенте
Функция ОписаниеИнструмента(ИмяИнструмента, Описание, Свойства, СтрокаОбязательных = "")

	Инструмент = Новый Структура;
	Инструмент.Вставить("name", ИмяИнструмента);
	Инструмент.Вставить("description", Описание);

	Схема = Новый Структура;
	Схема.Вставить("type", "object");
	Схема.Вставить("properties", Свойства);

	Если ЗначениеЗаполнено(СтрокаОбязательных) Тогда
		Обязательные = Новый Массив;
		Части = СтрРазделить(СтрокаОбязательных, ",");
		Для Каждого Часть Из Части Цикл
			Обязательные.Добавить(СокрЛП(Часть));
		КонецЦикла;
		Схема.Вставить("required", Обязательные);
	КонецЕсли;

	Инструмент.Вставить("inputSchema", Схема);
	Возврат Инструмент;

КонецФункции

// Создаёт описание свойства для inputSchema.
//
&НаКлиенте
Функция СвойствоСхемы(ТипСвойства, Описание)

	Поле = Новый Структура;
	Поле.Вставить("type", ТипСвойства);
	Поле.Вставить("description", Описание);
	Возврат Поле;

КонецФункции

// ─── Серверные обёртки для JSON ────────────────────────────
// Серверный fallback для случаев когда ПрочитатьЗначениеJSON/ЗаписатьЗначениеJSON недоступны.

&НаСервереБезКонтекста
Функция РазобратьJSONRPC_Сервер(Знач СтрокаJSON)
	ЧтениеJSON = Новый ЧтениеJSON;
	ЧтениеJSON.УстановитьСтроку(СтрокаJSON);
	Результат = ПрочитатьJSON(ЧтениеJSON, Истина);
	ЧтениеJSON.Закрыть();
	Возврат Результат;
КонецФункции

&НаСервереБезКонтекста
Функция СериализоватьВJSON_Сервер(Значение)
	ЗаписьJSON = Новый ЗаписьJSON;
	ЗаписьJSON.УстановитьСтроку();
	ЗаписатьJSON(ЗаписьJSON, Значение);
	Возврат ЗаписьJSON.Закрыть();
КонецФункции

// ─── Общие утилиты ────────────────────────────────────────

&НаКлиентеНаСервереБезКонтекста
Функция ПолучитьПараметр(ПарамыЗапроса, ИмяПараметра)

	Если ТипЗнч(ПарамыЗапроса) = Тип("Соответствие") Тогда
		Возврат ПарамыЗапроса.Получить(ИмяПараметра);

	ИначеЕсли ТипЗнч(ПарамыЗапроса) = Тип("Структура") Тогда
		Если ПарамыЗапроса.Свойство(ИмяПараметра) Тогда
			Возврат ПарамыЗапроса[ИмяПараметра];
		КонецЕсли;

	КонецЕсли;

	Возврат Неопределено;

КонецФункции

&НаСервере
Функция ЗначениеДляJSON(ИсходноеЗначение)

	Если ИсходноеЗначение = Неопределено ИЛИ ИсходноеЗначение = Null Тогда
		Возврат Null;
	ИначеЕсли ТипЗнч(ИсходноеЗначение) = Тип("Булево")
		ИЛИ ТипЗнч(ИсходноеЗначение) = Тип("Число")
		ИЛИ ТипЗнч(ИсходноеЗначение) = Тип("Строка") Тогда
		Возврат ИсходноеЗначение;
	ИначеЕсли ТипЗнч(ИсходноеЗначение) = Тип("Дата") Тогда
		Возврат Формат(ИсходноеЗначение, "ДФ=yyyy-MM-ddTHH:mm:ss");
	Иначе
		Возврат Строка(ИсходноеЗначение);
	КонецЕсли;

КонецФункции

#КонецОбласти
