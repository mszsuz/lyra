
// МодульСессия — управление сессией: подключение, протокол, баланс, настройки, QR.
// Служебная форма-модуль (не отображается), получается через ПолучитьФорму("МодульСессия").
//
// "Жив ли канал и кто мы" — всё что связано с установкой/поддержанием связи.
// Стриминг и UI делегируются в МодульЧат через Чат.ОбработатьСобытие().

#Область ПеременныеМодуля

// --- Ссылки на модули ---
&НаКлиенте
Перем Владелец;                  // главная форма (Форма)
&НаКлиенте
Перем Транспорт;                 // МодульТранспорт (для отправки сообщений)
&НаКлиенте
Перем Чат;                       // МодульЧат (для делегирования стриминга)
&НаКлиенте
Перем Напарник;                  // МодульНапарник (для запросов к 1С:Напарник)

// --- Состояние сессии ---
&НаКлиенте
Перем ФормИД;                    // UUID формы для переподключения (form_id)
&НаКлиенте
Перем ДанныеБазы;                // кэш данных о базе для hello (Структура)
&НаКлиенте
Перем СессияИД;                  // session_id из hello_ack
&НаКлиенте
Перем МобильныйJWT;              // mobile_jwt из hello_ack (для QR)
&НаКлиенте
Перем Баланс;                    // текущий баланс пользователя
&НаКлиенте
Перем БылоПодключение;           // флаг: первое подключение уже было
&НаКлиенте
Перем Авторизован;                // флаг: auth_ack ok получен (или reconnected/auto_auth)
&НаКлиенте
Перем QRСообщениеИД;              // ИД сообщения с QR-кодом (для обновления после auth)

#КонецОбласти

#Область ПрограммныйИнтерфейс

// Инициализация модуля.
//
// Параметры:
//  Контекст - Структура - DI-контейнер
//
&НаКлиенте
Процедура Инициализация(Контекст) Экспорт

	Владелец = Контекст.ГлавнаяФорма.Форма;
	Транспорт = Контекст.МодульТранспорт.Форма;
	Чат = Контекст.МодульЧат.Форма;
	Напарник = Контекст.МодульНапарник.Форма;
	ДанныеБазы = Контекст.ГлавнаяФорма.ДанныеБазы;
	ФормИД = Контекст.ГлавнаяФорма.ФормИД;
	БылоПодключение = Ложь;
	Авторизован = Ложь;

КонецПроцедуры

// Обрабатывает все события от транспорта (connected/closed/error/message/presence_leave).
//
// Параметры:
//  ИмяСобытия - Строка - имя события транспорта
//  Данные     - Произвольный - данные события
//
&НаКлиенте
Процедура ОбработатьСобытиеТранспорта(ИмяСобытия, Данные) Экспорт

	Если ИмяСобытия = "connected" Тогда

		// Данные — Структура с полями: client, status, subs
		Статус = Данные.status;

		Если Статус = "lobby" Тогда
			// Подключились к lobby — отправить hello
			ОтправитьHello();
		ИначеЕсли Статус = "session" Тогда
			// Переподключились с chat_jwt — канал сессии активен
			Если Авторизован Тогда
				// Авторизация уже пройдена — рабочее переподключение
				Если БылоПодключение Тогда
					ОповеститьВладельца("информация", "Соединение восстановлено!");
				Иначе
					БылоПодключение = Истина;
					ОповеститьВладельца("информация", "Лира на связи!");
				КонецЕсли;
				ОповеститьВладельца("занят", Ложь);
				Чат.ОбработатьГотовностьКанала();
			Иначе
				// Канал сессии активен, но ждём авторизацию (QR)
				БылоПодключение = Истина;
			КонецЕсли;
		КонецЕсли;

	ИначеЕсли ИмяСобытия = "closed" Тогда

		// Данные — Структура с полями: КодЗакрытия, ПредыдущийСтатус
		ОповеститьВладельца("занят", Ложь);
		ОповеститьВладельца("предупреждение",
			"Соединение закрыто (код " + Формат(Данные.КодЗакрытия, "ЧН=0; ЧГ=0") + "). <a href=""lyra://reconnect"" class=""chat-link"">Повторить подключение</a>");

	ИначеЕсли ИмяСобытия = "error" Тогда

		ОповеститьВладельца("предупреждение",
			Данные + ". <a href=""lyra://reconnect"" class=""chat-link"">Повторить подключение</a>");

	ИначеЕсли ИмяСобытия = "message" Тогда

		// Данные — JSON-строка (data из push.pub.data)
		ДанныеОтвета = Транспорт.РазобратьJSON(Данные);
		ОбработатьСообщениеПротокола(ДанныеОтвета);

	ИначеЕсли ИмяСобытия = "presence_leave" Тогда

		// Участник покинул канал сессии (Роутер упал / отключился)
		Если Чат.Активен() Тогда
			ОповеститьВладельца("предупреждение",
				"Сервер отключился от канала. <a href=""lyra://reconnect"" class=""chat-link"">Переподключиться</a>");
			ОповеститьВладельца("занят", Ложь);
		КонецЕсли;

	КонецЕсли;

КонецПроцедуры

// Подключение к Centrifugo.
//
&НаКлиенте
Процедура Подключиться() Экспорт
	АдресЦентрифуга = "ws://localhost:11000/connection/websocket";
	Транспорт.Подключиться(АдресЦентрифуга);
КонецПроцедуры

// Закрытие — disconnect + cleanup.
// Вызывается из Формы перед закрытием.
//
&НаКлиенте
Процедура ПередЗакрытием() Экспорт

	// Уведомить Роутер о закрытии формы (статус → disconnected)
	Если Транспорт <> Неопределено И ЗначениеЗаполнено(СессияИД) Тогда
		ДанныеОтключения = Новый Структура;
		ДанныеОтключения.Вставить("type", "disconnect");
		ДанныеОтключения.Вставить("form_id", ФормИД);
		Транспорт.ОтправитьСообщение(ДанныеОтключения);
	КонецЕсли;

	// Каскадное отключение WebSocket
	Если Транспорт <> Неопределено Тогда
		Транспорт.Отключиться();
	КонецЕсли;

КонецПроцедуры

// Отправляет настройки в Роутер для сохранения.
// Вызывается из формы Настройки при нажатии "Сохранить".
//
&НаКлиенте
Процедура ОтправитьНастройки() Экспорт

	Сообщение = Новый Структура;
	Сообщение.Вставить("type", "settings_save");
	Сообщение.Вставить("naparnik_token", Владелец.Объект.Токен1СНапарник);
	Сообщение.Вставить("user_name", Владелец.Объект.ИмяПользователяЛира);
	Сообщение.Вставить("user_level", Владелец.Объект.УровеньПодготовленностиПользователя);
	Сообщение.Вставить("db_name", Владелец.Объект.НазваниеИБ);
	Транспорт.ОтправитьСообщение(Сообщение);

	// Обновить индикатор Напарника
	Если Напарник <> Неопределено Тогда
		Напарник.ПроверитьДоступность(Владелец.Объект.Токен1СНапарник);
	КонецЕсли;

КонецПроцедуры

// Возвращает ФормИД для использования в сообщениях.
//
&НаКлиенте
Функция ПолучитьФормИД() Экспорт
	Возврат ФормИД;
КонецФункции

#КонецОбласти

#Область ОбработчикиПротокола

// Маршрутизация сообщений протокола.
// Системные (hello_ack, auth_ack, balance_update, session_*) — обрабатываем здесь.
// Стриминг (text_delta, thinking_*, tool_call, error, assistant_end, tool_status) → Чат.
//
&НаКлиенте
Процедура ОбработатьСообщениеПротокола(ДанныеОтвета)

	ТипСобытия = ПолучитьПоле(ДанныеОтвета, "type");
	Если ТипСобытия = Неопределено Тогда
		ТипСобытия = "";
	КонецЕсли;

	Если ТипСобытия = "hello_ack" Тогда
		ОбработатьHelloAck(ДанныеОтвета);
	ИначеЕсли ТипСобытия = "auth_ack" Тогда
		ОбработатьAuthAck(ДанныеОтвета);
	ИначеЕсли ТипСобытия = "balance_update" Тогда
		ОбработатьBalanceUpdate(ДанныеОтвета);
	ИначеЕсли ТипСобытия = "session_warning" Тогда
		ОбработатьПредупреждениеСессии(ДанныеОтвета);
	ИначеЕсли ТипСобытия = "session_expired" Тогда
		ОбработатьСессияИстекла(ДанныеОтвета);
	Иначе
		// Стриминг, ошибки, tool_call → делегируем в МодульЧат
		Чат.ОбработатьСобытие(ТипСобытия, ДанныеОтвета);
	КонецЕсли;

КонецПроцедуры

// Отправляет hello в session:lobby через Centrifugo с данными о базе.
//
&НаКлиенте
Процедура ОтправитьHello()

	// Собираем данные hello
	Привет = Новый Структура;
	Привет.Вставить("form_id", ФормИД);

	// Данные о базе (получены при открытии формы)
	Если ДанныеБазы <> Неопределено Тогда
		Привет.Вставить("config_name", ДанныеБазы.config_name);
		Привет.Вставить("config_version", ДанныеБазы.config_version);
		Привет.Вставить("config_id", ДанныеБазы.config_id);
		Привет.Вставить("computer", ДанныеБазы.computer);
		Привет.Вставить("connection_string", ДанныеБазы.connection_string);
		Привет.Вставить("base_ids", ДанныеБазы.base_ids);
		Привет.Вставить("epf_version", ДанныеБазы.epf_version);
	КонецЕсли;

	// Часовой пояс клиента (смещение от UTC)
	Привет.Вставить("timezone", ВычислитьЧасовойПоясКлиента());

	Транспорт.ОтправитьHello(Привет);

КонецПроцедуры

// Обрабатывает hello_ack от Роутера.
// Сохраняет session_id, chat_jwt, mobile_jwt. Переподключается на канал сессии.
//
&НаКлиенте
Процедура ОбработатьHelloAck(ДанныеОтвета)

	СессияИД = ПолучитьПоле(ДанныеОтвета, "session_id");
	ЧатJWT = ПолучитьПоле(ДанныеОтвета, "chat_jwt");
	МобильныйJWT = ПолучитьПоле(ДанныеОтвета, "mobile_jwt");
	СтатусОтвета = ПолучитьПоле(ДанныеОтвета, "status");

	Если СессияИД = Неопределено Тогда СессияИД = "" КонецЕсли;
	Если ЧатJWT = Неопределено Тогда ЧатJWT = "" КонецЕсли;
	Если МобильныйJWT = Неопределено Тогда МобильныйJWT = "" КонецЕсли;
	Если СтатусОтвета = Неопределено Тогда СтатусОтвета = "" КонецЕсли;

	Если НЕ ЗначениеЗаполнено(СессияИД) ИЛИ НЕ ЗначениеЗаполнено(ЧатJWT) Тогда
		ОповеститьВладельца("ошибка", "hello_ack без session_id или chat_jwt.");
		Возврат;
	КонецЕсли;

	// Сохранить session_id в Транспорте для publish в канал сессии
	Транспорт.УстановитьСессию(СессияИД);

	// Отобразить идентификатор сессии
	ОповеститьВладельца("ид_сессии", СессияИД);

	АвтоАвторизация = ПолучитьПоле(ДанныеОтвета, "auto_auth");
	Если АвтоАвторизация = Неопределено Тогда
		АвтоАвторизация = Ложь;
	КонецЕсли;

	Если СтатусОтвета = "reconnected" Тогда

		// Переподключение к существующей сессии — без QR
		Авторизован = Истина;
		ОповеститьВладельца("информация",
			"Переподключение к сессии " + Лев(СессияИД, 8) + "...");
		// Проверяем доступность Напарника (токен уже сохранён)
		Если Напарник <> Неопределено Тогда
			Напарник.ПроверитьДоступность(Владелец.Объект.Токен1СНапарник);
		КонецЕсли;

	ИначеЕсли АвтоАвторизация = Истина Тогда

		// Авто-авторизация (MVP) — без QR
		Авторизован = Истина;
		// Загружаем сохранённые настройки от Роутера
		ЗагрузитьНастройкиИзОтвета(ДанныеОтвета);
		// Проверяем доступность Напарника (индикатор)
		Если Напарник <> Неопределено Тогда
			Напарник.ПроверитьДоступность(Владелец.Объект.Токен1СНапарник);
		КонецЕсли;
		// Ввод разблокируется при connected(session)

	Иначе

		// Новая сессия — показать QR если есть mobile_jwt
		Если ЗначениеЗаполнено(МобильныйJWT) Тогда
			ПоказатьQR(МобильныйJWT);
		КонецЕсли;
		// Блокируем ввод до авторизации
		ОповеститьВладельца("доступность_ввода", Ложь);

	КонецЕсли;

	// Переподключиться к Centrifugo с персональным chat_jwt
	// (авто-подписка на канал сессии через channels claim в JWT)
	Транспорт.Переподключиться(ЧатJWT);

КонецПроцедуры

// Обрабатывает auth_ack от Роутера (после авторизации через мобильное приложение).
//
&НаКлиенте
Процедура ОбработатьAuthAck(ДанныеОтвета)

	СтатусАвторизации = ПолучитьПоле(ДанныеОтвета, "status");
	Если СтатусАвторизации = Неопределено Тогда
		СтатусАвторизации = "";
	КонецЕсли;
	Если СтатусАвторизации = "ok" Тогда

		Авторизован = Истина;
		// Загружаем сохранённые настройки от Роутера
		ЗагрузитьНастройкиИзОтвета(ДанныеОтвета);
		// Проверяем доступность Напарника (индикатор)
		Если Напарник <> Неопределено Тогда
			Напарник.ПроверитьДоступность(Владелец.Объект.Токен1СНапарник);
		КонецЕсли;
		// Заменить QR-код на «Лира на связи!» (или добавить новое сообщение)
		Если ЗначениеЗаполнено(QRСообщениеИД) Тогда
			Чат.ОбновитьСообщениеПоИД(QRСообщениеИД, "Лира на связи!");
			QRСообщениеИД = "";
		Иначе
			ОповеститьВладельца("информация", "Лира на связи!");
		КонецЕсли;
		ОповеститьВладельца("доступность_ввода", Истина);
		ОповеститьВладельца("занят", Ложь);
		Чат.ОбработатьГотовностьКанала();

	ИначеЕсли СтатусАвторизации = "insufficient_balance" Тогда

		СообщениеБаланса = ПолучитьПоле(ДанныеОтвета, "message");
		Если СообщениеБаланса = Неопределено ИЛИ НЕ ЗначениеЗаполнено(СообщениеБаланса) Тогда
			СообщениеБаланса = "Недостаточный баланс. Пополните баланс в мобильном приложении.";
		КонецЕсли;
		ОповеститьВладельца("предупреждение", СообщениеБаланса);
		ОповеститьВладельца("доступность_ввода", Ложь);

	ИначеЕсли СтатусАвторизации = "auth_failed" Тогда

		ОповеститьВладельца("ошибка", "Ошибка авторизации.");
		ОповеститьВладельца("занят", Ложь);

	ИначеЕсли СтатусАвторизации = "service_unavailable" Тогда

		ОповеститьВладельца("ошибка", "Сервис временно недоступен. Попробуйте позже.");
		ОповеститьВладельца("занят", Ложь);

	Иначе
		ОповеститьВладельца("предупреждение", "auth_ack: " + СтатусАвторизации);
	КонецЕсли;

КонецПроцедуры

// Обрабатывает balance_update от Биллинга.
// При пополнении баланса (был <= 0, стал > 0) разблокирует ввод.
//
&НаКлиенте
Процедура ОбработатьBalanceUpdate(ДанныеОтвета)

	НовыйБаланс = ПолучитьПоле(ДанныеОтвета, "balance");
	Валюта = ПолучитьПоле(ДанныеОтвета, "currency");
	Если Валюта = Неопределено Тогда
		Валюта = "руб";
	КонецЕсли;

	Если НовыйБаланс <> Неопределено Тогда
		СтарыйБаланс = Баланс;
		Баланс = НовыйБаланс;

		// Отобразить баланс в заголовке
		ОповеститьВладельца("заголовок",
			"Лира — " + Формат(Баланс, "ЧДЦ=2; ЧГ=0") + " " + Валюта);

		// Разблокировать ввод если баланс пополнен (был <= 0, стал > 0)
		Если СтарыйБаланс <> Неопределено И СтарыйБаланс <= 0 И Баланс > 0 Тогда
			ОповеститьВладельца("информация",
				"Баланс пополнен. Можно задавать вопросы.");
			ОповеститьВладельца("доступность_ввода", Истина);
		КонецЕсли;

		// Предупреждение при нулевом балансе (списание во время работы)
		Если Баланс <= 0 И (СтарыйБаланс = Неопределено ИЛИ СтарыйБаланс > 0) Тогда
			ОповеститьВладельца("предупреждение",
				"Баланс исчерпан. Пополните баланс в мобильном приложении.");
			ОповеститьВладельца("доступность_ввода", Ложь);
		КонецЕсли;
	КонецЕсли;

КонецПроцедуры

// Предупреждение: сессия скоро завершится из-за неактивности.
&НаКлиенте
Процедура ОбработатьПредупреждениеСессии(ДанныеОтвета)

	ОставшиесяСекунды = ПолучитьПоле(ДанныеОтвета, "remaining_seconds");
	Если ОставшиесяСекунды <> Неопределено И ОставшиесяСекунды > 0 Тогда
		Минуты = Цел(ОставшиесяСекунды / 60);
		Если Минуты >= 1 Тогда
			ТекстВремени = "" + Минуты + " мин.";
		Иначе
			ТекстВремени = "" + ОставшиесяСекунды + " сек.";
		КонецЕсли;
	Иначе
		ТекстВремени = "несколько минут";
	КонецЕсли;

	ТекстПредупреждения = "Сессия будет автоматически завершена через " + ТекстВремени
		+ " из-за неактивности.<br>Отправьте сообщение для продолжения.";

	ОповеститьВладельца("предупреждение", ТекстПредупреждения);
	ОповеститьВладельца("оповещение", ТекстПредупреждения);

КонецПроцедуры

// Обрабатывает уведомление о завершении сессии из-за неактивности.
&НаКлиенте
Процедура ОбработатьСессияИстекла(ДанныеОтвета)

	Чат.УстановитьСессияИстекла();
	ОповеститьВладельца("доступность_ввода", Ложь);

	ОповеститьВладельца("предупреждение",
		"Сессия завершена из-за неактивности.<br><a href=""lyra://reconnect"" class=""chat-link"">Начать новую.</a>");

КонецПроцедуры

// Загружает настройки из ответа Роутера (hello_ack / auth_ack).
//
&НаКлиенте
Процедура ЗагрузитьНастройкиИзОтвета(ДанныеОтвета)

	// Токен Напарника — на верхнем уровне
	ТокенНапарника = ПолучитьПоле(ДанныеОтвета, "naparnik_token");
	Если ЗначениеЗаполнено(ТокенНапарника) Тогда
		Владелец.Объект.Токен1СНапарник = ТокенНапарника;
	КонецЕсли;

	// Остальные настройки — в объекте settings
	Настройки = ПолучитьПоле(ДанныеОтвета, "settings");
	Если Настройки = Неопределено Тогда
		Возврат;
	КонецЕсли;

	Значение = ПолучитьПоле(Настройки, "user_name");
	Если ЗначениеЗаполнено(Значение) Тогда
		Владелец.Объект.ИмяПользователяЛира = Значение;
	КонецЕсли;

	Значение = ПолучитьПоле(Настройки, "user_level");
	Если ЗначениеЗаполнено(Значение) Тогда
		Владелец.Объект.УровеньПодготовленностиПользователя = Значение;
	КонецЕсли;

	Значение = ПолучитьПоле(Настройки, "db_name");
	Если ЗначениеЗаполнено(Значение) Тогда
		Владелец.Объект.НазваниеИБ = Значение;
	КонецЕсли;

КонецПроцедуры

// Генерирует QR-код из JWT и выводит в чат.
// QR = mobile_jwt, мобильное приложение сканирует для подключения к каналу сессии.
//
&НаКлиенте
Процедура ПоказатьQR(Знач JWT)

	Base64Картинка = СгенерироватьQRBase64(JWT);

	Если ЗначениеЗаполнено(Base64Картинка) Тогда
		// Base64Строка() в 1С добавляет переводы строк — убираем
		Base64Картинка = СтрЗаменить(Base64Картинка, Символы.ВК, "");
		Base64Картинка = СтрЗаменить(Base64Картинка, Символы.ПС, "");

		HTML = "<div style=""text-align:center;padding:16px;"">"
			+ "<img src=""data:image/png;base64," + Base64Картинка + """ style=""width:200px;height:200px;"" />"
			+ "<div style=""margin-top:8px;color:#888;font-size:0.85em;"">Отсканируйте QR-код в мобильном приложении Лира</div>"
			+ "</div>";
		QRСообщениеИД = "qr-" + Строка(Новый УникальныйИдентификатор);
		Чат.ДобавитьИнформациюСИД(QRСообщениеИД, HTML);
	Иначе
		// Fallback: JWT как текст для ручного ввода
		ОповеститьВладельца("предупреждение",
			"Не удалось сгенерировать QR-код. Код для мобильного приложения:<br/>"
			+ "<code style=""font-size:0.7em;word-break:break-all;"">" + JWT + "</code>");
	КонецЕсли;

КонецПроцедуры

&НаСервереБезКонтекста
Функция СгенерироватьQRBase64(Знач Текст)

	Попытка
		SSL = Новый ЗащищенноеСоединениеOpenSSL;
		Соединение = Новый HTTPСоединение("api.qrserver.com", 443, , , , 5, SSL);

		КодированныйТекст = КодироватьСтроку(Текст, СпособКодированияСтроки.КодировкаURL);
		Запрос = Новый HTTPЗапрос("/v1/create-qr-code/?size=256x256&data=" + КодированныйТекст);
		Ответ = Соединение.Получить(Запрос);

		Если Ответ.КодСостояния = 200 Тогда
			Возврат Base64Строка(Ответ.ПолучитьТелоКакДвоичныеДанные());
		КонецЕсли;
	Исключение
	КонецПопытки;

	Возврат "";

КонецФункции

#КонецОбласти

#Область СлужебныеПроцедуры

// Возвращает часовой пояс клиента как "GMT+7" или "GMT-5".
// Работает везде: тонкий клиент, веб-клиент, толстый клиент.
&НаСервереБезКонтекста
Функция ВычислитьЧасовойПоясКлиента()
	Текущая = ТекущаяДата();
	Смещение = Текущая - УниверсальноеВремя(Текущая);
	Смещение = Окр(Смещение / 3600, 0);
	Возврат "GMT" + ?(Смещение >= 0, "+", "") + Формат(Смещение, "ЧГ=0");
КонецФункции

// Отправляет событие владельцу (главной форме).
&НаКлиенте
Процедура ОповеститьВладельца(ИмяСобытия, Данные)
	Владелец.ОбработатьСобытиеМодуля("Сессия", ИмяСобытия, Данные);
КонецПроцедуры

// ─── JSON-утилиты (приватные копии для hot path) ───

&НаКлиенте
Функция ПолучитьПоле(Данные, Ключ)
	Если ТипЗнч(Данные) = Тип("Структура") Тогда
		Значение = Неопределено;
		Данные.Свойство(Ключ, Значение);
		Возврат Значение;
	ИначеЕсли ТипЗнч(Данные) = Тип("Соответствие") Тогда
		Возврат Данные.Получить(Ключ);
	Иначе
		Возврат Неопределено;
	КонецЕсли;
КонецФункции

#КонецОбласти
