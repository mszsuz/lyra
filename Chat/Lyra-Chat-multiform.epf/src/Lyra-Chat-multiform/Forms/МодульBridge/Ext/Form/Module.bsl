
// МодульBridge — мини-клиент Centrifugo на BSL.
// Служебная форма-модуль (не отображается), получается через ПолучитьФорму("МодульBridge").
// Реализует клиентский протокол Centrifugo: connect, publish, ping/pong, мульти-JSON, push-конверт.
// EPF работает без расширения ЕХТ_Центрифуга — вся логика протокола здесь.

#Область ПеременныеМодуля

&НаКлиенте
Перем Владелец;             // ссылка на главную форму (для обратной связи)
&НаКлиенте
Перем КлючСоединенияWS;    // ключ для WebSocketКлиентСоединения
&НаКлиенте
Перем ОбщийJWT;             // зашитый JWT для lobby (константа)
&НаКлиенте
Перем ТекущийJWT;           // chat_jwt после hello_ack (или общий JWT при первом connect)
&НаКлиенте
Перем СессияИД;             // session_id из hello_ack
&НаКлиенте
Перем КаналСессии;          // "session:<session_id>"
&НаКлиенте
Перем СтатусПодключения;   // "disconnected" / "lobby" / "session"
&НаКлиенте
Перем СчётчикКоманд;       // auto-increment id для команд Centrifugo
&НаКлиенте
Перем АдресСервера;         // URL WebSocket Centrifugo (для переподключения)
&НаКлиенте
Перем ClientUUID;           // UUID соединения из connect response

#КонецОбласти

#Область ПрограммныйИнтерфейс

// Инициализация модуля. Сохраняет ссылку на главную форму.
//
// Параметры:
//  ФормаВладелец - УправляемаяФорма - Главная форма чата
//
&НаКлиенте
Процедура Инициализация(ФормаВладелец) Экспорт

	Владелец = ФормаВладелец;
	КлючСоединенияWS = "LyraChatMultiform_Centrifugo";
	СчётчикКоманд = 0;
	СтатусПодключения = "disconnected";
	ОбщийJWT = "eyJhbGciOiJIUzI1NiIsInR5cCI6IkpXVCJ9.eyJzdWIiOiJsb2JieS11c2VyIiwiZXhwIjoyMDg4MzYwNzUzLCJpYXQiOjE3NzMwMDA3NTN9.2as7077BWfd-zmCRCvFRkLBVp4LtyguvZTtGCpL9SMA";

КонецПроцедуры

// Подключается к Centrifugo по WebSocket.
// Отправляет connect-команду с общим JWT для lobby.
//
// Параметры:
//  АдресЦентрифуга - Строка - URL WebSocket (например ws://localhost:11000/connection/websocket)
//
&НаКлиенте
Процедура Подключиться(Знач АдресЦентрифуга) Экспорт

	Если НЕ ЗначениеЗаполнено(АдресЦентрифуга) Тогда
		АдресЦентрифуга = "ws://localhost:11000/connection/websocket";
	КонецЕсли;

	АдресСервера = АдресЦентрифуга;
	ТекущийJWT = ОбщийJWT;
	СтатусПодключения = "disconnected";

	ОткрытьВебСокет(АдресЦентрифуга);

КонецПроцедуры

// Отправляет hello в session:lobby с данными о базе.
//
// Параметры:
//  ДанныеОБазе - Структура - данные для hello (form_id, config_name, config_version и т.д.)
//
&НаКлиенте
Процедура ОтправитьHello(Знач ДанныеОБазе) Экспорт

	ДанныеОБазе.Вставить("type", "hello");
	Опубликовать("session:lobby", ДанныеОБазе);

КонецПроцедуры

// Отправляет сообщение (publish) в канал сессии.
// Принимает Структуру (данные) или Строку (JSON — будет распарсена в объект,
// чтобы Centrifugo получил JSON-объект в data, а не строку).
//
// Параметры:
//  Данные - Структура, Соответствие, Строка - данные для публикации
//
// Возвращаемое значение:
//  Булево - Истина если отправлено, Ложь если ошибка
//
&НаКлиенте
Функция ОтправитьСообщение(Знач Данные) Экспорт

	Если НЕ ЗначениеЗаполнено(КаналСессии) Тогда
		ОповеститьВладельца("bridge_error", "Нет канала сессии.");
		Возврат Ложь;
	КонецЕсли;

	// Если передана JSON-строка — распарсить в объект для publish.data
	Если ТипЗнч(Данные) = Тип("Строка") Тогда
		Попытка
			Данные = ПрочитатьJSONИзСтроки(Данные);
		Исключение
			// Если не JSON — отправляем как есть (обёрнуто в data)
		КонецПопытки;
	КонецЕсли;

	Возврат Опубликовать(КаналСессии, Данные);

КонецФункции

// Переподключается к Centrifugo с новым JWT (chat_jwt).
// Закрывает текущее WS-соединение и открывает новое.
//
// Параметры:
//  JWT - Строка - персональный chat_jwt
//
&НаКлиенте
Процедура Переподключиться(Знач JWT) Экспорт

	ТекущийJWT = JWT;
	СтатусПодключения = "disconnected";

	// Закрыть старое соединение
	СтарыйКлюч = КлючСоединенияWS;
	Попытка
		Соединение = WebSocketКлиентСоединения.ПолучитьСоединение(СтарыйКлюч);
		Если Соединение <> Неопределено Тогда
			Соединение.Закрыть();
		КонецЕсли;
	Исключение
	КонецПопытки;

	// Новый ключ — старое соединение ещё закрывается асинхронно
	КлючСоединенияWS = "LyraChatMultiform_Session_" + Строка(Новый УникальныйИдентификатор);

	// Открыть новое с персональным JWT
	ОткрытьВебСокет(АдресСервера);

КонецПроцедуры

// Отключается от Centrifugo.
//
&НаКлиенте
Процедура Отключиться() Экспорт

	Попытка
		Соединение = WebSocketКлиентСоединения.ПолучитьСоединение(КлючСоединенияWS);
		Если Соединение <> Неопределено Тогда
			Соединение.Закрыть();
		КонецЕсли;
	Исключение
	КонецПопытки;

	СтатусПодключения = "disconnected";

КонецПроцедуры

// Возвращает текущий статус подключения.
//
// Возвращаемое значение:
//  Строка - "disconnected" / "lobby" / "session"
//
&НаКлиенте
Функция ПолучитьСтатусПодключения() Экспорт
	Возврат СтатусПодключения;
КонецФункции

// Устанавливает данные сессии после получения hello_ack.
//
// Параметры:
//  НовыйСессияИД - Строка - session_id из hello_ack
//
&НаКлиенте
Процедура УстановитьСессию(Знач НовыйСессияИД) Экспорт
	СессияИД = НовыйСессияИД;
	КаналСессии = "session:" + СессияИД;
КонецПроцедуры

#КонецОбласти

#Область ОбработчикиWebSocket

&НаКлиенте
Процедура WS_ПриОткрытии(Соединение) Экспорт

	// При открытии WS отправляем connect с JWT
	ОтправитьConnect(Соединение);

КонецПроцедуры

&НаКлиенте
Процедура WS_ПриЗакрытии(Соединение, КодЗакрытия) Экспорт

	ПредыдущийСтатус = СтатусПодключения;
	СтатусПодключения = "disconnected";

	// Оповещаем только при неожиданном закрытии
	// (при штатном отключении/переподключении статус уже "disconnected")
	Если ПредыдущийСтатус <> "disconnected" Тогда
		ОповеститьВладельца("bridge_closed",
			Новый Структура("КодЗакрытия, ПредыдущийСтатус", КодЗакрытия, ПредыдущийСтатус));
	КонецЕсли;

КонецПроцедуры

&НаКлиенте
Процедура WS_ПриОшибке(Соединение, КодОшибки, Описание) Экспорт

	// При штатном отключении/переподключении статус уже "disconnected" —
	// ошибка от закрывающегося соединения, не сообщать
	Если СтатусПодключения = "disconnected" Тогда
		Возврат;
	КонецЕсли;

	ОповеститьВладельца("bridge_error",
		"Ошибка WebSocket: " + КодОшибки + " — " + Описание);

КонецПроцедуры

&НаКлиенте
Процедура WS_ПриПолученииСообщения(Соединение, Сообщение) Экспорт

	// Получить текст из сообщения (может быть Строка или ДвоичныеДанные)
	ТекстСообщения = "";
	Если ТипЗнч(Сообщение) = Тип("Строка") Тогда
		ТекстСообщения = Сообщение;
	ИначеЕсли ТипЗнч(Сообщение) = Тип("ДвоичныеДанные") Тогда
		ТекстСообщения = ПолучитьСтрокуИзДвоичныхДанных(Сообщение);
	Иначе
		Возврат;
	КонецЕсли;

	// Мульти-JSON: Centrifugo может слать несколько JSON в одном WS-фрейме через \n
	Строки = СтрРазделить(ТекстСообщения, Символы.ПС, Ложь);

	Для Каждого СтрокаJSON Из Строки Цикл

		СтрокаJSON = СокрЛП(СтрокаJSON);
		Если НЕ ЗначениеЗаполнено(СтрокаJSON) Тогда
			Продолжить;
		КонецЕсли;

		// Ping: пустой JSON → ответить pong (пустой JSON)
		Если СтрокаJSON = "{}" Тогда
			Попытка
				Соединение.ОтправитьСообщение("{}");
			Исключение
			КонецПопытки;
			Продолжить;
		КонецЕсли;

		// Разобрать JSON
		// ВАЖНО: имя переменной НЕ "Объект" — конфликтует с реквизитом формы,
		// платформа при &НаСервереБезКонтекста путает с данными формы.
		Попытка
			СообщениеОбъект = ПрочитатьJSONИзСтроки(СтрокаJSON);
		Исключение
			Продолжить;
		КонецПопытки;

		Если ТипЗнч(СообщениеОбъект) <> Тип("Соответствие") Тогда
			Продолжить;
		КонецЕсли;

		// Ответ на команду (есть id)
		Если СообщениеОбъект["id"] <> Неопределено Тогда
			ОбработатьОтветКоманды(СообщениеОбъект);
			Продолжить;
		КонецЕсли;

		// Push-сообщение (нет id, есть push)
		ПушДанные = СообщениеОбъект["push"];
		Если ПушДанные = Неопределено Тогда
			Продолжить;
		КонецЕсли;

		Канал = ПушДанные["channel"];

		// Развернуть pub-конверт
		ПабДанные = ПушДанные["pub"];
		Если ПабДанные <> Неопределено Тогда
			Данные = ПабДанные["data"];
			ИнфоОтправителя = ПабДанные["info"];
			Если Данные <> Неопределено Тогда
				// Передать ТОЛЬКО data (не весь конверт) — совместимость с главной формой.
				// Главная форма ожидает JSON-строку в bridge_message.
				ДанныеJSON = ЗаписатьJSONВСтроку(Данные);
				ОповеститьВладельца("bridge_message", ДанныеJSON);
			КонецЕсли;
		КонецЕсли;

		// Push subscribe (авто-подписка через channels claim)
		Если ПушДанные["subscribe"] <> Неопределено Тогда
			// Подтверждение подписки на канал — информационное
		КонецЕсли;

	КонецЦикла;

КонецПроцедуры

#КонецОбласти

#Область СлужебныеПроцедуры

// Открывает WebSocket-соединение к Centrifugo.
//
&НаКлиенте
Процедура ОткрытьВебСокет(Знач URLВебСокет)

	// Закрытие старого соединения если есть
	Попытка
		СтароеСоединение = WebSocketКлиентСоединения.ПолучитьСоединение(КлючСоединенияWS);
		Если СтароеСоединение <> Неопределено Тогда
			СтароеСоединение.Закрыть();
		КонецЕсли;
	Исключение
	КонецПопытки;

	// Настройка обработчиков WebSocket
	ОбработчикиСокета = Новый ОбработчикиWebSocketКлиентСоединения;
	ОбработчикиСокета.Модуль = ЭтотОбъект;
	ОбработчикиСокета.ОбработчикОткрытияСоединения = "WS_ПриОткрытии";
	ОбработчикиСокета.ОбработчикЗакрытияСоединения = "WS_ПриЗакрытии";
	ОбработчикиСокета.ОбработчикПолученияСообщения = "WS_ПриПолученииСообщения";
	ОбработчикиСокета.ОбработчикОшибки = "WS_ПриОшибке";

	ПараметрыСоединения = Новый ПараметрыWebSocketКлиентСоединения;

	Попытка
		WebSocketКлиентСоединения.ОткрытьСоединение(КлючСоединенияWS, URLВебСокет,
			ОбработчикиСокета, ПараметрыСоединения);
	Исключение
		ОповеститьВладельца("bridge_error",
			"Не удалось подключиться к Centrifugo: " + ОписаниеОшибки());
	КонецПопытки;

КонецПроцедуры

// Отправляет connect-команду Centrifugo с JWT.
//
&НаКлиенте
Процедура ОтправитьConnect(Соединение)

	JWT = ТекущийJWT;
	Если НЕ ЗначениеЗаполнено(JWT) Тогда
		JWT = ОбщийJWT;
	КонецЕсли;

	ИДКоманды = СледующийИДКоманды();
	// Формируем JSON вручную для простоты и скорости
	КомандаJSON = "{""id"":" + Формат(ИДКоманды, "ЧГ=0")
		+ ",""connect"":{""token"":""" + JWT + """}}";

	Попытка
		Соединение.ОтправитьСообщение(КомандаJSON);
	Исключение
		ОповеститьВладельца("bridge_error",
			"Ошибка отправки connect: " + ОписаниеОшибки());
	КонецПопытки;

КонецПроцедуры

// Обрабатывает ответ на команду (connect response, publish response и т.д.)
//
&НаКлиенте
Процедура ОбработатьОтветКоманды(Объект)

	// Проверяем ошибку
	ОшибкаОтвета = Объект["error"];
	Если ОшибкаОтвета <> Неопределено Тогда
		КодОшибки = ОшибкаОтвета["code"];
		СообщениеОшибки = ОшибкаОтвета["message"];
		ОповеститьВладельца("bridge_error",
			"Ошибка Centrifugo: " + КодОшибки + " — " + СообщениеОшибки);
		Возврат;
	КонецЕсли;

	// Connect response
	КоннектДанные = Объект["connect"];
	Если КоннектДанные <> Неопределено Тогда
		ClientUUID = КоннектДанные["client"];

		// Определяем статус по текущему JWT
		Если ТекущийJWT = ОбщийJWT Тогда
			СтатусПодключения = "lobby";
		Иначе
			СтатусПодключения = "session";
		КонецЕсли;

		ОповеститьВладельца("bridge_connected",
			Новый Структура("client, status, subs",
				ClientUUID, СтатусПодключения, КоннектДанные["subs"]));
		Возврат;
	КонецЕсли;

	// Publish response — молча подтверждаем
	// Subscribe response — молча подтверждаем

КонецПроцедуры

// Публикует данные в канал Centrifugo через WebSocket publish.
//
// Параметры:
//  Канал  - Строка - имя канала
//  Данные - Произвольный - данные для публикации (будут сериализованы в JSON)
//
// Возвращаемое значение:
//  Булево - Истина если отправлено
//
&НаКлиенте
Функция Опубликовать(Знач Канал, Знач Данные)

	Соединение = WebSocketКлиентСоединения.ПолучитьСоединение(КлючСоединенияWS);
	Если Соединение = Неопределено Тогда
		ОповеститьВладельца("bridge_error", "Нет соединения с Centrifugo.");
		Возврат Ложь;
	КонецЕсли;

	ИДКоманды = СледующийИДКоманды();

	// Формируем publish-команду
	ПубликацияПараметры = Новый Соответствие;
	ПубликацияПараметры.Вставить("channel", Канал);
	ПубликацияПараметры.Вставить("data", Данные);

	Команда = Новый Соответствие;
	Команда.Вставить("id", ИДКоманды);
	Команда.Вставить("publish", ПубликацияПараметры);

	КомандаJSON = ЗаписатьJSONВСтроку(Команда);

	Попытка
		Соединение.ОтправитьСообщение(КомандаJSON);
		Возврат Истина;
	Исключение
		ОповеститьВладельца("bridge_error", "Ошибка отправки: " + ОписаниеОшибки());
		Возврат Ложь;
	КонецПопытки;

КонецФункции

// Возвращает следующий ID команды (auto-increment).
//
&НаКлиенте
Функция СледующийИДКоманды()
	СчётчикКоманд = СчётчикКоманд + 1;
	Возврат СчётчикКоманд;
КонецФункции

// Вызывает экспортный метод ОбработатьСобытиеМодуля владельца.
//
&НаКлиенте
Процедура ОповеститьВладельца(ИмяСобытия, Данные)

	Если Владелец <> Неопределено Тогда
		Попытка
			Владелец.ОбработатьСобытиеМодуля("Bridge", ИмяСобытия, Данные);
		Исключение
		КонецПопытки;
	КонецЕсли;

КонецПроцедуры

// Читает JSON из строки и возвращает Соответствие.
// НаСервереБезКонтекста — ПрочитатьJSON недоступен на клиенте в веб-клиенте.
//
&НаСервереБезКонтекста
Функция ПрочитатьJSONИзСтроки(Знач СтрокаJSON)

	ЧтениеJSON = Новый ЧтениеJSON;
	ЧтениеJSON.УстановитьСтроку(СтрокаJSON);
	Результат = ПрочитатьJSON(ЧтениеJSON, Истина);
	ЧтениеJSON.Закрыть();
	Возврат Результат;

КонецФункции

// Записывает значение в компактную JSON-строку (без переносов и отступов).
// НаСервереБезКонтекста — ЗаписатьJSON недоступен на клиенте в веб-клиенте.
// ВАЖНО: ПереносСтрокJSON.Нет — Centrifugo парсит каждую строку как отдельный JSON,
// переносы ломают протокол.
//
&НаСервереБезКонтекста
Функция ЗаписатьJSONВСтроку(Знач Значение)

	ЗаписьJSON = Новый ЗаписьJSON;
	ПараметрыJSON = Новый ПараметрыЗаписиJSON(ПереносСтрокJSON.Нет);
	ЗаписьJSON.УстановитьСтроку(ПараметрыJSON);
	ЗаписатьJSON(ЗаписьJSON, Значение);
	Возврат ЗаписьJSON.Закрыть();

КонецФункции

#КонецОбласти
