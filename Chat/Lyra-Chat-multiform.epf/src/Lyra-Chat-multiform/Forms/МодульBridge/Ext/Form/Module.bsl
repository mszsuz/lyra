
// МодульBridge — WebSocket-соединение с Bridge.
// Служебная форма-модуль (не отображается), получается через ПолучитьФорму("МодульBridge").
// Управляет WebSocket-подключением, отправкой сообщений и обработкой WS-событий.

#Область ПеременныеМодуля

&НаКлиенте
Перем Владелец;       // ссылка на главную форму (для обратной связи)
&НаКлиенте
Перем КлючСоединенияWS; // ключ для WebSocketКлиентСоединения

#КонецОбласти

#Область ПрограммныйИнтерфейс

// Инициализация модуля. Сохраняет ссылку на главную форму.
//
// Параметры:
//  ФормаВладелец - УправляемаяФорма - Главная форма чата
//
&НаКлиенте
Процедура Инициализация(ФормаВладелец) Экспорт

	Владелец = ФормаВладелец;
	КлючСоединенияWS = "LyraChatMultiform_Bridge";

КонецПроцедуры

// Подключается к Bridge по WebSocket.
//
// Параметры:
//  АдресBridge - Строка - URL WebSocket (по умолчанию ws://localhost:3003)
//  ИдентификаторСессии - Строка - ID сессии для claude-resume
//  Модель - Строка - Модель Claude (opus, sonnet, haiku)
//
&НаКлиенте
Процедура Подключиться(Знач АдресBridge, Знач ИдентификаторСессии, Знач Модель = "") Экспорт

	Если НЕ ЗначениеЗаполнено(АдресBridge) Тогда
		АдресBridge = "ws://localhost:3003";
	КонецЕсли;

	// Закрытие старого соединения если есть
	Попытка
		СтароеСоединение = WebSocketКлиентСоединения.ПолучитьСоединение(КлючСоединенияWS);
		Если СтароеСоединение <> Неопределено Тогда
			СтароеСоединение.Закрыть();
		КонецЕсли;
	Исключение
	КонецПопытки;

	// Настройка обработчиков WebSocket
	ОбработчикиСокета = Новый ОбработчикиWebSocketКлиентСоединения;
	ОбработчикиСокета.Модуль = ЭтотОбъект;
	ОбработчикиСокета.ОбработчикОткрытияСоединения = "WS_ПриОткрытии";
	ОбработчикиСокета.ОбработчикЗакрытияСоединения = "WS_ПриЗакрытии";
	ОбработчикиСокета.ОбработчикПолученияСообщения = "WS_ПриПолученииСообщения";
	ОбработчикиСокета.ОбработчикОшибки = "WS_ПриОшибке";

	// Параметры соединения с заголовками
	ПараметрыСоединения = Новый ПараметрыWebSocketКлиентСоединения;
	ПараметрыСоединения.Заголовки.Вставить("claude-resume", ИдентификаторСессии);
	Если ЗначениеЗаполнено(Модель) Тогда
		ПараметрыСоединения.Заголовки.Вставить("claude-model", Модель);
	КонецЕсли;

	Попытка
		WebSocketКлиентСоединения.ОткрытьСоединение(КлючСоединенияWS, АдресBridge,
			ОбработчикиСокета, ПараметрыСоединения);
	Исключение
		ОповеститьВладельца("bridge_error", "Не удалось подключиться к Лира Bridge: " + ОписаниеОшибки());
	КонецПопытки;

КонецПроцедуры

// Отключается от Bridge.
//
&НаКлиенте
Процедура Отключиться() Экспорт

	Попытка
		Соединение = WebSocketКлиентСоединения.ПолучитьСоединение(КлючСоединенияWS);
		Если Соединение <> Неопределено Тогда
			Соединение.Закрыть();
		КонецЕсли;
	Исключение
	КонецПопытки;

КонецПроцедуры

// Отправляет JSON-сообщение через WebSocket.
//
// Параметры:
//  ТекстJSON - Строка - JSON-строка для отправки
//
// Возвращаемое значение:
//  Булево - Истина если отправлено, Ложь если ошибка
//
&НаКлиенте
Функция ОтправитьСообщение(Знач ТекстJSON) Экспорт

	Соединение = WebSocketКлиентСоединения.ПолучитьСоединение(КлючСоединенияWS);
	Если Соединение = Неопределено Тогда
		ОповеститьВладельца("bridge_error", "Нет соединения с Лирой.");
		Возврат Ложь;
	КонецЕсли;

	Попытка
		Соединение.ОтправитьСообщение(ТекстJSON);
		Возврат Истина;
	Исключение
		ОповеститьВладельца("bridge_error", "Ошибка отправки: " + ОписаниеОшибки());
		Возврат Ложь;
	КонецПопытки;

КонецФункции

#КонецОбласти

#Область ОбработчикиWebSocket

&НаКлиенте
Процедура WS_ПриОткрытии(Соединение) Экспорт
	ОповеститьВладельца("bridge_connected", "");
КонецПроцедуры

&НаКлиенте
Процедура WS_ПриЗакрытии(Соединение, КодЗакрытия) Экспорт
	ОповеститьВладельца("bridge_closed", КодЗакрытия);
КонецПроцедуры

&НаКлиенте
Процедура WS_ПриОшибке(Соединение, КодОшибки, Описание) Экспорт
	ОповеститьВладельца("bridge_ws_error", "" + КодОшибки + " — " + Описание);
КонецПроцедуры

&НаКлиенте
Процедура WS_ПриПолученииСообщения(Соединение, Сообщение) Экспорт

	ТипСообщенияWS = ТипЗнч(Сообщение);
	ПолученныйТекст = "";
	Если ТипСообщенияWS = Тип("Строка") Тогда
		ПолученныйТекст = Сообщение;
	ИначеЕсли ТипСообщенияWS = Тип("ДвоичныеДанные") Тогда
		ПолученныйТекст = ПолучитьСтрокуИзДвоичныхДанных(Сообщение);
	Иначе
		Возврат;
	КонецЕсли;

	// Передаём сырой JSON-текст наверх в главную форму
	ОповеститьВладельца("bridge_message", ПолученныйТекст);

КонецПроцедуры

#КонецОбласти

#Область СлужебныеПроцедуры

// Вызывает экспортный метод ОбработатьСобытиеМодуля владельца.
//
&НаКлиенте
Процедура ОповеститьВладельца(ИмяСобытия, Данные)

	Если Владелец <> Неопределено Тогда
		Попытка
			Владелец.ОбработатьСобытиеМодуля("Bridge", ИмяСобытия, Данные);
		Исключение
		КонецПопытки;
	КонецЕсли;

КонецПроцедуры

#КонецОбласти
