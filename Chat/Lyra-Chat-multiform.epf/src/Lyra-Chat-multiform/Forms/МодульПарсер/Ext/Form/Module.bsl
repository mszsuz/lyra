
// МодульПарсер — JSON-обработка.
// Служебная форма-модуль (не отображается), получается через ПолучитьФорму("МодульПарсер").
// Первичный путь: ПрочитатьЗначениеJSON/ЗаписатьЗначениеJSON (клиент, 8.3.23+, Структура).
// Fallback: ПрочитатьJSON/ЗаписатьJSON через серверный вызов (Соответствие).

#Область ПрограммныйИнтерфейс

// Разбирает строку JSON.
// Основной путь: ПрочитатьЗначениеJSON (клиент, возвращает Структура).
// Fallback: ПрочитатьJSON на сервере (возвращает Соответствие).
//
// Параметры:
//  СтрокаJSON - Строка - JSON-строка
//
// Возвращаемое значение:
//  Структура, Соответствие, Массив или примитив — разобранные данные
//
&НаКлиенте
Функция РазобратьJSON(Знач СтрокаJSON) Экспорт

	Если НЕ ЗначениеЗаполнено(СтрокаJSON) Тогда
		Возврат Новый Структура;
	КонецЕсли;

	Попытка
		Возврат ПрочитатьЗначениеJSON(СтрокаJSON);
	Исключение
		Попытка
			Возврат РазобратьJSON_Сервер(СтрокаJSON);
		Исключение
			Возврат Новый Структура;
		КонецПопытки;
	КонецПопытки;

КонецФункции

// Извлекает текст дельты из разобранного stream_event.
// Ожидаемая структура: {"type":"stream_event","event":{"type":"content_block_delta","delta":{"text":"фрагмент"}}}
//
// Параметры:
//  Данные - Структура, Соответствие - Разобранный JSON (результат РазобратьJSON)
//
// Возвращаемое значение:
//  Строка - Текст дельты или ""
//
&НаКлиенте
Функция ИзвлечьТекстДельты(Данные) Экспорт

	Если НЕ ЭтоОбъектJSON(Данные) Тогда
		Возврат "";
	КонецЕсли;

	Событие = ПолучитьПоле(Данные, "event");
	Если НЕ ЭтоОбъектJSON(Событие) Тогда
		Возврат "";
	КонецЕсли;

	Дельта = ПолучитьПоле(Событие, "delta");
	Если НЕ ЭтоОбъектJSON(Дельта) Тогда
		Возврат "";
	КонецЕсли;

	ТипДельты = ПолучитьПоле(Дельта, "type");

	Если ТипДельты = "thinking_delta" Тогда
		Текст = ПолучитьПоле(Дельта, "thinking");
	ИначеЕсли ТипДельты = "text_delta" Тогда
		Текст = ПолучитьПоле(Дельта, "text");
	Иначе
		Возврат "";
	КонецЕсли;

	Если Текст = Неопределено Тогда
		Возврат "";
	КонецЕсли;

	Возврат Строка(Текст);

КонецФункции

// Извлекает значение поля верхнего уровня из разобранного JSON.
//
// Параметры:
//  Данные - Структура, Соответствие - Разобранный JSON
//  ИмяПоля - Строка - Имя поля (например "type", "result", "sessionId")
//
// Возвращаемое значение:
//  Произвольный - Значение поля или "" если не найдено
//
&НаКлиенте
Функция ИзвлечьЗначение(Данные, ИмяПоля) Экспорт

	Если НЕ ЭтоОбъектJSON(Данные) Тогда
		Возврат "";
	КонецЕсли;

	Значение = ПолучитьПоле(Данные, ИмяПоля);
	Если Значение = Неопределено Тогда
		Возврат "";
	КонецЕсли;

	Возврат Значение;

КонецФункции

// Извлекает тип события из разобранного JSON.
//
// Параметры:
//  Данные - Структура, Соответствие - Разобранный JSON
//
// Возвращаемое значение:
//  Строка - Тип события (session, system, stream_event, result, error и т.д.)
//
&НаКлиенте
Функция ИзвлечьТипСобытия(Данные) Экспорт
	Возврат ИзвлечьЗначение(Данные, "type");
КонецФункции

// Извлекает тип внутреннего события из stream_event.
// Возвращает event.type: "content_block_start", "content_block_delta", "content_block_stop" и т.д.
//
// Параметры:
//  Данные - Структура, Соответствие - Разобранный JSON
//
// Возвращаемое значение:
//  Строка - Тип внутреннего события или ""
//
&НаКлиенте
Функция ИзвлечьТипВнутреннегоСобытия(Данные) Экспорт

	Если НЕ ЭтоОбъектJSON(Данные) Тогда
		Возврат "";
	КонецЕсли;

	Событие = ПолучитьПоле(Данные, "event");
	Если НЕ ЭтоОбъектJSON(Событие) Тогда
		Возврат "";
	КонецЕсли;

	ТипВнутренний = ПолучитьПоле(Событие, "type");
	Если ТипВнутренний = Неопределено Тогда
		Возврат "";
	КонецЕсли;

	Возврат Строка(ТипВнутренний);

КонецФункции

// Извлекает тип блока контента из content_block_start.
// Возвращает event.content_block.type: "thinking", "text", "tool_use"
//
// Параметры:
//  Данные - Структура, Соответствие - Разобранный JSON
//
// Возвращаемое значение:
//  Строка - Тип блока или ""
//
&НаКлиенте
Функция ИзвлечьТипБлока(Данные) Экспорт

	Если НЕ ЭтоОбъектJSON(Данные) Тогда
		Возврат "";
	КонецЕсли;

	Событие = ПолучитьПоле(Данные, "event");
	Если НЕ ЭтоОбъектJSON(Событие) Тогда
		Возврат "";
	КонецЕсли;

	БлокКонтента = ПолучитьПоле(Событие, "content_block");
	Если НЕ ЭтоОбъектJSON(БлокКонтента) Тогда
		Возврат "";
	КонецЕсли;

	ТипБлока = ПолучитьПоле(БлокКонтента, "type");
	Если ТипБлока = Неопределено Тогда
		Возврат "";
	КонецЕсли;

	Возврат Строка(ТипБлока);

КонецФункции

// Сериализует значение в JSON-строку.
// Основной путь: ЗаписатьЗначениеJSON (клиент, принимает Структура).
// Fallback: ЗаписатьJSON на сервере (принимает и Соответствие).
//
// Параметры:
//  Значение - Произвольный - Структура, Соответствие, Массив или примитив
//
// Возвращаемое значение:
//  Строка - JSON-строка
//
&НаКлиенте
Функция СобратьJSON(Значение) Экспорт

	Попытка
		Возврат ЗаписатьЗначениеJSON(Значение);
	Исключение
		Попытка
			Возврат СобратьJSON_Сервер(Значение);
		Исключение
			Возврат "{}";
		КонецПопытки;
	КонецПопытки;

КонецФункции

// Экранирует спецсимволы в строке для безопасной вставки в JSON.
// \→\\, "→\", ПС→\n, ВК→(убираем), Таб→\t
//
// Параметры:
//  Текст - Строка - Исходный текст
//
// Возвращаемое значение:
//  Строка - Экранированный текст
//
&НаКлиенте
Функция ЭкранироватьJSON(Текст) Экспорт

	Результат = СтрЗаменить(Текст, "\", "\\");
	Результат = СтрЗаменить(Результат, """", "\""");
	Результат = СтрЗаменить(Результат, Символы.ПС, "\n");
	Результат = СтрЗаменить(Результат, Символы.ВК, "");
	Результат = СтрЗаменить(Результат, Символы.Таб, "\t");

	Возврат Результат;

КонецФункции

// Конвертирует 1С-значение в JSON-совместимый тип.
//
// Параметры:
//  ИсходноеЗначение - Произвольный - Значение для конвертации
//
// Возвращаемое значение:
//  Произвольный - JSON-совместимое значение
//
&НаКлиенте
Функция ЗначениеДляJSON(ИсходноеЗначение) Экспорт

	Если ИсходноеЗначение = Неопределено ИЛИ ИсходноеЗначение = Null Тогда
		Возврат Null;
	ИначеЕсли ТипЗнч(ИсходноеЗначение) = Тип("Булево")
		ИЛИ ТипЗнч(ИсходноеЗначение) = Тип("Число")
		ИЛИ ТипЗнч(ИсходноеЗначение) = Тип("Строка") Тогда
		Возврат ИсходноеЗначение;
	ИначеЕсли ТипЗнч(ИсходноеЗначение) = Тип("Дата") Тогда
		Возврат Формат(ИсходноеЗначение, "ДФ=yyyy-MM-ddTHH:mm:ss");
	Иначе
		Возврат Строка(ИсходноеЗначение);
	КонецЕсли;

КонецФункции

// Проверяет что значение является JSON-объектом (Структура или Соответствие).
//
// Параметры:
//  Значение - Произвольный
//
// Возвращаемое значение:
//  Булево
//
&НаКлиенте
Функция ЭтоОбъектJSON(Значение) Экспорт
	Возврат ТипЗнч(Значение) = Тип("Структура") ИЛИ ТипЗнч(Значение) = Тип("Соответствие");
КонецФункции

// Получает значение поля из Структуры или Соответствия.
// Универсальный геттер: Структура.Свойство() / Соответствие.Получить().
//
// Параметры:
//  Данные - Структура, Соответствие - Объект JSON
//  Ключ - Строка - Имя поля
//
// Возвращаемое значение:
//  Произвольный - Значение поля или Неопределено
//
&НаКлиенте
Функция ПолучитьПоле(Данные, Ключ) Экспорт

	Если ТипЗнч(Данные) = Тип("Структура") Тогда
		Значение = Неопределено;
		Данные.Свойство(Ключ, Значение);
		Возврат Значение;
	ИначеЕсли ТипЗнч(Данные) = Тип("Соответствие") Тогда
		Возврат Данные.Получить(Ключ);
	Иначе
		Возврат Неопределено;
	КонецЕсли;

КонецФункции

#КонецОбласти

#Область СлужебныеПроцедуры

// Серверный fallback для РазобратьJSON.
// Используется когда ПрочитатьЗначениеJSON недоступен (платформа < 8.3.23)
// или не может разобрать JSON (ключи с недопустимыми символами).
// Возвращает Соответствие (ПрочитатьJSON с Истина).

&НаСервереБезКонтекста
Функция РазобратьJSON_Сервер(Знач СтрокаJSON)
	ЧтениеJSON = Новый ЧтениеJSON;
	ЧтениеJSON.УстановитьСтроку(СтрокаJSON);
	Результат = ПрочитатьJSON(ЧтениеJSON, Истина);
	ЧтениеJSON.Закрыть();
	Возврат Результат;
КонецФункции

// Серверный fallback для СобратьJSON.
// Используется когда ЗаписатьЗначениеJSON недоступен или значение содержит Соответствие.

&НаСервереБезКонтекста
Функция СобратьJSON_Сервер(Значение)
	ЗаписьJSON = Новый ЗаписьJSON;
	ЗаписьJSON.УстановитьСтроку();
	ЗаписатьJSON(ЗаписьJSON, Значение);
	Возврат ЗаписьJSON.Закрыть();
КонецФункции

#КонецОбласти
