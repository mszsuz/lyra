
&НаСервере
Процедура ПриСозданииНаСервере(Отказ, СтандартнаяОбработка)

	МодульОбъекта = РеквизитФормыВЗначение("Объект");

	ЭтотОбъект.Контекст = Новый Структура;
	ЭтотОбъект.Контекст.Вставить("ИспользуемоеИмяФайла", МодульОбъекта.ИспользуемоеИмяФайла);
	ЭтотОбъект.Контекст.Вставить("ИмяОбработки", СтрРазделить(ЭтотОбъект.ИмяФормы, ".")[1]);
	ЭтотОбъект.Контекст.Вставить("ИменаФорм", Новый Массив);
	Для Каждого МетаФорма Из МодульОбъекта.Метаданные().Формы Цикл
		ЭтотОбъект.Контекст.ИменаФорм.Добавить(МетаФорма.Имя);
	КонецЦикла;

КонецПроцедуры

&НаКлиенте
Процедура ПриОткрытии(Отказ)
	ПодключитьОбработчикОжидания("ПослеОткрытияАсинх", 5, Истина);
КонецПроцедуры

&НаКлиенте
Асинх Процедура ПослеОткрытияАсинх()

	ИмяОбработки = ЭтотОбъект.Контекст.ИмяОбработки;

	// Создаём главную форму
	ГлавнаяФорма = ПолучитьФорму(ИмяДругойФормы("Форма"));

	// Создаём все модули (формы с префиксом "Модуль") — владелец = ГлавнаяФорма
	СписокМодулей = Новый Структура;
	Для Каждого ИмяФормыОбработки Из ЭтотОбъект.Контекст.ИменаФорм Цикл
		Если СтрНачинаетсяС(ИмяФормыОбработки, "Модуль") Тогда
			СписокМодулей.Вставить(ИмяФормыОбработки, ПолучитьФорму(ИмяДругойФормы(ИмяФормыОбработки), , ГлавнаяФорма));
		КонецЕсли;
	КонецЦикла;

	// Собираем Контекст — DI-контейнер со вложенными структурами
	Контекст = Новый Структура;

	// Контекст.Обработка — данные обработки
	Контекст.Вставить("Обработка", Новый Структура);
	Контекст.Обработка.Вставить("ИмяОбработки", ИмяОбработки);
	Контекст.Обработка.Вставить("ИспользуемоеИмяФайла", ЭтотОбъект.Контекст.ИспользуемоеИмяФайла);

	// Контекст.Модули — ссылки на формы-модули
	Контекст.Вставить("Модули", СписокМодулей);

	// Контекст.ГлавнаяФорма — заполняется в Форма.Инициализация()
	Контекст.Вставить("ГлавнаяФорма", Новый Структура);
	Контекст.ГлавнаяФорма.Вставить("Форма", Неопределено);
	Контекст.ГлавнаяФорма.Вставить("ЭлементЧата", Неопределено);
	Контекст.ГлавнаяФорма.Вставить("ФормИД", "");
	Контекст.ГлавнаяФорма.Вставить("ДанныеБазы", Неопределено);
	Контекст.ГлавнаяФорма.Вставить("ОбщиеПараметры", Неопределено);

	// Инициализация: ГлавнаяФорма заполнит свою секцию и инициализирует модули
	ГлавнаяФорма.Инициализация(Контекст);

	Закрыть();

	ГлавнаяФорма.Открыть();

КонецПроцедуры

&НаКлиенте
Функция ИмяДругойФормы(Знач Имя)
	Возврат СтрШаблон("ВнешняяОбработка.%1.Форма.%2", ЭтотОбъект.Контекст.ИмяОбработки, Имя);
КонецФункции
