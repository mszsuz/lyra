	МодульСессия.ОтправитьНастройки();
КонецПроцедуры

#КонецОбласти

#Область ЕХТ_Чат

// === НАЧАЛО: Код фреймворка ЕХТ_Чат (без изменений) ===

#Область ПрограммныйИнтерфейс

#Область ПрограммныйИнтерфейсСервер

&НаСервере
Процедура ЕХТ_Чат_Инициализация(Форма, Знач Параметры) Экспорт

	МодульОбъекта = МодульОбъекта();

	Если ТипЗнч(Форма) <> МодульОбъекта.ЕХТ_Тип_УправляемаяФорма() Тогда
		ВызватьИсключение МодульОбъекта.ЕХТ_Лог_ТекстИсключенияНедопустимыйПараметр(ПолноеИмя(), "Инициализация",
			"Форма", Форма);
	КонецЕсли;
	Если ТипЗнч(Параметры) <> Тип("Структура") Тогда
		ВызватьИсключение МодульОбъекта.ЕХТ_Лог_ТекстИсключенияНедопустимыйПараметр(ПолноеИмя(), "Инициализация",
			"Параметры", Параметры);
	КонецЕсли;
	ЗначенияПараметров = МодульОбъекта.ЕХТ_Свойства_вСтруктуру(Параметры, "Элемент, ДвоичныеДанныеПриложения");

	ДвоичныеДанныеПриложения = ЗначенияПараметров.ДвоичныеДанныеПриложения;
	ДвоичныеДанныеПриложенияТип = ТипЗнч(ДвоичныеДанныеПриложения);
	ОжидаемыеТипы = МодульОбъекта.ЕХТ_Тип_ОжидаемыеТипы("Неопределено, ДвоичныеДанные");
	Если ДвоичныеДанныеПриложенияТип = ОжидаемыеТипы.ДвоичныеДанные Тогда
		// Действие не требуется.
	ИначеЕсли ДвоичныеДанныеПриложенияТип = ОжидаемыеТипы.Неопределено Тогда
		ДвоичныеДанныеПриложения = ПолучитьОбщийМакет("ЕХТ_Чат_ДвоичныеДанныеПриложения");
	Иначе
		ВызватьИсключение МодульОбъекта.ЕХТ_Лог_ТекстИсключенияНедопустимыйПараметр(ПолноеИмя(), "Инициализация",
			"Параметры.ДвоичныеДанныеПриложения", ДвоичныеДанныеПриложения, ОжидаемыеТипы);
	КонецЕсли;

	Элемент = ЗначенияПараметров.Элемент;
	ОжидаемыеТипы = МодульОбъекта.ЕХТ_Тип_ОжидаемыеТипы("ПолеФормы, Массив");
	ЭлементыТип = ТипЗнч(Элемент);
	Если ЭлементыТип = ОжидаемыеТипы.ПолеФормы Тогда
		МассивЭлементов = ЕХТ_Массив(Элемент);
	ИначеЕсли ЭлементыТип = ОжидаемыеТипы.Массив Тогда
		МассивЭлементов = Элемент;
	Иначе
		ВызватьИсключение МодульОбъекта.ЕХТ_Лог_ТекстИсключенияНедопустимыйПараметр(ПолноеИмя(), "Инициализация",
			"Параметры.Элемент", Элемент, ОжидаемыеТипы);
	КонецЕсли;

	Для Каждого Элемент Из МассивЭлементов Цикл
		ЕХТ_Чат_УстановитьЭлемент(Форма, Элемент, ДвоичныеДанныеПриложения);
	КонецЦикла;

КонецПроцедуры

#КонецОбласти

#КонецОбласти

#Область СлужебныйПрограммныйИнтерфейс

#Область СлужебныйПрограммныйИнтерфейсСервер

&НаСервере
Процедура ЕХТ_Чат_УстановитьЭлемент(Форма, Знач Элемент, Знач ДвоичныеДанныеПриложения) Экспорт

	МодульОбъекта = МодульОбъекта();

	ЭлементТип = ТипЗнч(Элемент);
	Если ЭлементТип = Тип("Строка") Тогда

		ИмяЭлемента = Элемент;

		ИмяРеквизита = ИмяЭлемента;
		Если НЕ МодульОбъекта.ЕХТ_Форма_РеквизитСуществует(Форма, ИмяРеквизита) Тогда
			МодульОбъекта.ЕХТ_Форма_ДобавитьРеквизиты(Форма, Новый РеквизитФормы(ИмяРеквизита, МодульОбъекта.ЕХТ_Тип_ОписаниеСтрока()));
		КонецЕсли;

		Элемент = Форма.Элементы.Найти(ИмяЭлемента);
		Если Элемент = Неопределено Тогда
			Элемент = МодульОбъекта.ЕХТ_Форма_ДобавитьПолеФормыПолеHTMLДокумента(Форма, ИмяРеквизита);
		КонецЕсли;

	Иначе

		ИмяРеквизита = Элемент.ПутьКДанным;

	КонецЕсли;

	Элемент.УстановитьДействие("ПриНажатии", "Подключаемый_ПриНажатии");

	Если КлиентскоеПриложение.ТипПриложения() = ТипКлиентскогоПриложения.ВебКлиент Тогда
		Форма[ИмяРеквизита] = ПолучитьСтрокуИзДвоичныхДанных(ДвоичныеДанныеПриложения);
	Иначе
		Форма[ИмяРеквизита] = СтрШаблон("%1/%2",
			ПолучитьНавигационнуюСсылкуИнформационнойБазы(),
			ПоместитьВоВременноеХранилище(ДвоичныеДанныеПриложения, Форма.УникальныйИдентификатор));
	КонецЕсли;

КонецПроцедуры

#КонецОбласти

#КонецОбласти

