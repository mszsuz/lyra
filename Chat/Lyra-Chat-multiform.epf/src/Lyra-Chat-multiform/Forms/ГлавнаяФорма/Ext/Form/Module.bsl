
// Главная форма Lyra-Chat (модульный).
// Тонкий контроллер — только UI-события и координация модулей.
// Вся бизнес-логика разнесена по служебным формам-модулям:
//   МодульТранспорт — WebSocket-соединение + JSON
//   МодульОбработка — обработчики инструментов (exec-команды)
//   МодульСессия    — управление сессией: подключение, протокол, баланс, QR
//   МодульЧат       — жизненный цикл диалога: стриминг, tool_call, abort

#Область ПеременныеМодуля

&НаКлиенте
Перем МодульОбщий;       // форма-модуль общих утилит
&НаКлиенте
Перем МодульТранспорт;   // форма-модуль Centrifugo + JSON
&НаКлиенте
Перем МодульОбработка;   // форма-модуль обработки инструментов
&НаКлиенте
Перем МодульСессия;      // форма-модуль управления сессией
&НаКлиенте
Перем МодульЧат;         // форма-модуль жизненного цикла диалога
&НаКлиенте
Перем МодульНапарник Экспорт;    // форма-модуль интеграции с 1С:Напарник (Экспорт для Настроек)
&НаКлиенте
Перем ОбщиеПараметры Экспорт;   // Соответствие

#КонецОбласти

#Область ОбработчикиСобытийФормы

&НаСервере
Процедура ПриСозданииНаСервере(Отказ, СтандартнаяОбработка)

	ОбъектОбработки = РеквизитФормыВЗначение("Объект");
	
	ЭтотОбъект.ИмяОбработки = СтрРазделить(ОбъектОбработки, ".")[1];
	ЭтотОбъект.ИспользуемоеИмяФайла = ОбъектОбработки.ИспользуемоеИмяФайла;
	
	ЭтотОбъект.Элементы.Версия.Заголовок = "Версия: " + ОбъектОбработки.Метаданные().Комментарий;
	
	// Передача Соответствия с сериализуемыми значениями с сервера на клиент через временное хранилище.
	
	ОбщиеПараметры = Новый Соответствие;
	
	ОбщиеПараметры["КартинкаФонаТемная"] = "data:image/svg+xml;base64," 
		+ Base64Строка(ОбъектОбработки.ПолучитьМакет("ЕХТ_Чат_ДвоичныеДанныеКартинкаФонаТемная"));
	ОбщиеПараметры["КартинкаФонаСветлая"] = "data:image/svg+xml;base64," 
		+ Base64Строка(ОбъектОбработки.ПолучитьМакет("ЕХТ_Чат_ДвоичныеДанныеКартинкаФонаСветлая"));
		
	ЭтотОбъект.АдресОбщихПараметров = ПоместитьВоВременноеХранилище(ОбщиеПараметры, ЭтотОбъект.УникальныйИдентификатор);
	
	// Инициализация чата.
	
	ЕХТ_Чат_Инициализация(ЭтотОбъект, ЕХТ_Структура(
		"Элемент", 					ЭтотОбъект.Элементы.Чат1,
		"ДвоичныеДанныеПриложения", ОбъектОбработки.ПолучитьМакет("ЕХТ_Чат_ДвоичныеДанныеПриложения")));

КонецПроцедуры

&НаКлиенте
Процедура ПриОткрытии(Отказ)
	// Форму открывает Загрузчик, который вызывает Инициализация(Контекст)
КонецПроцедуры

// Инициализация главной формы. Вызывается из Загрузчика.
//
// Параметры:
//  Контекст - Структура - DI-контейнер с секциями Обработка, Модули, ГлавнаяФорма
//
&НаКлиенте
Процедура Инициализация(Контекст) Экспорт

	ОбщиеПараметры = ПолучитьИзВременногоХранилища(ЭтотОбъект.АдресОбщихПараметров);

	// Заполняем секцию ГлавнаяФорма

	Контекст.ГлавнаяФорма.Вставить(
		"ЭлементЧата", ЭтотОбъект.Элементы.Чат1);
	Контекст.ГлавнаяФорма.Вставить(
		"ФормИД", Строка(ЭтотОбъект.УникальныйИдентификатор));
	Контекст.ГлавнаяФорма.Вставить(
		"ДанныеБазы", ПолучитьДанныеБазыДляHello());
	Контекст.ГлавнаяФорма.Вставить(
		"ОбщиеПараметры", ОбщиеПараметры);

	// Сохраняем ссылки на модули
	МодульОбщий = Контекст.МодульОбщий.Форма;
	МодульТранспорт = Контекст.МодульТранспорт.Форма;
	МодульОбработка = Контекст.МодульОбработка.Форма;
	МодульНапарник = Контекст.МодульНапарник.Форма;
	МодульСессия = Контекст.МодульСессия.Форма;
	МодульЧат = Контекст.МодульЧат.Форма;

	// Инициализация модулей
	МодульТранспорт.Инициализация(Контекст);
	МодульНапарник.Инициализация(Контекст);
	МодульЧат.Инициализация(Контекст);
	МодульСессия.Инициализация(Контекст);

	// Автоподключение (с задержкой — WS не работает в ПриОткрытии веб-клиента)
	ПодключитьОбработчикОжидания("ОтложенноеПодключение", 1, Истина);

КонецПроцедуры

&НаКлиенте
Процедура ПередЗакрытием(Отказ, ЗавершениеРаботы, ТекстПредупреждения, СтандартнаяОбработка)

	// При завершении работы 1С не блокируем
	Если ЗавершениеРаботы Тогда
		Возврат;
	КонецЕсли;

	Если НЕ МожноЗакрытьФорму Тогда
		
		Отказ = Истина;
		СтандартнаяОбработка = Ложь;

		Если МодульСессия <> Неопределено Тогда
			МодульСессия.ПередЗакрытием();
		КонецЕсли;

		// Двухфазное закрытие: cleanup выполнен → разрешить закрытие
		МожноЗакрытьФорму = Истина;
		Закрыть();
		
	КонецЕсли;

КонецПроцедуры

#КонецОбласти

#Область ОбработчикиСобытийЭлементовФормы

&НаКлиенте
Процедура Подключаемый_ПриНажатии(Элемент, ДанныеСобытия, СтандартнаяОбработка)
	Если МодульЧат = Неопределено Тогда Возврат КонецЕсли;
	МодульЧат.ЕХТ_Чат_СобытиеПриНажатии(Элемент, ДанныеСобытия, СтандартнаяОбработка);
КонецПроцедуры

&НаКлиенте
Процедура Интеграция1СНапарникПриНажатии(Элемент, ДанныеСобытия, СтандартнаяОбработка)
	Если МодульНапарник = Неопределено Тогда Возврат КонецЕсли;
	МодульНапарник.Интеграция1СНапарникПриНажатии(Элемент, ДанныеСобытия, СтандартнаяОбработка);
КонецПроцедуры

#КонецОбласти

#Область ОбработчикиКомандФормы

&НаКлиенте
Процедура Чат1_Подключиться(Команда)
	МодульСессия.Подключиться();
КонецПроцедуры

&НаКлиенте
Процедура ОтложенноеПодключение()
	ЭтотОбъект.Активизировать();
	МодульСессия.Подключиться();
КонецПроцедуры

// Настройки чата

&НаКлиенте
Процедура Чат1_Настройка_Автосвертка_ПриИзменении(Элемент)

	Настройки = МодульЧат.ЕХТ_Чат_ПолучитьНастройки(ЭтотОбъект.Элементы.Чат1);
	Настройки.Сообщения.Автосвертка = ЭтотОбъект.Чат1_Настройка_Автосвертка;
	МодульЧат.ЕХТ_Чат_УстановитьНастройки(ЭтотОбъект.Элементы.Чат1, Настройки);

КонецПроцедуры

&НаКлиенте
Процедура Чат1_Настройка_ТемнаяТема_ПриИзменении(Элемент)

	Если ЭтотОбъект.Чат1_Настройка_ТемнаяТема Тогда
		НоваяТема = МодульЧат.ЕХТ_Чат_ТемнаяТемаПоУмолчанию();
	Иначе
		НоваяТема = МодульЧат.ЕХТ_Чат_СветлаяТемаПоУмолчанию();
	КонецЕсли;
	МодульЧат.ЕХТ_Чат_УстановитьТему(ЭтотОбъект.Элементы.Чат1, НоваяТема);

КонецПроцедуры

&НаКлиенте
Процедура Чат1_Настройка_Аватары_ПриИзменении(Элемент)

	Настройки = МодульЧат.ЕХТ_Чат_ПолучитьНастройки(ЭтотОбъект.Элементы.Чат1);
	Настройки.Аватары.Видимость = ЭтотОбъект.Чат1_Настройка_Аватары;
	МодульЧат.ЕХТ_Чат_УстановитьНастройки(ЭтотОбъект.Элементы.Чат1, Настройки);

КонецПроцедуры

// Таймер подготовки — делегирует в МодульЧат
&НаКлиенте
Процедура ОбновитьТаймерПодготовки() Экспорт
	МодульЧат.ОбновитьТаймерПодготовки();
КонецПроцедуры

#КонецОбласти

#Область ДиспетчерСобытийМодулей

// Центральный диспетчер событий от модулей.
// Модули вызывают этот метод для обратной связи с главной формой.
//
// Параметры:
//  ИмяМодуля - Строка - Имя модуля-источника (Транспорт, Сессия, Чат)
//  ИмяСобытия - Строка - Имя события
//  Данные - Произвольный - Данные события
//
&НаКлиенте
Процедура ОбработатьСобытиеМодуля(ИмяМодуля, ИмяСобытия, Данные) Экспорт

	Если ИмяМодуля = "Транспорт" Тогда
		МодульСессия.ОбработатьСобытиеТранспорта(ИмяСобытия, Данные);
	ИначеЕсли ИмяМодуля = "Сессия" ИЛИ ИмяМодуля = "Чат" Тогда
		ОбработатьСобытиеЧат(ИмяСобытия, Данные);
	КонецЕсли;

КонецПроцедуры

// Обработка событий от МодульЧат / МодульСессия.
// Только события, требующие доступа к UI главной формы.
&НаКлиенте
Процедура ОбработатьСобытиеЧат(ИмяСобытия, Данные)

	Если ИмяСобытия = "завершён" Тогда

		УстановитьЗанят(Ложь);

	ИначеЕсли ИмяСобытия = "занят" Тогда

		УстановитьЗанят(Данные);

	ИначеЕсли ИмяСобытия = "таймер_подготовки" Тогда

		Если Данные = "подключить" Тогда
			ПодключитьОбработчикОжидания("ОбновитьТаймерПодготовки", 1, Ложь);
		Иначе
			ОтключитьОбработчикОжидания("ОбновитьТаймерПодготовки");
		КонецЕсли;

	ИначеЕсли ИмяСобытия = "заголовок" Тогда

		ЭтотОбъект.Заголовок = Данные;

	ИначеЕсли ИмяСобытия = "доступность_ввода" Тогда

		МодульЧат.УстановитьДоступностьВвода(Данные);

	ИначеЕсли ИмяСобытия = "ид_сессии" Тогда

		ЭтотОбъект.Чат1_ИдентификаторСессии = Данные;

	ИначеЕсли ИмяСобытия = "оповещение" Тогда

		ПоказатьОповещениеПользователя("Лира",, Данные,, СтатусОповещенияПользователя.Важное);

	// Обратная совместимость — события от МодульСессия, выводящие в чат
	ИначеЕсли ИмяСобытия = "информация" Тогда
		МодульЧат.ВывестиВЧатИнформацию(ЭтотОбъект.Элементы.Чат1, Данные);

	ИначеЕсли ИмяСобытия = "предупреждение" Тогда
		МодульЧат.ВывестиВЧатПредупреждение(ЭтотОбъект.Элементы.Чат1, Данные);

	ИначеЕсли ИмяСобытия = "ошибка" Тогда
		МодульЧат.ВывестиВЧатОшибку(ЭтотОбъект.Элементы.Чат1, Данные);

	КонецЕсли;

КонецПроцедуры

#КонецОбласти


#Область СлужебныеПроцедуры

// Устанавливает флаг занятости и переключает кнопку Отправить/Прервать.
//
&НаКлиенте
Процедура УстановитьЗанят(НовоеЗначение)
	Занят = НовоеЗначение;
	МодульЧат.УстановитьРежимКнопки(НовоеЗначение);
КонецПроцедуры

// Возвращает модуль объекта обработки для вызова серверных методов.
