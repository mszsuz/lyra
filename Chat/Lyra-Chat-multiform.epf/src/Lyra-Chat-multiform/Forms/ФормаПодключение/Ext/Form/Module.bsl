
// ФормаПодключение — UI настроек подключения к Bridge.
// Открывается через ОткрытьФорму(), возвращает параметры через ОповещениеОЗакрытии.

#Область ОбработчикиСобытийФормы

&НаСервере
Процедура ПриСозданииНаСервере(Отказ, СтандартнаяОбработка)

	// Заполнение начальных значений из параметров
	Если Параметры.Свойство("АдресBridge") И ЗначениеЗаполнено(Параметры.АдресBridge) Тогда
		ЭтотОбъект.АдресBridge = Параметры.АдресBridge;
	Иначе
		ЭтотОбъект.АдресBridge = "ws://localhost:3003";
	КонецЕсли;

	Если Параметры.Свойство("Модель") Тогда
		ЭтотОбъект.Модель = Параметры.Модель;
	КонецЕсли;

	Если Параметры.Свойство("СистемныйПромпт") Тогда
		ЭтотОбъект.СистемныйПромпт = Параметры.СистемныйПромпт;
	КонецЕсли;

КонецПроцедуры

#КонецОбласти

#Область ОбработчикиКомандФормы

&НаКлиенте
Процедура КомандаОК(Команда)

	Результат = Новый Структура;
	Результат.Вставить("АдресBridge", ЭтотОбъект.АдресBridge);
	Результат.Вставить("Модель", ЭтотОбъект.Модель);
	Результат.Вставить("СистемныйПромпт", ЭтотОбъект.СистемныйПромпт);

	Закрыть(Результат);

КонецПроцедуры

&НаКлиенте
Процедура КомандаОтмена(Команда)
	Закрыть();
КонецПроцедуры

#КонецОбласти
