
// ФормаПодключение — UI настроек подключения к Centrifugo.
// Открывается через ОткрытьФорму(), возвращает параметры через ОповещениеОЗакрытии.

#Область ОбработчикиСобытийФормы

&НаСервере
Процедура ПриСозданииНаСервере(Отказ, СтандартнаяОбработка)

	// Заполнение начальных значений из параметров
	Если Параметры.Свойство("АдресЦентрифуга") И ЗначениеЗаполнено(Параметры.АдресЦентрифуга) Тогда
		ЭтотОбъект.АдресЦентрифуга = Параметры.АдресЦентрифуга;
	Иначе
		ЭтотОбъект.АдресЦентрифуга = "ws://localhost:11000/connection/websocket";
	КонецЕсли;

	Если Параметры.Свойство("Модель") Тогда
		ЭтотОбъект.Модель = Параметры.Модель;
	КонецЕсли;

	Если Параметры.Свойство("СистемныйПромпт") Тогда
		ЭтотОбъект.СистемныйПромпт = Параметры.СистемныйПромпт;
	КонецЕсли;

КонецПроцедуры

#КонецОбласти

#Область ОбработчикиКомандФормы

&НаКлиенте
Процедура КомандаОК(Команда)

	Результат = Новый Структура;
	Результат.Вставить("АдресЦентрифуга", ЭтотОбъект.АдресЦентрифуга);
	Результат.Вставить("Модель", ЭтотОбъект.Модель);
	Результат.Вставить("СистемныйПромпт", ЭтотОбъект.СистемныйПромпт);

	Закрыть(Результат);

КонецПроцедуры

&НаКлиенте
Процедура КомандаОтмена(Команда)
	Закрыть();
КонецПроцедуры

#КонецОбласти
