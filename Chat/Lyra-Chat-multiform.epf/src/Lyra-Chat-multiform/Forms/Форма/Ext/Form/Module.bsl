// HTML пульсирующих точек (SVG-анимация, работает без JS)
&НаКлиенте
Функция SVGПульсация()
	Возврат "<svg width='36' height='16' viewBox='0 0 40 16' style='vertical-align:-3px'>"
		+ "<circle cx='8' cy='8' r='4' fill='#888'>"
		+ "<animate attributeName='opacity' values='.3;1;.3' dur='1.2s' repeatCount='indefinite' begin='0s'/>"
		+ "</circle>"
		+ "<circle cx='20' cy='8' r='4' fill='#888'>"
		+ "<animate attributeName='opacity' values='.3;1;.3' dur='1.2s' repeatCount='indefinite' begin='.4s'/>"
		+ "</circle>"
		+ "<circle cx='32' cy='8' r='4' fill='#888'>"
		+ "<animate attributeName='opacity' values='.3;1;.3' dur='1.2s' repeatCount='indefinite' begin='.8s'/>"
		+ "</circle></svg>";
КонецФункции

// Форматирует миллисекунды в "12 сек" или "1 мин 45 сек"
&НаКлиенте
Функция ФорматВремениПодготовки(МиллисекундПрошло)
	Секунд = Цел(МиллисекундПрошло / 1000);
	Если Секунд < 60 Тогда
		Возврат "" + Формат(Секунд, "ЧН=0; ЧГ=0") + " сек";
	Иначе
		Минут = Цел(Секунд / 60);
		ОстСекунд = Секунд - Минут * 60;
		Возврат "" + Формат(Минут, "ЧН=0; ЧГ=0") + " мин " + Формат(ОстСекунд, "ЧН=0; ЧГ=0") + " сек";
	КонецЕсли;
КонецФункции

// Группирует статусы: ["a","b","b","c"] → [" • a", " • b × 2", " • c"]
&НаКлиенте
Функция СгруппироватьСтатусы()
	Результат = Новый Массив;
	Счётчики = Новый Соответствие; // Статус → Количество
	Порядок = Новый Массив;       // Порядок первого появления
	Для Каждого Статус Из СтатусыИнструментов Цикл
		Кол = Счётчики.Получить(Статус);
		Если Кол = Неопределено Тогда
			Счётчики.Вставить(Статус, 1);
			Порядок.Добавить(Статус);
		Иначе
			Счётчики.Вставить(Статус, Кол + 1);
		КонецЕсли;
	КонецЦикла;
	Для Каждого Статус Из Порядок Цикл
		Кол = Счётчики.Получить(Статус);
		Если Кол > 1 Тогда
			Результат.Добавить(" • " + Статус + " × " + Формат(Кол, "ЧН=0; ЧГ=0"));
		Иначе
			Результат.Добавить(" • " + Статус);
		КонецЕсли;
	КонецЦикла;
	Возврат Результат;
КонецФункции

// Группировка статусов для спойлера — без "Подготавливаю..."
&НаКлиенте
Функция СгруппироватьСтатусыИнструментов()
	Результат = Новый Массив;
	Счётчики = Новый Соответствие;
	Порядок = Новый Массив;
	Для Каждого Статус Из СтатусыИнструментов Цикл
		Если Статус = "Подготавливаю..." Тогда
			Продолжить;
		КонецЕсли;
		Кол = Счётчики.Получить(Статус);
		Если Кол = Неопределено Тогда
			Счётчики.Вставить(Статус, 1);
			Порядок.Добавить(Статус);
		Иначе
			Счётчики.Вставить(Статус, Кол + 1);
		КонецЕсли;
	КонецЦикла;
	Для Каждого Статус Из Порядок Цикл
		Кол = Счётчики.Получить(Статус);
		Если Кол > 1 Тогда
			Результат.Добавить(" • " + Статус + " × " + Формат(Кол, "ЧН=0; ЧГ=0"));
		Иначе
			Результат.Добавить(" • " + Статус);
		КонецЕсли;
	КонецЦикла;
	Возврат Результат;
КонецФункции

// Собирает HTML пузыря подготовки: список статусов + пульсация + таймер
&НаКлиенте
Функция СобратьHTMLПодготовки()
	HTML = "<div style=""color: #888; font-size: 0.9em; line-height: 1.8;"">";
	Для Каждого Строка Из СгруппироватьСтатусы() Цикл
		HTML = HTML + "<div>" + Строка + "</div>";
	КонецЦикла;
	Прошло = ТекущаяУниверсальнаяДатаВМиллисекундах() - НачалоПодготовкиОтвета;
	HTML = HTML + "<div style=""margin-top: 4px;"">"
		+ SVGПульсация() + " " + ФорматВремениПодготовки(Прошло)
		+ "</div></div>";
	Возврат HTML;
КонецФункции

// Собирает свёрнутый спойлер подготовки для финального ответа
&НаКлиенте
Функция СобратьСпойлерПодготовки()
	// Количество инструментов (без "Подготавливаю...")
	КолвоИнструментов = СтатусыИнструментов.Количество() - 1;

	// Спойлер показываем только если были реальные инструменты
	Если КолвоИнструментов <= 0 Тогда
		Возврат "";
	КонецЕсли;

	Если НачалоПодготовкиОтвета > 0 Тогда
		Прошло = ТекущаяУниверсальнаяДатаВМиллисекундах() - НачалоПодготовкиОтвета;
	Иначе
		Прошло = 0;
	КонецЕсли;

	ЗаголовокСпойлера = "Подготовка: " + ФорматВремениПодготовки(Прошло)
		+ ", инструментов: " + Формат(КолвоИнструментов, "ЧН=0; ЧГ=0");

	HTML = "<details style=""margin-bottom: 8px; color: #999; font-size: 0.85em;"">"
		+ "<summary>" + ЗаголовокСпойлера + "</summary>"
		+ "<div style=""padding: 4px 0 0 16px; line-height: 1.6;"">";
	Для Каждого Строка Из СгруппироватьСтатусыИнструментов() Цикл
		HTML = HTML + "<div>" + Строка + "</div>";
	КонецЦикла;
	HTML = HTML + "</div></details>";
	Возврат HTML;
КонецФункции

// Таймер обновления времени подготовки (каждую секунду)
&НаКлиенте
Процедура ОбновитьТаймерПодготовки() Экспорт
	Если ПустаяСтрока(ТекущееСообщениеИД) ИЛИ НачалоПодготовкиОтвета = 0 Тогда
		ОтключитьОбработчикОжидания("ОбновитьТаймерПодготовки");
		Возврат;
	КонецЕсли;

	// Проверка таймаута ответа: 30 сек без сигналов от сервера
	Если НЕ ТаймаутОтветаСработал Тогда
		ВремяОтсчёта = ?(ВремяПоследнегоСигнала > 0, ВремяПоследнегоСигнала, НачалоПодготовкиОтвета);
		ПрошлоМс = ТекущаяУниверсальнаяДатаВМиллисекундах() - ВремяОтсчёта;
		Если ПрошлоМс > 30000 Тогда
			ТаймаутОтветаСработал = Истина;
			ВывестиВЧатПредупреждение(ЭтотОбъект.Элементы.Чат1,
				"Ответ не приходит слишком долго. Возможно, соединение потеряно. <a href=""lyra://reconnect"" class=""chat-link"">Переподключиться</a>");
			УстановитьЗанят(Ложь);
		КонецЕсли;
	КонецЕсли;

	ОбновитьТекущееСообщение(СобратьHTMLПодготовки());
КонецПроцедуры

#КонецОбласти

#Область ОбработчикиЕХТЧат

&НаКлиенте
Функция ЕХТ_Чат_ПриОткрытии(
		Знач Элемент, Знач НастройкиПоУмолчанию,
		Знач Ширина = 0, Знач Высота = 0) Экспорт

	Результат = МодульОбщий.ЕХТ_Структура(
		"Настройки", НастройкиПоУмолчанию,
		"Сообщения", Новый Массив);

	Если Элемент = ЭтотОбъект.Элементы.Чат1 Тогда
		Результат.Настройки.Сообщения.Автосвертка = ЭтотОбъект.Чат1_Настройка_Автосвертка;
		Результат.Настройки.Аватары.Видимость = ЭтотОбъект.Чат1_Настройка_Аватары;
		Результат.Настройки.Оформление.КартинкаФона = ПолучитьКартинкуФона(Ложь);
		Результат.Сообщения = Новый Массив;
	КонецЕсли;

	Возврат Результат;

КонецФункции

&НаКлиенте
Функция ЕХТ_Чат_ПриИзмененииРазмера(
		Знач Элемент, Знач Ширина, Знач Высота) Экспорт
	Возврат Новый Структура;
КонецФункции

&НаКлиенте
Функция ЕХТ_Чат_ПриДобавленииСообщения(Знач Элемент) Экспорт
	Возврат Новый Структура("Сообщение", Новый Структура);
КонецФункции

&НаКлиенте
Функция ЕХТ_Чат_ПриНажатииСсылки(Знач Элемент, Знач АдресСсылки) Экспорт

	// Команды Лиры (lyra://)
	Если АдресСсылки = "lyra://reconnect" Тогда
		ВыполнитьПодключение();
		Возврат Новый Структура;
	КонецЕсли;

	// Навигационные ссылки 1С (e1cib/) — открываем объект/список/обработку
	Если СтрНачинаетсяС(АдресСсылки, "e1cib/") Тогда
		Попытка
			ПерейтиПоНавигационнойСсылке(АдресСсылки);
		Исключение
			ВывестиВЧатИнформацию(Элемент, "Не удалось открыть ссылку: " + ОписаниеОшибки());
		КонецПопытки;
	КонецЕсли;

