
// Главная форма Lyra-Chat (модульный).
// Тонкий контроллер — только UI-события и координация модулей.
// Вся бизнес-логика разнесена по служебным формам-модулям:
//   МодульBridge — WebSocket-соединение
//   МодульПарсер — JSON-обработка через ЧтениеJSON
//   МодульMCP — MCP strategy-dispatch + обработчики 1С-команд

#Область ПеременныеМодуля

&НаКлиенте
Перем МодульОбщий;    // форма-модуль общих утилит (ЕХТ_Структура, ЕХТ_Массив и др.)
&НаКлиенте
Перем МодульBridge;   // форма-модуль Centrifugo (мини-клиент)
&НаКлиенте
Перем МодульПарсер;   // форма-модуль JSON-парсинга
&НаКлиенте
Перем МодульMCP;      // форма-модуль MCP-обработки
&НаКлиенте
Перем ТекущееСообщениеИД;        // ИД единственного пузыря ответа (и размышления, и текст — в нём)
&НаКлиенте
Перем ТекущийРежимБлока;         // "thinking" / "text" / ""
&НаКлиенте
Перем НачалоРазмышления;         // время начала текущего блока размышлений (мс)
&НаКлиенте
Перем ДлительностьРазмышленияМс; // суммарная длительность всех блоков размышлений (мс)
&НаКлиенте
Перем ФормИД;         // UUID формы для переподключения (form_id)
&НаКлиенте
Перем СессияИД;       // session_id из hello_ack
&НаКлиенте
Перем МобильныйJWT;   // mobile_jwt из hello_ack (для QR)
&НаКлиенте
Перем Баланс;          // текущий баланс пользователя
&НаКлиенте
Перем ДанныеБазы;      // кэш данных о базе для hello (Структура)
&НаКлиенте
Перем ОтложенноеСообщение; // текст, ожидающий отправки после подключения
&НаКлиенте
Перем СтатусыИнструментов; // Массив строк — накопленные статусы подготовки ответа
&НаКлиенте
Перем НачалоПодготовкиОтвета; // время начала подготовки (мс), 0 = не идёт
&НаКлиенте
Перем БылоПодключение;    // флаг: первое подключение уже было
&НаКлиенте
Перем ВремяПоследнегоСигнала; // мс, время последнего сигнала от сервера (для таймаута ответа)
&НаКлиенте
Перем ТаймаутОтветаСработал;  // Булево, предупреждение уже показано

#КонецОбласти

#Область ОбработчикиСобытийФормы

&НаСервере
Процедура ПриСозданииНаСервере(Отказ, СтандартнаяОбработка)

	ОбъектОбработки = РеквизитФормыВЗначение("Объект");
	ЭтотОбъект.Версия = ОбъектОбработки.Метаданные().Комментарий;
	ДвоичныеДанныеПриложения = ОбъектОбработки.ПолучитьМакет("ЕХТ_Чат_ДвоичныеДанныеПриложения");
	ЕХТ_Чат_Инициализация(ЭтотОбъект, ЕХТ_Структура(
		"Элемент", 					ЭтотОбъект.Элементы.Чат1,
		"ДвоичныеДанныеПриложения", ДвоичныеДанныеПриложения));

КонецПроцедуры

&НаКлиенте
Процедура ПриОткрытии(Отказ)

	// UUID формы для переподключения
	ФормИД = Строка(ЭтотОбъект.УникальныйИдентификатор);

	// Инициализация переменных хронометража
	НачалоРазмышления = 0;
	ДлительностьРазмышленияМс = 0;
	СтатусыИнструментов = Новый Массив;
	НачалоПодготовкиОтвета = 0;
	ВремяПоследнегоСигнала = 0;
	ТаймаутОтветаСработал = Ложь;
	БылоПодключение = Ложь;

	// Инициализация модулей через ПолучитьФорму()
	МодульОбщий = ПолучитьФорму("ВнешняяОбработка.Lyra_Chat_multiform.Форма.МодульОбщий",, ЭтотОбъект);

	МодульBridge = ПолучитьФорму("ВнешняяОбработка.Lyra_Chat_multiform.Форма.МодульBridge",, ЭтотОбъект);
	МодульBridge.Инициализация(ЭтотОбъект);

	МодульПарсер = ПолучитьФорму("ВнешняяОбработка.Lyra_Chat_multiform.Форма.МодульПарсер",, ЭтотОбъект);

	МодульMCP = ПолучитьФорму("ВнешняяОбработка.Lyra_Chat_multiform.Форма.МодульMCP",, ЭтотОбъект);

	// Получить данные о базе для hello (серверный вызов, кэшируем)
	ДанныеБазы = ПолучитьДанныеБазыДляHello();

	// Автоподключение (с задержкой — WS не работает в ПриОткрытии веб-клиента)
	ПодключитьОбработчикОжидания("ОтложенноеПодключение", 1, Истина);

КонецПроцедуры

&НаКлиенте
Процедура ПередЗакрытием(Отказ, ЗавершениеРаботы, ТекстПредупреждения, СтандартнаяОбработка)

	// При завершении работы 1С не блокируем
	Если ЗавершениеРаботы Тогда
		Возврат;
	КонецЕсли;

	Если НЕ МожноЗакрытьФорму Тогда
		Отказ = Истина;
		СтандартнаяОбработка = Ложь;

		// Уведомить Роутер о закрытии формы (статус → disconnected)
		Если МодульBridge <> Неопределено И ЗначениеЗаполнено(СессияИД) Тогда
			ДанныеОтключения = Новый Структура;
			ДанныеОтключения.Вставить("type", "disconnect");
			ДанныеОтключения.Вставить("form_id", ФормИД);
			МодульBridge.ОтправитьСообщение(ДанныеОтключения);
		КонецЕсли;

		// Каскадное отключение WebSocket
		Если МодульBridge <> Неопределено Тогда
			МодульBridge.Отключиться();
		КонецЕсли;

		// Двухфазное закрытие: cleanup выполнен → разрешить закрытие
		МожноЗакрытьФорму = Истина;
		Закрыть();
	КонецЕсли;

КонецПроцедуры

#КонецОбласти

#Область ОбработчикиСобытийЭлементовФормы

&НаКлиенте
Процедура Подключаемый_ПриНажатии(Элемент, ДанныеСобытия, СтандартнаяОбработка)
	ЕХТ_Чат_СобытиеПриНажатии(Элемент, ДанныеСобытия, СтандартнаяОбработка);
КонецПроцедуры

#КонецОбласти

#Область ОбработчикиКомандФормы

&НаКлиенте
Процедура Чат1_Подключиться(Команда)

	ВыполнитьПодключение();

КонецПроцедуры

&НаКлиенте
Процедура ОтложенноеПодключение()

	ВыполнитьПодключение();

КонецПроцедуры

&НаКлиенте
Процедура ВыполнитьПодключение()

	АдресЦентрифуга = "ws://localhost:11000/connection/websocket";
	МодульBridge.Подключиться(АдресЦентрифуга);

КонецПроцедуры

&НаКлиенте
Процедура Чат1_ОтправитьСообщение(Команда)

	ТекстСообщения = СокрЛП(ЭтотОбъект.Чат1_ТекстСообщенияПользователя);

	// Прерывание текущего стрима
	Если Занят Тогда

		// Финализируем текущий пузырь (оставляем обрезанный текст как есть)
		ОтключитьОбработчикОжидания("ОбновитьТаймерПодготовки");
		Если НЕ ПустаяСтрока(ТекущееСообщениеИД) Тогда
			Если НачалоРазмышления > 0 Тогда
				ДлительностьРазмышленияМс = ДлительностьРазмышленияМс
					+ (ТекущаяУниверсальнаяДатаВМиллисекундах() - НачалоРазмышления);
				НачалоРазмышления = 0;
			КонецЕсли;
			Если НЕ ПустаяСтрока(ТекущееСообщениеТекст) Тогда
				ОбновитьТекущееСообщение(СобратьСпойлерПодготовки() + ТекущееСообщениеТекст);
			КонецЕсли;
		КонецЕсли;

		// Сбрасываем состояние для нового ответа
		ТекущееСообщениеТекст = "";
		ТекущееСообщениеИД = "";

		НачалоРазмышления = 0;
		ДлительностьРазмышленияМс = 0;
		НачалоПодготовкиОтвета = 0;
		СтатусыИнструментов = Новый Массив;
		ТекущийРежимБлока = "";

		Если ТекстСообщения = "" Тогда
			// Пустой ввод при стриме — просто abort, без сообщения в историю
			ДанныеСообщения = Новый Структура;
			ДанныеСообщения.Вставить("type", "abort");
			МодульBridge.ОтправитьСообщение(ДанныеСообщения);
		Иначе
			// Новый вопрос — прерываем текущий стрим и отправляем новый
			ДанныеСообщения = Новый Структура;
			ДанныеСообщения.Вставить("type", "chat");
			ДанныеСообщения.Вставить("form_id", ФормИД);
			ДанныеСообщения.Вставить("text", ТекстСообщения);
			МодульBridge.ОтправитьСообщение(ДанныеСообщения);
			ЭтотОбъект.Чат1_ТекстСообщенияПользователя = "";
			ВывестиВЧатСообщениеПользователя(ЭтотОбъект.Элементы.Чат1, ТекстСообщения);

			// Сразу создаём пузырь ответа с индикатором "Анализирую..."
			НачалоПодготовкиОтвета = ТекущаяУниверсальнаяДатаВМиллисекундах();
			ВремяПоследнегоСигнала = 0;
			ТаймаутОтветаСработал = Ложь;
			СтатусыИнструментов = Новый Массив;
			СтатусыИнструментов.Добавить("Подготавливаю...");
			Сообщение = ЕХТ_Чат_НовоеСообщение(СобратьHTMLПодготовки(), "Ассистент");
			ТекущееСообщениеИД = Сообщение.ИД;
			ЕХТ_Чат_ДобавитьСообщение(ЭтотОбъект.Элементы.Чат1, Сообщение);
			ПодключитьОбработчикОжидания("ОбновитьТаймерПодготовки", 1, Ложь);
		КонецЕсли;
		Возврат;
	КонецЕсли;

	Если ТекстСообщения = "" Тогда
		Возврат;
	КонецЕсли;

	// Формируем данные сообщения
	ДанныеСообщения = Новый Структура;
	ДанныеСообщения.Вставить("type", "chat");
	ДанныеСообщения.Вставить("form_id", ФормИД);
	ДанныеСообщения.Вставить("text", ТекстСообщения);

	// Отправляем через Bridge (Centrifugo publish в канал сессии)
	Если НЕ МодульBridge.ОтправитьСообщение(ДанныеСообщения) Тогда
		// Сообщение в очередь — отправится когда канал будет готов
		ОтложенноеСообщение = ТекстСообщения;
		ВыполнитьПодключение();
		// Показываем пузырь пользователя сразу — как будто отправлено
		ВывестиВЧатСообщениеПользователя(ЭтотОбъект.Элементы.Чат1, ТекстСообщения);
		ЭтотОбъект.Чат1_ТекстСообщенияПользователя = "";
		Возврат;
	КонецЕсли;

	// Очищаем поле ввода
	ЭтотОбъект.Чат1_ТекстСообщенияПользователя = "";

	ВывестиВЧатСообщениеПользователя(ЭтотОбъект.Элементы.Чат1, ТекстСообщения);

	ТекущееСообщениеТекст = "";
	ТекущееСообщениеИД = "";
	НачалоРазмышления = 0;
	ДлительностьРазмышленияМс = 0;
	НачалоПодготовкиОтвета = ТекущаяУниверсальнаяДатаВМиллисекундах();
	ВремяПоследнегоСигнала = 0;
	ТаймаутОтветаСработал = Ложь;
	СтатусыИнструментов = Новый Массив;
	СтатусыИнструментов.Добавить("Подготавливаю...");
	ТекущийРежимБлока = "";

	// Сразу создаём пузырь ответа с индикатором "Подготавливаю..."
	Сообщение = ЕХТ_Чат_НовоеСообщение(СобратьHTMLПодготовки(), "Ассистент");
	ТекущееСообщениеИД = Сообщение.ИД;
	ЕХТ_Чат_ДобавитьСообщение(ЭтотОбъект.Элементы.Чат1, Сообщение);
	ПодключитьОбработчикОжидания("ОбновитьТаймерПодготовки", 1, Ложь);

	УстановитьЗанят(Истина);

КонецПроцедуры

// Настройки чата

&НаКлиенте
Процедура Чат1_Настройка_Автосвертка_ПриИзменении(Элемент)

	Настройки = ЕХТ_Чат_ПолучитьНастройки(ЭтотОбъект.Элементы.Чат1);
	Настройки.Сообщения.Автосвертка = ЭтотОбъект.Чат1_Настройка_Автосвертка;
	ЕХТ_Чат_УстановитьНастройки(ЭтотОбъект.Элементы.Чат1, Настройки);

КонецПроцедуры

&НаКлиенте
Процедура Чат1_Настройка_ТемнаяТема_ПриИзменении(Элемент)

	Если ЭтотОбъект.Чат1_Настройка_ТемнаяТема Тогда
		НоваяТема = ЕХТ_Чат_ТемнаяТемаПоУмолчанию();
	Иначе
		НоваяТема = ЕХТ_Чат_СветлаяТемаПоУмолчанию();
	КонецЕсли;
	НоваяТема.Оформление.Вставить("КартинкаФона", ПолучитьКартинкуФона(ЭтотОбъект.Чат1_Настройка_ТемнаяТема));
	ЕХТ_Чат_УстановитьТему(ЭтотОбъект.Элементы.Чат1, НоваяТема);

КонецПроцедуры

&НаКлиенте
Процедура Чат1_Настройка_Аватары_ПриИзменении(Элемент)

	Настройки = ЕХТ_Чат_ПолучитьНастройки(ЭтотОбъект.Элементы.Чат1);
	Настройки.Аватары.Видимость = ЭтотОбъект.Чат1_Настройка_Аватары;
	ЕХТ_Чат_УстановитьНастройки(ЭтотОбъект.Элементы.Чат1, Настройки);

КонецПроцедуры

#КонецОбласти

#Область ДиспетчерСобытийМодулей

// Центральный диспетчер событий от модулей.
// Модули вызывают этот метод для обратной связи с главной формой.
//
// Параметры:
//  ИмяМодуля - Строка - Имя модуля-источника (Bridge, Parser, MCP)
//  ИмяСобытия - Строка - Имя события
//  Данные - Произвольный - Данные события
//
&НаКлиенте
Процедура ОбработатьСобытиеМодуля(ИмяМодуля, ИмяСобытия, Данные) Экспорт

	Если ИмяМодуля = "Bridge" Тогда
		ОбработатьСобытиеBridge(ИмяСобытия, Данные);
	КонецЕсли;

КонецПроцедуры

&НаКлиенте
Процедура ОбработатьСобытиеBridge(ИмяСобытия, Данные)

	Если ИмяСобытия = "bridge_connected" Тогда

		// Данные — Структура с полями: client, status, subs
		Статус = Данные.status;

		Если Статус = "lobby" Тогда
			// Подключились к lobby — отправить hello
			ОтправитьHello();
		ИначеЕсли Статус = "session" Тогда
			// Переподключились с chat_jwt — канал сессии активен
			Если БылоПодключение Тогда
				ВывестиВЧатИнформацию(ЭтотОбъект.Элементы.Чат1,
					"Соединение восстановлено!");
			Иначе
				БылоПодключение = Истина;
				ВывестиВЧатИнформацию(ЭтотОбъект.Элементы.Чат1,
					"Привет! Лира на связи!");
			КонецЕсли;
			УстановитьЗанят(Ложь);

			// Отправить отложенное сообщение (если было)
			Если ОтложенноеСообщение <> Неопределено Тогда
				ТекстОтложенный = ОтложенноеСообщение;
				ОтложенноеСообщение = Неопределено;
				ДанныеСообщения = Новый Структура;
				ДанныеСообщения.Вставить("type", "chat");
				ДанныеСообщения.Вставить("form_id", ФормИД);
				ДанныеСообщения.Вставить("text", ТекстОтложенный);
				МодульBridge.ОтправитьСообщение(ДанныеСообщения);
				УстановитьЗанят(Истина);
			КонецЕсли;
		КонецЕсли;

	ИначеЕсли ИмяСобытия = "bridge_closed" Тогда

		// Данные — Структура с полями: КодЗакрытия, ПредыдущийСтатус
		УстановитьЗанят(Ложь);
		ВывестиВЧатПредупреждение(ЭтотОбъект.Элементы.Чат1,
			"Соединение закрыто (код " + Формат(Данные.КодЗакрытия, "ЧН=0; ЧГ=0") + "). <a href=""lyra://reconnect"" class=""chat-link"">Повторить подключение</a>");

	ИначеЕсли ИмяСобытия = "bridge_error" Тогда

		ВывестиВЧатПредупреждение(ЭтотОбъект.Элементы.Чат1,
			Данные + ". <a href=""lyra://reconnect"" class=""chat-link"">Повторить подключение</a>");

	ИначеЕсли ИмяСобытия = "bridge_message" Тогда

		// Данные — JSON-строка (data из push.pub.data)
		ДанныеОтвета = МодульПарсер.РазобратьJSON(Данные);
		ОбработатьОтветBridge(ДанныеОтвета, Данные);

	КонецЕсли;

КонецПроцедуры

#КонецОбласти

#Область ОбработкаОтветовBridge

// Обработка разобранного JSON-сообщения от Bridge/Centrifugo.
// Сообщения приходят как push.pub.data из канала Centrifugo.
//
&НаКлиенте
Процедура ОбработатьОтветBridge(ДанныеОтвета, СтрокаJSON)

	// Обновляем время последнего сигнала для таймаута ответа
	ВремяПоследнегоСигнала = ТекущаяУниверсальнаяДатаВМиллисекундах();

	ТипСобытия = МодульПарсер.ИзвлечьТипСобытия(ДанныеОтвета);

	Если ТипСобытия = "hello_ack" Тогда

		// Роутер ответил на hello — сохранить данные сессии, переподключиться
		ОбработатьHelloAck(ДанныеОтвета);

	ИначеЕсли ТипСобытия = "auth_ack" Тогда

		// Роутер подтвердил авторизацию (после мобильного QR)
		ОбработатьAuthAck(ДанныеОтвета);

	ИначеЕсли ТипСобытия = "balance_update" Тогда

		// Биллинг прислал обновление баланса
		ОбработатьBalanceUpdate(ДанныеОтвета);

	ИначеЕсли ТипСобытия = "text_delta" Тогда

		// Фрагмент текста ответа (стриминг)
		ТекстДельты = МодульПарсер.ИзвлечьЗначение(ДанныеОтвета, "text");
		Если НЕ ПустаяСтрока(ТекстДельты) Тогда
			// Фиксируем длительность размышлений при первом тексте
			Если НачалоРазмышления > 0 Тогда
				ДлительностьРазмышленияМс = ДлительностьРазмышленияМс
					+ (ТекущаяУниверсальнаяДатаВМиллисекундах() - НачалоРазмышления);
				НачалоРазмышления = 0;
			КонецЕсли;
			ТекущийРежимБлока = "text";

			// Создаём пузырь при первом тексте
			Если ПустаяСтрока(ТекущееСообщениеИД) Тогда
				Сообщение = ЕХТ_Чат_НовоеСообщение("", "Ассистент");
				ТекущееСообщениеИД = Сообщение.ИД;
				ЕХТ_Чат_ДобавитьСообщение(ЭтотОбъект.Элементы.Чат1, Сообщение);
			КонецЕсли;

			ТекущееСообщениеТекст = ТекущееСообщениеТекст + ТекстДельты;
			ОбновитьТекущееСообщение(ТекущееСообщениеТекст);
		КонецЕсли;

	ИначеЕсли ТипСобытия = "thinking_start" ИЛИ ТипСобытия = "thinking_delta" Тогда

		// Размышления — засекаем время
		Если ТипСобытия = "thinking_start" Тогда
			Если НачалоРазмышления = 0 Тогда
				НачалоРазмышления = ТекущаяУниверсальнаяДатаВМиллисекундах();
			КонецЕсли;
		КонецЕсли;

		ТекущийРежимБлока = "thinking";

		// Начинаем подготовку — создаём пузырь с пульсацией
		Если ПустаяСтрока(ТекущееСообщениеИД) Тогда
			НачалоПодготовкиОтвета = ТекущаяУниверсальнаяДатаВМиллисекундах();
			СтатусыИнструментов = Новый Массив;
			СтатусыИнструментов.Добавить("Подготавливаю...");
			Сообщение = ЕХТ_Чат_НовоеСообщение(СобратьHTMLПодготовки(), "Ассистент");
			ТекущееСообщениеИД = Сообщение.ИД;
			ЕХТ_Чат_ДобавитьСообщение(ЭтотОбъект.Элементы.Чат1, Сообщение);
			ПодключитьОбработчикОжидания("ОбновитьТаймерПодготовки", 1, Ложь);
		КонецЕсли;

	ИначеЕсли ТипСобытия = "tool_status" Тогда

		// Статус использования инструмента — добавляем в цепочку
		Описание = МодульПарсер.ИзвлечьЗначение(ДанныеОтвета, "description");
		Если НЕ ПустаяСтрока(Описание) Тогда
			СтатусыИнструментов.Добавить(Описание);
			Если НЕ ПустаяСтрока(ТекущееСообщениеИД) Тогда
				ОбновитьТекущееСообщение(СобратьHTMLПодготовки());
			КонецЕсли;
		КонецЕсли;

	ИначеЕсли ТипСобытия = "thinking_end" Тогда

		// Блок размышлений завершён — фиксируем длительность
		Если НачалоРазмышления > 0 Тогда
			ДлительностьРазмышленияМс = ДлительностьРазмышленияМс
				+ (ТекущаяУниверсальнаяДатаВМиллисекундах() - НачалоРазмышления);
			НачалоРазмышления = 0;
		КонецЕсли;

	ИначеЕсли ТипСобытия = "assistant_end" Тогда

		// Ответ завершён — остановить таймер
		ОтключитьОбработчикОжидания("ОбновитьТаймерПодготовки");

		Если НачалоРазмышления > 0 Тогда
			ДлительностьРазмышленияМс = ДлительностьРазмышленияМс
				+ (ТекущаяУниверсальнаяДатаВМиллисекундах() - НачалоРазмышления);
			НачалоРазмышления = 0;
		КонецЕсли;

		// Полный текст может прийти в поле text (fallback без стриминга)
		ПолныйТекст = МодульПарсер.ИзвлечьЗначение(ДанныеОтвета, "text");
		Если НЕ ЗначениеЗаполнено(ПолныйТекст) Тогда
			ПолныйТекст = ТекущееСообщениеТекст;
		КонецЕсли;

		Если ЗначениеЗаполнено(ПолныйТекст) Тогда
			// Спойлер подготовки + финальный текст
			ИтогHTML = СобратьСпойлерПодготовки() + ПолныйТекст;
			Если НЕ ПустаяСтрока(ТекущееСообщениеИД) Тогда
				ОбновитьТекущееСообщение(ИтогHTML);
			Иначе
				ВывестиВЧатСообщениеАссистента(ЭтотОбъект.Элементы.Чат1, ИтогHTML);
			КонецЕсли;
		КонецЕсли;

		ТекущееСообщениеТекст = "";
		ТекущееСообщениеИД = "";

		НачалоРазмышления = 0;
		ДлительностьРазмышленияМс = 0;
		НачалоПодготовкиОтвета = 0;
		СтатусыИнструментов = Новый Массив;
		ТекущийРежимБлока = "";
		УстановитьЗанят(Ложь);

	ИначеЕсли ТипСобытия = "error" Тогда

		ПричинаОшибки = МодульПарсер.ИзвлечьЗначение(ДанныеОтвета, "reason");
		ТекстОшибки = МодульПарсер.ИзвлечьЗначение(ДанныеОтвета, "message");
		Если ПустаяСтрока(ТекстОшибки) Тогда
			ТекстОшибки = "Неизвестная ошибка";
		КонецЕсли;
		Если ПричинаОшибки = "busy" Тогда
			ВывестиВЧатПредупреждение(ЭтотОбъект.Элементы.Чат1, ТекстОшибки);
		Иначе
			ВывестиВЧатОшибку(ЭтотОбъект.Элементы.Чат1, ТекстОшибки);
			УстановитьЗанят(Ложь);
		КонецЕсли;

	ИначеЕсли ТипСобытия = "tool_call" Тогда

		// exec-команда от Роутера к базе (lyra_data_query, lyra_data_eval, lyra_data_exec, lyra_meta_list)
		ИДЗапроса = МодульПарсер.ИзвлечьЗначение(ДанныеОтвета, "request_id");
		ИмяИнструмента = МодульПарсер.ИзвлечьЗначение(ДанныеОтвета, "tool");
		ПараметрыИнструмента = ДанныеОтвета["params"];

		Попытка
			Результат = МодульMCP.ВыполнитьИнструмент(ИмяИнструмента, ПараметрыИнструмента);
			ОтветИнструмента = Новый Структура;
			ОтветИнструмента.Вставить("type", "tool_result");
			ОтветИнструмента.Вставить("request_id", ИДЗапроса);
			ОтветИнструмента.Вставить("result", Результат);
			МодульBridge.ОтправитьСообщение(ОтветИнструмента);
		Исключение
			ОтветИнструмента = Новый Структура;
			ОтветИнструмента.Вставить("type", "tool_result");
			ОтветИнструмента.Вставить("request_id", ИДЗапроса);
			ОтветИнструмента.Вставить("error", ОписаниеОшибки());
			МодульBridge.ОтправитьСообщение(ОтветИнструмента);
		КонецПопытки;

	КонецЕсли;

	// Логирование
	Попытка
		ЛогЗапись = МодульПарсер.СобратьJSON(ДанныеОтвета);
		ЭтотОбъект.Лог.ДобавитьСтроку(ЛогЗапись);
	Исключение
	КонецПопытки;

КонецПроцедуры

#КонецОбласти

