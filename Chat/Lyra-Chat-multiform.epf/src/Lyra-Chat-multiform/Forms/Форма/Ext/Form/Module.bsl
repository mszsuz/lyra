// Отправляет Bridge сообщение hello с инструментами и MCP-серверами.
//
&НаКлиенте
Процедура ОтправитьHello()

	Привет = Новый Соответствие;
	Привет.Вставить("type", "hello");
	Привет.Вставить("tools", МодульMCP.ПолучитьИменаИнструментов());

	// Внешние MCP-серверы
	ВнешниеСерверы = ПолучитьВнешниеMCPСерверы();
	Если ВнешниеСерверы.Количество() > 0 Тогда
		Привет.Вставить("mcpServers", ВнешниеСерверы);
	КонецЕсли;

	МодульBridge.ОтправитьСообщение(МодульПарсер.СобратьJSON(Привет));

КонецПроцедуры

// Возвращает описание внешних MCP-серверов для Bridge.
//
&НаКлиенте
Функция ПолучитьВнешниеMCPСерверы()

	Серверы = Новый Соответствие;

	// Vega — визуализация данных
	Vega = Новый Соответствие;
	Vega.Вставить("type", "http");
	Vega.Вставить("url", "http://localhost:60040/mcp");
	Заголовки = Новый Соответствие;
	Заголовки.Вставить("X-API-Key", "vega");
	Vega.Вставить("headers", Заголовки);
	Серверы.Вставить("vega", Vega);

	Возврат Серверы;

