Функция ЕХТ_Чат_НовоеСообщение(Текст, Шаблон, ЛевыйВерх = "", ПравыйВерх = "", ЛевыйНиз = "", ПравыйНиз = "") Экспорт

	Сообщение = Новый Структура;
	Сообщение.Вставить("ИД", Строка(Новый УникальныйИдентификатор));
	Сообщение.Вставить("Текст", Текст);
	Сообщение.Вставить("Шаблон", Шаблон);

	Сообщение.Вставить("Надписи", Новый Структура);
	Если ЗначениеЗаполнено(ЛевыйВерх) Тогда
		Сообщение.Надписи.Вставить("ЛевыйВерх", ЛевыйВерх);
	КонецЕсли;
	Если ЗначениеЗаполнено(ПравыйВерх) Тогда
		Сообщение.Надписи.Вставить("ПравыйВерх", ПравыйВерх);
	КонецЕсли;
	Если ЗначениеЗаполнено(ЛевыйНиз) Тогда
		Сообщение.Надписи.Вставить("ЛевыйНиз", ЛевыйНиз);
	КонецЕсли;
	Если ЗначениеЗаполнено(ПравыйНиз) Тогда
		Сообщение.Надписи.Вставить("ПравыйНиз", ПравыйНиз);
	КонецЕсли;

	Возврат Сообщение;

