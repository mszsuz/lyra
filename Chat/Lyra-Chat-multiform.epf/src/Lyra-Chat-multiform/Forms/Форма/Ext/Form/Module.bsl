#Область СлужебныйПрограммныйИнтерфейсСервер

&НаСервере
Процедура ЕХТ_Чат_УстановитьЭлемент(Форма, Знач Элемент, Знач ДвоичныеДанныеПриложения) Экспорт

	МодульОбъекта = МодульОбъекта();

	ЭлементТип = ТипЗнч(Элемент);
	Если ЭлементТип = Тип("Строка") Тогда

		ИмяЭлемента = Элемент;

		ИмяРеквизита = ИмяЭлемента;
		Если НЕ МодульОбъекта.ЕХТ_Форма_РеквизитСуществует(Форма, ИмяРеквизита) Тогда
			МодульОбъекта.ЕХТ_Форма_ДобавитьРеквизиты(Форма, Новый РеквизитФормы(ИмяРеквизита, МодульОбъекта.ЕХТ_Тип_ОписаниеСтрока()));
		КонецЕсли;

		Элемент = Форма.Элементы.Найти(ИмяЭлемента);
		Если Элемент = Неопределено Тогда
			Элемент = МодульОбъекта.ЕХТ_Форма_ДобавитьПолеФормыПолеHTMLДокумента(Форма, ИмяРеквизита);
		КонецЕсли;

	Иначе

		ИмяРеквизита = Элемент.ПутьКДанным;

	КонецЕсли;

	Элемент.УстановитьДействие("ПриНажатии", "Подключаемый_ПриНажатии");

	Если КлиентскоеПриложение.ТипПриложения() = ТипКлиентскогоПриложения.ВебКлиент Тогда
		Форма[ИмяРеквизита] = ПолучитьСтрокуИзДвоичныхДанных(ДвоичныеДанныеПриложения);
	Иначе
		Форма[ИмяРеквизита] = СтрШаблон("%1/%2",
			ПолучитьНавигационнуюСсылкуИнформационнойБазы(),
			ПоместитьВоВременноеХранилище(ДвоичныеДанныеПриложения, Форма.УникальныйИдентификатор));
	КонецЕсли;

КонецПроцедуры

