Функция ПолучитьКартинкуФона(Знач ТемнаяТема)
	ОбъектОбработки = РеквизитФормыВЗначение("Объект");
	Если ТемнаяТема Тогда
		ДвоичныеДанные = ОбъектОбработки.ПолучитьМакет("ЕХТ_Чат_ДвоичныеДанныеКартинкаФонаТемная");
	Иначе
		ДвоичныеДанные = ОбъектОбработки.ПолучитьМакет("ЕХТ_Чат_ДвоичныеДанныеКартинкаФонаСветлая");
	КонецЕсли;
	Возврат "data:image/svg+xml;base64," + Base64Строка(ДвоичныеДанные);
КонецФункции

