
// Главная форма Lyra-Chat (модульный).
// Тонкий контроллер — только UI-события и координация модулей.
// Вся бизнес-логика разнесена по служебным формам-модулям:
//   МодульТранспорт — WebSocket-соединение + JSON
//   МодульОбработка — обработчики инструментов (exec-команды)
//   МодульСессия    — управление сессией: подключение, протокол, баланс, QR
//   МодульЧат       — жизненный цикл диалога: стриминг, tool_call, abort

#Область ПеременныеМодуля

&НаКлиенте
Перем МодульОбщий;       // форма-модуль общих утилит
&НаКлиенте
Перем МодульТранспорт;   // форма-модуль Centrifugo + JSON
&НаКлиенте
Перем МодульОбработка;   // форма-модуль обработки инструментов
&НаКлиенте
Перем МодульСессия;      // форма-модуль управления сессией
&НаКлиенте
Перем МодульЧат;         // форма-модуль жизненного цикла диалога
&НаКлиенте
Перем МодульНапарник;    // форма-модуль интеграции с 1С:Напарник
&НаКлиенте
Перем ОбщиеПараметры Экспорт;   // Соответствие

#КонецОбласти

#Область ОбработчикиСобытийФормы

&НаСервере
Процедура ПриСозданииНаСервере(Отказ, СтандартнаяОбработка)

	ОбъектОбработки = РеквизитФормыВЗначение("Объект");
	
	ЭтотОбъект.ИмяОбработки = СтрРазделить(ОбъектОбработки, ".")[1];
	ЭтотОбъект.ИспользуемоеИмяФайла = ОбъектОбработки.ИспользуемоеИмяФайла;
	
	ЭтотОбъект.Элементы.Версия.Заголовок = "Версия: " + ОбъектОбработки.Метаданные().Комментарий;
	
	// Передача Соответствия с сериализуемыми значениями с сервера на клиент через временное хранилище.
	
	ОбщиеПараметры = Новый Соответствие;
	
	ОбщиеПараметры["КартинкаФонаТемная"] = "data:image/svg+xml;base64," 
		+ Base64Строка(ОбъектОбработки.ПолучитьМакет("ЕХТ_Чат_ДвоичныеДанныеКартинкаФонаТемная"));
	ОбщиеПараметры["КартинкаФонаСветлая"] = "data:image/svg+xml;base64," 
		+ Base64Строка(ОбъектОбработки.ПолучитьМакет("ЕХТ_Чат_ДвоичныеДанныеКартинкаФонаСветлая"));
		
	ЭтотОбъект.АдресОбщихПараметров = ПоместитьВоВременноеХранилище(ОбщиеПараметры, ЭтотОбъект.УникальныйИдентификатор);
	
	// Инициализация чата.
	
	ЕХТ_Чат_Инициализация(ЭтотОбъект, ЕХТ_Структура(
		"Элемент", 					ЭтотОбъект.Элементы.Чат1,
		"ДвоичныеДанныеПриложения", ОбъектОбработки.ПолучитьМакет("ЕХТ_Чат_ДвоичныеДанныеПриложения")));

КонецПроцедуры

&НаКлиенте
Процедура ПриОткрытии(Отказ)

	ОбщиеПараметры = ПолучитьИзВременногоХранилища(ЭтотОбъект.АдресОбщихПараметров);

	// Инициализация модулей через ПолучитьФорму()
	МодульОбщий = ПолучитьФорму("ВнешняяОбработка.ЛираЧат.Форма.МодульОбщий",, ЭтотОбъект);

	МодульТранспорт = ПолучитьФорму("ВнешняяОбработка.ЛираЧат.Форма.МодульТранспорт",, ЭтотОбъект);
	МодульТранспорт.Инициализация(ЭтотОбъект);

	МодульОбработка = ПолучитьФорму("ВнешняяОбработка.ЛираЧат.Форма.МодульОбработка",, ЭтотОбъект);

	МодульНапарник = ПолучитьФорму("ВнешняяОбработка.ЛираЧат.Форма.МодульНапарник",, ЭтотОбъект);
	МодульНапарник.Инициализация(ЭтотОбъект, МодульТранспорт);

	МодульСессия = ПолучитьФорму("ВнешняяОбработка.ЛираЧат.Форма.МодульСессия",, ЭтотОбъект);

	МодульЧат = ПолучитьФорму("ВнешняяОбработка.ЛираЧат.Форма.МодульЧат",, ЭтотОбъект);
	МодульЧат.Инициализация(ЭтотОбъект, МодульТранспорт, МодульОбработка, МодульНапарник, МодульСессия);

	МодульСессия.Инициализация(ЭтотОбъект, МодульТранспорт, МодульЧат, МодульНапарник,
		ПолучитьДанныеБазыДляHello(), Строка(ЭтотОбъект.УникальныйИдентификатор));

	// Автоподключение (с задержкой — WS не работает в ПриОткрытии веб-клиента)
	ПодключитьОбработчикОжидания("ОтложенноеПодключение", 1, Истина);

КонецПроцедуры

&НаКлиенте
Процедура ПередЗакрытием(Отказ, ЗавершениеРаботы, ТекстПредупреждения, СтандартнаяОбработка)

	// При завершении работы 1С не блокируем
	Если ЗавершениеРаботы Тогда
		Возврат;
	КонецЕсли;

	Если НЕ МожноЗакрытьФорму Тогда
		Отказ = Истина;
		СтандартнаяОбработка = Ложь;

		МодульСессия.ПередЗакрытием();

		// Двухфазное закрытие: cleanup выполнен → разрешить закрытие
		МожноЗакрытьФорму = Истина;
		Закрыть();
	КонецЕсли;

КонецПроцедуры

#КонецОбласти

#Область ОбработчикиСобытийЭлементовФормы

&НаКлиенте
Процедура Подключаемый_ПриНажатии(Элемент, ДанныеСобытия, СтандартнаяОбработка)
	ЕХТ_Чат_СобытиеПриНажатии(Элемент, ДанныеСобытия, СтандартнаяОбработка);
КонецПроцедуры

&НаКлиенте
Процедура Интеграция1СНапарникПриНажатии(Элемент, ДанныеСобытия, СтандартнаяОбработка)
	МодульНапарник.Интеграция1СНапарникПриНажатии(Элемент, ДанныеСобытия, СтандартнаяОбработка);
КонецПроцедуры

#КонецОбласти

#Область ОбработчикиКомандФормы

&НаКлиенте
Процедура Чат1_Подключиться(Команда)
	МодульСессия.Подключиться();
КонецПроцедуры

&НаКлиенте
Процедура ОтложенноеПодключение()
	ЭтотОбъект.Активизировать();
	МодульСессия.Подключиться();
КонецПроцедуры

&НаКлиенте
Процедура Чат1_ОтправитьСообщение(Команда)
	ТекстСообщения = СокрЛП(ЭтотОбъект.Чат1_ТекстСообщенияПользователя);
	МодульЧат.ОтправитьСообщениеПользователя(ТекстСообщения);
КонецПроцедуры

// Настройки чата

&НаКлиенте
Процедура Чат1_Настройка_Автосвертка_ПриИзменении(Элемент)

	Настройки = ЕХТ_Чат_ПолучитьНастройки(ЭтотОбъект.Элементы.Чат1);
	Настройки.Сообщения.Автосвертка = ЭтотОбъект.Чат1_Настройка_Автосвертка;
	ЕХТ_Чат_УстановитьНастройки(ЭтотОбъект.Элементы.Чат1, Настройки);

КонецПроцедуры

&НаКлиенте
Процедура Чат1_Настройка_ТемнаяТема_ПриИзменении(Элемент)

	Если ЭтотОбъект.Чат1_Настройка_ТемнаяТема Тогда
		НоваяТема = ЕХТ_Чат_ТемнаяТемаПоУмолчанию();
	Иначе
		НоваяТема = ЕХТ_Чат_СветлаяТемаПоУмолчанию();
	КонецЕсли;
	// НоваяТема.Оформление.Вставить("КартинкаФона", ПолучитьКартинкуФона(ЭтотОбъект.Чат1_Настройка_ТемнаяТема));
	ЕХТ_Чат_УстановитьТему(ЭтотОбъект.Элементы.Чат1, НоваяТема);

КонецПроцедуры

&НаКлиенте
Процедура Чат1_Настройка_Аватары_ПриИзменении(Элемент)

	Настройки = ЕХТ_Чат_ПолучитьНастройки(ЭтотОбъект.Элементы.Чат1);
	Настройки.Аватары.Видимость = ЭтотОбъект.Чат1_Настройка_Аватары;
	ЕХТ_Чат_УстановитьНастройки(ЭтотОбъект.Элементы.Чат1, Настройки);

КонецПроцедуры

// Таймер подготовки — делегирует в МодульЧат
&НаКлиенте
Процедура ОбновитьТаймерПодготовки() Экспорт
	МодульЧат.ОбновитьТаймерПодготовки();
КонецПроцедуры

#КонецОбласти

#Область ДиспетчерСобытийМодулей

// Центральный диспетчер событий от модулей.
// Модули вызывают этот метод для обратной связи с главной формой.
//
// Параметры:
//  ИмяМодуля - Строка - Имя модуля-источника (Транспорт, Сессия, Чат)
//  ИмяСобытия - Строка - Имя события
//  Данные - Произвольный - Данные события
//
&НаКлиенте
Процедура ОбработатьСобытиеМодуля(ИмяМодуля, ИмяСобытия, Данные) Экспорт

	Если ИмяМодуля = "Транспорт" Тогда
		МодульСессия.ОбработатьСобытиеТранспорта(ИмяСобытия, Данные);
	ИначеЕсли ИмяМодуля = "Сессия" ИЛИ ИмяМодуля = "Чат" Тогда
		ОбработатьСобытиеЧат(ИмяСобытия, Данные);
	КонецЕсли;

КонецПроцедуры

// Обработка событий от МодульЧат
&НаКлиенте
Процедура ОбработатьСобытиеЧат(ИмяСобытия, Данные)

	Если ИмяСобытия = "добавить_сообщение" Тогда

		// Данные — Структура с полями ИД, Текст, Шаблон
		Сообщение = ЕХТ_Чат_НовоеСообщение(Данные.Текст, Данные.Шаблон);
		// Используем ИД от МодульЧат если есть
		Если Данные.Свойство("ИД") И ЗначениеЗаполнено(Данные.ИД) Тогда
			Сообщение.ИД = Данные.ИД;
		КонецЕсли;
		ЕХТ_Чат_ДобавитьСообщение(ЭтотОбъект.Элементы.Чат1, Сообщение);

	ИначеЕсли ИмяСобытия = "обновить_сообщение" Тогда

		// Данные — Структура с полями ИД, Текст
		ЕХТ_Чат_ОбновитьСообщение(ЭтотОбъект.Элементы.Чат1, Данные);

	ИначеЕсли ИмяСобытия = "завершён" Тогда

		УстановитьЗанят(Ложь);

	ИначеЕсли ИмяСобытия = "предупреждение" Тогда

		ВывестиВЧатПредупреждение(ЭтотОбъект.Элементы.Чат1, Данные);

	ИначеЕсли ИмяСобытия = "ошибка" Тогда

		ВывестиВЧатОшибку(ЭтотОбъект.Элементы.Чат1, Данные);

	ИначеЕсли ИмяСобытия = "занят" Тогда

		УстановитьЗанят(Данные);

	ИначеЕсли ИмяСобытия = "таймер_подготовки" Тогда

		Если Данные = "подключить" Тогда
			ПодключитьОбработчикОжидания("ОбновитьТаймерПодготовки", 1, Ложь);
		Иначе
			ОтключитьОбработчикОжидания("ОбновитьТаймерПодготовки");
		КонецЕсли;

	ИначеЕсли ИмяСобытия = "информация" Тогда

		ВывестиВЧатИнформацию(ЭтотОбъект.Элементы.Чат1, Данные);

	ИначеЕсли ИмяСобытия = "заголовок" Тогда

		ЭтотОбъект.Заголовок = Данные;

	ИначеЕсли ИмяСобытия = "очистить_чат" Тогда

		ЕХТ_Чат_Очистить(ЭтотОбъект.Элементы.Чат1);

	ИначеЕсли ИмяСобытия = "доступность_ввода" Тогда

		Элементы.КомандаОтправитьСообщение.Доступность = Данные;

	ИначеЕсли ИмяСобытия = "ид_сессии" Тогда

		ЭтотОбъект.Чат1_ИдентификаторСессии = Данные;

	ИначеЕсли ИмяСобытия = "очистить_поле_ввода" Тогда

		ЭтотОбъект.Чат1_ТекстСообщенияПользователя = "";
		ЭтотОбъект.ТекущийЭлемент = ЭтотОбъект.Элементы.Чат1_ТекстСообщенияПользователя;

	ИначеЕсли ИмяСобытия = "сообщение_пользователя" Тогда

		ВывестиВЧатСообщениеПользователя(ЭтотОбъект.Элементы.Чат1, Данные);

	ИначеЕсли ИмяСобытия = "оповещение" Тогда

		ПоказатьОповещениеПользователя("Лира",, Данные,, СтатусОповещенияПользователя.Важное);

	КонецЕсли;

КонецПроцедуры

#КонецОбласти

#Область ВыводВЧат

&НаКлиенте
Процедура ВывестиВЧат(Знач Элемент, Знач ТекстСообщения, Знач Шаблон)

	Сообщение = ЕХТ_Чат_НовоеСообщение(ТекстСообщения, Шаблон);
	ЕХТ_Чат_ДобавитьСообщение(Элемент, Сообщение);

КонецПроцедуры

&НаКлиенте
Процедура ВывестиВЧатСообщениеПользователя(Знач Элемент, Знач ТекстСообщения)
	ВывестиВЧат(Элемент, ТекстСообщения, "Пользователь");
КонецПроцедуры

&НаКлиенте
Процедура ВывестиВЧатСообщениеАссистента(Знач Элемент, Знач ТекстСообщения)
	ВывестиВЧат(Элемент, ТекстСообщения, "Ассистент");
КонецПроцедуры

&НаКлиенте
Процедура ВывестиВЧатПредупреждение(Знач Элемент, Знач ТекстСообщения)
	ВывестиВЧат(Элемент, ТекстСообщения, "Предупреждение");
КонецПроцедуры

&НаКлиенте
Процедура ВывестиВЧатОшибку(Знач Элемент, Знач ТекстСообщения)
	ВывестиВЧат(Элемент, ТекстСообщения, "Ошибка");
КонецПроцедуры

&НаКлиенте
Процедура ВывестиВЧатИнформацию(Знач Элемент, Знач ТекстСообщения)
	ВывестиВЧат(Элемент, ТекстСообщения, "Информация");
КонецПроцедуры

#КонецОбласти

#Область ОбработчикиЕХТЧат

&НаКлиенте
Функция ЕХТ_Чат_ПриОткрытии(Знач Элемент, Знач НастройкиПоУмолчанию, Знач Ширина = 0, Знач Высота = 0) Экспорт

	Результат = ЕХТ_Структура(
		"Настройки", НастройкиПоУмолчанию,
		"Сообщения", Новый Массив);

	Если Элемент = ЭтотОбъект.Элементы.Чат1 Тогда
		Результат.Настройки.Сообщения.Автосвертка = ЭтотОбъект.Чат1_Настройка_Автосвертка;
		Результат.Настройки.Аватары.Видимость = ЭтотОбъект.Чат1_Настройка_Аватары;
		Результат.Настройки.Оформление.КартинкаФона = ПолучитьКартинкуФона(Ложь);
		Результат.Сообщения = Новый Массив;
	КонецЕсли;

	Возврат Результат;

КонецФункции

&НаКлиенте
Функция ЕХТ_Чат_ПриИзмененииРазмера(
		Знач Элемент, Знач Ширина, Знач Высота) Экспорт
	Возврат Новый Структура;
КонецФункции

&НаКлиенте
Функция ЕХТ_Чат_ПриДобавленииСообщения(Знач Элемент) Экспорт
	Возврат Новый Структура("Сообщение", Новый Структура);
КонецФункции

&НаКлиенте
Функция ЕХТ_Чат_ПриНажатииСсылки(Знач Элемент, Знач АдресСсылки) Экспорт

	// Команды Лиры (lyra://)
	Если АдресСсылки = "lyra://reconnect" Тогда
		МодульЧат.ОбработатьКомандуЧата("reconnect");
		Возврат Новый Структура;
	КонецЕсли;

	// Навигационные ссылки 1С (e1cib/) — открываем объект/список/обработку
	Если СтрНачинаетсяС(АдресСсылки, "e1cib/") Тогда
		Попытка
			ПерейтиПоНавигационнойСсылке(АдресСсылки);
		Исключение
			ВывестиВЧатИнформацию(Элемент, "Не удалось открыть ссылку: " + ОписаниеОшибки());
		КонецПопытки;
	КонецЕсли;

	Возврат Новый Структура;

КонецФункции

&НаКлиенте
Функция ЕХТ_Чат_ПриОбновленииСообщения(Знач Элемент) Экспорт
	Возврат Новый Структура;
КонецФункции

&НаКлиенте
Процедура ЕХТ_Чат_ДобавитьСообщение(Знач Элемент, Знач Сообщение) Экспорт
	СообщениеJSON = МодульОбщий.ЕХТ_Значение_вJSON(Сообщение);
	ЕХТ_Чат_Объект(Элемент).addMessage(СообщениеJSON);
КонецПроцедуры

&НаКлиенте
Процедура ЕХТ_Чат_ОбновитьСообщение(Знач Элемент, Знач Сообщение) Экспорт
	СообщениеJSON = МодульОбщий.ЕХТ_Значение_вJSON(Сообщение);
	ЕХТ_Чат_Объект(Элемент).updateMessage(СообщениеJSON);
КонецПроцедуры

#КонецОбласти

#Область СлужебныеПроцедуры

// Устанавливает флаг занятости и переключает кнопку Отправить/Прервать.
//
&НаКлиенте
Процедура УстановитьЗанят(НовоеЗначение)
	Занят = НовоеЗначение;
	Элементы.КомандаОтправитьСообщение.Заголовок = ?(Занят, "Прервать", "Отправить");
КонецПроцедуры

// Возвращает модуль объекта обработки для вызова серверных методов.
//
&НаСервере
Функция МодульОбъекта()
	Возврат РеквизитФормыВЗначение("Объект");
КонецФункции

&НаСервере
Функция ПолноеИмя()
	Возврат РеквизитФормыВЗначение("Объект").Метаданные().ПолноеИмя();
КонецФункции

// Возвращает данные о базе для отправки в hello.
// Вызывается один раз при открытии формы, результат кэшируется.
