
// Главная форма Lyra-Chat (модульный).
// Тонкий контроллер — только UI-события и координация модулей.
// Вся бизнес-логика разнесена по служебным формам-модулям:
//   МодульBridge — WebSocket-соединение
//   МодульПарсер — JSON-обработка через ЧтениеJSON
//   МодульMCP — MCP strategy-dispatch + обработчики 1С-команд

#Область ПеременныеМодуля

&НаКлиенте
Перем МодульBridge;   // форма-модуль WebSocket
&НаКлиенте
Перем МодульПарсер;   // форма-модуль JSON-парсинга
&НаКлиенте
Перем МодульMCP;      // форма-модуль MCP-обработки

#КонецОбласти

#Область ОбработчикиСобытийФормы

&НаСервере
Процедура ПриСозданииНаСервере(Отказ, СтандартнаяОбработка)

	ОбъектОбработки = РеквизитФормыВЗначение("Объект");
	ЭтотОбъект.Версия = ОбъектОбработки.Метаданные().Комментарий;
	ДвоичныеДанныеПриложения = ОбъектОбработки.ПолучитьМакет("ДвоичныеДанныеПриложения");

	Чат = ЕХТ_Чат_ПриСозданииНаСервере(ЭтотОбъект, Отказ, СтандартнаяОбработка);
	Чат.ЕХТ_Чат_Инициализация(ЭтотОбъект, ЕХТ.Структура(
		"Элемент", 					ЭтотОбъект.Элементы.Чат1,
		"ДвоичныеДанныеПриложения", ДвоичныеДанныеПриложения));

КонецПроцедуры

&НаКлиенте
Процедура ПриОткрытии(Отказ)

	// Инициализация модулей через ПолучитьФорму()
	МодульBridge = ПолучитьФорму("ВнешняяОбработка.Lyra_Chat_multiform.Форма.МодульBridge",, ЭтотОбъект);
	МодульBridge.Инициализация(ЭтотОбъект);

	МодульПарсер = ПолучитьФорму("ВнешняяОбработка.Lyra_Chat_multiform.Форма.МодульПарсер",, ЭтотОбъект);

	МодульMCP = ПолучитьФорму("ВнешняяОбработка.Lyra_Chat_multiform.Форма.МодульMCP",, ЭтотОбъект);
	МодульMCP.Инициализация();

КонецПроцедуры

&НаКлиенте
Процедура ПередЗакрытием(Отказ, ЗавершениеРаботы, ТекстПредупреждения, СтандартнаяОбработка)

	// При завершении работы 1С не блокируем
	Если ЗавершениеРаботы Тогда
		Возврат;
	КонецЕсли;

	Если НЕ МожноЗакрытьФорму Тогда
		Отказ = Истина;
		СтандартнаяОбработка = Ложь;
		// Каскадное отключение
		Если МодульBridge <> Неопределено Тогда
			МодульBridge.Отключиться();
		КонецЕсли;
	КонецЕсли;

КонецПроцедуры

#КонецОбласти

#Область ОбработчикиСобытийЭлементовФормы

&НаКлиенте
Процедура Подключаемый_ПриНажатии(Элемент, ДанныеСобытия, СтандартнаяОбработка)
	ЕХТ_Чат_СобытиеПриНажатии(Элемент, ДанныеСобытия, СтандартнаяОбработка);
КонецПроцедуры

#КонецОбласти

#Область ОбработчикиКомандФормы

&НаКлиенте
Процедура Чат1_Подключиться(Команда)

	Если НЕ ЗначениеЗаполнено(ЭтотОбъект.Чат1_ИдентификаторСессии) Тогда
		ЭтотОбъект.Чат1_ИдентификаторСессии = Строка(Новый УникальныйИдентификатор);
	КонецЕсли;

	МодульBridge.Подключиться("ws://localhost:3003",
		ЭтотОбъект.Чат1_ИдентификаторСессии, ЭтотОбъект.Модель);

КонецПроцедуры

&НаКлиенте
Процедура Чат1_ОтправитьСообщение(Команда)

	ТекстСообщения = СокрЛП(ЭтотОбъект.Чат1_ТекстСообщенияПользователя);
	Если ТекстСообщения = "" Тогда
		Возврат;
	КонецЕсли;

	// Формируем JSON через парсер
	ДанныеСообщения = Новый Соответствие;
	ДанныеСообщения.Вставить("type", "chat");
	ДанныеСообщения.Вставить("content", ТекстСообщения);
	СтрокаJSON = МодульПарсер.СобратьJSON(ДанныеСообщения);

	// Отправляем через Bridge
	Если НЕ МодульBridge.ОтправитьСообщение(СтрокаJSON) Тогда
		ВывестиВЧатПредупреждение(ЭтотОбъект.Элементы.Чат1,
			"Нет соединения с Лирой. Нажмите ""Подключиться"".");
		Возврат;
	КонецЕсли;

	// Очищаем поле ввода
	ЭтотОбъект.Чат1_ТекстСообщенияПользователя = "";

	ВывестиВЧатСообщениеПользователя(ЭтотОбъект.Элементы.Чат1, ТекстСообщения);

	ТекущееСообщениеТекст = "";
	Занят = Истина;

КонецПроцедуры

// Настройки чата

&НаКлиенте
Процедура Чат1_Настройка_Автосвертка_ПриИзменении(Элемент)

	Настройки = ЕХТ_Чат_ПолучитьНастройки(ЭтотОбъект.Элементы.Чат1);
	Настройки.Сообщения.Автосвертка = ЭтотОбъект.Чат1_Настройка_Автосвертка;
	ЕХТ_Чат_УстановитьНастройки(ЭтотОбъект.Элементы.Чат1, Настройки);

КонецПроцедуры

&НаКлиенте
Процедура Чат1_Настройка_ТемнаяТема_ПриИзменении(Элемент)

	Если ЭтотОбъект.Чат1_Настройка_ТемнаяТема Тогда
		НоваяТема = ЕХТ_Чат_ТемнаяТемаПоУмолчанию();
	Иначе
		НоваяТема = ЕХТ_Чат_СветлаяТемаПоУмолчанию();
	КонецЕсли;
	ЕХТ_Чат_УстановитьТему(ЭтотОбъект.Элементы.Чат1, НоваяТема);

КонецПроцедуры

&НаКлиенте
Процедура Чат1_Настройка_Аватары_ПриИзменении(Элемент)

	Настройки = ЕХТ_Чат_ПолучитьНастройки(ЭтотОбъект.Элементы.Чат1);
	Настройки.Аватары.Видимость = ЭтотОбъект.Чат1_Настройка_Аватары;
	ЕХТ_Чат_УстановитьНастройки(ЭтотОбъект.Элементы.Чат1, Настройки);

КонецПроцедуры

#КонецОбласти

#Область ДиспетчерСобытийМодулей

// Центральный диспетчер событий от модулей.
// Модули вызывают этот метод для обратной связи с главной формой.
//
// Параметры:
//  ИмяМодуля - Строка - Имя модуля-источника (Bridge, Parser, MCP)
//  ИмяСобытия - Строка - Имя события
//  Данные - Произвольный - Данные события
//
&НаКлиенте
Процедура ОбработатьСобытиеМодуля(ИмяМодуля, ИмяСобытия, Данные) Экспорт

	Если ИмяМодуля = "Bridge" Тогда
		ОбработатьСобытиеBridge(ИмяСобытия, Данные);
	КонецЕсли;

КонецПроцедуры

&НаКлиенте
Процедура ОбработатьСобытиеBridge(ИмяСобытия, Данные)

	Если ИмяСобытия = "bridge_connected" Тогда

		Занят = Ложь;

	ИначеЕсли ИмяСобытия = "bridge_closed" Тогда

		Занят = Ложь;
		МожноЗакрытьФорму = Истина;
		Закрыть();

	ИначеЕсли ИмяСобытия = "bridge_ws_error" Тогда

		Занят = Ложь;
		Если НЕ МожноЗакрытьФорму Тогда
			МожноЗакрытьФорму = Истина;
			Закрыть();
		КонецЕсли;

	ИначеЕсли ИмяСобытия = "bridge_error" Тогда

		ВывестиВЧатОшибку(ЭтотОбъект.Элементы.Чат1, Данные);

	ИначеЕсли ИмяСобытия = "bridge_message" Тогда

		// Разбираем JSON через МодульПарсер
		ДанныеОтвета = МодульПарсер.РазобратьJSON(Данные);
		ОбработатьОтветBridge(ДанныеОтвета, Данные);

	КонецЕсли;

КонецПроцедуры

#КонецОбласти

#Область ОбработкаОтветовBridge

// Обработка разобранного JSON-сообщения от Bridge.
//
&НаКлиенте
Процедура ОбработатьОтветBridge(ДанныеОтвета, СтрокаJSON)

	ТипСобытия = МодульПарсер.ИзвлечьТипСобытия(ДанныеОтвета);

	Если ТипСобытия = "session" Тогда

		ЭтотОбъект.Чат1_ИдентификаторСессии = МодульПарсер.ИзвлечьЗначение(ДанныеОтвета, "sessionId");
		ВывестиВЧатИнформацию(ЭтотОбъект.Элементы.Чат1,
			"Подключено к Лире (сессия " + Лев(ЭтотОбъект.Чат1_ИдентификаторСессии, 8) + "...)");

	ИначеЕсли ТипСобытия = "system" Тогда

		// Claude Code CLI инициализирован — не требует действий

	ИначеЕсли ТипСобытия = "stream_event" Тогда

		ТекстДельты = МодульПарсер.ИзвлечьТекстДельты(ДанныеОтвета);
		Если НЕ ПустаяСтрока(ТекстДельты) Тогда
			ТекущееСообщениеТекст = ТекущееСообщениеТекст + ТекстДельты;
		КонецЕсли;

	ИначеЕсли ТипСобытия = "result" Тогда

		ПолныйТекст = МодульПарсер.ИзвлечьЗначение(ДанныеОтвета, "result");
		Если ЗначениеЗаполнено(ПолныйТекст) Тогда
			ВывестиВЧатСообщениеАссистента(ЭтотОбъект.Элементы.Чат1, ПолныйТекст);
		ИначеЕсли НЕ ПустаяСтрока(ТекущееСообщениеТекст) Тогда
			ВывестиВЧатСообщениеАссистента(ЭтотОбъект.Элементы.Чат1, ТекущееСообщениеТекст);
		КонецЕсли;
		ТекущееСообщениеТекст = "";
		Занят = Ложь;

	ИначеЕсли ТипСобытия = "error" Тогда

		ПричинаОшибки = МодульПарсер.ИзвлечьЗначение(ДанныеОтвета, "reason");
		ТекстОшибки = МодульПарсер.ИзвлечьЗначение(ДанныеОтвета, "message");
		Если ПустаяСтрока(ТекстОшибки) Тогда
			ТекстОшибки = "Неизвестная ошибка";
		КонецЕсли;
		Если ПричинаОшибки = "busy" Тогда
			ВывестиВЧатПредупреждение(ЭтотОбъект.Элементы.Чат1, ТекстОшибки);
		Иначе
			ВывестиВЧатОшибку(ЭтотОбъект.Элементы.Чат1, ТекстОшибки);
			Занят = Ложь;
		КонецЕсли;

	ИначеЕсли ТипСобытия = "assistant" Тогда

		// Промежуточные сообщения — не показываем, покажем по "result"

	ИначеЕсли ТипСобытия = "mcp_request" Тогда

		// Обрабатываем MCP-запрос через МодульMCP
		ОтветJSON = МодульMCP.ОбработатьЗапрос(ДанныеОтвета);
		МодульBridge.ОтправитьСообщение(ОтветJSON);

	ИначеЕсли ТипСобытия = "claude_exit" Тогда

		КодЗавершения = МодульПарсер.ИзвлечьЗначение(ДанныеОтвета, "code");
		Если КодЗавершения <> "0" И ЗначениеЗаполнено(КодЗавершения) Тогда
			ВывестиВЧатПредупреждение(ЭтотОбъект.Элементы.Чат1,
				"Claude завершился с кодом " + КодЗавершения);
		КонецЕсли;
		Занят = Ложь;

	КонецЕсли;

	// Логирование
	Попытка
		ЛогЗапись = МодульПарсер.СобратьJSON(ДанныеОтвета);
		ЭтотОбъект.Лог.ДобавитьСтроку(ЛогЗапись);
	Исключение
	КонецПопытки;

КонецПроцедуры

#КонецОбласти

#Область ВыводВЧат

&НаКлиенте
Процедура ВывестиВЧат(Знач Элемент, Знач ТекстСообщения, Знач Шаблон)

	Сообщение = ЕХТ_Чат_НовоеСообщение(ТекстСообщения, Шаблон);
	ЕХТ_Чат_ДобавитьСообщение(Элемент, Сообщение);

КонецПроцедуры

&НаКлиенте
Процедура ВывестиВЧатСообщениеПользователя(Знач Элемент, Знач ТекстСообщения)
	ВывестиВЧат(Элемент, ТекстСообщения, "Пользователь");
КонецПроцедуры

&НаКлиенте
Процедура ВывестиВЧатСообщениеАссистента(Знач Элемент, Знач ТекстСообщения)
	ВывестиВЧат(Элемент, ТекстСообщения, "Ассистент");
КонецПроцедуры

&НаКлиенте
Процедура ВывестиВЧатПредупреждение(Знач Элемент, Знач ТекстСообщения)
	ВывестиВЧат(Элемент, ТекстСообщения, "Предупреждение");
КонецПроцедуры

&НаКлиенте
Процедура ВывестиВЧатОшибку(Знач Элемент, Знач ТекстСообщения)
	ВывестиВЧат(Элемент, ТекстСообщения, "Ошибка");
КонецПроцедуры

&НаКлиенте
Процедура ВывестиВЧатИнформацию(Знач Элемент, Знач ТекстСообщения)
