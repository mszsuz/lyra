
// МодульОбработка — серверные обработчики инструментов Лиры.
// Служебная форма-модуль (не отображается), получается через ПолучитьФорму("МодульОбработка").
//
// Обработка tool_call/tool_result — в МодульЧат.
// Этот модуль только выполняет инструменты: получает имя + параметры → возвращает результат.

#Область ПрограммныйИнтерфейс

// Выполняет инструмент по имени.
//
// Параметры:
//  ИмяИнструмента      - Строка - имя инструмента (lyra_data_query, lyra_data_eval, lyra_meta_list, lyra_data_exec, lyra_nav_resolve, lyra_diag_read_log)
//  ПараметрыИнструмента - Структура, Соответствие - параметры вызова
//
// Возвращаемое значение:
//  Строка - результат выполнения (JSON-строка или текст)
//
&НаКлиенте
Функция ВыполнитьИнструмент(Знач ИмяИнструмента, Знач ПараметрыИнструмента) Экспорт

	Если ПараметрыИнструмента = Неопределено Тогда
		ПараметрыИнструмента = Новый Структура;
	КонецЕсли;

	// Сервер всегда возвращает JSON-строку (сериализация на сервере)
	Возврат ВыполнитьИнструментНаСервере(ИмяИнструмента, ПараметрыИнструмента);

КонецФункции

#КонецОбласти

#Область ОбработчикиИнструментов

&НаСервереБезКонтекста
Функция ВыполнитьИнструментНаСервере(Знач ИмяИнструмента, Знач Ввод)

	Если ИмяИнструмента = "lyra_data_query" Тогда
		Результат = Обработчик_lyra_data_query(Ввод);
		
	ИначеЕсли ИмяИнструмента = "lyra_meta_list" Тогда
		Результат = Обработчик_lyra_meta_list(Ввод);
		
	ИначеЕсли ИмяИнструмента = "lyra_data_eval" Тогда
		Результат = Обработчик_lyra_data_eval(Ввод);
		
	ИначеЕсли ИмяИнструмента = "lyra_data_exec" Тогда
		Результат = Обработчик_lyra_data_exec(Ввод);
		
	ИначеЕсли ИмяИнструмента = "lyra_nav_resolve" Тогда
		Результат = Обработчик_lyra_nav_resolve(Ввод);
		
	ИначеЕсли ИмяИнструмента = "lyra_diag_read_log" Тогда
		Результат = Обработчик_lyra_diag_read_log(Ввод);
		
	ИначеЕсли ИмяИнструмента = "lyra_meta_describe" Тогда
		Результат = Обработчик_lyra_meta_describe(Ввод);
		
	ИначеЕсли ИмяИнструмента = "lyra_data_read" Тогда
		Результат = Обработчик_lyra_data_read(Ввод);
		
	Иначе
		Результат = Новый Структура("error", "Неизвестный инструмент: " + ИмяИнструмента);
	КонецЕсли;

	// Сериализуем в JSON прямо на сервере — не зависим от клиентской ЗаписатьЗначениеJSON
	Если ТипЗнч(Результат) = Тип("Строка") Тогда
		Возврат Результат;
	КонецЕсли;

	Попытка
		ЗаписьJSON = Новый ЗаписьJSON;
		ЗаписьJSON.УстановитьСтроку();
		ЗаписатьJSON(ЗаписьJSON, Результат);
		Возврат ЗаписьJSON.Закрыть();
	Исключение
		Возврат "{""error"":""Ошибка сериализации: " + ОписаниеОшибки() + """}";
	КонецПопытки;

КонецФункции

&НаСервереБезКонтекста
Функция Обработчик_lyra_data_query(ПарамыЗапроса)

	ТекстЗапроса = ПолучитьПараметр(ПарамыЗапроса, "query");
	Если ТекстЗапроса = Неопределено Тогда
		Возврат Новый Структура("error", "Отсутствует параметр query");
	КонецЕсли;

	Попытка
		Схема = Новый СхемаЗапроса;
		Схема.УстановитьТекстЗапроса(ТекстЗапроса);
	Исключение
		Возврат Новый Структура("error", "Ошибка синтаксиса запроса: " + ОписаниеОшибки()
			+ ". Проверь имена таблиц и полей через lyra_meta_list — в базе могут быть доработки и расширения.");
	КонецПопытки;

	Попытка
		Запрос = Новый Запрос(ТекстЗапроса);

		ПараметрыВвода = ПолучитьПараметр(ПарамыЗапроса, "params");
		ПараметрыДат = ПолучитьПараметр(ПарамыЗапроса, "date_params");
		// fallback: Claude может вложить date_params внутрь params
		Если ПараметрыДат = Неопределено И ПараметрыВвода <> Неопределено Тогда
			ПараметрыДат = ПолучитьПараметр(ПараметрыВвода, "date_params");
		КонецЕсли;
		Если ПараметрыВвода <> Неопределено Тогда
			УстановитьПараметрыЗапроса(Запрос, ПараметрыВвода, ПараметрыДат);
		КонецЕсли;

		Результат = Запрос.Выполнить();

		Если Результат.Пустой() Тогда
			Возврат Новый Структура("data,columns,count", Новый Массив, Новый Массив, 0);
		КонецЕсли;

		Колонки = Новый Массив;
		Для Каждого Колонка Из Результат.Колонки Цикл
			Колонки.Добавить(Колонка.Имя);
		КонецЦикла;

		Данные = Новый Массив;
		Выборка = Результат.Выбрать();
		Счетчик = 0;

		Пока Выборка.Следующий() И Счетчик <= 100 Цикл
			СтрокаДанных = Новый Структура;
			Для Каждого ИмяКолонки Из Колонки Цикл
				Попытка
					Значение = Выборка[ИмяКолонки];
					СтрокаДанных.Вставить(ИмяКолонки, ЗначениеДляJSON(Значение));
				Исключение
					СтрокаДанных.Вставить(ИмяКолонки, Неопределено);
				КонецПопытки;
			КонецЦикла;
			Данные.Добавить(СтрокаДанных);
			Счетчик = Счетчик + 1;
		КонецЦикла;

		Если Данные.Количество() > 100 Тогда
			Возврат Новый Структура("error",
				"Запрос вернул " + Данные.Количество() + " строк — слишком много. "
				+ "Уточни запрос: добавь ПЕРВЫЕ N, сузь условия ГДЕ, добавь СГРУППИРОВАТЬ ПО или уменьши количество колонок.");
		КонецЕсли;

		Возврат Новый Структура("data,columns,count", Данные, Колонки, Данные.Количество());

	Исключение
		Возврат Новый Структура("error", "Ошибка запроса: " + ОписаниеОшибки());
	КонецПопытки;

КонецФункции

&НаСервереБезКонтекста
Функция Обработчик_lyra_meta_list(ПарамыЗапроса)

	Путь = ПолучитьПараметр(ПарамыЗапроса, "path");
	Если Путь = Неопределено Тогда Путь = ""; КонецЕсли;

	Результат = Новый Массив;

	Попытка
		Если Путь = "" ИЛИ Путь = "Справочники" Тогда
			Для Каждого М Из Метаданные.Справочники Цикл
				Результат.Добавить(Новый Структура("type,name,synonym",
					"Справочник", М.Имя, Строка(М.Синоним)));
			КонецЦикла;
		КонецЕсли;

		Если Путь = "" ИЛИ Путь = "Документы" Тогда
			Для Каждого М Из Метаданные.Документы Цикл
				Результат.Добавить(Новый Структура("type,name,synonym",
					"Документ", М.Имя, Строка(М.Синоним)));
			КонецЦикла;
		КонецЕсли;

		Если Путь = "" ИЛИ Путь = "РегистрыСведений" Тогда
			Для Каждого М Из Метаданные.РегистрыСведений Цикл
				Результат.Добавить(Новый Структура("type,name,synonym",
					"РегистрСведений", М.Имя, Строка(М.Синоним)));
			КонецЦикла;
		КонецЕсли;

		Если Путь = "" ИЛИ Путь = "РегистрыНакопления" Тогда
			Для Каждого М Из Метаданные.РегистрыНакопления Цикл
				Результат.Добавить(Новый Структура("type,name,synonym",
					"РегистрНакопления", М.Имя, Строка(М.Синоним)));
			КонецЦикла;
		КонецЕсли;

		Если Путь = "" ИЛИ Путь = "РегистрыБухгалтерии" Тогда
			Для Каждого М Из Метаданные.РегистрыБухгалтерии Цикл
				Результат.Добавить(Новый Структура("type,name,synonym",
					"РегистрБухгалтерии", М.Имя, Строка(М.Синоним)));
			КонецЦикла;
		КонецЕсли;

		Если Путь = "" ИЛИ Путь = "РегистрыРасчета" Тогда
			Для Каждого М Из Метаданные.РегистрыРасчета Цикл
				Результат.Добавить(Новый Структура("type,name,synonym",
					"РегистрРасчета", М.Имя, Строка(М.Синоним)));
			КонецЦикла;
		КонецЕсли;

		Если Путь = "" ИЛИ Путь = "Перечисления" Тогда
			Для Каждого М Из Метаданные.Перечисления Цикл
				Результат.Добавить(Новый Структура("type,name,synonym",
					"Перечисление", М.Имя, Строка(М.Синоним)));
			КонецЦикла;
		КонецЕсли;

		Если Путь = "" ИЛИ Путь = "ПланыВидовХарактеристик" Тогда
			Для Каждого М Из Метаданные.ПланыВидовХарактеристик Цикл
				Результат.Добавить(Новый Структура("type,name,synonym",
					"ПланВидовХарактеристик", М.Имя, Строка(М.Синоним)));
			КонецЦикла;
		КонецЕсли;

		Если Путь = "" ИЛИ Путь = "ПланыСчетов" Тогда
			Для Каждого М Из Метаданные.ПланыСчетов Цикл
				Результат.Добавить(Новый Структура("type,name,synonym",
					"ПланСчетов", М.Имя, Строка(М.Синоним)));
			КонецЦикла;
		КонецЕсли;

		Если Путь = "" ИЛИ Путь = "ПланыВидовРасчета" Тогда
			Для Каждого М Из Метаданные.ПланыВидовРасчета Цикл
				Результат.Добавить(Новый Структура("type,name,synonym",
					"ПланВидовРасчета", М.Имя, Строка(М.Синоним)));
			КонецЦикла;
		КонецЕсли;

		Если Путь = "" ИЛИ Путь = "ПланыОбмена" Тогда
			Для Каждого М Из Метаданные.ПланыОбмена Цикл
				Результат.Добавить(Новый Структура("type,name,synonym",
					"ПланОбмена", М.Имя, Строка(М.Синоним)));
			КонецЦикла;
		КонецЕсли;

		Если Путь = "" ИЛИ Путь = "Константы" Тогда
			Для Каждого М Из Метаданные.Константы Цикл
				Результат.Добавить(Новый Структура("type,name,synonym",
					"Константа", М.Имя, Строка(М.Синоним)));
			КонецЦикла;
		КонецЕсли;

		Если Путь = "" ИЛИ Путь = "БизнесПроцессы" Тогда
			Для Каждого М Из Метаданные.БизнесПроцессы Цикл
				Результат.Добавить(Новый Структура("type,name,synonym",
					"БизнесПроцесс", М.Имя, Строка(М.Синоним)));
			КонецЦикла;
		КонецЕсли;

		Если Путь = "" ИЛИ Путь = "Задачи" Тогда
			Для Каждого М Из Метаданные.Задачи Цикл
				Результат.Добавить(Новый Структура("type,name,synonym",
					"Задача", М.Имя, Строка(М.Синоним)));
			КонецЦикла;
		КонецЕсли;

		Если Путь = "" ИЛИ Путь = "ЖурналыДокументов" Тогда
			Для Каждого М Из Метаданные.ЖурналыДокументов Цикл
				Результат.Добавить(Новый Структура("type,name,synonym",
					"ЖурналДокументов", М.Имя, Строка(М.Синоним)));
			КонецЦикла;
		КонецЕсли;

		Если Путь = "" ИЛИ Путь = "Обработки" Тогда
			Для Каждого М Из Метаданные.Обработки Цикл
				Результат.Добавить(Новый Структура("type,name,synonym",
					"Обработка", М.Имя, Строка(М.Синоним)));
			КонецЦикла;
		КонецЕсли;

		Если Путь = "" ИЛИ Путь = "Отчеты" Тогда
			Для Каждого М Из Метаданные.Отчеты Цикл
				Результат.Добавить(Новый Структура("type,name,synonym",
					"Отчет", М.Имя, Строка(М.Синоним)));
			КонецЦикла;
		КонецЕсли;

		Если Путь = "" ИЛИ Путь = "ОбщиеМодули" Тогда
			Для Каждого М Из Метаданные.ОбщиеМодули Цикл
				Результат.Добавить(Новый Структура("type,name,synonym",
					"ОбщийМодуль", М.Имя, Строка(М.Синоним)));
			КонецЦикла;
		КонецЕсли;

		Если Путь = "" ИЛИ Путь = "Последовательности" Тогда
			Для Каждого М Из Метаданные.Последовательности Цикл
				Результат.Добавить(Новый Структура("type,name,synonym",
					"Последовательность", М.Имя, Строка(М.Синоним)));
			КонецЦикла;
		КонецЕсли;

		Если Путь = "" ИЛИ Путь = "ВнешниеИсточникиДанных" Тогда
			Для Каждого М Из Метаданные.ВнешниеИсточникиДанных Цикл
				Результат.Добавить(Новый Структура("type,name,synonym",
					"ВнешнийИсточникДанных", М.Имя, Строка(М.Синоним)));
			КонецЦикла;
		КонецЕсли;

		Если Путь = "" ИЛИ Путь = "РегламентныеЗадания" Тогда
			Для Каждого М Из Метаданные.РегламентныеЗадания Цикл
				Результат.Добавить(Новый Структура("type,name,synonym",
					"РегламентноеЗадание", М.Имя, Строка(М.Синоним)));
			КонецЦикла;
		КонецЕсли;

		Возврат Результат;

	Исключение
		Возврат Новый Структура("error", "Ошибка метаданных: " + ОписаниеОшибки());
	КонецПопытки;

КонецФункции

&НаСервереБезКонтекста
Функция Обработчик_lyra_data_eval(ПарамыЗапроса)

	Выражение = ПолучитьПараметр(ПарамыЗапроса, "expression");
	Если Выражение = Неопределено Тогда
		Возврат Новый Структура("error", "Отсутствует параметр expression");
	КонецЕсли;

	УстановитьБезопасныйРежим(Истина);
	
	НачатьТранзакцию();
	Попытка
		РезультатВыражения = Вычислить(Выражение);
		Результат = Новый Структура("result", ЗначениеДляJSON(РезультатВыражения));
	Исключение
		Результат = Новый Структура("error", "Ошибка вычисления: " + ОписаниеОшибки());
	КонецПопытки;
	Если ТранзакцияАктивна() Тогда
		ОтменитьТранзакцию();
	КонецЕсли;

	Возврат Результат;

КонецФункции

&НаСервереБезКонтекста
Функция Обработчик_lyra_data_exec(ПарамыЗапроса)

	Код = ПолучитьПараметр(ПарамыЗапроса, "code");
	Если Код = Неопределено Тогда
		Возврат Новый Структура("error", "Отсутствует параметр code");
	КонецЕсли;

	УстановитьБезопасныйРежим(Истина);
	
	НачатьТранзакцию();
	Попытка
		Результат = Неопределено;
		Выполнить(Код);
		Если Результат <> Неопределено Тогда
			Результат = Новый Структура("result", ЗначениеДляJSON(Результат));
		Иначе
			Результат = Новый Структура("result", "Выполнено");
		КонецЕсли;
	Исключение
		Результат = Новый Структура("error", "Ошибка выполнения: " + ОписаниеОшибки());
	КонецПопытки;
	Если ТранзакцияАктивна() Тогда
		ОтменитьТранзакцию();
	КонецЕсли;

	Возврат Результат;
	
КонецФункции

&НаСервереБезКонтекста
Функция Обработчик_lyra_nav_resolve(ПарамыЗапроса)

	ТипОбъекта = ПолучитьПараметр(ПарамыЗапроса, "type");
	ИмяОбъекта = ПолучитьПараметр(ПарамыЗапроса, "name");

	Если ТипОбъекта = Неопределено ИЛИ ИмяОбъекта = Неопределено Тогда
		Возврат Новый Структура("error", "Отсутствуют параметры type и name");
	КонецЕсли;

	СсылкаОбъекта = ПолучитьПараметр(ПарамыЗапроса, "ref");

	Попытка
		ПолноеИмя = ТипОбъекта + "." + ИмяОбъекта;

		Если СсылкаОбъекта = Неопределено ИЛИ СсылкаОбъекта = "" Тогда
			Возврат Новый Структура("url,description",
				"e1cib/list/" + ПолноеИмя,
				"Список: " + ПолноеИмя);
		КонецЕсли;

		МенеджерОбъекта = Неопределено;
		Если ТипОбъекта = "Справочник" Тогда
			МенеджерОбъекта = Справочники[ИмяОбъекта];
		ИначеЕсли ТипОбъекта = "Документ" Тогда
			МенеджерОбъекта = Документы[ИмяОбъекта];
		Иначе
			Возврат Новый Структура("url,description",
				"e1cib/data/" + ПолноеИмя + "?ref=" + СсылкаОбъекта,
				ПолноеИмя);
		КонецЕсли;

		Попытка
			Ссылка = МенеджерОбъекта.ПолучитьСсылку(Новый УникальныйИдентификатор(СсылкаОбъекта));
			Если Ссылка.ПолучитьОбъект() = Неопределено Тогда
				Возврат Новый Структура("error", "Объект не найден: " + СсылкаОбъекта);
			КонецЕсли;
			НавСсылка = ПолучитьНавигационнуюСсылку(Ссылка);
		Исключение
			НавСсылка = "e1cib/data/" + ПолноеИмя + "?ref=" + СсылкаОбъекта;
		КонецПопытки;

		Возврат Новый Структура("url,description", НавСсылка, Строка(Ссылка));

	Исключение
		Возврат Новый Структура("error", "Ошибка получения ссылки: " + ОписаниеОшибки());
	КонецПопытки;

КонецФункции

