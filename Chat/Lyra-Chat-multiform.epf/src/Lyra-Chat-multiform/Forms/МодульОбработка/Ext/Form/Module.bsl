Функция Обработчик_lyra_data_read(ПарамыЗапроса)

	ОписаниеСсылки = ПолучитьПараметр(ПарамыЗапроса, "ref");
	Если ОписаниеСсылки = Неопределено Тогда
		Возврат Новый Структура("error", "Отсутствует параметр ref (объект _ref из результата запроса)");
	КонецЕсли;

	Ссылка = Неопределено;
	Если ТипЗнч(ОписаниеСсылки) = Тип("Соответствие") ИЛИ ТипЗнч(ОписаниеСсылки) = Тип("Структура") Тогда
		Ссылка = СсылкаИзJSON(ОписаниеСсылки);
	КонецЕсли;

	Если Ссылка = Неопределено Тогда
		Возврат Новый Структура("error", "Не удалось получить ссылку. Передайте объект _ref: {""_ref"": ""СправочникСсылка.Имя"", ""id"": ""uuid""}");
	КонецЕсли;

	Попытка
		Объект = Ссылка.ПолучитьОбъект();
	Исключение
		Возврат Новый Структура("error", "Ошибка чтения объекта: " + ОписаниеОшибки());
	КонецПопытки;

	Если Объект = Неопределено Тогда
		Возврат Новый Структура("error", "Объект не найден");
	КонецЕсли;

	Результат = Новый Структура;
	Результат.Вставить("_ref", ЗначениеДляJSON(Ссылка));
	Результат.Вставить("title", Строка(Ссылка));

	МетаданныеОбъекта = Ссылка.Метаданные();

	Реквизиты = Новый Структура;
	Попытка
		Для Каждого Рекв Из МетаданныеОбъекта.Реквизиты Цикл
			Попытка
				Реквизиты.Вставить(Рекв.Имя, ЗначениеДляJSON(Объект[Рекв.Имя]));
			Исключение
				Реквизиты.Вставить(Рекв.Имя, Строка(Объект[Рекв.Имя]));
			КонецПопытки;
		КонецЦикла;
	Исключение
	КонецПопытки;
	Результат.Вставить("attributes", Реквизиты);

	Попытка
		ТабЧасти = Новый Структура;
		Для Каждого ТабЧасть Из МетаданныеОбъекта.ТабличныеЧасти Цикл
			СтрокиТЧ = Новый Массив;
			ТЧОбъекта = Объект[ТабЧасть.Имя];
			Лимит = 50;
			Если ТЧОбъекта.Количество() < Лимит Тогда
				Лимит = ТЧОбъекта.Количество();
			КонецЕсли;
			Для Инд = 0 По Лимит - 1 Цикл
				СтрокаТЧ = ТЧОбъекта[Инд];
				Запись = Новый Структура;
				Для Каждого Рекв Из ТабЧасть.Реквизиты Цикл
					Попытка
						Запись.Вставить(Рекв.Имя, ЗначениеДляJSON(СтрокаТЧ[Рекв.Имя]));
					Исключение
						Запись.Вставить(Рекв.Имя, Строка(СтрокаТЧ[Рекв.Имя]));
					КонецПопытки;
				КонецЦикла;
				СтрокиТЧ.Добавить(Запись);
			КонецЦикла;
			ТабЧасти.Вставить(ТабЧасть.Имя, СтрокиТЧ);
		КонецЦикла;
		Результат.Вставить("tabularSections", ТабЧасти);
	Исключение
	КонецПопытки;

	Возврат Результат;

КонецФункции

#КонецОбласти

