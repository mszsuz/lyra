// Модуль общего назначения — клиентские утилиты, не зависящие от фреймворка ЕХТ.
// Доступ из других форм: МодульОбщий = ПолучитьФорму("...Форма.МодульОбщий",, ЭтотОбъект)

#Область ПрограммныйИнтерфейс

#Область ЕХТ_Лог

// Возвращает текст исключения при недопустимом типе или значении параметра.
// Порт ЕХТ_Лог.ТекстИсключенияНедопустимыйПараметр().
//
&НаКлиенте
Функция ЕХТ_Лог_ТекстИсключенияНедопустимыйПараметр(Знач ИмяМодуля, Знач МетодМодуля,
		Знач ИмяПараметра, Знач ЗначениеПараметра,
		Знач П01 = Неопределено, Знач П02 = Неопределено,
		Знач П03 = Неопределено, Знач П04 = Неопределено) Экспорт
	ТекстНедопустимыйПараметр = ЕХТ_Ошибка_ТекстНедопустимыйПараметр(
		ИмяПараметра, ЗначениеПараметра, П01, П02, П03, П04);
	Возврат ЕХТ_Лог_ТекстИсключения(ИмяМодуля, МетодМодуля, ТекстНедопустимыйПараметр);
КонецФункции

&НаКлиенте
Функция ЕХТ_Лог_ТекстИсключения(Знач ИмяМодуля, Знач МетодМодуля, Знач Комментарий,
		Знач П01 = Неопределено, Знач П02 = Неопределено, Знач П03 = Неопределено,
		Знач П04 = Неопределено, Знач П05 = Неопределено, Знач П06 = Неопределено,
		Знач П07 = Неопределено, Знач П08 = Неопределено, Знач П09 = Неопределено)
	Если НЕ СтрЗаканчиваетсяНа(МетодМодуля, "()") Тогда
		МетодМодуля = МетодМодуля + "()";
	КонецЕсли;
	Комментарий = ЕХТ_Строка_Шаблон(Комментарий, П01, П02, П03, П04, П05, П06, П07, П08, П09);
	Возврат ЕХТ_Строка_Шаблон("%1.%2:|%3", ИмяМодуля, МетодМодуля, Комментарий);
КонецФункции

&НаКлиенте
Функция ЕХТ_Ошибка_ТекстНедопустимыйПараметр(Знач ИмяПараметра, Знач ЗначениеПараметра,
		Знач П01 = Неопределено, Знач П02 = Неопределено,
		Знач П03 = Неопределено, Знач П04 = Неопределено)
	ЗначениеПараметраТип = ТипЗнч(ЗначениеПараметра);
	Если ЗначениеПараметраТип = Тип("Тип") Тогда
		Результат = ЕХТ_Строка_Шаблон(
			НСтр("ru = 'Параметр <%1> недопустимого типа: <%2>'"),
			ИмяПараметра, ЗначениеПараметра);
	Иначе
		Результат = ЕХТ_Строка_Шаблон(
			НСтр("ru = 'В параметре <%1> недопустимое значение: <%2> (тип <%3>)'"),
			ИмяПараметра, ЗначениеПараметра, ЗначениеПараметраТип);
	КонецЕсли;
	Если ТипЗнч(П01) = Тип("Строка") Тогда
		Результат = Результат + " - " + ЕХТ_Строка_Шаблон(П01, П02, П03, П04);
	ИначеЕсли ТипЗнч(П01) = Тип("Структура") Тогда
		МассивКлючей = Новый Массив;
		Для Каждого КЗ Из П01 Цикл МассивКлючей.Добавить(КЗ.Ключ) КонецЦикла;
		Результат = Результат + " - ожидаемые типы: " + СтрСоединить(МассивКлючей, ", ");
	КонецЕсли;
	Возврат Результат;
КонецФункции

&НаКлиенте
Функция ЕХТ_Строка_Шаблон(Знач Шаблон, Знач П01 = Неопределено, Знач П02 = Неопределено,
		Знач П03 = Неопределено, Знач П04 = Неопределено, Знач П05 = Неопределено,
		Знач П06 = Неопределено, Знач П07 = Неопределено, Знач П08 = Неопределено,
		Знач П09 = Неопределено, Знач П10 = Неопределено)
	Шаблон = СтрЗаменить(Шаблон, " | ", Символы.ПС);
	Шаблон = СтрЗаменить(Шаблон, " |", Символы.ПС);
	Шаблон = СтрЗаменить(Шаблон, "| ", Символы.ПС);
	Шаблон = СтрЗаменить(Шаблон, "|", Символы.ПС);
	Попытка
		Возврат СтрШаблон(Шаблон, П01, П02, П03, П04, П05, П06, П07, П08, П09, П10);
	Исключение
		Возврат Шаблон;
	КонецПопытки;
КонецФункции

#КонецОбласти

