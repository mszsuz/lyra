#Область ЕХТ_Свойства

// Возвращает структуру со значениями свойств объекта или коллекции.
// Порт ЕХТ_Свойства.вСтруктуру().
//
// Параметры:
//  Объект             - Произвольный - объект из которого нужно получить структуру
//  Свойства           - Строка, Массив, Структура - имена свойств через запятую
//  ИсключаяСвойства   - Строка, Неопределено - исключаемые свойства
//
// Возвращаемое значение:
//  Структура
//
&НаКлиенте
Функция ЕХТ_Свойства_вСтруктуру(Знач Объект, Знач Свойства, Знач ИсключаяСвойства = Неопределено) Экспорт
	СвойстваТип = ТипЗнч(Свойства);
	Если СвойстваТип = Тип("Строка") Тогда
		СтрокаСвойств = Свойства;
	ИначеЕсли ЕХТ_Тип_ЭтоЛюбойМассив(СвойстваТип) Тогда
		СтрокаСвойств = СтрСоединить(Свойства, ",");
	ИначеЕсли ЕХТ_Тип_ЭтоЛюбаяСтруктура(СвойстваТип) Тогда
		МассивКлючей = Новый Массив;
		Для Каждого КЗ Из Свойства Цикл МассивКлючей.Добавить(КЗ.Ключ) КонецЦикла;
		СтрокаСвойств = СтрСоединить(МассивКлючей, ",");
	Иначе
		ВызватьИсключение ЕХТ_Лог_ТекстИсключенияНедопустимыйПараметр("МодульОбщий", "ЕХТ_Свойства_вСтруктуру",
			"Свойства", Свойства);
	КонецЕсли;
	Результат = Новый Структура(СтрокаСвойств);
	Если ИсключаяСвойства <> Неопределено Тогда
		Для Каждого ИмяСвойства Из СтрРазделить(ИсключаяСвойства, ",", Ложь) Цикл
			Результат.Удалить(СокрЛП(ИмяСвойства));
		КонецЦикла;
	КонецЕсли;
	ЗаполнитьЗначенияСвойств(Результат, Объект);
	Возврат Результат;
КонецФункции

// Возвращает значение свойства объекта или коллекции.
// Порт ЕХТ_Свойства.Значение().
//
// Параметры:
//  Объект                - Произвольный - объект из которого нужно получить значение
//  Свойство              - Строка - имя свойства
//  ЗначениеПоУмолчанию   - Произвольный - значение если свойство не найдено (NULL = без дефолта)
//
// Возвращаемое значение:
//  Произвольный
//
&НаКлиенте
Функция ЕХТ_Свойства_Значение(Знач Объект, Знач Свойство, Знач ЗначениеПоУмолчанию = NULL) Экспорт
	Если ЗначениеПоУмолчанию = NULL Тогда
		Возврат ЕХТ_Свойства_вСтруктуру(Объект, Свойство)[Свойство];
	Иначе
		Результат = Неопределено;
		Если НЕ ЕХТ_Свойства_Существует(Объект, Свойство, Результат) Тогда
			Результат = ЗначениеПоУмолчанию;
		КонецЕсли;
		Возврат Результат;
	КонецЕсли;
КонецФункции

&НаКлиенте
Функция ЕХТ_Свойства_Существует(Знач Объект, Знач Свойство, ЗначениеСвойства = Неопределено)
	УникальноеЗначение = "ca956580-1b8a-41ef-a221-1ff94717c33d";
	СтруктураПроверки = Новый Структура(Свойство, УникальноеЗначение);
	Попытка
		ЗаполнитьЗначенияСвойств(СтруктураПроверки, Объект);
	Исключение
		Возврат Ложь;
	КонецПопытки;
	Если СтруктураПроверки[Свойство] <> УникальноеЗначение Тогда
		ЗначениеСвойства = СтруктураПроверки[Свойство];
		Возврат Истина;
	Иначе
		Возврат Ложь;
	КонецЕсли;
КонецФункции

#КонецОбласти

#Область ЕХТ_ЭлементФормы

// Поднимается по родителям элемента до управляемой формы.
// Порт ЕХТ_ЭлементФормы.Форма().
//
// Параметры:
//  Элемент - ЭлементФормы
//
// Возвращаемое значение:
//  УправляемаяФорма
//
&НаКлиенте
Функция ЕХТ_ЭлементФормы_Форма(Знач Элемент) Экспорт
	ТипУправляемаяФорма = ЕХТ_Тип_УправляемаяФорма();
	Результат = Элемент.Родитель;
	Пока ТипЗнч(Результат) <> ТипУправляемаяФорма Цикл Результат = Результат.Родитель КонецЦикла;
	Возврат Результат;
КонецФункции

#КонецОбласти

#Область ЕХТ_Структура

// Получает значение свойства с поддержкой иерархии через точку.
// Порт ЕХТ_Структура.Получить().
//
// Параметры:
//  Источник              - Произвольный - объект или коллекция
//  Свойство              - Строка, Массив - иерархия свойств (через ".")
//  ЗначениеПоУмолчанию   - Произвольный
//
// Возвращаемое значение:
//  Произвольный
//
&НаКлиенте
Функция ЕХТ_Структура_Получить(Знач Источник, Знач Свойство, Знач ЗначениеПоУмолчанию = Неопределено) Экспорт
	СвойствоТип = ТипЗнч(Свойство);
	Если СвойствоТип = Тип("Строка") Тогда
		МассивСвойств = СтрРазделить(Свойство, ".", Ложь);
	ИначеЕсли СвойствоТип = Тип("Массив") Тогда
		МассивСвойств = Свойство;
	Иначе
		ВызватьИсключение ЕХТ_Лог_ТекстИсключенияНедопустимыйПараметр("МодульОбщий", "ЕХТ_Структура_Получить",
			"Свойство", Свойство);
	КонецЕсли;
	ТекущееСвойство = МассивСвойств[0];
	ТекущееЗначение = Неопределено;
	Если НЕ ЕХТ_Свойства_Существует(Источник, ТекущееСвойство, ТекущееЗначение) Тогда
		Результат = ЗначениеПоУмолчанию;
	ИначеЕсли МассивСвойств.Количество() = 1 Тогда
		Результат = ТекущееЗначение;
	Иначе
		МассивСвойств.Удалить(0);
		Результат = ЕХТ_Структура_Получить(ТекущееЗначение, МассивСвойств, ЗначениеПоУмолчанию);
	КонецЕсли;
	Возврат Результат;
КонецФункции

#КонецОбласти

#Область ЕХТ_Значение

// Сериализует 1С-значение в JSON-строку.
// Порт ЕХТ_Значение.вJSON().
// ЗаписьJSON/ЗаписатьJSON — серверные, делегируем через &НаСервереБезКонтекста.
//
&НаКлиенте
Функция ЕХТ_Значение_вJSON(Знач Значение) Экспорт
	Попытка
		Возврат ЗаписатьЗначениеJSON(Значение);
	Исключение
		Возврат ЕХТ_Значение_вJSONСервер(Значение);
	КонецПопытки;
КонецФункции

&НаСервереБезКонтекста
Функция ЕХТ_Значение_вJSONСервер(Знач Значение)
	ЗаписьJSON = Новый ЗаписьJSON;
	ЗаписьJSON.УстановитьСтроку(Новый ПараметрыЗаписиJSON);
	ЗаписатьJSON(ЗаписьJSON, Значение);
	Возврат ЗаписьJSON.Закрыть();
КонецФункции

// Десериализует JSON-строку в 1С-значение.
// Порт ЕХТ_Значение.ИзJSON().
// ЧтениеJSON/ПрочитатьJSON — серверные, делегируем через &НаСервереБезКонтекста.
//
&НаКлиенте
Функция ЕХТ_Значение_ИзJSON(Знач СтрокаJSON) Экспорт
	Возврат ЕХТ_Значение_ИзJSONСервер(СтрокаJSON);
КонецФункции

&НаСервереБезКонтекста
Функция ЕХТ_Значение_ИзJSONСервер(Знач СтрокаJSON)
	ЧтениеJSON = Новый ЧтениеJSON;
	ЧтениеJSON.УстановитьСтроку(СтрокаJSON);
	Возврат ПрочитатьJSON(ЧтениеJSON, Истина);
КонецФункции

