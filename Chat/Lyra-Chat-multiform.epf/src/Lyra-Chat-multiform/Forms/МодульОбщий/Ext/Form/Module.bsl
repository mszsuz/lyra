// Модуль общего назначения — клиентские утилиты, не зависящие от фреймворка ЕХТ.
// Доступ из других форм: МодульОбщий = ПолучитьФорму("...Форма.МодульОбщий",, ЭтотОбъект)

#Область ПрограммныйИнтерфейс

// Создаёт Структуру из пар Ключ-Значение.
// Замена ЕХТ.Структура() без зависимости от фреймворка.
//
// Параметры:
//  К01..К30 - Строка  - ключи структуры (NULL = конец списка)
//  З01..З30 - Произвольный - значения структуры
//
// Возвращаемое значение:
//  Структура
//
&НаКлиенте
Функция ЕХТ_Структура(Знач К01 = NULL, Знач З01 = Неопределено, Знач К02 = NULL, Знач З02 = Неопределено,
					  Знач К03 = NULL, Знач З03 = Неопределено, Знач К04 = NULL, Знач З04 = Неопределено,
					  Знач К05 = NULL, Знач З05 = Неопределено, Знач К06 = NULL, Знач З06 = Неопределено,
					  Знач К07 = NULL, Знач З07 = Неопределено, Знач К08 = NULL, Знач З08 = Неопределено,
					  Знач К09 = NULL, Знач З09 = Неопределено, Знач К10 = NULL, Знач З10 = Неопределено,
					  Знач К11 = NULL, Знач З11 = Неопределено, Знач К12 = NULL, Знач З12 = Неопределено,
					  Знач К13 = NULL, Знач З13 = Неопределено, Знач К14 = NULL, Знач З14 = Неопределено,
					  Знач К15 = NULL, Знач З15 = Неопределено, Знач К16 = NULL, Знач З16 = Неопределено,
					  Знач К17 = NULL, Знач З17 = Неопределено, Знач К18 = NULL, Знач З18 = Неопределено,
					  Знач К19 = NULL, Знач З19 = Неопределено, Знач К20 = NULL, Знач З20 = Неопределено,
					  Знач К21 = NULL, Знач З21 = Неопределено, Знач К22 = NULL, Знач З22 = Неопределено,
					  Знач К23 = NULL, Знач З23 = Неопределено, Знач К24 = NULL, Знач З24 = Неопределено,
					  Знач К25 = NULL, Знач З25 = Неопределено, Знач К26 = NULL, Знач З26 = Неопределено,
					  Знач К27 = NULL, Знач З27 = Неопределено, Знач К28 = NULL, Знач З28 = Неопределено,
					  Знач К29 = NULL, Знач З29 = Неопределено, Знач К30 = NULL, Знач З30 = Неопределено) Экспорт

	Если К01 = NULL Тогда Возврат Новый Структура КонецЕсли;

	Ключи = ЕХТ_Массив(К01, К02, К03, К04, К05, К06, К07, К08, К09, К10,
					   К11, К12, К13, К14, К15, К16, К17, К18, К19, К20,
					   К21, К22, К23, К24, К25, К26, К27, К28, К29, К30);
	Значения = ЕХТ_Массив(З01, З02, З03, З04, З05, З06, З07, З08, З09, З10,
						  З11, З12, З13, З14, З15, З16, З17, З18, З19, З20,
						  З21, З22, З23, З24, З25, З26, З27, З28, З29, З30);

	Результат = Новый Структура;
	Для н = 0 По Ключи.ВГраница() Цикл
		Результат.Вставить(Ключи[н], Значения[н]);
	КонецЦикла;

	Возврат Результат;

КонецФункции

// Создаёт Массив из переданных элементов.
// Замена ЕХТ.Массив() без зависимости от фреймворка.
//
// Параметры:
//  П01..П30 - Произвольный - элементы массива (NULL = конец списка)
//
// Возвращаемое значение:
//  Массив
//
&НаКлиенте
Функция ЕХТ_Массив(Знач П01 = NULL, Знач П02 = NULL, Знач П03 = NULL, Знач П04 = NULL, Знач П05 = NULL,
				   Знач П06 = NULL, Знач П07 = NULL, Знач П08 = NULL, Знач П09 = NULL, Знач П10 = NULL,
				   Знач П11 = NULL, Знач П12 = NULL, Знач П13 = NULL, Знач П14 = NULL, Знач П15 = NULL,
				   Знач П16 = NULL, Знач П17 = NULL, Знач П18 = NULL, Знач П19 = NULL, Знач П20 = NULL,
				   Знач П21 = NULL, Знач П22 = NULL, Знач П23 = NULL, Знач П24 = NULL, Знач П25 = NULL,
				   Знач П26 = NULL, Знач П27 = NULL, Знач П28 = NULL, Знач П29 = NULL, Знач П30 = NULL) Экспорт

	Если П01 = NULL Тогда Возврат Новый Массив КонецЕсли;

	Результат = Новый Массив;
	ВсеПараметры = Новый Структура("П01, П02, П03, П04, П05, П06, П07, П08, П09, П10,
								   |П11, П12, П13, П14, П15, П16, П17, П18, П19, П20,
								   |П21, П22, П23, П24, П25, П26, П27, П28, П29, П30",
								    П01, П02, П03, П04, П05, П06, П07, П08, П09, П10,
								    П11, П12, П13, П14, П15, П16, П17, П18, П19, П20,
								    П21, П22, П23, П24, П25, П26, П27, П28, П29, П30);
	Для Каждого КЗ Из ВсеПараметры Цикл
		Если КЗ.Значение = NULL Тогда Прервать КонецЕсли;
		Результат.Добавить(КЗ.Значение);
	КонецЦикла;

	Возврат Результат;

КонецФункции

