&НаКлиенте
Функция ЕХТ_Тип_УправляемаяФорма() Экспорт
	Возврат Тип("ФормаКлиентскогоПриложения");
КонецФункции

// Возвращает Структуру {ИмяТипа → Тип} по строке с именами типов через запятую.
// Порт ЕХТ_Тип.ОжидаемыеТипы().
//
&НаКлиенте
Функция ЕХТ_Тип_ОжидаемыеТипы(Знач СтрокаОжидаемыеТипы) Экспорт
	Результат = Новый Структура;
	Разделители = "," + " " + Символы.ПС + Символы.ВК + Символы.Таб;
	Для Каждого ИмяТипа Из СтрРазделить(СтрокаОжидаемыеТипы, Разделители, Ложь) Цикл
		Если СтрСравнить(ИмяТипа, "ЛюбойМассив") = 0 Тогда
			Результат.Вставить("Массив",               Тип("Массив"));
			Результат.Вставить("ФиксированныйМассив",  Тип("ФиксированныйМассив"));
		ИначеЕсли СтрСравнить(ИмяТипа, "ЛюбаяСтруктура") = 0 Тогда
			Результат.Вставить("Структура",               Тип("Структура"));
			Результат.Вставить("ФиксированнаяСтруктура",  Тип("ФиксированнаяСтруктура"));
		ИначеЕсли СтрСравнить(ИмяТипа, "ЛюбоеСоответствие") = 0 Тогда
			Результат.Вставить("Соответствие",               Тип("Соответствие"));
			Результат.Вставить("ФиксированноеСоответствие",  Тип("ФиксированноеСоответствие"));
		ИначеЕсли СтрСравнить(ИмяТипа, "ЛюбаяКоллекция") = 0 Тогда
			Результат.Вставить("Массив",                    Тип("Массив"));
			Результат.Вставить("ФиксированныйМассив",       Тип("ФиксированныйМассив"));
			Результат.Вставить("Структура",                 Тип("Структура"));
			Результат.Вставить("ФиксированнаяСтруктура",    Тип("ФиксированнаяСтруктура"));
			Результат.Вставить("Соответствие",              Тип("Соответствие"));
			Результат.Вставить("ФиксированноеСоответствие", Тип("ФиксированноеСоответствие"));
		Иначе
			Результат.Вставить(ИмяТипа, Тип(ИмяТипа));
		КонецЕсли;
	КонецЦикла;
	Возврат Результат;
КонецФункции

// Возвращает ОписаниеТипов для строки заданной длины.
// Порт ЕХТ_Тип.ОписаниеСтрока().
//
&НаКлиенте
Функция ЕХТ_Тип_ОписаниеСтрока(Знач ДлинаСтроки = Неопределено, Знач ДопустимаяДлинаСтроки = Неопределено) Экспорт
	Если ДлинаСтроки = Неопределено Тогда
		ДлинаСтроки = 0;
	КонецЕсли;
	ДопустимаяДлинаСтрокиТип = ТипЗнч(ДопустимаяДлинаСтроки);
	Если ДопустимаяДлинаСтрокиТип = Тип("Неопределено") Тогда
		ДопустимаяДлинаСтроки = ДопустимаяДлина.Переменная;
	ИначеЕсли ДопустимаяДлинаСтрокиТип = Тип("Строка") Тогда
		ДопустимаяДлинаСтроки = ДопустимаяДлина[ДопустимаяДлинаСтроки];
	ИначеЕсли ДопустимаяДлинаСтрокиТип = Тип("ДопустимаяДлина") Тогда
		// Действие не требуется.
	Иначе
		ВызватьИсключение ЕХТ_Лог_ТекстИсключенияНедопустимыйПараметр("МодульОбщий", "ЕХТ_Тип_ОписаниеСтрока",
			"ДопустимаяДлинаСтроки", ДопустимаяДлинаСтроки);
	КонецЕсли;
	Возврат Новый ОписаниеТипов("Строка", , , , Новый КвалификаторыСтроки(ДлинаСтроки, ДопустимаяДлинаСтроки));
КонецФункции

// Возвращает Истина, если тип — любая коллекция (Массив/Структура/Соответствие, вкл. фиксированные).
// Порт ЕХТ_Тип.ЭтоЛюбаяКоллекция().
//
&НаКлиенте
Функция ЕХТ_Тип_ЭтоЛюбаяКоллекция(Знач Тип) Экспорт
	Возврат Тип = Тип("Массив")
		ИЛИ Тип = Тип("ФиксированныйМассив")
		ИЛИ Тип = Тип("Структура")
		ИЛИ Тип = Тип("ФиксированнаяСтруктура")
		ИЛИ Тип = Тип("Соответствие")
		ИЛИ Тип = Тип("ФиксированноеСоответствие");
КонецФункции

// Возвращает Истина, если тип — Массив или ФиксированныйМассив.
