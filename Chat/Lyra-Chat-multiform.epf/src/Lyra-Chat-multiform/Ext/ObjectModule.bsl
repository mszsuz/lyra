
// Модуль объекта обработки Lyra-Chat-multiform.
// Предоставляет общие функции, доступные через РеквизитФормыВЗначение("Объект").

#Область ПрограммныйИнтерфейс

// Возвращает полное имя обработки динамически.
//
// Возвращаемое значение:
//  Строка - Полное имя обработки (например "ВнешняяОбработка.Lyra_Chat_multiform")
//
Функция ПолноеИмя() Экспорт
	Возврат ЭтотОбъект.Метаданные().ПолноеИмя();
КонецФункции

// Возвращает версию обработки из комментария метаданных.
//
// Возвращаемое значение:
//  Строка - Версия (например "26.02.28.1")
//
Функция ПолучитьВерсию() Экспорт
	Возврат ЭтотОбъект.Метаданные().Комментарий;
КонецФункции

// Загружает настройку из ХранилищаОбщихНастроек.
//
// Параметры:
//  Ключ - Строка - Ключ настройки
//
// Возвращаемое значение:
//  Произвольный - Значение настройки или Неопределено
//
Функция НастройкиЗагрузить(Ключ) Экспорт
	Попытка
		Возврат ХранилищеОбщихНастроек.Загрузить(ПолноеИмя(), Ключ);
	Исключение
		Возврат Неопределено;
	КонецПопытки;
КонецФункции

// Сохраняет настройку в ХранилищеОбщихНастроек.
//
// Параметры:
//  Ключ - Строка - Ключ настройки
//  Значение - Произвольный - Значение для сохранения
//
Процедура НастройкиСохранить(Ключ, Значение) Экспорт
	Попытка
		ХранилищеОбщихНастроек.Сохранить(ПолноеИмя(), Ключ, Значение);
	Исключение
	КонецПопытки;
КонецПроцедуры

// Возвращает данные о базе для hello-сообщения Centrifugo.
//
// Возвращаемое значение:
//  Структура - config_name, config_version, config_id, computer, connection_string, base_ids
//
Функция ПолучитьДанныеБазыДляHello() Экспорт

	Результат = Новый Структура;
	Результат.Вставить("config_name", Метаданные.Имя);
	Результат.Вставить("config_version", Метаданные.Версия);
	Результат.Вставить("computer", ИмяКомпьютера());
	Результат.Вставить("connection_string", СтрокаСоединенияИнформационнойБазы());

	// config_id — идентификатор конфигурации (для типовых конфигураций)
	Результат.Вставить("config_id", ПолучитьИдентификаторКонфигурацииMD5());

	// Версия обработки
	Результат.Вставить("epf_version", ЭтотОбъект.Метаданные().Комментарий);

	// base_ids — набор идентификаторов базы для надёжного матчинга на Роутере
	Результат.Вставить("base_ids", ПолучитьИдентификаторыБазы());

	Возврат Результат;

КонецФункции

// Собирает все доступные идентификаторы базы.
// Порядок приоритета: ssl_id → user_id → storage_id → connect_id.
// Каждый метод может не сработать (нет прав, нет БСП, нет пользователей).
// connect_id вычисляется всегда как fallback.
//
// Возвращаемое значение:
//  Структура - ключи: ssl_id, user_id, storage_id, connect_id (заполнены только доступные)
//
Функция ПолучитьИдентификаторыБазы()

	Результат = Новый Структура;

	// 1. ssl_id — Константа.ИдентификаторИнформационнойБазы (БСП)
	Попытка
		УстановитьПривилегированныйРежим(Истина);
		МетаданныеКонстанты = Метаданные.Константы.Найти("ИдентификаторИнформационнойБазы");
		Если МетаданныеКонстанты <> Неопределено Тогда
			ЗначениеКонстанты = Константы["ИдентификаторИнформационнойБазы"].Получить();
			Если ЗначениеЗаполнено(ЗначениеКонстанты) Тогда
				Результат.Вставить("ssl_id", Строка(ЗначениеКонстанты));
			КонецЕсли;
		КонецЕсли;
		УстановитьПривилегированныйРежим(Ложь);
	Исключение
		УстановитьПривилегированныйРежим(Ложь);
	КонецПопытки;

	// 2. user_id — УникальныйИдентификатор текущего пользователя ИБ
	Попытка
		ПользователиИБ = ПользователиИнформационнойБазы.ПолучитьПользователей();
		Если ПользователиИБ.Количество() > 0 Тогда
			ТекущийПользователь = ПользователиИнформационнойБазы.ТекущийПользователь();
			ИдПользователя = ТекущийПользователь.УникальныйИдентификатор;
			Если ЗначениеЗаполнено(ИдПользователя) Тогда
				Результат.Вставить("user_id", Строка(ИдПользователя));
			КонецЕсли;
		КонецЕсли;
	Исключение
		// Нет прав — пропускаем
	КонецПопытки;

	// 3. storage_id — UUID в ХранилищеОбщихНастроек (per-user)
	Попытка
		ИдХранилища = НастройкиЗагрузить("lira_base_id");
		Если НЕ ЗначениеЗаполнено(ИдХранилища) Тогда
			ИдХранилища = Строка(Новый УникальныйИдентификатор);
			НастройкиСохранить("lira_base_id", ИдХранилища);
		КонецЕсли;
		Результат.Вставить("storage_id", ИдХранилища);
	Исключение
		// Нет прав на СохранениеДанныхПользователя — пропускаем
	КонецПопытки;

	// 4. connect_id — хеш от computer + connection_string (всегда доступен)
	Попытка
		КлючСоединения = ИмяКомпьютера() + "|" + СтрокаСоединенияИнформационнойБазы();
		ХешированиеДанных = Новый ХешированиеДанных(ХешФункция.MD5);
		ХешированиеДанных.Добавить(КлючСоединения);
		Результат.Вставить("connect_id",
			НРег(СтрЗаменить(Строка(ХешированиеДанных.ХешСумма), " ", "")));
	Исключение
		// Маловероятно, но подстрахуемся
	КонецПопытки;

	Возврат Результат;

КонецФункции

// Возвращает идентификатор конфигурации.
// Берёт платформенный ПолучитьИдентификаторКонфигурации(), убирает последнюю строку
// (она уникальна для каждой базы), хеширует MD5 и оформляет как UUID.
// У типовых конфигураций на поддержке одной версии результат совпадает.
// У доработанных или снятых с поддержки — свой уникальный.
//
// Возвращаемое значение:
//  Строка - UUID-подобный идентификатор (32 hex + дефисы), или "" при ошибке.
//
Функция ПолучитьИдентификаторКонфигурацииMD5() Экспорт

	Попытка
		// Требуются права администратора
		УстановитьПривилегированныйРежим(Истина);

		// Платформенный идентификатор — многострочная строка.
		// Последняя строка уникальна для каждой базы — убираем её.
		МассивСтрок = СтрРазделить(ПолучитьИдентификаторКонфигурации(), Символы.ПС);

		// Убрать пустые строки в конце
		Пока МассивСтрок.Количество() > 0
			И НЕ ЗначениеЗаполнено(МассивСтрок[МассивСтрок.ВГраница()]) Цикл
			МассивСтрок.Удалить(МассивСтрок.ВГраница());
		КонецЦикла;

		Если МассивСтрок.Количество() = 0 Тогда
			Возврат "";
		КонецЕсли;

		// Удалить последнюю значащую строку
		МассивСтрок.Удалить(МассивСтрок.ВГраница());

		// MD5 от склеенного остатка
		ХешированиеДанных = Новый ХешированиеДанных(ХешФункция.MD5);
		ХешированиеДанных.Добавить(СтрСоединить(МассивСтрок, ""));
		ХешСумма = НРег(СтрЗаменить(Строка(ХешированиеДанных.ХешСумма), " ", ""));

		УстановитьПривилегированныйРежим(Ложь);

		// Оформить как UUID: 8-4-4-4-12, первый символ "2"
		Возврат "2" + Сред(ХешСумма, 2, 7)
			+ "-" + Сред(ХешСумма, 9, 4)
			+ "-" + Сред(ХешСумма, 13, 4)
			+ "-" + Сред(ХешСумма, 17, 4)
			+ "-" + Сред(ХешСумма, 21, 12);
	Исключение
		УстановитьПривилегированныйРежим(Ложь);
		Возврат "";
	КонецПопытки;

КонецФункции

#КонецОбласти

#Область ЕХТ_Лог

// Возвращает текст исключения при недопустимом типе или значении параметра.
// Порт ЕХТ_Лог.ТекстИсключенияНедопустимыйПараметр().
//
// Параметры:
//  ИмяМодуля          - Строка
//  МетодМодуля        - Строка
//  ИмяПараметра       - Строка
//  ЗначениеПараметра  - Произвольный - фактическое значение или его тип
//  П01..П04           - Строка, Неопределено - уточняющий комментарий
//
// Возвращаемое значение:
//  Строка - текст для ВызватьИсключение
//
Функция ЕХТ_Лог_ТекстИсключенияНедопустимыйПараметр(Знач ИмяМодуля, Знач МетодМодуля,
		Знач ИмяПараметра, Знач ЗначениеПараметра,
		Знач П01 = Неопределено, Знач П02 = Неопределено,
		Знач П03 = Неопределено, Знач П04 = Неопределено) Экспорт
	ТекстНедопустимыйПараметр = ЕХТ_Ошибка_ТекстНедопустимыйПараметр(
		ИмяПараметра, ЗначениеПараметра, П01, П02, П03, П04);
	Возврат ЕХТ_Лог_ТекстИсключения(ИмяМодуля, МетодМодуля, ТекстНедопустимыйПараметр);
КонецФункции

// Форматирует строку "ИмяМодуля.МетодМодуля():\nКомментарий".
// Порт ЕХТ_Лог.ТекстИсключения().
//
Функция ЕХТ_Лог_ТекстИсключения(Знач ИмяМодуля, Знач МетодМодуля, Знач Комментарий,
		Знач П01 = Неопределено, Знач П02 = Неопределено, Знач П03 = Неопределено,
		Знач П04 = Неопределено, Знач П05 = Неопределено, Знач П06 = Неопределено,
		Знач П07 = Неопределено, Знач П08 = Неопределено, Знач П09 = Неопределено)
	Если НЕ СтрЗаканчиваетсяНа(МетодМодуля, "()") Тогда
		МетодМодуля = МетодМодуля + "()";
	КонецЕсли;
	Комментарий = ЕХТ_Строка_Шаблон(Комментарий, П01, П02, П03, П04, П05, П06, П07, П08, П09);
	Возврат ЕХТ_Строка_Шаблон("%1.%2:|%3", ИмяМодуля, МетодМодуля, Комментарий);
КонецФункции

// Формирует текст "Параметр <X> недопустимого типа/значения...".
// Порт ЕХТ_Ошибка.ТекстНедопустимыйПараметр().
//
Функция ЕХТ_Ошибка_ТекстНедопустимыйПараметр(Знач ИмяПараметра, Знач ЗначениеПараметра,
		Знач П01 = Неопределено, Знач П02 = Неопределено,
		Знач П03 = Неопределено, Знач П04 = Неопределено)
	ЗначениеПараметраТип = ТипЗнч(ЗначениеПараметра);
	Если ЗначениеПараметраТип = Тип("Тип") Тогда
		Результат = ЕХТ_Строка_Шаблон(
			НСтр("ru = 'Параметр <%1> недопустимого типа: <%2>'"),
			ИмяПараметра, ЗначениеПараметра);
	Иначе
		Результат = ЕХТ_Строка_Шаблон(
			НСтр("ru = 'В параметре <%1> недопустимое значение: <%2> (тип <%3>)'"),
			ИмяПараметра, ЗначениеПараметра, ЗначениеПараметраТип);
	КонецЕсли;
	Если ТипЗнч(П01) = Тип("Строка") Тогда
		Результат = Результат + " - " + ЕХТ_Строка_Шаблон(П01, П02, П03, П04);
	ИначеЕсли ТипЗнч(П01) = Тип("Структура") Тогда
		МассивКлючей = Новый Массив;
		Для Каждого КЗ Из П01 Цикл МассивКлючей.Добавить(КЗ.Ключ) КонецЦикла;
		Результат = Результат + " - ожидаемые типы: " + СтрСоединить(МассивКлючей, ", ");
	КонецЕсли;
	Возврат Результат;
КонецФункции

// Форматирует строку-шаблон, заменяя | на переносы строк и %N на параметры.
// Порт ЕХТ_Строка.Шаблон() — не бросает исключения при некорректном шаблоне.
//
Функция ЕХТ_Строка_Шаблон(Знач Шаблон, Знач П01 = Неопределено, Знач П02 = Неопределено,
		Знач П03 = Неопределено, Знач П04 = Неопределено, Знач П05 = Неопределено,
		Знач П06 = Неопределено, Знач П07 = Неопределено, Знач П08 = Неопределено,
		Знач П09 = Неопределено, Знач П10 = Неопределено)
	Шаблон = СтрЗаменить(Шаблон, " | ", Символы.ПС);
	Шаблон = СтрЗаменить(Шаблон, " |", Символы.ПС);
	Шаблон = СтрЗаменить(Шаблон, "| ", Символы.ПС);
	Шаблон = СтрЗаменить(Шаблон, "|", Символы.ПС);
	Попытка
		Возврат СтрШаблон(Шаблон, П01, П02, П03, П04, П05, П06, П07, П08, П09, П10);
	Исключение
		Возврат Шаблон;
	КонецПопытки;
КонецФункции

#КонецОбласти

#Область ЕХТ_Тип

// Возвращает тип УправляемаяФорма (ФормаКлиентскогоПриложения).
// Порт ЕХТ_Тип.УправляемаяФорма().
//
Функция ЕХТ_Тип_УправляемаяФорма() Экспорт
	Возврат Тип("ФормаКлиентскогоПриложения");
КонецФункции

// Возвращает Структуру {ИмяТипа → Тип} по строке с именами типов через запятую.
// Псевдонимы: "ЛюбойМассив", "ЛюбаяСтруктура", "ЛюбоеСоответствие", "ЛюбаяКоллекция" разворачиваются в пары.
// Порт ЕХТ_Тип.ОжидаемыеТипы().
//
Функция ЕХТ_Тип_ОжидаемыеТипы(Знач СтрокаОжидаемыеТипы) Экспорт
	Результат = Новый Структура;
	Разделители = "," + " " + Символы.ПС + Символы.ВК + Символы.Таб;
	Для Каждого ИмяТипа Из СтрРазделить(СтрокаОжидаемыеТипы, Разделители, Ложь) Цикл
		Если СтрСравнить(ИмяТипа, "ЛюбойМассив") = 0 Тогда
			Результат.Вставить("Массив",               Тип("Массив"));
			Результат.Вставить("ФиксированныйМассив",  Тип("ФиксированныйМассив"));
		ИначеЕсли СтрСравнить(ИмяТипа, "ЛюбаяСтруктура") = 0 Тогда
			Результат.Вставить("Структура",               Тип("Структура"));
			Результат.Вставить("ФиксированнаяСтруктура",  Тип("ФиксированнаяСтруктура"));
		ИначеЕсли СтрСравнить(ИмяТипа, "ЛюбоеСоответствие") = 0 Тогда
			Результат.Вставить("Соответствие",               Тип("Соответствие"));
			Результат.Вставить("ФиксированноеСоответствие",  Тип("ФиксированноеСоответствие"));
		ИначеЕсли СтрСравнить(ИмяТипа, "ЛюбаяКоллекция") = 0 Тогда
			Результат.Вставить("Массив",                    Тип("Массив"));
			Результат.Вставить("ФиксированныйМассив",       Тип("ФиксированныйМассив"));
			Результат.Вставить("Структура",                 Тип("Структура"));
			Результат.Вставить("ФиксированнаяСтруктура",    Тип("ФиксированнаяСтруктура"));
			Результат.Вставить("Соответствие",              Тип("Соответствие"));
			Результат.Вставить("ФиксированноеСоответствие", Тип("ФиксированноеСоответствие"));
		Иначе
			Результат.Вставить(ИмяТипа, Тип(ИмяТипа));
		КонецЕсли;
	КонецЦикла;
	Возврат Результат;
КонецФункции

// Возвращает ОписаниеТипов для строки заданной длины.
// Порт ЕХТ_Тип.ОписаниеСтрока().
//
Функция ЕХТ_Тип_ОписаниеСтрока(Знач ДлинаСтроки = Неопределено, Знач ДопустимаяДлинаСтроки = Неопределено) Экспорт
	Если ДлинаСтроки = Неопределено Тогда
		ДлинаСтроки = 0;
	КонецЕсли;
	ДопустимаяДлинаСтрокиТип = ТипЗнч(ДопустимаяДлинаСтроки);
	Если ДопустимаяДлинаСтрокиТип = Тип("Неопределено") Тогда
		ДопустимаяДлинаСтроки = ДопустимаяДлина.Переменная;
	ИначеЕсли ДопустимаяДлинаСтрокиТип = Тип("Строка") Тогда
		ДопустимаяДлинаСтроки = ДопустимаяДлина[ДопустимаяДлинаСтроки];
	ИначеЕсли ДопустимаяДлинаСтрокиТип = Тип("ДопустимаяДлина") Тогда
		// Действие не требуется.
	Иначе
		ВызватьИсключение ЕХТ_Лог_ТекстИсключенияНедопустимыйПараметр(ПолноеИмя(), "ЕХТ_Тип_ОписаниеСтрока",
			"ДопустимаяДлинаСтроки", ДопустимаяДлинаСтроки);
	КонецЕсли;
	Возврат Новый ОписаниеТипов("Строка", , , , Новый КвалификаторыСтроки(ДлинаСтроки, ДопустимаяДлинаСтроки));
КонецФункции

// Возвращает Истина, если тип — любая коллекция (Массив/Структура/Соответствие, вкл. фиксированные).
// Порт ЕХТ_Тип.ЭтоЛюбаяКоллекция().
//
Функция ЕХТ_Тип_ЭтоЛюбаяКоллекция(Знач Тип) Экспорт
	Возврат Тип = Тип("Массив")
		ИЛИ Тип = Тип("ФиксированныйМассив")
		ИЛИ Тип = Тип("Структура")
		ИЛИ Тип = Тип("ФиксированнаяСтруктура")
		ИЛИ Тип = Тип("Соответствие")
		ИЛИ Тип = Тип("ФиксированноеСоответствие");
КонецФункции

// Возвращает Истина, если тип — Массив или ФиксированныйМассив.
// Порт ЕХТ_Тип.ЭтоЛюбойМассив().
//
Функция ЕХТ_Тип_ЭтоЛюбойМассив(Знач Тип)
	Возврат Тип = Тип("Массив") ИЛИ Тип = Тип("ФиксированныйМассив");
КонецФункции

// Возвращает Истина, если тип — Структура или ФиксированнаяСтруктура.
// Порт ЕХТ_Тип.ЭтоЛюбаяСтруктура().
//
Функция ЕХТ_Тип_ЭтоЛюбаяСтруктура(Знач Тип)
	Возврат Тип = Тип("Структура") ИЛИ Тип = Тип("ФиксированнаяСтруктура");
КонецФункции

#КонецОбласти

#Область ЕХТ_Свойства

// Возвращает структуру со значениями свойств объекта или коллекции.
// Порт ЕХТ_Свойства.вСтруктуру().
//
// Параметры:
//  Объект             - Произвольный - объект из которого нужно получить структуру
//  Свойства           - Строка, Массив, Структура - имена свойств через запятую
//  ИсключаяСвойства   - Строка, Неопределено - исключаемые свойства
//
// Возвращаемое значение:
//  Структура
//
Функция ЕХТ_Свойства_вСтруктуру(Знач Объект, Знач Свойства, Знач ИсключаяСвойства = Неопределено) Экспорт
	СвойстваТип = ТипЗнч(Свойства);
	Если СвойстваТип = Тип("Строка") Тогда
		СтрокаСвойств = Свойства;
	ИначеЕсли ЕХТ_Тип_ЭтоЛюбойМассив(СвойстваТип) Тогда
		СтрокаСвойств = СтрСоединить(Свойства, ",");
	ИначеЕсли ЕХТ_Тип_ЭтоЛюбаяСтруктура(СвойстваТип) Тогда
		МассивКлючей = Новый Массив;
		Для Каждого КЗ Из Свойства Цикл МассивКлючей.Добавить(КЗ.Ключ) КонецЦикла;
		СтрокаСвойств = СтрСоединить(МассивКлючей, ",");
	Иначе
		ВызватьИсключение ЕХТ_Лог_ТекстИсключенияНедопустимыйПараметр(ПолноеИмя(), "ЕХТ_Свойства_вСтруктуру",
			"Свойства", Свойства);
	КонецЕсли;
	Результат = Новый Структура(СтрокаСвойств);
	Если ИсключаяСвойства <> Неопределено Тогда
		Для Каждого ИмяСвойства Из СтрРазделить(ИсключаяСвойства, ",", Ложь) Цикл
			Результат.Удалить(СокрЛП(ИмяСвойства));
		КонецЦикла;
	КонецЕсли;
	ЗаполнитьЗначенияСвойств(Результат, Объект);
	Возврат Результат;
КонецФункции

#КонецОбласти

#Область ЕХТ_Форма

// Возвращает Истина, если реквизит с заданным путём существует в форме.
// Порт ЕХТ_Форма.РеквизитСуществует().
//
Функция ЕХТ_Форма_РеквизитСуществует(Знач Форма, Знач ПутьКДанным) Экспорт
	Если ПустаяСтрока(ПутьКДанным) Тогда
		Возврат Ложь;
	КонецЕсли;
	Родитель = Форма;
	Для Каждого ЧастьПути Из СтрРазделить(ПутьКДанным, ".") Цикл
		Родитель = ЕХТ_Свойства_вСтруктуру(Родитель, ЧастьПути)[ЧастьПути];
		Если Родитель = Неопределено Тогда
			Возврат Ложь;
		КонецЕсли;
	КонецЦикла;
	Возврат Истина;
КонецФункции

// Добавляет реквизиты в форму через ИзменитьРеквизиты().
// Порт ЕХТ_Форма.ДобавитьРеквизиты().
//
Процедура ЕХТ_Форма_ДобавитьРеквизиты(Форма, Знач Реквизиты) Экспорт
	МассивРеквизитов = Новый Массив;
	Если ТипЗнч(Реквизиты) = Тип("РеквизитФормы") Тогда
		МассивРеквизитов.Добавить(Реквизиты);
	ИначеЕсли ТипЗнч(Реквизиты) = Тип("Массив") Тогда
		Для Каждого Реквизит Из Реквизиты Цикл МассивРеквизитов.Добавить(Реквизит) КонецЦикла;
	КонецЕсли;
	Если МассивРеквизитов.Количество() > 0 Тогда
		Форма.ИзменитьРеквизиты(МассивРеквизитов);
	КонецЕсли;
КонецПроцедуры

// Добавляет ПолеФормы/ПолеHTMLДокумента в форму.
// Порт ЕХТ_Форма.ДобавитьПолеФормыПолеHTMLДокумента().
//
// Параметры:
//  Форма          - УправляемаяФорма
//  ИмяРеквизита   - Строка - имя реквизита и создаваемого элемента
//
// Возвращаемое значение:
//  ЭлементФормы - добавленный элемент
//
Функция ЕХТ_Форма_ДобавитьПолеФормыПолеHTMLДокумента(Форма, Знач ИмяРеквизита) Экспорт
	Элемент = Форма.Элементы.Добавить(ИмяРеквизита, Тип("ПолеФормы"));
	Элемент.Вид = ВидПоляФормы.ПолеHTMLДокумента;
	Элемент.ПутьКДанным = ИмяРеквизита;
	Возврат Элемент;
КонецФункции

#КонецОбласти

