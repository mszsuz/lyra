#Область ОбработчикиСобытийФормы

&НаСервере
Процедура ПриСозданииНаСервере(Отказ, СтандартнаяОбработка)

	ОбъектОбработки = РеквизитФормыВЗначение("Объект");
	ДвоичныеДанныеПриложения = ОбъектОбработки.ПолучитьМакет("ДвоичныеДанныеПриложения");

	Чат = ЕХТ_Чат_ПриСозданииНаСервере(ЭтотОбъект, Отказ, СтандартнаяОбработка);
	Чат.ЕХТ_Чат_Инициализация(ЭтотОбъект, ЕХТ.Структура(
		"Элемент", 					ЭтотОбъект.Элементы.Чат1,
		"ДвоичныеДанныеПриложения", ДвоичныеДанныеПриложения));

КонецПроцедуры

&НаКлиенте
Процедура ПриОткрытии(Отказ)
	// Bridge запускается вручную (НачатьЗапускПриложения не работает в веб-клиенте).
	// Только подключаемся по WebSocket с задержкой (ждём загрузку HTML чата).
	ПодключитьОбработчикОжидания("ПодключитьсяКBridge", 2, Истина);
КонецПроцедуры

&НаКлиенте
Процедура ПередЗакрытием(Отказ, ЗавершениеРаботы, ТекстПредупреждения, СтандартнаяОбработка)
	// Автоматически отключаемся от bridge при закрытии формы
	ОтключитьсяОтBridge();
КонецПроцедуры

#КонецОбласти

#Область ОбработчикиСобытийЭлементовФормы

&НаКлиенте
Процедура Подключаемый_ПриНажатии(Элемент, ДанныеСобытия, СтандартнаяОбработка)
	ЕХТ_Чат_СобытиеПриНажатии(Элемент, ДанныеСобытия, СтандартнаяОбработка);
КонецПроцедуры

#КонецОбласти

#Область ОбработчикиКомандФормы

&НаКлиенте
Процедура КомандаОтправитьСообщение(Команда)

	Текст = СокрЛП(ЭтотОбъект.ТекстСообщения);
	Если ПустаяСтрока(Текст) Тогда
		Возврат;
	КонецЕсли;

	// Добавляем сообщение пользователя в чат через стандартный callback-цикл:
	// addMessageFromV8() → JS вызывает AddMessage → ЕХТ_Чат_ПриДобавленииСообщения берёт ТекстСообщения
	Приложение(ЭтотОбъект.Элементы.Чат1).addMessageFromV8();

	// Очищаем поле ввода
	ЭтотОбъект.ТекстСообщения = "";

	// Отправляем в Лиру через WebSocket
	ОтправитьВClaude(Текст);

КонецПроцедуры

&НаКлиенте
Процедура КомандаЗагрузитьСообщения(Команда)
	ЕХТ_Чат_ЗагрузитьСообщения(ЭтотОбъект.Элементы.Чат1);
КонецПроцедуры

&НаКлиенте
Процедура КомандаДобавитьСообщение(Команда)
	ЕХТ_Чат_ДобавитьСообщение(ЭтотОбъект.Элементы.Чат1);
КонецПроцедуры

&НаКлиенте
Процедура КомандаОчиститьЧат(Команда)
	ЕХТ_Чат_Очистить(ЭтотОбъект.Элементы.Чат1);
КонецПроцедуры

// Настройки

&НаКлиенте
Процедура Чат1АвтосверткаПриИзменении(Элемент)

	Настройки = ЕХТ_Чат_ПолучитьНастройки(ЭтотОбъект.Элементы.Чат1);
	Настройки.Сообщения.Автосвертка = ЭтотОбъект.Чат1Автосвертка;
	ЕХТ_Чат_УстановитьНастройки(ЭтотОбъект.Элементы.Чат1, Настройки);

КонецПроцедуры

&НаКлиенте
Процедура Чат1ТемнаяТемаПриИзменении(Элемент)

	Если ЭтотОбъект.Чат1ТемнаяТема Тогда
		НоваяТема = ЕХТ_Чат_ТемнаяТемаПоУмолчанию();
	Иначе
		НоваяТема = ЕХТ_Чат_СветлаяТемаПоУмолчанию();
	КонецЕсли;
	ЕХТ_Чат_УстановитьТему(ЭтотОбъект.Элементы.Чат1, НоваяТема);

КонецПроцедуры

&НаКлиенте
Процедура Чат1АватарыПриИзменении(Элемент)

	Настройки = ЕХТ_Чат_ПолучитьНастройки(ЭтотОбъект.Элементы.Чат1);
	Настройки.Аватары.Видимость = ЭтотОбъект.Чат1Аватары;
	ЕХТ_Чат_УстановитьНастройки(ЭтотОбъект.Элементы.Чат1, Настройки);

КонецПроцедуры

#КонецОбласти

#Область Bridge

// Bridge (bridge.js) запускается вручную ДО открытия формы.
// Команда запуска:  node bridge.js [--port 3003]
// Протокол: session → chat → stream_event/assistant → result
// Bridge спавнит Claude Code CLI и проксирует WebSocket ↔ stdin/stdout.

&НаКлиенте
Процедура ПодключитьсяКBridge() Экспорт

	КлючСоединения = "claude-bridge";

	// Закрываем старое соединение если есть
	Попытка
		СтароеСоединение = WebSocketКлиентСоединения.ПолучитьСоединение(КлючСоединения);
		Если СтароеСоединение <> Неопределено Тогда
			СтароеСоединение.Закрыть();
		КонецЕсли;
	Исключение
	КонецПопытки;

	ОбработчикиСокета = Новый ОбработчикиWebSocketКлиентСоединения;
	ОбработчикиСокета.Модуль = ЭтотОбъект;
	ОбработчикиСокета.ОбработчикОткрытияСоединения = "WS_ПриОткрытии";
	ОбработчикиСокета.ОбработчикЗакрытияСоединения = "WS_ПриЗакрытии";
	ОбработчикиСокета.ОбработчикПолученияСообщения = "WS_ПриПолученииСообщения";
	ОбработчикиСокета.ОбработчикОшибки = "WS_ПриОшибке";

	// URL с переподключением к существующей сессии (если есть)
	АдресBridge = "ws://localhost:3003";
	Если ЗначениеЗаполнено(СессияИД) Тогда
		АдресBridge = АдресBridge + "?session=" + СессияИД;
	КонецЕсли;

	Попытка
		WebSocketКлиентСоединения.ОткрытьСоединение(КлючСоединения, АдресBridge, ОбработчикиСокета);
	Исключение
		ДобавитьСообщениеВЧат("Не удалось подключиться к Лира Bridge: " + ОписаниеОшибки(), "Ошибка");
	КонецПопытки;

КонецПроцедуры

&НаКлиенте
Процедура ОтключитьсяОтBridge()

	Попытка
		Соединение = WebSocketКлиентСоединения.ПолучитьСоединение("claude-bridge");
		Если Соединение <> Неопределено Тогда
			Соединение.Закрыть();
		КонецЕсли;
	Исключение
	КонецПопытки;

КонецПроцедуры

// Отправка текста пользователя в Bridge.
// Формат: {"type":"chat","content":"текст"}
// Bridge конвертирует в stdin Claude: {"type":"user","message":{"role":"user","content":"текст"}}
//
&НаКлиенте
Процедура ОтправитьВClaude(Текст)

	Если Занят = Истина Тогда
		ДобавитьСообщениеВЧат("Подождите, обрабатываю предыдущий запрос.", "Предупреждение");
		Возврат;
	КонецЕсли;

	Соединение = WebSocketКлиентСоединения.ПолучитьСоединение("claude-bridge");
	Если Соединение = Неопределено Тогда
		ДобавитьСообщениеВЧат("Нет соединения с Лира. Нажмите ""Подключиться"".", "Предупреждение");
		Возврат;
	КонецЕсли;

	// Формируем JSON: {"type":"chat","content":"..."}
	СтрокаJSON = "{""type"":""chat"",""content"":""" + ЭкранироватьJSON(Текст) + """}";
	Соединение.ОтправитьСообщение(СтрокаJSON);

	// Создаём пустое сообщение от ассистента для накопления дельт стриминга
	ТекущееСообщениеТекст = "";
	Занят = Истина;

КонецПроцедуры

#КонецОбласти

#Область ОбработчикиWebSocket

&НаКлиенте
Процедура WS_ПриОткрытии(Соединение) Экспорт
	// Подключение установлено. Ждём session от bridge, затем Claude будет запущен.
	Занят = Ложь;
КонецПроцедуры

&НаКлиенте
Процедура WS_ПриЗакрытии(Соединение, КодЗакрытия) Экспорт
	ДобавитьСообщениеВЧат("Соединение с Лирой закрыто (код " + КодЗакрытия + ")", "Информация");
	Занят = Ложь;
КонецПроцедуры

&НаКлиенте
Процедура WS_ПриОшибке(Соединение, КодОшибки, Описание) Экспорт
	ДобавитьСообщениеВЧат("Ошибка WebSocket: " + КодОшибки + " — " + Описание, "Ошибка");
	Занят = Ложь;
КонецПроцедуры

&НаКлиенте
Процедура WS_ПриПолученииСообщения(Соединение, Сообщение) Экспорт

	// ВАЖНО: НЕ использовать имя ТекстСообщения — это реквизит формы!
	ТипСообщенияWS = ТипЗнч(Сообщение);
	ПолученныйТекст = "";
	Если ТипСообщенияWS = Тип("Строка") Тогда
		ПолученныйТекст = Сообщение;
	ИначеЕсли ТипСообщенияWS = Тип("ДвоичныеДанные") Тогда
		ПолученныйТекст = ПолучитьСтрокуИзДвоичныхДанных(Сообщение);
	Иначе
		Возврат;
	КонецЕсли;

	// Каждое WS-сообщение = один JSON объект (NDJSON от Claude stdout)
	ОбработатьОтветBridge(Соединение, ПолученныйТекст);

КонецПроцедуры

#КонецОбласти

#Область ОбработкаОтветовClaude

// Обработка одного JSON-сообщения от Bridge.
// Типы: session, system, stream_event, assistant, result, error, mcp_request, claude_exit.
//
// Строковый парсинг через СтрНайти — потому что ЕХТ_Значение.ИзJSON()
// парсит в Структуру, а ключи с дефисами (session_id и т.п.) невалидны для имён свойств.
//
&НаКлиенте
Процедура ОбработатьОтветBridge(Соединение, СтрокаJSON)

	ТипСобытия = ИзвлечьЗначениеJSON(СтрокаJSON, "type");

	// ── session: bridge отправляет sessionId при подключении ──
	Если ТипСобытия = "session" Тогда
		СессияИД = ИзвлечьЗначениеJSON(СтрокаJSON, "sessionId");
		ДобавитьСообщениеВЧат("Подключено к Лире (сессия " + Лев(СессияИД, 8) + "...)", "Информация");

	// ── system: Claude Code CLI инициализирован ──
	ИначеЕсли ТипСобытия = "system" Тогда
		// Claude CLI запущен и готов принимать сообщения
		// Можно показать session_id: ИзвлечьЗначениеJSON(СтрокаJSON, "session_id")

	// ── stream_event: дельта текста (стриминг по буквам) ──
	ИначеЕсли ТипСобытия = "stream_event" Тогда
		// Формат: {"type":"stream_event","event":{"type":"content_block_delta","delta":{"text":"фрагмент"}}}
		ТекстДельты = ИзвлечьТекстДельты(СтрокаJSON);
		Если НЕ ПустаяСтрока(ТекстДельты) Тогда
			ТекущееСообщениеТекст = ТекущееСообщениеТекст + ТекстДельты;
			// TODO: стриминг в чат (обновление последнего пузыря вместо создания нового).
			// Пока только накапливаем текст — финальный результат покажем по "result".
		КонецЕсли;

	// ── result: финальный ответ ──
	ИначеЕсли ТипСобытия = "result" Тогда
		// Заменяем накопленные дельты полным текстом из result
		// ИзвлечьЗначениеJSON уже декодирует JSON-экранирование
		ПолныйТекст = ИзвлечьЗначениеJSON(СтрокаJSON, "result");
		Если НЕ ПустаяСтрока(ПолныйТекст) Тогда
			ДобавитьСообщениеВЧат(ПолныйТекст);
		ИначеЕсли НЕ ПустаяСтрока(ТекущееСообщениеТекст) Тогда
			// result пустой — показываем накопленный текст из assistant/дельт
			ДобавитьСообщениеВЧат(ТекущееСообщениеТекст);
		КонецЕсли;
		ТекущееСообщениеТекст = "";
		Занят = Ложь;

	// ── error: busy rejection или ошибка агента ──
	ИначеЕсли ТипСобытия = "error" Тогда
		ПричинаОшибки = ИзвлечьЗначениеJSON(СтрокаJSON, "reason");
		ТекстОшибки = ИзвлечьЗначениеJSON(СтрокаJSON, "message");
		Если ПустаяСтрока(ТекстОшибки) Тогда
			ТекстОшибки = "Неизвестная ошибка";
		КонецЕсли;
		// ИзвлечьЗначениеJSON уже декодирует JSON-экранирование
		Если ПричинаОшибки = "busy" Тогда
			ДобавитьСообщениеВЧат(ТекстОшибки, "Предупреждение");
		Иначе
			// agent_error или другое — можно повторить запрос
			ДобавитьСообщениеВЧат(ТекстОшибки, "Ошибка");
			Занят = Ложь;
		КонецЕсли;

	// ── assistant: полное сообщение от Claude (с --include-partial-messages) ──
	ИначеЕсли ТипСобытия = "assistant" Тогда
		// Формат: {"type":"assistant","message":{"content":[{"type":"text","text":"..."},...]}}
		// Извлекаем текст из content[0].text — обновляем накопленное сообщение
		ТекстОтвета = ИзвлечьТекстИзAssistant(СтрокаJSON);
		Если НЕ ПустаяСтрока(ТекстОтвета) Тогда
			ТекущееСообщениеТекст = ТекстОтвета;
			// НЕ показываем здесь — покажем по "result", иначе будет дубль
		КонецЕсли;

	// ── mcp_request: bridge просит выполнить инструмент в 1С ──
	ИначеЕсли ТипСобытия = "mcp_request" Тогда
		ОбработатьMCPЗапрос(Соединение, СтрокаJSON);

	// ── claude_exit: процесс Claude завершился ──
	ИначеЕсли ТипСобытия = "claude_exit" Тогда
		КодЗавершения = ИзвлечьЗначениеJSON(СтрокаJSON, "code");
		Если КодЗавершения <> "0" И НЕ ПустаяСтрока(КодЗавершения) Тогда
			ДобавитьСообщениеВЧат("Claude завершился с кодом " + КодЗавершения, "Предупреждение");
		КонецЕсли;
		Занят = Ложь;

	КонецЕсли;

КонецПроцедуры

// Извлекает текст дельты из stream_event.
// JSON: {"type":"stream_event","event":{"type":"content_block_delta","delta":{"text":"фрагмент"}}}
// Ищем "text":" внутри "delta" и извлекаем значение.
//
&НаКлиенте
Функция ИзвлечьТекстДельты(СтрокаJSON)

	// Ищем маркер "delta":{  внутри JSON
	МаркерДельта = """delta"":{";
	ПозицияДельта = СтрНайти(СтрокаJSON, МаркерДельта);
	Если ПозицияДельта = 0 Тогда
		// Пробуем с пробелом
		МаркерДельта = """delta"": {";
		ПозицияДельта = СтрНайти(СтрокаJSON, МаркерДельта);
		Если ПозицияДельта = 0 Тогда
			Возврат "";
		КонецЕсли;
	КонецЕсли;

	// Ищем "text":"..." после "delta"
	ПозицияНачала = ПозицияДельта + СтрДлина(МаркерДельта);
	Хвост = Сред(СтрокаJSON, ПозицияНачала);

	// Извлекаем значение text из хвоста
	МаркерТекст = """text"":""";
	ПозицияТекст = СтрНайти(Хвост, МаркерТекст);
	Если ПозицияТекст = 0 Тогда
		МаркерТекст = """text"": """;
		ПозицияТекст = СтрНайти(Хвост, МаркерТекст);
		Если ПозицияТекст = 0 Тогда
			Возврат "";
		КонецЕсли;
	КонецЕсли;

	НачалоТекста = ПозицияТекст + СтрДлина(МаркерТекст);

	// Ищем закрывающую кавычку, учитывая экранирование
	Возврат ИзвлечьЭкранированнуюСтроку(Хвост, НачалоТекста);

КонецФункции

// Извлекает текст из assistant-сообщения Claude Code CLI.
// JSON: {"type":"assistant","message":{"content":[{"type":"text","text":"..."},...]}}
// Ищем "type":"text" внутри content, затем "text":"..." после него.
//
&НаКлиенте
Функция ИзвлечьТекстИзAssistant(СтрокаJSON)

	// Ищем маркер "type":"text" внутри массива content
	МаркерТип = """type"":""text""";
	ПозицияТип = СтрНайти(СтрокаJSON, МаркерТип);
	Если ПозицияТип = 0 Тогда
		Возврат "";
	КонецЕсли;

	// Ищем "text":"..." после маркера типа
	Хвост = Сред(СтрокаJSON, ПозицияТип + СтрДлина(МаркерТип));

	МаркерТекст = """text"":""";
	ПозицияТекст = СтрНайти(Хвост, МаркерТекст);
	Если ПозицияТекст = 0 Тогда
		МаркерТекст = """text"": """;
		ПозицияТекст = СтрНайти(Хвост, МаркерТекст);
		Если ПозицияТекст = 0 Тогда
			Возврат "";
		КонецЕсли;
	КонецЕсли;

	НачалоТекста = ПозицияТекст + СтрДлина(МаркерТекст);
	Возврат ИзвлечьЭкранированнуюСтроку(Хвост, НачалоТекста);

КонецФункции

// Извлекает значение строкового поля из JSON через строковый поиск.
// Пример: ИзвлечьЗначениеJSON('{"type":"session",...}', "type") → "session"
//
&НаКлиенте
Функция ИзвлечьЗначениеJSON(СтрокаJSON, ИмяПоля)

	// Ищем "имяПоля":"значение" или "имяПоля": "значение"
	Маркер = """" + ИмяПоля + """:""";
	Позиция = СтрНайти(СтрокаJSON, Маркер);
	Если Позиция = 0 Тогда
		Маркер = """" + ИмяПоля + """: """;
		Позиция = СтрНайти(СтрокаJSON, Маркер);
		Если Позиция = 0 Тогда
			Возврат "";
		КонецЕсли;
	КонецЕсли;

	НачалоЗначения = Позиция + СтрДлина(Маркер);

	// Ищем закрывающую кавычку с учётом экранирования
	Возврат ИзвлечьЭкранированнуюСтроку(СтрокаJSON, НачалоЗначения);

КонецФункции

// Извлекает строковое значение начиная с указанной позиции до закрывающей кавычки.
// Учитывает JSON-экранирование: \\, \", \n, \t
//
&НаКлиенте
Функция ИзвлечьЭкранированнуюСтроку(СтрокаJSON, НачалоТекста)

	ТекущаяПозиция = НачалоТекста;
	ДлинаJSON = СтрДлина(СтрокаJSON);

	Пока ТекущаяПозиция <= ДлинаJSON Цикл
		ТекущийСимвол = Сред(СтрокаJSON, ТекущаяПозиция, 1);
		Если ТекущийСимвол = "\" Тогда
			// Экранированный символ — пропускаем следующий
			ТекущаяПозиция = ТекущаяПозиция + 2;
		ИначеЕсли ТекущийСимвол = """" Тогда
			Прервать;
		Иначе
			ТекущаяПозиция = ТекущаяПозиция + 1;
		КонецЕсли;
	КонецЦикла;

	Если ТекущаяПозиция > ДлинаJSON Тогда
		Возврат "";
	КонецЕсли;

	СыройТекст = Сред(СтрокаJSON, НачалоТекста, ТекущаяПозиция - НачалоТекста);
	Возврат ДекодироватьJSONСтроку(СыройТекст);

КонецФункции

// Декодирует JSON-экранированную строку: \\→\, \"→", \n→ПС, \t→Таб
//
&НаКлиенте
Функция ДекодироватьJSONСтроку(СыройТекст)

	// Порядок важен: сначала \\ → маркер, потом остальное, потом маркер → \
	Результат = СтрЗаменить(СыройТекст, "\\", Символы.Таб + "SLASH");
	Результат = СтрЗаменить(Результат, "\n", Символы.ПС);
	Результат = СтрЗаменить(Результат, "\t", Символы.Таб);
	Результат = СтрЗаменить(Результат, "\""", """");
	Результат = СтрЗаменить(Результат, Символы.Таб + "SLASH", "\");

	Возврат Результат;

КонецФункции

// ── Обработка MCP запросов от bridge ──
// Bridge отправляет: {"type":"mcp_request","requestId":"uuid","tool":"1c_query","params":{...}}
// 1С выполняет и отвечает: {"type":"mcp_response","requestId":"uuid","result":{...}}
//
&НаКлиенте
Процедура ОбработатьMCPЗапрос(Соединение, СтрокаJSON)

	ИДЗапроса = ИзвлечьЗначениеJSON(СтрокаJSON, "requestId");
	ИмяИнструмента = ИзвлечьЗначениеJSON(СтрокаJSON, "tool");

	// Извлекаем параметры как Соответствие через ЕХТ_Значение.ИзJSON()
	// (в params нет ключей с дефисами, парсинг безопасен)
	Ввод = ИзвлечьОбъектJSON(СтрокаJSON, "params");

	// Выполняем инструмент на сервере
	Попытка
		Если ИмяИнструмента = "1c_query" Тогда
			Результат = ВыполнитьЗапросНаСервере(Ввод);

		ИначеЕсли ИмяИнструмента = "1c_metadata" Тогда
			Результат = ПолучитьМетаданныеНаСервере(Ввод);

		ИначеЕсли ИмяИнструмента = "1c_eval" Тогда
			Результат = ВычислитьНаСервере(Ввод);

		ИначеЕсли ИмяИнструмента = "1c_exec" Тогда
			Результат = ВыполнитьКодНаСервере(Ввод);

		Иначе
			Результат = Новый Структура("error", "Неизвестный инструмент: " + ИмяИнструмента);
		КонецЕсли;
	Исключение
		Результат = Новый Структура("error", ОписаниеОшибки());
	КонецПопытки;

	// Формируем ответ mcp_response
	ЕстьОшибка = Ложь;
	Попытка
		ЕстьОшибка = (ТипЗнч(Результат) = Тип("Структура") И Результат.Свойство("error"));
	Исключение
	КонецПопытки;

	Если ЕстьОшибка Тогда
		ОтветJSON = "{""type"":""mcp_response"",""requestId"":""" + ИДЗапроса
			+ """,""error"":""" + ЭкранироватьJSON(Результат.error) + """}";
	Иначе
		РезультатJSON = ЕХТ_Значение.вJSON(Результат);
		ОтветJSON = "{""type"":""mcp_response"",""requestId"":""" + ИДЗапроса
			+ """,""result"":" + РезультатJSON + "}";
	КонецЕсли;

	Соединение.ОтправитьСообщение(ОтветJSON);

КонецПроцедуры

// Извлекает вложенный JSON-объект по имени поля.
// Пример: ИзвлечьОбъектJSON('...,"params":{"query":"ВЫБРАТЬ..."},...}', "params")
// Возвращает Соответствие через ЕХТ_Значение.ИзJSON() или пустое Соответствие.
//
&НаКлиенте
Функция ИзвлечьОбъектJSON(СтрокаJSON, ИмяПоля)

	// Ищем "имяПоля":{
	Маркер = """" + ИмяПоля + """:{";
	Позиция = СтрНайти(СтрокаJSON, Маркер);
	Если Позиция = 0 Тогда
		Маркер = """" + ИмяПоля + """: {";
		Позиция = СтрНайти(СтрокаJSON, Маркер);
		Если Позиция = 0 Тогда
			Возврат Новый Соответствие;
		КонецЕсли;
	КонецЕсли;

	// Находим начало объекта (символ {)
	НачалоОбъекта = СтрНайти(СтрокаJSON, "{", , Позиция + СтрДлина("""" + ИмяПоля + """:"));

	// Ищем соответствующую закрывающую скобку с учётом вложенности
	Глубина = 0;
	ДлинаJSON = СтрДлина(СтрокаJSON);
	Для Поз = НачалоОбъекта По ДлинаJSON Цикл
		ТекущийСимвол = Сред(СтрокаJSON, Поз, 1);
		Если ТекущийСимвол = "{" Тогда
			Глубина = Глубина + 1;
		ИначеЕсли ТекущийСимвол = "}" Тогда
			Глубина = Глубина - 1;
			Если Глубина = 0 Тогда
				ПодстрокаJSON = Сред(СтрокаJSON, НачалоОбъекта, Поз - НачалоОбъекта + 1);
				Попытка
					Возврат ЕХТ_Значение.ИзJSON(ПодстрокаJSON);
				Исключение
					Возврат Новый Соответствие;
				КонецПопытки;
			КонецЕсли;
		КонецЕсли;
	КонецЦикла;

	Возврат Новый Соответствие;

КонецФункции

#КонецОбласти

#Область ОбработкаКоманд1С

&НаСервере
Функция ВыполнитьЗапросНаСервере(ПарамыЗапроса)

	ТекстЗапроса = ПолучитьПараметр(ПарамыЗапроса, "query");
	Если ТекстЗапроса = Неопределено Тогда
		Возврат Новый Структура("error", "Отсутствует параметр query");
	КонецЕсли;

	Попытка
		Запрос = Новый Запрос(ТекстЗапроса);
		Результат = Запрос.Выполнить();

		Если Результат.Пустой() Тогда
			Возврат Новый Структура("data,columns,count", Новый Массив, Новый Массив, 0);
		КонецЕсли;

		// Колонки
		Колонки = Новый Массив;
		Для Каждого Колонка Из Результат.Колонки Цикл
			Колонки.Добавить(Колонка.Имя);
		КонецЦикла;

		// Данные (макс 1000 строк)
		Данные = Новый Массив;
		Выборка = Результат.Выбрать();
		Счетчик = 0;

		Пока Выборка.Следующий() И Счетчик < 1000 Цикл
			СтрокаДанных = Новый Структура;
			Для Каждого ИмяКолонки Из Колонки Цикл
				Значение = Выборка[ИмяКолонки];
				СтрокаДанных.Вставить(ИмяКолонки, ЗначениеДляJSON(Значение));
			КонецЦикла;
			Данные.Добавить(СтрокаДанных);
			Счетчик = Счетчик + 1;
		КонецЦикла;

		Возврат Новый Структура("data,columns,count", Данные, Колонки, Данные.Количество());

	Исключение
		Возврат Новый Структура("error", "Ошибка запроса: " + ОписаниеОшибки());
	КонецПопытки;

КонецФункции

&НаСервере
Функция ПолучитьМетаданныеНаСервере(ПарамыЗапроса)

	ТипМета = ПолучитьПараметр(ПарамыЗапроса, "type");
	Если ТипМета = Неопределено Тогда ТипМета = ""; КонецЕсли;

	Результат = Новый Массив;

	Попытка
		Если ТипМета = "" ИЛИ ТипМета = "Catalogs" Тогда
			Для Каждого М Из Метаданные.Справочники Цикл
				Результат.Добавить(Новый Структура("type,name,synonym", "Справочник", М.Имя, Строка(М.Синоним)));
			КонецЦикла;
		КонецЕсли;

		Если ТипМета = "" ИЛИ ТипМета = "Documents" Тогда
			Для Каждого М Из Метаданные.Документы Цикл
				Результат.Добавить(Новый Структура("type,name,synonym", "Документ", М.Имя, Строка(М.Синоним)));
			КонецЦикла;
		КонецЕсли;

		Если ТипМета = "" ИЛИ ТипМета = "InformationRegisters" Тогда
			Для Каждого М Из Метаданные.РегистрыСведений Цикл
				Результат.Добавить(Новый Структура("type,name,synonym", "РегистрСведений", М.Имя, Строка(М.Синоним)));
			КонецЦикла;
		КонецЕсли;

		Если ТипМета = "" ИЛИ ТипМета = "AccumulationRegisters" Тогда
			Для Каждого М Из Метаданные.РегистрыНакопления Цикл
				Результат.Добавить(Новый Структура("type,name,synonym", "РегистрНакопления", М.Имя, Строка(М.Синоним)));
			КонецЦикла;
		КонецЕсли;

		Если ТипМета = "" ИЛИ ТипМета = "AccountingRegisters" Тогда
			Для Каждого М Из Метаданные.РегистрыБухгалтерии Цикл
				Результат.Добавить(Новый Структура("type,name,synonym", "РегистрБухгалтерии", М.Имя, Строка(М.Синоним)));
			КонецЦикла;
		КонецЕсли;

		Возврат Результат;

	Исключение
		Возврат Новый Структура("error", "Ошибка метаданных: " + ОписаниеОшибки());
	КонецПопытки;

КонецФункции

&НаСервере
Функция ВычислитьНаСервере(ПарамыЗапроса)

	Выражение = ПолучитьПараметр(ПарамыЗапроса, "expression");
	Если Выражение = Неопределено Тогда
		Возврат Новый Структура("error", "Отсутствует параметр expression");
	КонецЕсли;

	Попытка
		Результат = Вычислить(Выражение);
		Возврат Новый Структура("result", ЗначениеДляJSON(Результат));
	Исключение
		Возврат Новый Структура("error", "Ошибка вычисления: " + ОписаниеОшибки());
	КонецПопытки;

КонецФункции

// Выполнить произвольный блок кода на языке 1С (для инструмента 1c_exec).
//
&НаСервере
Функция ВыполнитьКодНаСервере(ПарамыЗапроса)

	Код = ПолучитьПараметр(ПарамыЗапроса, "code");
	Если Код = Неопределено Тогда
		Возврат Новый Структура("error", "Отсутствует параметр code");
	КонецЕсли;

	Попытка
		Выполнить(Код);
		Возврат Новый Структура("result", "Выполнено");
	Исключение
		Возврат Новый Структура("error", "Ошибка выполнения: " + ОписаниеОшибки());
	КонецПопытки;

КонецФункции

#КонецОбласти

#Область СлужебныеПроцедурыИФункции

// Экранирует спецсимволы в строке для безопасной вставки в JSON.
// \→\\, "→\", ПС→\n, ВК→(убираем), Таб→\t
//
&НаКлиенте
Функция ЭкранироватьJSON(Текст)

	Результат = СтрЗаменить(Текст, "\", "\\");
	Результат = СтрЗаменить(Результат, """", "\""");
	Результат = СтрЗаменить(Результат, Символы.ПС, "\n");
	Результат = СтрЗаменить(Результат, Символы.ВК, "");
	Результат = СтрЗаменить(Результат, Символы.Таб, "\t");

	Возврат Результат;

КонецФункции

&НаКлиенте
Функция ЕХТ_Чат_ПриОткрытии(Знач Элемент, Знач НастройкиПоУмолчанию) Экспорт

	Результат = ЕХТ_Результат.Создать(
		"Настройки", НастройкиПоУмолчанию,
		"Сообщения", Новый Массив);

	Если Элемент = ЭтотОбъект.Элементы.Чат1 Тогда

		Результат.Настройки.Сообщения.Автосвертка = ЭтотОбъект.Чат1Автосвертка;
		Результат.Настройки.Аватары.Видимость = ЭтотОбъект.Чат1Аватары;

		Результат.Сообщения = Новый Массив;

	КонецЕсли;

	Возврат Результат;

КонецФункции

&НаКлиенте
Функция ЕХТ_Чат_ПриДобавленииСообщения(Знач Элемент) Экспорт

	Результат = Новый Структура(
		"Сообщение", Новый Структура);

	Если Элемент = ЭтотОбъект.Элементы.Чат1 Тогда
		Текст = ЭтотОбъект.ТекстСообщения;
		// Маркер [TPL:Шаблон] в начале текста — программное сообщение (от Claude/системы)
		Если СтрНачинаетсяС(Текст, "[TPL:") Тогда
			ПозицияЗакрытия = СтрНайти(Текст, "]");
			Шаблон = Сред(Текст, 6, ПозицияЗакрытия - 6);
			ТекстСообщения = Сред(Текст, ПозицияЗакрытия + 1);
			Результат.Сообщение = ЕХТ_Чат_НовоеСообщение(ТекстСообщения, Шаблон);
		Иначе
			// Обычное сообщение пользователя из поля ввода
			Результат.Сообщение = ЕХТ_Чат_НовоеСообщение(Текст, "Пользователь");
		КонецЕсли;
	КонецЕсли;

	Возврат Результат;

КонецФункции

&НаКлиенте
Функция ЕХТ_Чат_ПриНажатииСсылки(Знач Элемент, Знач АдресСсылки) Экспорт

	Результат = Новый Структура;

	Если Элемент = ЭтотОбъект.Элементы.Чат1 Тогда
		ЕХТ.Вывести("Нажата ссылка: %1", АдресСсылки);
	КонецЕсли;

	Возврат Результат;

КонецФункции

// Добавляет программное сообщение в HTML-чат.
// Записывает текст с маркером [TPL:Шаблон] в ТекстСообщения,
// вызывает addMessageFromV8(), callback определяет шаблон по маркеру.
//
// Параметры:
//  Текст - Строка - текст сообщения
//  Шаблон - Строка - имя шаблона (Ассистент, Ошибка, Предупреждение, Информация)
//
&НаКлиенте
Процедура ДобавитьСообщениеВЧат(Текст, Шаблон = "Ассистент")

	Попытка
		ЭтотОбъект.ТекстСообщения = "[TPL:" + Шаблон + "]" + Текст;
		Приложение(ЭтотОбъект.Элементы.Чат1).addMessageFromV8();
		ЭтотОбъект.ТекстСообщения = "";
	Исключение
		// HTML чата ещё не загружен — пропускаем
	КонецПопытки;

КонецПроцедуры

&НаКлиентеНаСервереБезКонтекста
Функция ПолучитьПараметр(ПарамыЗапроса, ИмяПараметра)
	Если ТипЗнч(ПарамыЗапроса) = Тип("Соответствие") Тогда
		Возврат ПарамыЗапроса.Получить(ИмяПараметра);
	ИначеЕсли ТипЗнч(ПарамыЗапроса) = Тип("Структура") Тогда
		Если ПарамыЗапроса.Свойство(ИмяПараметра) Тогда
			Возврат ПарамыЗапроса[ИмяПараметра];
		КонецЕсли;
	КонецЕсли;
	Возврат Неопределено;
КонецФункции

&НаСервере
Функция ЗначениеДляJSON(ИсходноеЗначение)

	Если ИсходноеЗначение = Неопределено ИЛИ ИсходноеЗначение = Null Тогда
		Возврат Null;
	ИначеЕсли ТипЗнч(ИсходноеЗначение) = Тип("Булево") ИЛИ ТипЗнч(ИсходноеЗначение) = Тип("Число") ИЛИ ТипЗнч(ИсходноеЗначение) = Тип("Строка") Тогда
		Возврат ИсходноеЗначение;
	ИначеЕсли ТипЗнч(ИсходноеЗначение) = Тип("Дата") Тогда
		Возврат Формат(ИсходноеЗначение, "ДФ=yyyy-MM-ddTHH:mm:ss");
	Иначе
		Возврат Строка(ИсходноеЗначение);
	КонецЕсли;

КонецФункции

#КонецОбласти

#Область ЕХТ_Чат

// === НАЧАЛО: Код фреймворка ЕХТ_Чат (без изменений) ===

#Область ПрограммныйИнтерфейс

#Область КлиентСервер

// Создаёт структуру сообщения для чата.
//
// Параметры:
//  Текст - Строка - Текст сообщения (поддерживает Markdown)
//  Шаблон - Строка - Имя шаблона из настроек (Пользователь, Ассистент, Ошибка и т.д.)
//  ЛевыйВерх - Строка - Текст надписи в левом верхнем углу
//  ПравыйВерх - Строка - Текст надписи в правом верхнем углу
//  ЛевыйНиз - Строка - Текст надписи в левом нижнем углу
//  ПравыйНиз - Строка - Текст надписи в правом нижнем углу
//
// Возвращаемое значение:
//  Структура - Сообщение с полями: ИД, Текст, Шаблон, Надписи
//
&НаКлиентеНаСервереБезКонтекста
Функция ЕХТ_Чат_НовоеСообщение(Текст, Шаблон, ЛевыйВерх = "", ПравыйВерх = "", ЛевыйНиз = "", ПравыйНиз = "") Экспорт

	Сообщение = Новый Структура;
	Сообщение.Вставить("ИД", Строка(Новый УникальныйИдентификатор));
	Сообщение.Вставить("Текст", Текст);
	Сообщение.Вставить("Шаблон", Шаблон);

	Сообщение.Вставить("Надписи", Новый Структура);
	Если ЗначениеЗаполнено(ЛевыйВерх) Тогда
		Сообщение.Надписи.Вставить("ЛевыйВерх", ЛевыйВерх);
	КонецЕсли;
	Если ЗначениеЗаполнено(ПравыйВерх) Тогда
		Сообщение.Надписи.Вставить("ПравыйВерх", ПравыйВерх);
	КонецЕсли;
	Если ЗначениеЗаполнено(ЛевыйНиз) Тогда
		Сообщение.Надписи.Вставить("ЛевыйНиз", ЛевыйНиз);
	КонецЕсли;
	Если ЗначениеЗаполнено(ПравыйНиз) Тогда
		Сообщение.Надписи.Вставить("ПравыйНиз", ПравыйНиз);
	КонецЕсли;

	Возврат Сообщение;

КонецФункции

&НаКлиентеНаСервереБезКонтекста
Функция ЕХТ_Чат_НастройкиПоУмолчанию() Экспорт

